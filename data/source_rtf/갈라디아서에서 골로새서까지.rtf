\par\pard\plain \s77\ql\fi-720\lin1080\rin0\sb0\sa0\b0\i0\ul0\scaps0\nosupersub\cf2\fs22 "\u193?uw\u233?ghan an\u233?m, f\u233?m ambumofnar amaf!
