\par\pard\plain \s60\ql\fi180\lin0\rin0\sb0\sa0\b0\i0\ul0\scaps0\nosupersub\cf2\fs22 {\cs57\b0\i0\ul0\scaps0\super\cf2\fs22 25\~}
