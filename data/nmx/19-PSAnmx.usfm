\id PSA - - Nama Translation
\c 1
\q1 \v 1 O, áuwégh yéfene emofem yau ewaitotat mámáfi árfene watamegh,
\q2 o ewakai yaufiyam wafrogh árfé,
\q2 o nénguféindat sénanégh téfnárafefaf.
\q1 \v 2 Wénde fá namyotat Yurane nákan,
\q2 mwighaye eknat efogh a sémbár.
\q1 \v 3 Fá ndenanit em wanje téndomé yénau eyang wén
\q2 néngafotat mbwe yéfenjo wérwéran.
\q1 Yéfene árau yau ghérnat kamndangi
\q2 a fá nawaindat méinyotio yéfene wafrogh yaman.
\q1 \v 4 Wénde yau yaufiyam téfnár ár!
\q2 Fá ndenanit em mámáfi fénjfénj, yétarne mbormboram.
\q1 \v 5 Fá so sémta tawayangé yéné mogh efghon.
\q2 Yaufiyam wafrogh ár em sifayafnar Ngánjánene ár kénjún.
\q1 \v 6 Ménamén Yuram efande Ngánjánene árfene yam,
\q2 wénde yaufi árfene end siyém elimnde kétán kérfaf.
\c 2
\q1 \v 1 Némamén ndimbal yu nékwafé em?
\q2 Némamén yémofem efogh fifiofnar mwighé faroréghan?
\q1 \v 2 Mbandmén warsagh ár nafrendat ásméghét;
\q2 limánégh árém kwankwane yam yéngfaronat mérne Yuré
\q2 a wéi yéfeyot yáne waingéghkaf árét.
\q1 \v 3 Fá kendawét, "So yéndfem etyanam yéfene sein,
\q2 a kaferngém kétamé yau so yéném yauyau Ngánjánefaf."
\q1 \v 4 Wénde fá emo elimnde kété njafaran nénurte.
\q2 Yuram ekarote fá.
\q1 \v 5 Féyo nékwe yémo eusérmbote fá,
\q2 férférot ewawainde yéfe ménaye yáne ndimbal férférafé yame.
\q1 \v 6 Yá Yuram safét yékmete ndené, "Yéndo té yéfayoyén tane kaféghmén limánégh ámnjogh sifayé ámnjogh sifayan
\q2 kété Jerusalemén, tane njúnnjúnofnar mband tunakfan."
\q1 \v 7 Warsagh ár nafrote Yurane wafaréghmén:
\q1 "Yuram wémndai yénd, 'Fém ném tane ambum.
\q2 Fém ném tane ambum."
\q1 \v 8 Mé komnenda, a yéndo so tawaraman mband marat kés em sái em féfene rokarafé,
\q2 a méinyotio yu sái em ásáfogh sifayé.
\q1 \v 9 Féyo fémofem so etyanati ménaye tot téfén ngiye
\q2 a so ewironati ndenanit ngénd wafroghmén sin."
\q1 \v 10 Yénamé ndené, fém warsagh ár, nimndati káfeté mwighaye!
\q2 Néwéngsotati, fém limánégh téfnár mband maratan!
\q1 \v 11 Násáfotati Yurai yáne férférafé,
\q2 a náuwetati ngerngerafé.
\q1 \v 12 Karamangi kétán Ngánjánene áyárégh kér ro ambumoefaf, ménamén fá mété nafgheta nékwafé,
\q2 a fém so tawalindangé féfenjo yam wafrogh kénjún,
\q1 ménamén yáne nékw fés nufrote wékeye.
\q2 Wénde nderé áuwégh yém yéfe méinyotio emofem tanangi atnogh sifayé yáne kénjún!
\c 3
\s Deifidene wagh, yéné efghon Deifid ánde nawatembai kétamé
\q1 \v 1 O Yuré, tane em tárfár ta ásmégh ár,
\q2 tárfár fifi em tane usérmbogh ár.
\q1 \v 2 Tárfár néngorayat,
\q2 Ngánjánam yau so ghérsé turtongé fá!
\q1 \v 3 Wénde fém, O Yuré, ném mbakw tafafmé,
\q2 fém ném tane ndimbal kwayaghé, fá emo yérete tane sénko tukén.
\q1 \v 4 Yénd nutnan kétán Yurafaf,
\q2 a yémo wénmawangote kétamé njúnnjúnofnar mband tunakéfta.
\q1 \v 5 Yénd kolinjon a kakman,
\q2 wénde yénd mé kanon wambégh kénjún,
\q2 ménamén Yuram mé wéfande yénd.
\q1 \v 6 Yénd yau férfér wém ten tausen tane mék téfnárafenemén
\q2 emofem warendat yénamé tane téndomé.
\q1 \v 7 Kane, O Yuré!
\q2 Ghérsé kurto yénd, tane Ngánján!
\q1 Tatumnda tane mék téfnár yéfene sáfamé!
\q2 Engétyana yéfene sén efe em áyáréghofnar!
\q1 \v 8 Waingéghét siyém yéném kétamé feta, O Yuré.
\q2 So fémo efrende fene ár.
\c 4
\s Sémbár wagh
\q1 \v 1 Wawangota ta njam yénd nutnan fefaf,
\q2 O Ngánján emo wiyátote yénd kértafnar.
\q1 Yuwek kwiyáto yénd kétamé kértata.
\q2 Ghérghérsisé so ném tafaf a náyáreta tane orayégh.
\q1 \v 2 Nderé teke so yasérmbotati fémofem yéné árém tane yam?
\q2 Nderé teke so fémofem ewafrotati téfnofnar amrorégh?
\q2 Nderé teke so elimndati féfene unyégh?
\q1 \v 3 Fém kor aem yénémamén:
\q2 Yuram fénataye ekmete Ngánján ghérsafé yandio.
\q2 Yuram so kwawangongé njam yénd nutnam yáfaf.
\q1 \v 4 Yau yaufiyam yafrota ménayan sái tumyo nékwam nélimnda fém.
\q2 Nemna yénémamén sémbár néndkfan a miya ném métar.
\q1 \v 5 Ghéngén ramégh ewafrota mbarkánd mbérmbéran,
\q2 a namyota Yurafaf.
\q1 \v 6 Tárfár ár néngorayat, "Emo so yéngmauyafote mer efoghféneféne?"
\q2 Yumyota fene sáf so nurte tafaf Yuré.
\q1 \v 7 Fémo té waramai ta ndimbal áuwégh
\q2 yéfeta endefene em ndimbale wagh yuwon rais mbwe a totér wéri nu.
\q1 \v 8 Krufrát kénjún yénd so kolinjon a kakman,
\q2 ménamén mé fémonro, O Yuré, so warawene yénd.
\c 5
\s
\q1 \v 1 O Yuré, wiyáreta yénd njam Ngánjánafé norayan,
\q2 náyáreta tane mike.
\q1 \v 2 Náyáreta tane ye ménát wáutárghét, tane warsagh ár a tane Ngánján,
\q2 ménamén yénd yau norayan endefaf wénde fefaf.
\q1 \v 3 Náyáreta tane kém akwan, Yuré.
\q2 Akw tárfár yéndo enérsan tane ménde kétán fefaf a nawanjetan mwighafé.
\q1 \v 4 O Ngánján, fémo yau yérse ménde mámáfi yaman,
\q2 fém yau nafghete áyáréghofnar árfene yaufiyamfaf.
\q1 \v 5 Yénémaménnde, tuktuk ár yau so ewakai fene rére,
\q2 ménamén fémo méinyotio efande emofem ewafrotati mámáfi.
\q1 \v 6 Fémo so engwirone fá efe nénguindat.
\q2 Yuram méndefnar efande ár ngi téfnár a unyégh téfnár.
\q1 \v 7 Ménamén fene uwégh yakai, yénd so kényawan fene méngon,
\q2 yéndo so wáwefnogh yafrotan fene wáwefnogh méngo ménayafé kénjkam matafé.
\q1 \v 8 Wélimnda yénd yénamé mbarkánd endmé, O Yuré,
\q2 o tane mék téfnáram so kwaindangi.
\q1 Yafrota fene end yaina tayot ménát so yaitotan.
\q1 \v 9 Tane mék téfnár yau so norayat efalo si.
\q2 Yéfene ndimbal ménde siyém siya engwironat ámb ár.
\q1 Yéfene si sem yaufi, ndenanit ngauros wím kétamé wafaréghofnar mbéwéta.
\q2 Yéfene kanké snafote mé awarmbogh siam.
\q1 \v 10 O Ngánján, safét taufar fá kértafé em.
\q2 Taumyo fá so kwamangi yéfenjo uréran.
\q1 Englimnda nayu ménamén yéfene tárfár yaufiyammén,
\q2 ménamén yémofem té wékenangi yénd.
\q1 \v 11 Wénde taumyo méinyotio efe nawanganat fene kénjún náuwetat,
\q2 taumyo fá so eufanat áuwéghafé wafyagh wagh tuot.
\q1 Tafarna fene wambégh yéfefaf,
\q2 ndené méinyotio emofem yuwetat fene yétkwén so ewafote áuwégham.
\q1 \v 12 Ménamén fémo efrende ngánján ghérsafé efe em, O Yuré,
\q2 fémo ewarenda fá ménaye fene wambégh uwéghe.
\c 6
\s
\q1 \v 1 O Yuré, yau wusérmbota yénd fene nékw
\q2 o téfél wafrota fene kwérnare.
\q1 \v 2 Aném ghérghérsisé tafaf, Yuré, ménamén yénd wém njangénnjangén.
\q2 Mer kwiyáto yénd, Yuré, ménamén tane sot em tékratan.
\q1 \v 3 Yénd wém enjnefé tikfan.
\q2 nde nayu, O Yuré, kétánotio fémo yénd kwénmurto?
\q1 \v 4 Kwénmurto yénd, O Yuré, a kwénmurot yénd.
\q2 Kwanjar yénd ménamén fene olawéghofnar uwégh.
\q1 \v 5 Ménamén kér árém yau fém némafarotat.
\q2 Emo so fém némarse kétamé mbéwéta.
\q1 \v 6 Yénd yongnai namndetan máméghéraye yeyan.
\q2 Méinyotio sémbár yéndo yengame yérametan tane kémégh sifayé,
\q2 yiyátotan tane yengame.
\q1 \v 7 Onjo yau kor mer yém ménamén yemén,
\q2 tane ghékéf féyo em ménamén tane méinyotio mék téfnárafenemén.
\q1 \v 8 Nguwanongi nde nayu, méinyotio fém yaufiyam wafroghofnar,
\q2 ménamén Yuram té náyára tane ye.
\q1 \v 9 Yuram té náyára tane ármanégh,
\q2 Yuram so tane Ngánjánafé orayégh kwawangongé.
\q1 \v 10 So méinyotio tane mék téfnár yuwan kakmangi a néwérsotat.
\q2 Fá so tekofnar kéngawengongi wáiwáiafé.
\c 7
\s
\q1 \v 1 Yénd wéném fefaf ménát so wambete, O Yuré tane Ngánján.
\q2 Kwanjar yénd kétamé tane ngi téfnárafeta-kwanjar yénd!
\q1 \v 2 Njam yau, yémofem so tiyárégh kwafngongi ndenanit ndimbal munjan fus,
\q2 wétirnat yénd kétán némbne karéfkaréf árké árom yau so kwanjarngé.
\q1 \v 3 O Yuré tane Ngánján, njam yéndo té tafrotan mámáfi
\q2 o yénd kértafé wém ménamén mbarkánd yam yau.
\q1 \v 4 Njam yéndo té sén térametan fútar
\q2 kwérnare tafáretan tane ásnanégh téfnár téfnofnar,
\q1 \v 5 féyo téu tane ásnanégh téfnáram kwerangi.
\q2 Téu yémofem wésénat yénd mbandot
\q2 a yéroghat tane utmanégh ngwérméngamé.
\q1 \v 6 Kokai, O Yuré, kwérnarafé!
\q2 Kokai yéné nékwta tane sénanégh ár!
\q2 Kunja, tane Ngánján, a ténmau mbarkánd ghérsé!
\q1 \v 7 Taumenda ndimbal yu fene sáfrére,
\q2 limánégh yénmafrota yéfefaf kétamé tukta.
\q1 \v 8 Yuram moghan emete ndimbal yu, kwiyáto mbarkándro, O Yuré,
\q2 ménamén yénd wém téfnofnar, O Minde Tukén!
\q1 \v 9 Takmbo mámáfi yéfene efe em yaufi,
\q2 a tawamarota mbarkánd yam téfnár.
\q1 Ménamén fém nérete kénjút kétán mwighafaf a tikéffaf,
\q2 o mbarkándro Ngánján.
\q1 \v 10 Ngánján siyém tane wambégh,
\q2 ewanjane fá endefene tikéf em efalo mbarkánd.
\q1 \v 11 Ngánján siyém efalo migh ár,
\q2 fá siyém nékwafé yém mámáfi wafrogh árfefaf túmén efogh.
\q1 \v 12 Njam ár yau kékmbongé yaufiyamta.
\q2 Ngánjánam so yéfane yánjo witmafé sénté naifé,
\q2 fá so kawefrongé a téknangé yánjo námb.
\q1 \v 13 Yémo so efrende yánjo kérafé fimb
\q2 a ewita yánjo fésafé fimb.
\q1 \v 14 Mámáfi wafrogh árém téraftangi yaufi,
\q2 fá em kérté tiyárégh suafé a yéraftat unyégh.
\q1 \v 15 Yémofem yétanat kénjút yékw ménát sái ereindat ámb ár,
\q2 féyo kényawangi kétánotio yénayan fáyo.
\q1 \v 16 Kérté árké yémofem ewafrotat yéfe ámb árét kénawengongi.
\q2 Yéta yaufiyot mwighé siyéfaronat kénuyangi yéfenjo sénkofaf kafayongi.
\q1 \v 17 Yéndo so kánjo yarametan Ngánjáne ménamén fá yém njúnnjúnofnar,
\q2 yéndo so áuwégh wagh yérametan Yurane yétkwénan efe yém Minde Tukén.
\c 8
\s
\q1 \v 1 O Yuré, téfene Yuré, fene sariafé yétkwénam yafne mband marat!
\q2 Fene ndimbal kwayaghé siyém minde tukén yáinde njafar.
\q1 \v 2 Fémo té tawatamete ambumtértér a efe wéi nonoan mé nénafamndat
\q2 ménát sái néngafrotat fene muyamén,
\q1 métar sái engyátotat fene ásnanégh téfnár
\q2 a méinyotio fá emofem nékarotat fém.
\q1 \v 3 Njam yénd kéretangén sémbáran njafar tukét a efandan fene ngángé wafroghmén ásáfogh
\q2 ghérare a kénd fémo ndernaye takmetau sifayamé.
\q1 \v 4 Némé fifiofnar ár em sái mwighé nemnati yéfenemén,
\q2 mé ár mbané ndené fémo sái ewarawena?
\q1 \v 5 Wénde fémo ewafrotam yuwanyo Ngánján tukén yém
\q2 a ákiki ewafayotam a ndimbal kwayaghé a utmanégh.
\q1 \v 6 Fémo ewarametam yéfe wafté yénat méinyotio fémo kés ewafrotam,
\q2 takmetau méinyotio rokar yéfene wafté mbanmbanan.
\q1 \v 7 sif a kau a méinyotio kéghat wérár.
\q1 \v 8 men njafar tukmé, wagif arakafamé
\q2 a méinyotio árkéméné nakmetat arakaf wéréramé.
\q1 \v 9 O Yuré, téfene Yuré, fene sariafé yétkwénam yafne mband marat!
\c 9
\s
\q1 \v 1 Yéndon so námarsan fém, Yuré, ménaye méinyotio tikfe,
\q2 yénd so néngafrotan némé mafulafé yam fémo yafrotam.
\q1 \v 2 Yénd so wiyanje áuwégham ménamén fenemén,
\q2 yéndon so waghe yarsan fene yétkwén, o Minde Tukén Ngánján.
\q1 \v 3 Tane sénanégh téfnáram kwasérmbotawét.
\q2 Fá néngtam ewafrotam a kér emormén.
\q1 \v 4 Ménamén fémo té moghan takmetau kértat tane méndeyan.
\q2 Kétamé fenjo limánégh ámnjogh sifayata fémo mogh yafrote ndené ndenaro.
\q1 \v 5 Fémo té eusérmbotam ndimbal yu a tényau mámáfi yamafé ár,
\q2 fémo té engwalindai yéfene yétkwén tuot.
\q1 \v 6 Sénanégh téfnár té nefo, kwémboghofnar otaréghofnar sifayan.
\q2 Ndimbal tesen fémo árké tanéghyote yau sénonjo ewafarotat.
\q1 \v 7 Wénde Yuraro ghérsé mé yém limánéghan tuot,
\q2 mogh ngiye yénmafngo kétamé yánjo limánégh ámnjogh sifayata.
\q1 \v 8 Yémo so moghan tékmangé mband marat mbarkándro moghan
\q2 a elimnda ndimbal yu ndené ndenaro moghan.
\q1 \v 9 Yuré siyém kitaré yéfe efe esénat,
\q2 a ténogh sifayé kérté yam efghon.
\q1 \v 10 Fá efe mat em fene yétkwén mwighé em fefaf,
\q2 ménamén fém, o Yuré, yau tafrango fá emofem nénronjat fém.
\q1 \v 11 Áuwégh wagh yérametati Yurai emo yélimnde Jerusalemén.
\q2 Mband marat mat yiyátotati ménamén yáne frangoghofnar yammén.
\q1 \v 12 Ménamén emo fai yangote ár ngimén ewarawene fá efe yau ewáutánat.
\q2 Yémo yau ekarote ye yéfene efe tékratan.
\q1 \v 13 Yuré, ném ghérghérsisafé tafaf.
\q2 Téfanda ndernaye tane sénanégh téfnáram ndémke warametat ta.
\q2 Kwitremb yénd kwango kétamé fétkam kérté.
\q1 \v 14 Kwanjar yénd ménát yéndo so némarsan fém sáfmaro kété Jerusalem sésafnefafmé,
\q2 ménamén yénd so náuwetan ndené fémo té yénd wanjaryéng.
\q1 \v 15 Ndimbal yu ámb té kényawetat yékwét yémo árké tatanat ámb árfet.
\q2 Yéfenjoyo kafkaf té narnangi uréran yémofemyo árké ekindaménd.
\q1 \v 16 Yuranemén mat yéném ménamén yáne fifiafé yammén.
\q2 Mámáfiyam téfnár nawametat ménamén yéfenjo yam wafroghan.
\q1 \v 17 Mámáfi ár so ewewonat mbéwéfaf.
\q2 Yéné siyém yéfe sifayé méinyotio mband maratamé ár kér yémor emofem yékenat Ngánján.
\q1 \v 18 Wénde efe méndeyan em yau so ekene tuot,
\q2 kamnang sái em yauyau árfene yau so túmén náwasémbotat.
\q1 \v 19 Kunja, O Yuré,
\q2 yau eumyota órngégh árém nékenat fém!
\q2 Mogh ekemeta ndimbal yu!
\q1 \v 20 Eyátota so ngerngerafé em férférmén, O Yuré.
\q2 So méinyotio mband marat mat em ndené mé ár mbané em.
\c 10
\s
\q1 \v 1 O Yuré, némamén fém némakai minde nayu?
\q2 Némamén fém nátnote yénd njam wém kérté kénjún?
\q1 \v 2 Mámáfi árém mermer ewawindat a alé narotat yauyau árét.
\q2 Taumyo fá so kawamangi yaufi yau árké téfarnat yéfe ámb árét.
\q1 \v 3 Ménamén fá nawarsat yéfenjo yaufiyam méndemén.
\q2 Fá nawarmbotat kwénjtamén a yafalngotat Yuré.
\q1 \v 4 Mámáfi wafrogh ár awarmboghétro em, wénde yéta yéronjat Ngánján.
\q2 Fá ndené nemnat ndené Ngánján kérté yémormén.
\q1 \v 5 A fá engremngote méinyotio yam wafrogh kénjún némé yémofem engwafrotat.
\q2 Yémofem yau yéfandat kérté yamam ewanjete fá.
\q2 Yémofem sáf ngiye esmetat méinyotio yéfene sénanégh téfnár.
\q1 \v 6 Fá nemnat, "Némé mámáfi yau so nufrote yénan téfefaf!
\q2 Yénd so yéngém kértafnar tuot!"
\q1 \v 7 Yéfene mbérmbér wafalngogh si afoghare em, unyégh, a yéru wamégh.
\q2 Kérté a yaufi yém yéfene kanké fétfétan.
\q1 \v 8 Fá nátnoyénd werghét méngotuan,
\q2 kwanjetawét ménát sái tásmetawét kérot ménd ár.
\q2 Yémofem táf túmén eronjat yéné wáutáréghofnar enjnefé.
\q1 \v 9 Ndenanit ndimbal munjan fus yénau budme náráfnat átnoghan,
\q2 fá nawanjetat ménát sái tawifnangi wáutáréghofnar.
\q1 Ndenanit alé téfnáram yénau terangi wáutáréghofnar
\q2 a engroghét nayuyo netafé.
\q1 \v 10 Yéfene wáutáréghofnar enjnekaf ewasérmbotat.
\q2 Fá kuyangi yaufi árfene muyé mbanmbanot.
\q1 \v 11 Yaufi ár nemnat, "Ngánjánam yau kar yénfande yénd!
\q2 Yémo té ghékéf eumbérto a yau so yénfande némé yéndfem ewafrotam!"
\q1 \v 12 Kunja, O Yuré!
\q2 Tékratan takém yaufiyam ár, O Ngánján!
\q2 Yau ekena wáutáréghofnar!
\q1 \v 13 Némamén yaufi ár nayu kamndangi Ngánjánene wasálighan?
\q2 Fá nemnat, Ngánjánam yau so ténmotangé sái yénmawafta."
\q1 \v 14 Wénde fémo efande tékrat yam a kérté yémofem yéngétyanat.
\q2 Fémo yénayoene kérté tana a tékratan takém fá.
\q1 Wáutáréghofnar efe em yémofem tákmangi yéfene mwighé fefaf.
\q2 Fémo ewamarote séfarékw ambum.
\q1 \v 15 Ewarafna yéné yaufi, mámáfi árfene ndangwés!
\q2 Néngém mé yéfe sémta kétánotio kerkermén ár kor talinda.
\q1 \v 16 Yuré siyém warsagh ár tuot a mbanjat!
\q2 Ngánjánofnar ndimbal yu so nérndat mbandan.
\q1 \v 17 Yuré, fém mat ném kamnang wáutáréghofnar árfene.
\q2 So fémo káyára yéfene ye a tawamarota.
\q1 \v 18 Fémo so yénérse mer yam séfarékw árét a kenagh árét,
\q2 ménát árfifiam yau so ghékéfghékéf ewafrotat fá.
\c 11
\s
\q1 \v 1 Yénd namyotan Yurane kénjún wambghét.
\q1 Féyo némamén fémo kwémnda yénd,
\q2 "Kénaf ndenanit men kétán mband tunakéf awambghét!
\q1 \v 2 Mámáfi árém ekeindat yéfenjo námb
\q2 a eurauetat yéfenjo fimb námb atéran.
\q1 Yémofem enamndat kétamé njarta
\q2 fá endefene tikéf em mbarkánd.
\q1 \v 3 Nákoene téfén sifayé a mbarkánd té nuyang.
\q2 Némé so mbarkánd árém yafrotat?"
\q1 \v 4 Wénde Yuré siyém yényau yánjo njúnnjúnofnar limánégh ámnjogh sifayan.
\q2 Yuram mé yénlimnde kétamé njafarta.
\q1 Yémo efande méinyotio ár mé kaka,
\q2 ewafénmete méinyotio ár yéné mbandan.
\q1 \v 5 Yuram ewafénmete fá efe em mbarkánd a mámáfi.
\q2 Yémo fá méndméndat efande efe ménde engém yaufiyam tiyárghét.
\q1 \v 6 Yémo so yénmasune máméghérayé fés akrarghét a nakernat arenjan mámáfi ár,
\q2 tékratan ekmeta ménaye mbormbor ngiye.
\q1 \v 7 Yéfeyot efe em mbarkánd Yuré nauwete mer yamfaf.
\q2 Minde mer yam wafrogh téfnáram so tinjongi yáne sáf.
\c 12
\s
\q1 \v 1 Ténmáutár, O Yuré, ménamén ngánjánofnar ár wékeye em nénufanat!
\q2 Ndimbal mwighé téfnár té kérndat mbandan!
\q1 \v 2 Ár fútar néngawawindat fárofáro,
\q2 méndefé siye a awaunégh tikfe.
\q1 \v 3 So Yuram enfete yéfene méndefé si mbírmbír
\q2 a métar táyátongé yéfene awarmbogh kanké.
\q1 \v 4 Fá norayat, "Yénd so nuindam téfene tikéf kénjún.
\q2 Téfene mbírmbír sem téfene em- emo so ténékmbongé yénd?"
\q1 \v 5 Yuram yénmawangote, "Yéndo té téfandan mámáfi yam wafrogh yéfefaf mbané árfefaf,
\q2 a yéndo té náyáran yauyau árfene mike.
\q1 Sénonjo yénd so kokayon ménát so tawanjarén fá,
\q2 ndené fété fá té karonjat tane yam wafroghét."
\q1 \v 6 Yurane unyéghofnar si sem féwénféwénofnar,
\q2 ndenanit silfé yénau merot eneghét fésan,
\q2 mer sáfot tayátongi 7 mbinotmé.
\q1 \v 7 Yénémaménnde, Yuré, yénd mat yéném fémo so ewarawene efe ekarotat,
\q2 ewamnda fá tuot yéné unyégh ár satata.
\q1 \v 8 Ndemamén mámáfi árém tuktuk yéfandat,
\q2 a yaufi siyém yuyotat mbandan.
\c 13
\s
\q1 \v 1 O Yuré, nderé nayu fémo so mwighafnar kwaya yénd? Ambino?
\q2 Nderé teke fém so nérete ámb ende?
\q1 \v 2 Nderé nayu yénd so wawérsote tékratam tane kénjún,
\q2 ménayata ghérghérsisafé tane tikfan túmén efogh?
\q2 Nderé nayu so tane sénanégh téfnárafene em tukén ngángé?
\q1 \v 3 Kénawengo a kwénmawango ta, o Yuré tane Ngánján!
\q2 Múyé kwaram, o mété kér wém.
\q1 \v 4 Yau eumyota tane mék téfnár néngorayat, “Yéndfem té yáindangém fá!”
\q2 Yau eumyota fá sái náuwetat tane uyégh sifayan.
\q1 \v 5 Wénde yéndo efalo yiyátotan fene uwégh yau kuyangé.
\q2 Yénd so náuwetan ménamén fémo yénd té ghérsé wanjaryéng.
\q1 \v 6 Yéndo so wagh erametan Yurai
\q2 ménamén fá siyém mer tafaf.
\c 14
\s
\q1 \v 1 Ongén mwighafé ár néngorayat yéfenjo tikfan,
\q2 “Yau yém Ngánján.”
\q1 Fá em méinyotio awasnengéghan, yémofem té tawafrotat mámáfi yam.
\q2 Kété ámb yau efe yém mbarkándyam wafrogh ár.
\q1 \v 2 Yuré nénrete yuwot kétamé njafarta
\q2 yénan méinyotio ár sáffaf.
\q1 Fá nénrete efande té ámb ár yém efalofifi káfeté mwighafé,
\q2 njam ámb ár yéronja Ngánján.
\q1 \v 3 Wénde yau, méinyotio té néngawengongi,
\q2 méinyotio té nénamndangi a wasérmboghan.
\q1 Emo ámb yau yafrote mer,
\q2 yau ámb ámbiro árom!
\q1 \v 4 So fá emofem ewafrotat mámáfi yau so notametat?
\q2 Yémofem enetat tane ár ndenanit féskaf flawé
\q2 a yau nemnat Yurafaf orayéghét.
\q1 \v 5 Férféram so ewerete fá,
\q2 ménamén Ngánján siyém yémafé em emofem yiyáretat fá.
\q1 \v 6 Mámáfi árém fifiofnar yame ewasérmbotat yéfene mwighé farorégh efe mere yau ewanjetat,
\q2 wénde Yuram so ewarawene yánjo ár.
\q1 \v 7 Efe so yéném kétamé Jaion mband tunakéfta ménát sái tawanjarngé Israil ár?
\q2 Njam Yuram tanwangongé yánjo ár,
\q2 Jeikof so nutne áuwéghafé, a Israil ár so náuwetat.
\c 15
\s
\p
\v 1 Efe so wáwefnoghan em fene njúnnjúnofnar sifayan, O Yuré?
\q2 Efe so kényawangi fene ghékéf fayogh sifayafaf fene njúnnjúnofnar mband tunakéffaf?
\q1 \v 2 Fá em emofem elimndat téfnofnar ghérsé a ewafrotat némé yém mbarkánd,
\q2 norayat efalomén kétamé unyéghofnar tikéfta.
\q1 \v 3 Fá em efe nakenat ár si wafroghta
\q2 o ewaghnat yéfene kaka ár
\q2 o emndetat yaufi so yéfenjo fútaréf.
\q1 \v 4 Fá em emofem méndméndat efandat méndefé wimafé yaufiyam téfnár,
\q2 a eutémndat ndimbal mwighafé Yurane waitogh ár,
\q2 a ewarawenat yéfenjo unyéghofnar si njam sot enfetat.
\q1 \v 5 Fá em emofem tákmangi mani fai wangoghofnar,
\q2 a efe yau so yasotat manie ménát sái nuinda ménd ároenemén.
\q1 Ndené ár so ewakai taikrataye tuot.
\c 16
\s
\q1 \v 1 Warawena yénd, O Ngánján,
\q2 ménamén yénd té nénaflan yénan fefaf ménát átnoghét.
\q1 \v 2 Yénd norayangén kétán Yurafaf, "Fém ném tane ndimbal!
\q2 Méinyotio tárfár mer rokar tane sem eném kétamé feta."
\q1 \v 3 Ngánján ghérsafé ár mbandan em tane efalo sotafé muyafé ár!
\q2 Yéndo yérsan klisa yéfene kénjún.
\q1 \v 4 Kérté nafune yéfefaf emofem méndefé efandat ámb ngánján.
\q2 Yéndo yau so yérsan ámb sifayé yéfene férék ghéngén wafroghan
\q2 o sái engémndetan yéfene ngánjánafene yétkwén
\q1 \v 5 Yuré, mé fémro fété ném tayot rokar raméghét, tane kafusi frengéghafé.
\q2 Fémo ewarawene méinyotio árkéméné em tane.
\q1 \v 6 Mband fémo árké waramai ta yém méndefé mband.
\q2 Nderé sariafé rokar em!
\q1 \v 7 Yéndo so yéfrendan Yuré emo wambete yénd!
\q2 Njam sémbáran tane tikfam táf kwaramangé wawéngsogh si ta.
\q1 \v 8 Yénd mat wém Yuré túmén tafaf.
\q2 Yénd yau so kwésambnetangi, ménamén fá siyém yétém tafaf.
\q1 \v 9 Wawéngsoghofnar tane tikéf násnete, a yénd náuwetan.
\q2 Tane fifi nene wambégh kénjún.
\q1 \v 10 Ménamén fémo yau so téfrango tane árngéghofnar fifi kér árfefaf
\q2 o tumyo fene njúnnjúnofnar ár ménát sái nornda mbéwéyan.
\q1 \v 11 Fémo so kwayafo ghérsamén end,
\q2 wéngwarameta ta fene áuwégh sáf
\q2 a ménde ménayan sái yénmorare fémafé tuot.
\c 17
\s
\q1 \v 1 O Yuré, náyáreta tane ndimbal ménde ménát mbarkándot.
\q2 Náyáreta tane ye ménát wáutárghét.
\q1 Kamyo tane Ngánjánafé orayéghfaf,
\q2 ménamén yéném kétamé unyéghofnar mbírmbírta.
\q1 \v 2 Marat tiyáto tanemén téfnofnar wém,
\q2 ménamén fémo efande fá emofem ewafrotat mbarkándyam.
\q1 \v 3 Fémo té taufote tane mwighé a tayamngote tane tikéf sémbáran.
\q2 Fémo té kwéfande yénd a yau yinjo mámáfi.
\q2 Yéndo mwighé yéngsotan yau so yaufi yam yafrotan némé njam norayan.
\q1 \v 4 Yéndo té tawaitotan fene wafarégh si
\q2 árkéménayam kwambete yéfe waitoghta wasnengégh a yaufiyam árta.
\q1 \v 5 Tane kafkaf té táyá fene endén,
\q2 yénd yau kawafnan njam fém kémaitotan.
\q1 \v 6 Yénd norayan yénan fefaf ménamén yénd mat wém fémo so kwawango, O Ngánján.
\q2 Káwefno a náyáreta njam yénd néngorayan.
\q1 \v 7 Kwauyafo ta fene olaghofnar uwégh sariafé endmé.
\q2 Ménaye fene ndimbal waftaye fémo ewanjane
\q2 fá emofem yéronjat átnogh yéfenjo mék téfnárafeta.
\q1 \v 8 Wambete yénd ndené fété fémo ndernaye ewarawene fenjo ghékéf.
\q2 Kwamo yénd fene njamb mbanmbanan.
\q1 \v 9 Warawena kétamé mámáfi árfeta emofem yénd wénmafngongi séméghét,
\q2 kétamé ár ngi téfnár sénanégh ár emofem yénd warendangi.
\q1 \v 10 Fá em ghérghérsisafnar.
\q2 Náyáreta yéfene awarmbogh sifaf!
\q1 \v 11 Yémofem kwérnangayénd yénd a kwarendangayénd,
\q2 kéretawét ménát so féneféne tinjongayénd sái kwitawét mbandot.
\q1 \v 12 Fá ndenanit em nékwafé ndimbal munjan fus, yéta wérametat sái wétirnat kwéfarngi karéf-
\q2 ndenanit tosé ndimbal munjan fus nátnotat.
\q1 \v 13 Kokai, O Yuré!
\q2 Kokai yéfe wifarghét, a tanman yéfene budmeyot!
\q2 Kwanjar yénd kétamé yaufi árta ménaye fene witmafé sénté naifaye!
\q1 \v 14 Ménaye fene wafté ngángaye, O Yuré,
\q2 yénya fá efe néretat mband maratan fai résaghét.
\q1 Wénde eremngota fene siogh ngonjélafé ár.
\q2 So yéfene ambum em tárfár rokarafé,
\q2 engéfrangotat yéfenjo rokar yéfene ákiambumafefaf.
\q1 \v 15 Ménamén yénd wém mbarkánd, yéndo so néfandan fém.
\q2 Njam yénd kanon, yéndo so nafandwam sáfero a wéremngota.
\c 18
\s
\q1 \v 1 Yéndo némuwetan fém, Yuré!
\q2 Fém ném tane muyé.
\q1 \v 2 Yuré yém tane wím, tane átnogh méngo, a tane wanjarégh ár,
\q2 tane Ngánján siyém tane wím, endefaf yéndo tinjon átnogh.
\q1 Fá siyém tane mbakw, yéné wafté árkéménayam wanjane,
\q2 a yém tane wanjarégh sifayé.
\q1 \v 3 Yénd nutnan Yurafaf, efe yém ndimbal utmanéghafé,
\q2 a yémo wanjaryéng yénd tane mék téfnárafeta.
\q1 \v 4 Kér ángégham yénd wengoyénd;
\q2 kértafé kéféram wafaryéng yénd.
\q1 \v 5 Mbéwé méngoyam eumbetam yánjo ángégh tafafmé ewarendam;
\q2 kéram yéknai urér tane endén.
\q1 \v 6 Wénde tane mwighé kértayan yénd kutnangén kétán Yurafaf;
\q2 néméwét, yénd ghékéf numbértotan kétán tane Ngánjánefaf ménát wáutárghét.
\q1 Yémo kwiyárangé kétamé yánjo utmanégh méngota;
\q2 tane yeyam eyanje yáne téngan.
\q1 \v 7 Féyo sokrere kásámbnetau.
\q2 Mband tunakéf téfnan ngasambnetawét;
\q2 fá ngasambnetawét ménamén yáne nékwmén.
\q1 \v 8 Kwam kénasunau kétamé yáne min féneta;
\q2 waftafé kankékanké kénatnawét kétamé yáne sénféneta.
\q2 Kwayaghé fés waftafé ténmorwén kétamé yá tambén.
\q1 \v 9 Yémo yasaweryéng njafar a nénewéryéng;
\q2 kwéfité kiwal nu kwéf témorwén yáne kafkaf mbanmbanan.
\q1 \v 10 Mband tunakéf nufrotam minde ndimbal njafar si résagh ár sáf ároefaf,
\q2 fá nanefai, tukét njamb mbormbore.
\q1 \v 11 Fá nawafaryéng fáyo kwéfitaye,
\q2 tuyafotau yánjo sáf ménaye kwéfité nu kwéfe.
\q1 \v 12 Sénjté nu kwéfam yénawetam fá yarendam
\q2 a afamégh nénufngoi krufér nu mbwe a wakraréghafé mband fés.
\q1 \v 13 Yuré toyaye yénmormén kétamé njafarta;
\q2 minde Tukén ároene kém wéikor nutnai
\q2 krufrát nu afamégh kénjún a mband akraréghfaf.
\q1 \v 14 Yémo yánjo fimbe enamndam a ewafarnai yáne sénanégh téfnár;
\q2 yáne toyé natremngoi, a fá ndimbal kéráye uwérsoghan témorwén.
\q1 \v 15 Féyo fene wafaréghan, O Yuré,
\q2 kété fene ambone ngifaf arakaf
\q1 kwémb mé fandagh témorwén,
\q2 a mbandoene téfén mé safénro témorwén.
\q1 \v 16 Yémo ngángé tanwatembangé kétamé njafarta a kwambangé,
\q2 yémo kwénmurtongé yénd kénjkam nuta.
\q1 \v 17 Yémo yénd kwambangé kétamé tane wafté kér ro mék téfnárafeta,
\q2 yéfeta kétamé emofem méndméndat wéfandat a em minde kwérnarafé tayot.
\q1 \v 18 Yémofem yénd kwafngongayénd yéné efoghféneféneyan yénd njam mwighé kértayan kwémorwén,
\q2 wénde Yuram kwamarotau yénd.
\q1 \v 19 Yémo kwélimndau yénd kétán wanjarégh sifayafaf;
\q2 yémo kwambangai yénd ménamén yémo yénd méndefé kwéfandau.
\q1 \v 20 Yuram fai kwafrotau yénd ménamén mbarkánd yam wafroghmén;
\q2 yémo kwangongai wéikor fronde mer wafroghyamfaf ménamén tane téfnofnarmén.
\q1 \v 21 Ménamén yéndo té tawarawenan Yurane end;
\q2 yéndo yau tawengotan sem tane Ngánjáne ménát sái tawaitotawén yaufiyam.
\q1 \v 22 Yéndo té tawaitotawén méinyotio yáne nák;
\q2 yéndo yau tafrangotawén yáne wafarégh si.
\q1 \v 23 Yénd wém téfnofnar Ngánjánene réré
\q2 yénd té kawamotan yéndio kétamé yaufiyamta.
\q1 \v 24 Yuram fai wafrotam yénd ménamén mbarkánd yam wafroghmén.
\q2 Yémo té kwafandau tane téfnofnar yam.
\q1 \v 25 Yéfeyot efe mé ndimbal mwighé fá fem nauyafote fémyo ném ndimbal mwighata.
\q2 Yéfeyot efe em méinyotio yaman mer fémo yuyafote méinyotio yam merro.
\q1 \v 26 Yéfeyot efe em féwénféwénofnar fém fémyo nauyafote ném féwénféwénofnar,
\q2 wénde yéfefaf efe em mámáfi fem nauyafote fémyo méndefnar ném.
\q1 \v 27 Fémo tawanjar yuwan ghérsafé,
\q2 wénde fémo yuwot tawewor tuktuk ár.
\q1 \v 28 Fémo kwawaro lambefé tayot.
\q2 Yuré, tane Ngánján, kwayaghat tufarngé tane kwéfité.
\q1 \v 29 Fene muyé kénjún yéndon so féyotaro yaghnan tane mék téfnár;
\q2 yémafé tane Ngánjánafé yéndon so kor yafenan árké mbakw téu.
\q1 \v 30 Ngánjánene end siyém njúnnjúnofnar.
\q2 Méinyotio Yurane unyéghofnar si sem efalo.
\q2 Fá siyém awangogh mbakw yéfe méinyotio emofem yéronjat fá ménát wambghét.
\q1 \v 31 Ménamén efe yém Ngánján mé Yuraro?
\q2 Efe wénde téfene Ngánján siyém táikér wém?
\q1 \v 32 Ngánjánam ásmégh yafrote tayot muyafé,
\q2 a yémo tane end yafrote féwénféwénofnar.
\q1 \v 33 Yémo wafrotam yénd ndenanit rusane ghambér,
\q2 wiyátote yénd ménát sái wakai mband tunakéf tukén.
\q1 \v 34 Yémo ewatamete tane ngángé ásméghét;
\q2 yémo muyé ewaramete tane ngángat ménát sái yélimndan bronjmén namb.
\q1 \v 35 Fémo té waramai ta fene mbakw waingéghét.
\q2 Fene tambénta ngángayam wamarote yénd;
\q2 fene wáutárgham té yénd wiyáto ndimbal.
\q1 \v 36 Fémo té yafrotam marat end tane kafkafot
\q2 ménát yau so néunotat.
\q1 \v 37 Yéndo tawifnawén tane mék téfnár a ewarayén.
\q2 Yénd yau nékmboyén kétánotio ewaindayén.
\q1 \v 38 Yéndo tatarmangayén fá yau kanongayénd;
\q2 fá kénuyangayénd tane kafkaf mbanmbanot.
\q1 \v 39 Fémo té mékot kwamanete yénd muyaye ménát mékot;
\q2 fémo té tane limánéghétro enram tane mék téfnár tane kafkaf mbanmbanot.
\q1 \v 40 Fémo tane kafkaf tafayote yéfene kémamé.
\q2 Yéndo té ténan méinyotio fá emofem méndméndat kéfandat yénd.
\q1 \v 41 Fá kutnat wáutárghét, wénde fá kakenangai wawangoghét.
\q2 Fá yéta kutnawét Yurafaf, wénde fá kakenangai wawangoghét.
\q1 \v 42 Yéndo mere ekmayén fá njúnnjúnofnar yau ndené ngwérméng mbormboram yénau efnje.
\q2 Yéndo esambunan fá kétán end yékwét ndenanit njénnjén.
\q1 \v 43 Fémo waramai ta waingégh muyé tane wánangogh árét.
\q2 Fémo wékafai yénd ndimbal yu limánéghét;
\q2 ár efe yénd mat yau wém sénonjo násáfotat tayot.
\q1 \v 44 Njam fá káyárangé tanemén, fá kamyongi;
\q2 ámb dabi ndimbal yu táf férfére tane rére.
\q1 \v 45 Fá omyégh káyátongi
\q2 a eném ngerngerero yéfenjo táikér sifayata.
\q1 \v 46 Yuré ghérsé mé yém! Yuwetam tane wím!
\q2 So tane Ngánján wanjarégh ár yuyotam!
\q1 \v 47 Fá yéné Ngánján yém emo fai ewawangote yéfe emofem yénd tékrat wéfandat.
\q2 Fá emeinde ndimbal yu wiyárayénd yénd,
\q2 \v 48 a wanjana tane mék téfnárafeta.
\q1 Fémo kwére kwanjar tane mék téfnárafene weréghta;
\q2 fémo wanjana yénd kétamé wasérmbogh árfeta.
\q1 \v 49 Yénémamén, O Yuré, yéndo so némarsan yénamé ndimbal yu kés em;
\q2 yéndo so wagh yérametan fene yétkwénan.
\q1 \v 50 Fémo eramete ndimbal waingégh muyé kétán fene warsagh ároefaf;
\q2 fémo yuyafote taikre uwégh fene téghkaf ároefaf,
\q2 yáfaf Deifid a yáne méinyotio ákiambumat tuot.
\c 19
\s
\q1 \v 1 Njafaram néngafrotat Ngánjánene ndimbal kwayaghamén.
\q2 njafar nekérnekéram yufarotat yáne ngángé wafroghmén.
\q1 \v 2 Méinyotio efogh fá mégh nénorayat;
\q2 méinyotio sémbár yémofem fá mat yéngyátotat.
\q1 \v 3 Fá néngorayat kém rérkefnar o siofnar;
\q2 yéfene kém yau náyáretat.
\q1 \v 4 Wénde yéfene si té téngém méinyotio yuwomé
\q2 a yéfene afrogh méinyotio mband maratan.
\q1 Ngánjánam té yafrogh méngo njafaran efghoe.
\q1 \v 5 Fá kénamndangé ndenanit kwayaghé totér awerégh ár yénau yém awerégh afrengéghan.
\q2 Fá náuwéte ndenanit wérse ufoghan yénau yém ménát sái nérsat efe so kawaindangé.
\q1 \v 6 Efogh nénareinde njafar fétfétta
\q2 a yaitote yánjo wérse kétánotio ámb fétfét.
\q1 \v 7 Wafroghét si Yurane sem merro,
\q2 yengote tikéf.
\q1 Wafarégh si Yurane sem efalo yátoghét,
\q2 engyátote káfeté mwighé téfnár mé nekamb.
\q1 \v 8 A nák Yurane sem mbarkánd,
\q2 enérse áuwégh kétán tikfot.
\q1 Wafarégh si Yurane sem mé safénro,
\q2 yaramete kénjú mwighai ménát ghérsé ámnjoghét.
\q1 \v 9 Sái yufarota Yuré siyém féwénféwénofnar,
\q2 nakete tuot.
\q1 Nák Yurane sem efalo;
\q2 méinyotio ndenaro em.
\q1 \v 10 Yéné sem minde tikfafé yau gol,
\q2 o ámb frengéghmén gol.
\q1 Yéné sem méndero yau faméghar,
\q2 a yau kor ndené wékwér yénau nérte faméghar fifita.
\q1 \v 11 Yéné sem matot em fene wásáfogh ároe,
\q2 a ndimbal faiot yéfeyot emofem ewaitotat yéné.
\q1 \v 12 Ndernáye so yénd mat wém méinyotio yaufiyammén mé senglaitan tane tikfan?
\q2 Kwaina yénd kétamé yéné kénjú tékratmén.
\q1 \v 13 Yarawena fene wásáfogh ár kétamé Afrátaye yaufiyam kés em!
\q2 Yau eumyota siya wélimndat.
\q1 Féyo yénd so wém yuwek kértafnar
\q2 a téfnofnar ndimbal yaufiyammén.
\q1 \v 14 So tane mbírmbírta si
\q2 a tane awáyárégh tikéf
\q1 so yém klisafé fefaf,
\q2 O Yuré, tane wém a tane yaufi wányányégh ár.
\c 20
\s
\q1 \v 1 Kérté yam efghon, so Yuram kémawangongé fene yeyan táf.
\q2 So Jeikofene Ngánjánene yétkwénam némarawena fém kértafnar kétamé méinyotio ngita.
\q1 \v 2 So yémo yénmafarete fe wáutárégh kétamé yáne wáwefnogh méngota
\q2 a muyé tawaramangé kétamé Jerusalemta.
\q1 \v 3 So yémo mwighaye ewafarote méinyotio féfene ramégh
\q2 a néreta méndefé féfene ghéngén waroghfaf.
\q1 \v 4 So yémo efrende féfene tikéfmén ménde
\q2 a ewawafrota féfene mwighé faroréghmén fifiyafé.
\q1 \v 5 So yénd nutnam áuwéghmén njam yénd náyáretam fene waingéghmén
\q2 a tuyongém fene waingégh férén téfene Ngánjánene yétkwénan.
\q1 So Yuram ewawangote féfene orayéghmén.
\q1 \v 6 Sénonjo yénd mat wém ndené Yuram yanjane yánjo téghmén warsagh ár.
\q2 Yémo so yénmawangote yá kétán yánjo njúnnjúnofnar njafarta
\q2 a tanjarngé ménaye yánjo ndimbal waftaye.
\q1 \v 7 Ámb ndimbal yu néngawarsat yéfene kariot wérse árfenemén a os kés em,
\q2 wénde yénd nawarsam téfene Yuré Ngánjánene yétkwénan.
\q1 \v 8 Yéné ndimbal yu so nuitat a néngironat,
\q2 wénde yénd so nanotam a yénmakai taikrataye.
\q1 \v 9 Yarametam waingéghét kétán téfene warsagh ároe, O Yuré!
\q2 Yénmawangota téfene yemén yénmáutána.
\c 21
\s
\q1 \v 1 Ndernáye warsagh ár náuwete fene muyé kénjún, O Yuré!
\q2 Fá nutne áuwéghafé ménamén fémo taram yá waingégh.
\q1 \v 2 Yénat fémo té yaramai yá yáne tikfan méndé
\q2 fémo yau yerang némndafi fá némat ménde tém.
\q1 \v 3 Fémo yumyo fá yénmango ménayafé remngoghafé a néférmeta.
\q2 Fémo yafayoi kor mer frengéghmén ákiki yáne sénkoyan.
\q1 \v 4 Yémo némamnendai ménát so tanjanam yáne ghérsé,
\q2 a fémo yawafrotam némat nomnendai.
\q2 Efogh yáne ghérsamén néngalimayénd tuot.
\q1 \v 5 Fene waingégham yénérse ndimbal utmanégh,
\q2 a fémo té tawote fá ménaye ndibal kwayaghaye a utmanéghe.
\q1 \v 6 Fémo té yaramai yá ménayafé akegh frengéghafé
\q2 a yaramai yá fene auyafogh áuwégh.
\q1 \v 7 Ménamén warsagh árom mwighafé yéfande Yuré.
\q2 Minde Tukénene uwégham so yerete taikre fá kétamé uyoghta.
\q1 \v 8 Fémo so muyaye ewerete méinyotio fene mék téfnár.
\q2 Fene muyé kér ro tambén ngángayam so kwérnare ewerete méinyotio fá emofem méndméndat néfandat fém.
\q1 \v 9 Fémo so ewite fá fés kankékankéfaf
\q2 njam fém kufar.
\q1 Yuram so tawifongé fá yáne nékwé
\q2 fésam so ewakerne fá.
\q1 \v 10 Fémo so tawalinda yéfene ambum mband maratan,
\q2 yéfene yau so em ákiambum.
\q1 \v 11 Ndemamén téu yémofem kwankwane mwighé yétarnat fefaf,
\q2 yéfene yaufiyot mwighé wafrogh yau so nufrote.
\q1 \v 12 Ménamén fá so kokayongi a kengongi
\q2 njam yémofem tawonjongi fene fimbam ewafarenat fá.
\q1 \v 13 Kunja, O Yuré, méinyotio fene waftaye.
\q2 Ménayafé gita kembnefé a waghafé yéndfem yafyam fene ndimbal wafroghyam.
\c 22
\s
\q1 \v 1 Tane Ngánján, tane Ngánján, némamén wét fémo ndimbal wéfrango yénd?
\q2 Némamén fém minde nayufifi ném njam yénd mikefé nafghetan wáutárghét.
\q1 \v 2 Méinyotio efghon yénd nutnan fefaf, tane Ngánján, wénde fém yau kénwango.
\q2 Méinyotio sémbáran fém náyárete tane kém, wénde yéndo yau tinjon mer té náyáton.
\q1 \v 3 Wénde fém ném njúnnjúnofnar,
\q2 limánégh ámnjogh sifayan Israil árém némarsat.
\q1 \v 4 Téfene ákiam mwighafé kénfandawét fém,
\q2 a fémo tawanjarngai fá.
\q1 \v 5 Fá kunangayénd fefaf a kunjarngayénd.
\q2 Yémofem mwighafé kénfandawét fém a yau tamorwén wáiwái.
\q1 \v 6 Wénde yénd wém ndénd a yau árfifi.
\q2 Yénd tékrat wéfandat a wéngemndetat méinyotio árém!
\q1 \v 7 Méinyotio árém emo kwinjongé yénd sie ngi kwafngongi.
\q2 Yémofem ághéághé fén kurtangi a tangsambnetangi yéfenjo sénko, néngorayat,
\q1 \v 8 "Yéné fété fá yém efe namyote Yurafaf?
\q2 Féyo téu Yuram tanjarngé!
\q1 Njam Yuram yuweta fá mindefifi,
\q2 Yuram tanjarngé fá!"
\q1 \v 9 Wénde fémo wénérsam yénd kwanjanau kétamé tane amane fút kénjúta
\q2 a kwélindau yénd mwighafé kénfandawén fém kété tane amane nonoan.
\q1 \v 10 Yénd té wékeye wéramai fene ngángat kété tane araféghan.
\q2 Fém té kénmorwén tane Ngánján yéné efghon táf yénd njam náftamén.
\q1 \v 11 Yau táf mámé nayu ném ta tambén,
\q2 ménamén kérté yam siyém kaka,
\q2 a emo yau ámb so wáutáne.
\q1 \v 12 Tane mék téfnáram kwarendangi ndenanit séfafé ndimbal kau
\q2 férférafé ndimbal kau Basanmén té warendangi yénd.
\q1 \v 13 Yémofem tasafongi marat yéfene sén féne tayot
\q2 ndenanit kwagh a wánangogh ndimbal munjan fus.
\q1 \v 14 Yénd ndenanit wasunat nu,
\q2 a tane sot sem yau nusamngotat.
\q1 Tane tikéf yém ndenanit raba,
\q2 yéné nérnde tane kénjún.
\q1 \v 15 Tane muyé té ghérnat namnda ndenanit efogh falaghmén ngénd.
\q2 Tane kanké yéngwalinjo tane sénféneyan tukta.
\q2 Fémo té wékmai mbandan a wéfrangoi kérot.
\q1 \v 16 Tane mék téfnáram kwarendangi;
\q2 ndenanit ághé séf a yaufi mérén kaka nénáyátotat tane kénjút.
\q2 Yémofem té yékunangi tane ngángé a tane kafkaf.
\q1 \v 17 Yéndo so féyotaro ewaftan méinyoto tane sot.
\q2 Tane mék téfnár néretayénd, yémofem wánangogh wénmafngoyénd.
\q1 \v 18 Yémofem kawaftawét tane soda yéfe kénjúnro
\q2 a tane sálámeyot fá kambnawét dais mbwe.
\q1 \v 19 Wénde fém, O Yuré, yau nayu ném!
\q2 Fém ném tane wáutárégh, néném tane wáutárghét!
\q1 \v 20 Tanjar tane mbérmbér kétamé witmafé sénté naifata;
\q2 tané yénaro ghérsé kétamé ághafene waftata.
\q1 \v 21 Kwanjar yénd kétamé ndimbal munjan fusafene sénféneta
\q2 kétamé kéghat kauwafene tártárafeta fémo wénmawango ta.
\q1 \v 22 Yénd so nafrotan fene yétkwénmén kétán tane árfefaf.
\q2 tárfár ár áumengégh kénjún yéndon so némarsan fém.
\q1 \v 23 Fém emo férférafé yéfande Yuré, yarsa fá!
\q2 Fém méinyotio Jeikofene ákif, ndimbal kwayaghé yarametati yá.
\q2 A ewakai yánemén mat siafé méinyotio fém Israilene ákiambum.
\q1 \v 24 Ménamén yémo yau ekenayéng o némbnar eyátoi tékrat ménde téfnárafene.
\q2 Yémo yau ewawengoi sém yéfe,
\q2 wénde té náyárai yéfe ye ménát wáutárghét.
\q1 \v 25 Yéndo so némuyotan ndimbal áumengégh kénjún.
\q2 Yéndo so efalo eyátotan tanjo kém yéfene sáfan emofem némáwefnotat fe.
\q1 \v 26 Yauyau árém so enetat a eremngota.
\q2 Méinyotio árém emofem yéronjat Yuré so yuyotat fá.
\q2 Yéfene tikéf so náuwetat tuot akegh áuwéghafé.
\q1 \v 27 Méinyotio mband so mat náyátotat Yuranemén a nangotat yáfaf.
\q2 Méinyotio mérén ndimbal yu kénjúmé so budém náwefnotan yáne sáfrére.
\q1 \v 28 Ménamén tikéfmén wafté yáne yém Yurane.
\q2 Yémo elimnde méinyotio yu.
\q1 \v 29 So mbandmén wemar árém yafrotat téménd a yáwefnotat.
\q2 Budém yáwefnotat yáne sáfrére, méinyotio ár efe em orngégh ár,
\q2 méinyotio fá endefene ghérsé so néngefotat ngwérméngot.
\q1 \v 30 Téfene ambumam so fété násáfotat yáyot.
\q2 Soramé yu ár saté so néngáyáretat ménamén Yurane sariafé yammén.
\q1 \v 31 Yáne mbarkánd yam wafrogh so engwaufrotat yéfe efe mé yau karáftat.
\q2 Fá so náyáretat ménamén méinyotio yémo némé té tawafrotau.
\c 23
\s
\q1 \v 1 Yuré siyém tane sif wanjengégh ár,
\q2 tane em méinyotio yénd árké ménát ménde kwém.
\q1 \v 2 Yémo kwaramangé ta enagh mer sifayan,
\q2 yémo wélimnde métar nu téndomé.
\q2 \v 3 Yémo kwaramangé totér muyé.
\q1 Yémo kwauyafongé mbarkánd end.
\q2 Ngánjánam yafrote yéné ménamén fá siyém mer.
\q1 \v 4 Ndemamén end téu kwéfité yém,
\q2 yénd yau so wém férfér.
\q1 Ménamén fémafé yénd yénre.
\q2 Fene yaké a wétuam wiyatote sénté mwighé emaréghafé.
\q1 \v 5 Fémo yafrote téménd tayot
\q2 tane mék téfnárafene sáfan.
\q1 Fémo tékém oil tane sénkoyan.
\q2 Tane kafusi kafongé a kawetongé.
\q1 \v 6 Yénd nemnan ndené fene mer a kwénjtafnar uwégham so waitote yénd
\q2 méinyotio efogh tane ghérsayan.
\q1 Yénd so wémor Yurane méngo kénjún tuot.”
\c 24
\s
\q1 \v 1 Mband siyém Yurane a méinyotio rokar yéné kénjún.
\q2 Mband marat a ár yéné kénjún.
\q1 \v 2 Ménamén yémo eitan mbandoene téfén arakafan
\q2 a yérametam arakaf kénjún.
\q1 \v 3 Efe so narmbote Yurane mband tunakfot?
\q2 Efe so kokayongé yane njúnnjúnofnar sifayan?
\q1 \v 4 Mé fáro endefene ngángé a tikéf em njúnnjúnofnar,
\q2 emofem yau ewáwefnotat mewangat
\q2 a yau unyégh si néngafrotat.
\q1 \v 5 Yémofem so ewinjotat Yurane frengégh
\q2 a ewam mbarkánd fútar yam yémafé Ngánjánafé yéfene wanjarégh ár.
\q1 \v 6 Ndené árém fiya kor kénronjangi fém
\q2 a wáwefnogh yafrotat fene sáfan, o Jeikofene Ngánján.
\q1 \v 7 Tasawérngi, tándáwár sésafne
\q2 tasawérngi tándáwár sésafne,
\q2 a tumyongi warsagh ár ndimbal kwayaghé Yuré kényawangé.
\q1 \v 8 Efe yém warsagh ár ndimbal kwayaghafé?
\q2 Fá Yuré, muyé kér ro a wafté,
\q2 fá Yuré, fandaghofnar ménayan mék kénjún.
\q1 \v 9 Tasawérngi, tándáwár sésafne!
\q2 Tasawérngi, tándáwár sésafne,
\q2 a tumyongi warsagh ár ndimbal kwayaghafé kényawangé.
\q1 \v 10 Efe yém warsagh ár ndimbal kwayaghafé?
\q2 Fá njafar fiyarafene Yuré-
\q2 fá yéné féyém warsagh ár ndimbal kwayaghafé.
\c 25
\s
\q1 \v 1 O Yuré, yéndo yérametan tane ghérsé fefaf.
\q2 \v 2 Yéndo mwighafé néfandan fém, tane Ngánján!
\q1 Yau táf wumyota yénd sái wiyátotat áuwéghofnarot,
\q2 o eumyota tane mék téfnár náuwetat táf mékan njam kwaindangi.
\q1 \v 3 Emo njam efalo niyátota fém yau so wáiwáiot tékém,
\q2 wénde wáiwái yéném yéfeyot emo yéta eutanat ámb ár.
\q1 \v 4 Kwauyafo ta mbarkánd end, O Yuré;
\q2 tuyafo end tayot ménát waitoghét.
\q1 \v 5 Wélimnda yénd fene efalo fifian a watameta yénd,
\q2 ménamén fém ném Ngánján emo wanjane yénd.
\q2 Méinyotio efogh tombé yéndo yékmetan tane kamnang fene kénjún.
\q1 \v 6 Nawafarota, O Yuré, fene ghérghérsisé a kwénjtafnar uwégh,
\q2 árkéméné fémo yuyafotam kétamé tainda efogh kés nénawaindayénd.
\q1 \v 7 Yau ewafarota áyáréghofnar yaufiyam tane tot ambum tawar.
\q2 Wafarota yénd fene kwénjtafnar uwégh kwayaghaye,
\q2 ménamén fém ném ghérghérsisé kér ro, O Yuré.
\q1 \v 8 Yuré siyém mer a ewafrote némé yém mbarkánd;
\q2 yémo ewauyafote merfifi end yéfe efe engém nayu.
\q1 \v 9 Yémo elimnde yuwan ár mbarkánd wafrogh yam kénjún,
\q2 engwatamete yánjo end.
\q1 \v 10 Yuram limánégh yafrote ménaye kwénjtafnar uwéghe a ndimbal mwighaye
\q2 méinyotio emofem yarawenat yémafé árnégh yam a ewaitotat yáne wafarégh si.
\q1 \v 11 Ménát fene utmanégh yétkwénot, O Yuré,
\q2 kwawai tane tárfár yaufiyam.
\q1 \v 12 Efe fá em emofem férférafé yéfandat Yuré?
\q2 Yémo so ewauyafote end yémofem sái tékafangi.
\q1 \v 13 Fá so nawaindat ámnjogh kénjún,
\q2 a yéfene ambumam so tanangi mband.
\q1 \v 14 Yuré siyém fútar yéfefaf emofem férférafé yéfandat fá.
\q2 Yémo ewatamete yémafé arnégh yam.
\q1 \v 15 Tane ghékéf túmén em kétán Yurafaf,
\q2 ménamén yémo ghérsé urtote yénd kétamé tane mék téfnárafene urérta.
\q1 \v 16 Kénawengo yénan tafaf a ném ghérghérsisé,
\q2 ménamén yénd tambia wém a kénjkam kérté yam wétumnde.
\q1 \v 17 Tane kérté yam yéngém mámáfie kétán minde mámáfifaf.
\q2 o, kwanjar yénd yéfeta méinyotio!
\q1 \v 18 Yáyáreta tane ndémke a yéfanda tane kérté yam.
\q2 Kwawai tane méinyotio yaufiyam.
\q1 \v 19 Kéreta njénamb mék téfnár tayot em
\q2 a nderé mámáfie yémofem méndméndat wéfandat yénd!
\q1 \v 20 Wambete yénd! Ghérsé kwanjar kétamé yéfeta!
\q2 Yau kumyo yénd sái wáiwáiot kwékmangi, ménamén fene kénjún yéndo tanan atnogh.
\q1 \v 21 So mbarkánd ghérsayam a efalo ghérsayam wambete yénd,
\q2 ménamén yéndo tane méghmégh yékmetan fene kénjún.
\q1 \v 22 O Ngánján, fai nufrota manie Israil árét
\q2 ménamén méinyotio yéfene tékratmén.
\c 26
\s
\q1 \v 1 Kuyafo yénd téfnofnar wém, O Yuré,
\q2 ménamén yénd té kimndan mbarkánd ghérsayé
\q2 yénd té mwighafé kwém Yurane kénjún déudéuofnar.
\q1 \v 2 Kwékem yénd méngon ufoghan, Yuré, a kor férghe wafénmete yénd.
\q2 Eufota tane mwighane yam a tikéf.
\q1 \v 3 Ménamén yénd túmén matafé wém fene kwénjtafnar uwéghmén,
\q2 a yénd té kwémor fene efalo sian.
\q1 \v 4 Yéndo yau efogh yanetan unyégh téfnárafé
\q2 o yéngém endefé farun mer néretati wénde kénjún yau.
\q1 \v 5 Yéndo méndméndafé yéfandan áumengégh yémafé emofem yéngwafrotat mámáfi,
\q2 a yénd néngakenan sái néngufeindan yéfefaf emofem yéngwafrotat yaufi.
\q1 \v 6 Yéndo taumbarén tane ngángé ménát sái kauyafon yénd wém téfnofnar.
\q2 Yénd wéném fene ghéngén kitarafaf, O Yuré.
\q1 \v 7 Yéngufanan kánjo ramégh wagh
\q2 a engwaufrotan fene sélngwélafé yammén.
\q1 \v 8 Yéndo yuwetan fene wáwefnogh méngon, O Yuré,
\q2 yéné sifayé ánde fene ndimbal kwayaghane sáf yém.
\q1 \v 9 Yau wumyota yénd sái wém yaufiyam árfene tékratan.
\q2 Yau wéfrangota yénd yéfefafmé ár ngi téfnárafefafmé.
\q1 \v 10 Yéfene ngángé sem njúnnjúnro ménayafé yaufi wafrogh yamafé,
\q2 a yémofem túmén táf ewasotat manie.
\q1 \v 11 Wénde yénd yau ndené wém, yénd wémor mbarkánd ghérsafé.
\q2 Féyo kwanjar yénd a tuyafo ta ghérghérsisé.
\q1 \v 12 Sénonjo yénd wakai táikér mbandan,
\q2 a yéndo so marataye yuyotan Yuré.
\c 27
\s
\q1 \v 1 Yuré siyém tane kwayaghé a tane wanjarégh-
\q2 féyo némamén yénd so férfér wém?
\q1 Yuré siyém tane anawégh méngo, warawene yénd kétamé kértata,
\q2 féyo némamén so yénd ngernger wém?
\q1 \v 2 Njam yaufiyam ár eném ménát siya kwifongi yénd,
\q2 njam tane mék téfnár a karogh árém kwafngongi yénd,
\q2 fá so néunotat a nuitat.
\q1 \v 3 Ndemamén téu waftafé fiyaram kwarendangi yénd,
\q2 tane tikéf yau so férféram tifongé.
\q1 Njam téu kwafngongi ngiot
\q2 yénd mé so wém táikér.
\q1 \v 4 Ámbiro yammén yénd namotan Yurafaf
\q2 méinyotio efghon tane ghérsayan
\q1 namyotan fémoghfémoghofnar Yurane kénjún
\q2 a yafénmetan yáne wáwefnogh méngon.
\q1 \v 5 Ménamén yémo so kwémnangé yénd kété njam kérté yam yéném;
\q2 yémo so kwétnongé yénd yáne wáwefnogh méngon.
\q2 Yémo so kwékmangé nayu yau so kwiyánjangi minde tukén wíman.
\q1 \v 6 Féyo yéndo so teran tane sénko yéfene
\q2 tukén tane mék téfnár emofem warendat yénd.
\q1 Kété yáne wáwefnogh méngon yéndo so taraman ghéngén áuwégh keyafé
\q2 waghe a yuwetam Yuré gita kembneye.
\q1 \v 7 Wiyáret yénd njam norayan, O Yuré.
\q2 Táf ném ghérghérsisafé a kwawango ta!
\q1 \v 8 Tane tikfam té niyára fém koraye, "Kénaf a noraiwam yéndfé."
\q2 A tikéf namyo, "Yuré, yénd wéném."
\q1 \v 9 Yau táf kwawengo fene sém tayot.
\q2 Yau táf yékena fene wásáfogh ár nékwe.
\q2 Fém té túmén kénmorwén tane wáutárégh ár.
\q1 Yau kwéfrango sénonjo; yau mwighafnar wit yénd.
\q2 O Ngánján tane wanjarégh ár!
\q1 \v 10 Téu njam tane afam a amé mwighafnar wit yénd,
\q2 Yuram so kwérangé yénd kakaye.
\q1 \v 11 Watameta ndernaye so wémor, O Yuré.
\q2 Wélimnda yénd yénamé mbarkánd endmé,
\q2 ménamén tane mék téfnár nawanjetat tayot.
\q1 \v 12 Yau kwumyo sái nguyan yéfene ngángat.
\q2 Ménamén yémofem wánangotat yénd yéné yammén yéndo árké yau tawafrotan;
\q2 ménaye yéfene amboneye méinyotio yémofem yéta kwéfrotat máméghéraye yénd ménaye tékrate.
\q1 \v 13 Wénde yénd mwighé táikér wém yéndo so yéfandan Yurane meryam
\q2 njamandio yénd yéna wém ghérsé ároene mbandan.
\q1 \v 14 Nawanjeta Yurai.
\q2 Aném muyafé a tumyo fene tikfam tanangé klisa.
\q2 Néméwét, kwawanjeta yáyot Yuré.
\c 28
\s
\q1 \v 1 Yénd norayan kétán fefaf, O Yuré, tane wím.
\q2 Yau táf tanwengo áyáréghofnar téngan tafaf.
\q1 Ménamén fém njam ném métar,
\q2 yénd mété táf féyo wém a kér wém.
\q1 \v 2 Náyáreta tane orayéghfaf ghérghérsisamén
\q2 njam yénd nendan fefaf ménát wáutárghét,
\q2 njam yéndo tauyon tane ngángé kétán fene njúnnjúnofnar utmanégh méngot.
\q1 \v 3 Yau fémo wéngroghe yénd mérne yémafé yaufiyam árfé,
\q2 yémafé emofem ewafrotat mámáfi
\q1 fá efe néngorayat nit si kém kétán yéfe fútarfefaf
\q2 táf yaufi mwighé yéfaronat yéfene tikfan.
\q1 \v 4 Tawaram yéfe tékrat yam ménoe so tanangi!
\q2 Yéné féyotaroan yéfene yaufiyam.
\q1 Fai ewafrota fá yéfene mámáfi yam téfnan!
\q2 Tawaram yéfe so tufongi yénémamén némé té tawawafrotat ámb árét.
\q1 \v 5 Yémofem ámb yau némé yarawenat yénayan Yuram némé yafrotam
\q2 o yénayan némé yáne ngángayam yafrotam.
\q1 Féyo yémo so etirne fá yuwot,
\q2 a fá wéi yau kor so narametat!
\q1 \v 6 Ngánján yarsan!
\q2 Ménamén yémo té náyáre tane ye ghérghérsisamén.
\q1 \v 7 Yuré siyém tane muyé a mbakw.
\q2 Yéndo mwighé ekmetan yáfaf ménaye méinyotio tane tikfe.
\q1 Yémo wáutáne ta, a tane tikéf siyém yafote áuwéghe.
\q2 Yénd kanewén táf kánjo ramégh waghan.
\q1 \v 8 Yuram ewaramete yánjo árét muyé.
\q2 Fá siyém wambégh méngo yáyot yáne teghkaf warsagh ároe.
\q1 \v 9 Tawanjar fenjo ár!
\q2 Frengégh taram Israile, fene minde utmanéghafé sifayé.
\q1 Elimnda fá ndenanit sif yénau elimnde sif limánégh téfnáram,
\q2 a ersa fá fene tangwése tuot.
\c 29
\s
\q1 \v 1 Yutémndati Yuré, fém njafar méngotumén ár;
\q2 yutémndati Yuré ménamén yáne ndimbal kwayaghamén a muyamén.
\q1 \v 2 Yutémndati Yuré ménamén yáne ndimbal kwayaghé yétkwénmén.
\q2 Yáwefnotati Yurai njúnnjúnofnar álálégh kwayaghé kénjún.
\q1 \v 3 Yurane si kém nénamnde arakaf tukmé.
\q2 Ngánjáne ndimbal kwayaghé toyé násmetat.
\q2 Yurane toyé násmetat muyé kér ro arakafan tukmé.
\q1 \v 4 Yurane si kém siyém waftafé;
\q2 Yurane si kém siyém sariafé.
\q1 \v 5 Yurane si kémam engfarone ndimbal suwake wén,
\q2 Yuram tawafarnangé Lebanonmén suwake wén.
\q1 \v 6 Yémo táyátongé Lebanon mband tunakéf nátnát ndenanit totér kaunit;
\q2 yémo tiyátongé Ermon mband tunakéf nátne ndenanit kéghat ndimbal kauoene tosé.
\q1 \v 7 Yurane so kémam tásmangé
\q2 ménaye toyé weréghmén tot téfne.
\q1 \v 8 Yurane si kémam tiyátongé fanfne yu tiyátongé sokreret.
\q2 Yuram yésambnete Kades fanfne yu.
\q1 \v 9 Yurane si kémam tawanjmetangé ndimbal ok wén
\q2 a engénfete wénaro sáfro.
\q1 Yane wáwefnogh méngo kénjún méinyotio ár nutnat, "Minde kwayaghé!"
\q1 \v 10 Yuram limánégh yafrote nu kéféran.
\q2 Yuré limánéghan ndené fété warsagh ár tuot.
\q1 \v 11 Yuram ewaramete muyé yánjo árét.
\q2 Yuram efrende fá ménaye krufrat yame.
\c 30
\s
\q1 \v 1 Yéndon so némuyot fém, Yuré, ménamén fémo ghérsé urtoi yénd.
\q2 Fémo ekene yau eumyote tane mék téfnár sái taramangé tanemén.
\q1 \v 2 O Yuré tane Ngánján, yénd néngendan fefaf wáutárghét,
\q2 a fémo téfuna tayot frengégh.
\q1 \v 3 Fémo wénmanai yénd tukét kétamé mbéwéta O Yuré.
\q2 Fémo kwarawene yénd kétamé kér yékw enyawéghta.
\q1 \v 4 Wagh yéngrametati, méinyotio fém ngánjánene fifi!
\q2 Yarsati yáne njúnnjúnofnar yétkwén.
\q1 \v 5 Ménamén yémo yau nékw yélimnde,
\q2 wénde yáne ngárám nakete ghérsayan!
\q1 Ye awaramégh téu naketa sémbáranro,
\q2 wénde áuwégh yéném akwafé.
\q1 \v 6 Njam yénd kwémorwén waingéghofnar, yénd korayangayén,
\q2 "Némayam yau so kwékmbongé sénonjo!"
\q1 \v 7 Fene ménde, O Yuré, wiyátoi yénat siya wém ndené mband tunakéf.
\q2 Féyo fém néngawengoi ámb tambén tata, a yénd sunsun wémorwén.
\q1 \v 8 Yénd nutnayén kétán fefaf, O Yuré.
\q2 Yéndon yamnendayén Yuré ménát ghérghérsisat, korayawén,
\q1 \v 9 "Némé so fémo taso njam yénd kér wém,
\q2 njam yénd kolitotan mbéwé kénjút?
\q1 So tane ngwérméngam némarse fém?
\q2 So ámb nafrote fene ndimbal mwighamén?
\q1 \v 10 Wiyáreta yénd, Yuré, a ném ghérghérsisafé tafaf.
\q2 Wáutána ta, O Yuré.
\q1 \v 11 Fémo té tengote tane ye awarsamégh kétán áuwéghe wagh ermángéghét.
\q2 Fémo té engwanai tane ye awaramégh sáláme a wawotam yénd ménaye áuwéghe,
\q1 \v 12 ndené yéndo so warsau wagh némarsametau fe a yau so métar wém.
\q2 O Yuré tane Ngánján, yéndo so némarametan fe kánjo tuot!
\c 31
\s
\q1 \v 1 O Yuré, yénd té nénafiyan fefaf ménát wambéghét;
\q2 yau wumyota yénd sái wém áuwéghofnar.
\q2 Kwanjar yénd, ménamén fémo ewafrote némé yém mbarkánd.
\q1 \v 2 Tanwengo fene téngan ménát sái náyáreta yénan tafaf;
\q2 ghérsé kwanjar wékeye.
\q1 Ném tane wambégh wém,
\q2 a átnogh méngo ánde yénd so wém wambéghan.
\q1 \v 3 Fém ném tane wém a tane átnogh méngo.
\q2 Ménát fene yétkwén utmanéghét, wélimnda yénd kwutor yéné kértafé yamta.
\q1 \v 4 Kwénlim yénd kétamé urérta tane mék téfnáram árké takeinde tayot,
\q2 ménamén yéndo yinjon wambégh fene kénjúnro.
\q1 \v 5 Yéndon tikfe némarametan tane mbérmbér fene ngángé kénjút,
\q2 yénd ghérsé kurto, Yure ménamén fém ném ndimbal mwighé kér ro Ngánján.
\q1 \v 6 Yéndo méndméndafé efanda fá emofem ewáwefnotat fifiofnar mewangat.
\q2 Yéndo mwighafé yéfandan Yuré.
\q1 \v 7 Yénd so klisafé wém a néngáuwétan fene kwénjtafnar uwéghan,
\q2 ménamén fémo té ewinjoi tane kérté yam,
\q2 a fémo yarawene ménamén tane mbérmbére tékratmén.
\q1 \v 8 Fémo yau wéram yénd kétán tane mék téfnárafefaf
\q2 wénde té wékmai yénd kété wanjarégh sifayan.
\q1 \v 9 Aném ghérghérsisafé tafaf, Yuré, ménamén yénd kérté yam wétumnde.
\q2 Yéngamam tane ghékéf ewafne.
\q2 Tane fifi a mbérmbér muyafnar namndet.
\q1 \v 10 Yénd kérot nufngon tékratmén;
\q2 tane yúnjéf ténjfi eyátote áuwéghofnar yamam.
\q1 Yaufiyamam té tiyátote sotro tane muyé;
\q2 yénd omyégh té náyáton kétamé kénjún.
\q1 \v 11 Yénd méndefnar wéfandat tane méinyotio mék téfnáram
\q2 a tékrat wéfandat tane kaka fútaram
\q2 wéi tane fútar sem férfér em ménát sái eném kaka tafaf.
\q1 Njam yémofem kwinjongi endén,
\q2 fá kengongi ámb endmé.
\q1 \v 12 Yénd wékarotat ndenanit kar té kwém,
\q2 ndenanit kar wém átyaréghkaf sin.
\q1 \v 13 Yénd té ngáyáretan tárfár si tanemén,
\q2 a yénd ndimbal férféram.
\q1 Tane mék téfnár kwankwane mwighé yéfaronat tayot,
\q2 mwighé yafrotat ménát tane ghérsé sái ténfangi.
\q1 \v 14 Wénde yénd mwighé wém fefaf, O Yuré,
\q2 norayan, "Fém ném tane Ngánján!"
\q1 \v 15 Tane soramé yu siyém fene ngángayan.
\q2 Kwanjar yénd yéfeta efe narotat tayot ékmboghofnar.
\q1 \v 16 Tumyo fene ménde nálálá fene faiofnar ásáfogh ároefaf.
\q2 Fene kwénjtafnar uwégh kénjún, kwanjar yénd.
\q1 \v 17 Yau wéfrangota wáiwáiafé, O Yuré,
\q2 ménát yénd nutnam fefaf wáutárghét.
\q1 Taumyo mámáfiyam ár em wáiwáiafé;
\q2 taumyo fá so ewalinjo métar mbéwé kénjún.
\q1 \v 18 Métar táyáto yéfene unyéghro kanké
\q2 yéné tuktuk a áyáréghofnar kanké árkéménayam tamronat ngánjánene ár.
\q1 \v 19 Nderé ndimbal yém meryam fém
\q2 árké yamndai yéfeyot emofem férférafé néfandat fém.
\q1 Fém kwatékwaté kéném yénat yéfefaf efe eném fefaf ménát wambéghét,
\q2 efrende mband maratoene ghékéf rére.
\q1 \v 20 Fémo etnote fá fene sáf áuyafogh sékisékiyan,
\q2 awanjar yéfeta emofem kwankwane mwighé téfaronat yéfeyot.
\q1 Fémo fene sáf áuyafogh séki tawaramete yéfe,
\q2 nayu kétamé amrorégh kankata.
\q1 \v 21 Yarsan Yuré,
\q2 ménamén yémo té wauyafo ta yáne sariafé kwénjtafnar uwégh.
\q2 Yémo ghérsé kwanjanau njam tane ndimbal tesen wanégh mbanmbanan témorwén.
\q1 \v 22 Tikéf ánefégh kénjún yénd kutnangayén,
\q2 "Yénd té nanfan kétamé Yurata!"
\q1 Wénde fémo náyárai tane ye ghérghérsisafé
\q2 a náyárai tane ke ménát wáutárghét.
\q1 \v 23 Yuwetati Yuré, méinyotio fém ngánjánene ár!
\q2 Ménamén Yuram ewarawene fá efe mé tikéfafé em yáfaf,
\q2 wénde yémo máméghéraye tékratan tákmangé áyáréghofnar.
\q1 \v 24 Yénémamén aem muyafé méghméghafé
\q2 méinyotio fém emofem ekmetati féfene kamnang Yurane kénjún!
\c 32
\s
\q1 \v 1 O, nderé áuwégh yéfe
\q2 endefene áyáréghofnar yam engwawite,
\q2 endefene yaufiyam tákmangé fandaghofnar!
\q1 \v 2 Néméwét, nderé áuwégh yéfeyot
\q2 endefene yaufiyam ásáfoghmén fai té engwawalindai,
\q2 endefene ghérsé sénonjo emo méinyotio efalofifian!
\q1 \v 3 Njam yénd kakenangén sái eufanan tane yaufiyam,
\q2 tane fifi nawaghne,
\q2 a yénd mikefé naféghtan méinyotio efogh tombé.
\q1 \v 4 Efghon a sémbár fene téfél ngángé tamorwén kértafé tayot.
\q2 Tane muyé kawengongé ndenanit nu yénau yém efogh yu waftayan.
\q1 \v 5 Ambinomén, yéndo eufanan méinyotio tane yaufiyam fefaf
\q2 a yéta yau tane áyáréghofnar yam kétán Yurafaf."
\q1 A fémo walindangé ta!
\q2 Méinyotio tane kérté kés néngafnar.
\q1 \v 6 Yénémaménnde, so méinyotio ngánjánene ár norayat fefaf njamandio mé yém efogh,
\q2 ndené yau so nolitotat nu kéféran moghan.
\q1 \v 7 Ménamén fém tane átnogh sifayé;
\q2 fémo wambete kétamé kérté yamta.
\q2 Fémo warende yénd ménayafé waingégh waghafé.
\q1 \v 8 Yuré noraye, "Yéndo so némambetan fém yénamé merfifi endmé fenjo ghérsat.
\q2 Yéndo so watamegh si némarameta fe a ghékéfanro so ném fém.
\q1 \v 9 Yau táf ném ndenanit mwighafnar os a ndonki
\q2 sái yéfrena a kendarie sái yélimnda."
\q1 \v 10 Tárfár ghérghérsisé yéném yénan yaufiyam árfefaf.
\q2 wénde kwénjtafnar uwégham ewarende fá emofem mwighafé yéfandat Yuré.
\q1 \v 11 Féyo náuwetati Yurane kénjún a em klisafé, méinyotio fém emofem yiyáretati fá!
\q2 Nutnati áuwéghét, méinyotio fém endefene tikéf em njúnnjúnofnar!
\c 33
\s
\q1 \v 1 So ngánjánene árém wagh yérametat áuwéghét Yurai;
\q2 yéné siyém nátémnde njúnnjúnofnar árfefaf ménát siya yuyotat fá.
\q1 \v 2 Yuyotati Yuré ménaye melodie laireyé
\q2 yafrotati musik yáyot ten ángéghafé afe.
\q1 \v 3 Yérametati totér warsagh wagh yáfaf;
\q2 nambnat maté afe, a erametati wagh áuwéghafé.
\q1 \v 4 Ménamén efalo yérete Yurane siam
\q2 a yéndfem so mwighafé yéfandam méinyotio yémo sái ewafrota.
\q1 \v 5 Yémo euwete némé em mbarkánd a mer;
\q2 Yurane kwénjtafnar uwégham yafote mband marat.
\q1 \v 6 Yuré mé ngorayangai
\q2 a njafar ngufrotawét.
\q1 Yémo ambone titau sian,
\q2 a méinyotio kénd táf káráftawét.
\q1 \v 7 Yémo yanjo fuafayo taramangai arakafe
\q2 a tamndau tárfár wamángégh nuye.
\q1 \v 8 So méinyotio mband maratam férférafé yéfandat Yuré,
\q2 a so méinyotio ár ewakai yá matafé.
\q1 \v 9 Ménamén fá njam korayangai, mband marat kufrotau!
\q2 Yéné kafunau yáne wafarégh sian.
\q1 \v 10 Yuram wáiwáiot ekmete ndimbal yuafene mwighé farorégh
\q2 a yau nufrotat yéfene afrengégh yam.
\q1 \v 11 Wénde Yurane mwighé farorégh yakai taikrataye tuot;
\q2 némat yáne mwighé em yau emo so esambnete.
\q1 \v 12 Nderé áuwégh yém yéné ndimbal yuoe endene Ngánján yém Yuré,
\q2 yéné ár yémo té ekafai sái em yáne kénjút.
\q1 \v 13 Yuré nénrete kétamé njafarta
\q2 a efande méinyotio ár sáf.
\q1 \v 14 Kétamé yáne limánégh ámnjogh sifayata yémo kor ewayarngote
\q2 méinyotio efe emor mband maratan.
\q1 \v 15 Yémo ewawafrotam yéfene tikéf,
\q2 féyo fá mat yém méinyotio yam yémofem sewafrotat.
\q1 \v 16 Merfifi námb táikér fiyaram yau so tanjarngé warsagh ár,
\q2 yau yáne ndimbal muyé féyotaro ménát sái tanjarngé mék téfnár.
\q1 \v 17 Yau ewafta fenjo mék os ménát sái kawainda mékan
\q2 yéné méinyotio muyayan, yéné yam yau so kémanjarngi.
\q1 \v 18 Wénde Yuram efanda fá méinyotio efe férfér em yáfaf,
\q2 fá efe namyotat yáne kwénjtafnar uwéghan.
\q1 \v 19 Yémo tawanjarngé fá kétamé kérta
\q2 a naketat ghérsé mé yáne wambéghan kaukauan efghon.
\q1 \v 20 Yéndfem tákmangém téfene kamnang Yurane kénjún.
\q2 Fá siyém téfene wáutárégh ár a téfene mbakw.
\q1 \v 21 Yáne kénjún téfene tikéf náuwetat,
\q2 ménamén yéndfem mwighafé yéfandam yáne njúnnjúnofnar yétkwén.
\q1 \v 22 So fene kwénjtafnar uwégham yénmarende yénd, Yuré,
\q2 ménamén téfene kamnang siyém fefatro yém.
\c 34
\s
\q1 \v 1 Yéndo so yuyotan Yuré méinyotio efghon.
\q2 Yéndo so ménjtaye néngorayan yáne yétkwén uyoghmén.
\q1 \v 2 Yénd so néngawarsan mé Yurane kénjúnro;
\q2 so méinyotio fá efe em wáutáréghofnar mbané tikfan tékmangi.
\q1 \v 3 Taném, so mérne yéndfem engwawaitotam Yurane ndimbalfifimén,
\q2 so yéndfem yáne yétkwén yuyotam mérne.
\q1 \v 4 Yénd korayan kétán Yurafaf, a yémo wawangoi ta.
\q2 Yémo yuwek wiyátoi yénd kétamé méinyotio tane férférta.
\q1 \v 5 Fá efe néretat kétán yáfaf ménát wáutárghét so áuwégh kwayaghayam etremngoté
\q2 yau wáiwái njaram so kwéfité eyátote yéfene sáf.
\q1 \v 6 Tane taikrafé yam kénjún yénd Ngánjánafé korayawén, a Yuré náyárai;
\q2 yémo wanjaryéng yénd kétamé méinyotio tane kérté yamta.
\q1 \v 7 Ménamén Yurane njafar si résagh ár siyém wanjengégh ár;
\q2 yémo tawarendangé a tawamarotangé méinyotio fá emofem férférafé yéfandat fá.
\q1 \v 8 Tufo téfanda ndené Yuré siyém mer,
\q2 o, áuwégh yéfene emofem tanangi átnogh yáne kénjún!
\q1 \v 9 Férférafé yéfandati Yuré, fém yáne ngánjánene ár,
\q2 ménamén fá emofem férférafé yéfandat fá yéfene so em méinyotio némat ménde em.
\q1 \v 10 Táf totér muyé kér ro ndimbal munjan fus ámb kaye engém siogh,
\q2 wénde fá emofem mwighé fá yéfandat Yuré a em yáne kénjún so méndefnar engfandat némé mer rokar engém.
\q1 \v 11 Kénaflangi, tane ambumtértér, a káyárangi tafaf,
\q2 a yéndo so ewatametan ménát férférafé so yéfandati Yuré.
\q1 \v 12 Té ámb ár ménde yém siya yémor tombé ghérsé
\q2 a siya ménde yifota?
\q1 \v 13 Féyo yékmbota fene kanké kétamé yaufi sita
\q2 a fene mbérmbér kétamé unyégh si afrogh ta!
\q1 \v 14 Kawengo kétamé yaufita a mer wafrogh tawafngo.
\q2 Yéronja krufrat yam, a násáfota ménát so yanote.
\q1 \v 15 Yurane ghékéf em yéfefaf emofem ewafrotat mbarkánd yam.
\q2 A yáne téngan sem asauréghkaf yéfene yefaf.
\q1 \v 16 Wénde Yuram yau sáf tanwawengongé yéfe emofem ewafrotat mámáfi yam;
\q2 yémo so ewawalinde yéfene yam yéna mband marat.
\q1 \v 17 Yuram eyárete yánjoro ár njam fá kutnangi yáfaf ménát wáutárghét.
\q2 Yémo ghérsé tawanjarngé fá kétamé méinyotio yéfene kérté yamta.
\q1 \v 18 Yuré siyém kaka yéfefaf efe tikéf afaroréghkaf em;
\q2 yémo ghérsé ewanjane fá efe mbérmbére iroréghkaf em.
\q1 \v 19 Mbarkánd árom so efangote tárfár kérté yam,
\q2 wénde Yuré táf yéném kétán wanjaréghét túmén yéné efoghféneféneyamé.
\q1 \v 20 Ménamén Yuram ewarawene mbarkánd ároene sot;
\q2 yau ámbiro so náráfne!
\q1 \v 21 Yaufiyamam so esmete mámáfiyam wafrogh ár.
\q2 A fá emofem méndméndat efandat mbarkánd ár so yém tékratamé.
\q1 \v 22 Wénde Yuram so ghérsé tawertongé fá efe násáfotat yáyot.
\q2 Árké árom yau njam tanangé átnogh sifayé yáne kénjún so yém tékratamé.
\c 35
\s
\q1 \v 1 O Yuré, ekarota fá emofem wékarotat yénd.
\q2 Esmeta fá emofem wésmetat yénd.
\q1 \v 2 Tawar fene mék rokar, a tané fene anawégh mbakw.
\q2 Kafrende ásméghét, a kénaf kétán tane wáutáréghfaf.
\q1 \v 3 Tuyo tukét fene fimb a tombé fimb
\q2 yéfeta emofem wénmaitotat yénd.
\q1 So yéndo náyáretan fém sái noraya,
\q2 "Yéndo so kémaraman sái tawainda!"
\q1 \v 4 Yénérsa wáiwái a férfér yéfefaf yéta emo ngiot wérametat yénd;
\q2 Tangwango fá a wáiwáiot takém fá emofem yénd ngiot wérametat.
\q1 \v 5 Engéfnja fá nayu ndenanit ngwérméng yénau em mbormboran
\q2 yéné mbormbor árké yénmafarete Yurane njafar si résagh árom.
\q1 \v 6 Táyáto yéfene end kwéfité a eunouro,
\q2 yénayafé Yurane njafar si résagh árom sái engwifna fá.
\q1 \v 7 Yéndo yau yéfe mámáfi tawawafrotan, wénde yémofem urér yéknyangi tayot.
\q2 Yéndo yau yéfe mámáfi tawawafrotan, wénde yémofem tétanat yékw ménát sái kwerangi yénd.
\q1 \v 8 Féyo tumyo sunsune wasérmbogh so yéném yéfefaf!
\q2 Taumyo fá so kawamangi uréran árké yémofem takeindat tayot.
\q2 Taumyo fá so kawalindangi yékwén yémofem sitanaménd tayot.
\q1 \v 9 Féyo yénd so náuwetan Yurane kénjún.
\q2 Yénd so áuwéghafé wém ménamén yémo yénd wanjane.
\q1 \v 10 Ménaye méinyotio sote tane fifian yéndo so yarsan fá:
\q2 "Yuré, emo so némafarnje fém?
\q1 Emo ámb tawanjarngé wáutáréghofnar kétamé muyafé árta?
\q2 Emo ámb ewarawene wáutáréghofnar a yauyau kétamé yéfeta emofem oro ewafrotat fá.
\q1 \v 11 Ár wasérmbogh yam téfnár néngafrotat yau mere tanemén.
\q2 Yémofem aninjo kérté tafayongi tafaf árkéménamén yénd yau mat wém.
\q1 \v 12 Yémofem ta fai kwawangongi mámáfie mermén.
\q2 Yénd enjne wém ménamén mer ámb yau.
\q1 \v 13 Wénde táf fá njam tamorwén enjnefé, yénd yeyan kwémorwén yéfenemén.
\q2 Yénd yéndio kakenangayén ménayan kawafarmangayén yéfenemén,
\q2 wénde tane Ngánjánafé orayégh kénangongai wangoghofnar.
\q1 \v 14 Yénd kwémorwén ghérghérsisé, ndemamén tamorwén fá tane fútar o mérén,
\q2 ndenanit yénd kar kendawén tanjo amanemén.
\q1 \v 15 Wénde fá sénonjo áuwéghafé em táf yénd kértayan wém;
\q2 fá táf náfghetat áuwéghafaro ta sénanéghét.
\q1 Yénd yéné árém táf kwafngongi endefenmén yénd mat yam wém;
\q2 yémofem ta si wawafrotat túmén.
\q1 \v 16 Yémofem wurtat yénd a yétkwén tafare wémndetat;
\q2 yémofem wánangotat yénd.
\q1 \v 17 Nderé teke, O Yuré, mé fandagh so yénfande o yau némé ámb so yafrote?
\q2 Kwanjar kétamé yéfene mámé férférafé kés wafngongi.
\q2 També tane ghérsé kétamé yéné ndimbal munjan fusafeta!
\q1 \v 18 Féyo yéndo kánjo némarametan yéfene sáfan ár tárfár séfe náumende.
\q2 Yéndo so némarsan méinyotio árfene sáfan.
\q1 \v 19 Yau taumyo tane sénanégh ár sén téfnár sái náuwetat tane waingéghmén.
\q2 Yau taumyo fá emofem méndméndat wéfandat yénd téfnofnar méndeménde wawafrotat tane ghérghérsisayan.
\q1 \v 20 Fá yau norayat krufratmén,
\q2 yémofem kwankwane si yafrotat ménd árfenemén efe yéfenjo yaman néngareindat.
\q1 \v 21 Fá nutnat, "A! A!
\q2 Téfenjo ghékfeyo yéndfem yinjoyém tafrotau yéné!"
\q1 \v 22 O Yuré fém mat ném méinyotio yénémamén.
\q2 Yau fém némor métar.
\q2 Yau yénd kwéfrangon sénonjo, O Yuré.
\q1 \v 23 Kano! Kokai tane wamaroghét!
\q2 Tanégh tane kérté, tane Ngánján a tane Yuré.
\q1 \v 24 Kwuyafo yénd yau ámb téfén yém tafaf, O Yuré tane Ngánján, ménamén fémo ewaramete mbarkánd yam.
\q2 Yau eumyota tane mék téfnár nurtat tanemén tane kérté kénjúmé.
\q1 \v 25 Yau eumyota sái norayat, "Kénretangi téfene em yéné némat yénd ménde téném!
\q2 Sénonjo yéndfem so yénetam fá ghérséghérsé!"
\q1 \v 26 So fá efe náuwetat tane kérté yaman
\q2 so em wáiwái a áuwéghofnar.
\q1 So fá emofem yafrotat tafaf
\q2 so ewafne wáiwáiyam a yau so eutémndat.
\q1 \v 27 Wénde tawaram ndimbal áuwégh yéfe efe taném tane wamaroghét.
\q2 Taumyo fá ménjtaye so norayat, "Ndimbal yém Yuré,
\q2 efe náuwete ménayan efrende yánjo ásáfogh ár ménaye krufrate!"
\q1 \v 28 Féyo yéndon so néngafrotan fene mbarkánd yaman,
\q2 a yéndon so némarsan fém méinyotio kwéf tombé.
\c 36
\s
\q1 \v 1 Yaufiyamam ewawanje áyáréghofnar ár yéfene tikéf kénjún.
\q2 Yéfefaf ámb yau yém Ngánján férfér yau fifi.
\q1 \v 2 Yéfene kwéfkwéf tuktuk ghérsé kénjún,
\q2 fá yau so kér nafandat nderé áyáréghofnarfifi fá em.
\q1 \v 3 Méinyotio fá némé norayat sem awakénéghe a utaréghafé
\q2 Fá nakenat ménát sái em káfetaye o ewafrotat mer.
\q1 \v 4 Fá nuindat kangongi sémbáran, etyanat yaufiménro kwankwane mwighé.
\q2 Yéfene yam wafrogh yau mer em.
\q2 Yémofem ámb yau mwighé tawafrotangi ménát sái kwawengongi kétamé mámáfi yamta.
\q1 \v 5 Fene kwénjtafnar uwégh, O Yuré, siyém ndimbalfifi ndené njafar;
\q2 fene ndimbal mwighayam engwainde njafar kwamkwam.
\q1 \v 6 Fene mbarkánd yam siyém ndenanit ndaima mband tunakéf kés em,
\q2 fene ámb rérero yam ndenanit em árkafafene kénjkam kés em.
\q2 Fene warawerégh yém árét a wérár ámb rérero, O Yuré.
\q1 \v 7 Nderé merro yém fene kénjtafnar uwégh, O Ngánján!
\q2 Méinyotio árém tinjongi átnogh sifayé fene njamb njar kénjún.
\q1 \v 8 Fémo emanjne fá kétamé fenjo njamke tarétaré méngota,
\q2 eumyote fá nu yéngnetat kétamé fene ménde wáyárégh wanjeta.
\q1 \v 9 Ménamén fém ném afamégh nuwan ghérsé,
\q2 a kwayaghé yénayan yéndfem yéfandam.
\q1 \v 10 Tasur fene kénjtafnar uwégh yéfefaf emofem némuwetat fém;
\q2 tawaram ámb rérero yéfe efe em unyéghofnar tikéfafé.
\q1 \v 11 Yau eumyota tuktuk kér ro árém wékenat yénd
\q2 o áyáréghofnar árém wéfetat yénamé.
\q1 \v 12 Kéreta! Fá emofem tawafrotat mámáfi té nuyangi!
\q2 Fá té tawitat yuwot, yau wéi kor so kokayongi wéikor.
\c 37
\s
\q1 \v 1 Yau mámé mwighé ném ménamén mámáfi yam árfenemén
\q2 o etémnda yam yéfefaf emofem ewafrotat mámáfi.
\q1 \v 2 Ménamén ndenanit yus fá so kawaindangi.
\q2 Ndenanit mbumbunit, fá tekofnar ghérnát kamndangi.
\q1 \v 3 Yuré mwighafé yéfanda a ewafrota mer.
\q2 Féyo fém so némor wambérghan mband a remngongafé.
\q1 \v 4 Tanang ménde wáyárégh Yurane kénjún
\q2 a yémo taramangé feyot tikfot ménde.
\q1 \v 5 Taram méinyotio némé fémo ewafrote kétán Yurafaf.
\q2 Mwighafé yéfandat a yémon so némáutáne fém.
\q1 \v 6 Yémo so tawafrotangé fene téfnofnar yam ndenanit akw efogh kwayaghé yénau kénálálangé,
\q2 a fene ámb rérero yam so nérete ndenanit efoghméf.
\q1 \v 7 Mé aném Yurafaf
\q2 a nawanjeta métare yáfaf ménát so yafrote.
\q1 Yau mámé mwighé ném yéfenemén yaufi árfenemén emofem remngogh yérsat
\q2 o mámé mwighé ném ménamén yéfene mámáfi mwighé faroréghmén.
\q1 \v 8 Kékmbo kétamé nékwta! Kawengo kétamé fene kwérnarta!
\q2 Yau nékwam nélimnda, mé yéné yam so kénlimangé ásméghét!
\q1 \v 9 Ménamén mámáfi ár so tawirorngé,
\q2 wénde fá emofem mwighafé yéfandat Yuré so tanangi mband.
\q1 \v 10 Tekofnar mámáfi ár so ofé karamangi.
\q2 Fémo yéta so eronje, fá té nénwanongi.
\q1 \v 11 Yuwan árém so tanangi mband
\q2 a so emor krufrate a remngoghafé.
\q1 \v 12 Mámáfi árém kwankwane mwighé yéfaronat yéfeta ngánjánene ár;
\q2 yémofem ewánangotat fá nawamarotat.
\q1 \v 13 Wénde Yuré táf nurte,
\q2 ménamén yémo ewafande yéfene mogh kwéf yéném.
\q1 \v 14 Mámáfi árém eutoryénd yéfenjo witmafé sénté naifé
\q2 a takeindawét yéfenjo námb
\q2 ménát so tényáwét fá emofem tawafrotat mbarkánd yam
\q1 \v 15 Wénde yéfenjo witmafé sénté naifayam so ekindat yéfenjo tikfan,
\q2 yéfene namb so náráfnat.
\q1 \v 16 Yéné mer yém siya yéném ngánján ghérsafé
\q2 a sái yénmam némbnare rokar yau yaufiyam kér ro a rokare nawayotam.
\q1 \v 17 Ménamén yaufi árfene muyé so muyafnar káyátongi,
\q2 wénde Yuram ewarawene nganjanene ghérsafé ár.
\q1 \v 18 Méinyotio efghon Yuram ewambete téfnofnar
\q2 a yémofem so tawanangi yéta rokar árkéméné so naketat tuot.
\q1 \v 19 Fá yau so ekmetat yuwot táikér efghon,
\q2 téu kaukau yéfene mé so ewam féyotaro.
\q1 \v 20 Wénde yaufi ár so kér em.
\q2 Yurane sénanégh téfnár em ndenanit mbumbu ndau kénjún-
\q2 fá so kolingangi ndenanit kwam.
\q1 \v 21 Yaufi ár komnendangi watmé rokarot, wénde yau ewafangotat,
\q2 wénde nganjan ghérsafé em marataye ramégh téfnár.
\q1 \v 22 Fá Yuram efe efrende so tanangi mband,
\q2 wénde fá efe ewafalngote so kér em.
\q1 \v 23 Yuram ewawasane kafkaf nganjan ghérsafé árfene.
\q2 Yémo ndimbal méndefé efande méinyotio yam yéfene ghérsayan.
\q1 \v 24 Ndemamén fá téu néunotat, fá yau so kuyangi,
\q2 ménamén Yuram ewerete ngángayan.
\q1 \v 25 Njam yénd kwémorwén totér ambum, a sénonjo yénd wém bulu.
\q2 Wénde yéndo yau ámb efandamén ngánján ghérsafé ár euroyénd
\q2 o yéfene ambum komnendawét ménát flawat.
\q1 \v 26 Ngánján ghérsafé árém táf túmén mé tawaramangi ámb árét,
\q2 marataye mani witmayero sorámé wafangoghét, a yéfene ambum sem frengégh em.
\q1 \v 27 Kawengongi yaufita a tawafngongi mer
\q2 a fém so emor mbandan tuot.
\q1 \v 28 Ménamén Yuram méndefé yéfande ámbrérero afrengégh yam
\q2 a yémo yau so tafrangongé ngánján ghérsafé ár.
\q1 Yémo so ewanjane fá tuot
\q2 wénde yaufiyamoene ambumtértér so kér em.
\q1 \v 29 Ngánján ghérsafé árém so tanangi mband
\q2 a so kété emor tuot.
\q1 \v 30 Ngánján ghérsafé árém ewarametat mere fenagh,
\q2 yémofem ewatametat mbarkánd yamménro yaufita.
\q1 \v 31 Yémofme té eyátongi Ngánjánene nák yéfendio,
\q2 féyo fá yau so kéunotangi yáne endén.
\q1 \v 32 Yaufiyam téfnár natnotat nwanjetat yéfe ngánjánene árét,
\q2 néretat unyégh siyot ménát sái esmetat.
\q1 \v 33 Wénde Yuram yau so taumyongé yaufi ár wafroghét
\q2 o taumyongé ngánján ghérsafé sái tafrangongé táf njam fá tákmangi efoghan.
\q1 \v 34 Takmangi féfenjo kamnang Yurafane kénjún.
\q2 Eyota mbarkándero yénamé yáne endmé.
\q1 Yémo so némutémnde fém ménayan sái kémaramangé mband.
\q2 Fémo so efande yaufi ár néngawalindat.
\q1 \v 35 Yéndo té tafandan yaufi a awanmengégh ár wafyongégh
\q2 sari warafarégh ewafngoi ndenanit wén yénau yém yánjo mer mbandan!
\q1 \v 36 Wénde njam yénd wéikor néngretayén, fá té néngwasnoyénd!
\q2 Yéta taronjan fá, yéndo yau ewinjon.
\q1 \v 37 Tafandangi fá efe em efalo a mer
\q2 yéné sariafé soramé yu nawanjete yéfeyot emofem méndefé yéfandat krufrat ghérsé.
\q1 \v 38 Wénde tikéf táikér téfnár so tawalindangé;
\q2 yéfene yau yém soramé yu.
\q1 \v 39 Yuram tawanjarngé ngánján ghérsafé ár.
\q2 Fá siyém yéfene wambégh méngo kérté yam efghon.
\q1 \v 40 Yuram ewáutáne fá,
\q2 ewanjane kétamé yaufiyam árfeta.
\q2 Yémo tawanjarngé yémofem tinjongi enagh yáne kénjún.
\c 38
\s
\q1 \v 1 O Yuré, yau uwérmbota yénd fene nékwe
\q2 o téfél warameta fene kwérnare.
\q1 \v 2 Fene fimb té tangém kénjút,
\q2 a fene wanefégham yénd wéngtirnat.
\q1 \v 3 Ménamén fene nékw téfnan, tane méinyotio fifi siyém enjné
\q2 tane sariafé ámnjogh siyém fétraréghkaf yém ménamén tane yaufiyammén.
\q1 \v 4 Tane kértafé yamam wétumnde yénd
\q2 yéné siyém kértaye fifi yém mer áyátoghét.
\q1 \v 5 Tane kalmén mwighé minde mámáfi té namnda a kérkéf
\q2 ménamén tane onoe yaufiyammén.
\q1 \v 6 Yénd té wefno a wafngo ménayam ndémkeyam
\q2 Méinyotio efghon yénd yénamé wiyota tikéf kértafé afoghare.
\q1 \v 7 Wasnengéghét méndménd nakérne tane kénjún,
\q2 a tane klisa ghérsé té kirone.
\q1 \v 8 Yénd kwésyote a té ndetro wésém.
\q2 Tane mike yéném kétamé wasérmbogh tikéfta.
\q1 \v 9 Fém mat ném némat yénd naronjam, Yuré;
\q2 fémo náyárete tane tárfár wáiwái.
\q1 \v 10 Tane tikéf nanambete máméghéraye, tane muyé kwiyangé,
\q2 a yénd wéngém kwéfkwéfe.
\q1 \v 11 Tane áuwéghafé ár a fútar em nayu, férfér nufrotat tane enjnemén.
\q2 Wéi ndenáyo tanjoyo mérén kénokayongi nayu.
\q1 \v 12 Tekofnar, tane sénanégh téfnáram yéngékmetat urér ménát siya kwésmangi yénd.
\q2 Fá efe ménde em ta wasérmboghét mwighé yéfaronat ta wawérmboghét.
\q2 Túmén méinyotio efogh yémofem mwighé yéfaronat yéfene yéte wasérmboghét.
\q1 \v 13 Wénde yénd ménguméngu wém méinyotio yéfene yérufaf.
\q2 Yénd wém métar yéfe rére ámbiro efe yau so noraye.
\q1 \v 14 Yénd méndefnar wém siya náyáretan
\q2 a yéndo yau ewawangotat.
\q1 \v 15 Ménamén yénd nawanjetan fefaf, O Yuré.
\q2 Fémo táf kwawango ta, O Yuré tane Ngánján.
\q1 \v 16 Yénd Ngánjánefaf korayau, "Yau eumyota tane sénanégh téfnár méndeménde wawafrotat ta
\q2 o náuwetat tane wighan."
\q1 \v 17 Yénd wém mé fétfétan wighétro,
\q2 yafarenan ménjtaye ndémke.
\q1 \v 18 Wénde yénd náwafenan tane yaufiyamta.
\q2 Yénd kénjkame ghérghérsisé wém ménamén yéndo némé tafrotan.
\q1 \v 19 Tane em tárfárafé kwérnár sáfot sénanégh ár;
\q2 yémofem méndméndat wifandat fifiofnar.
\q1 \v 20 Yémofem wawangotat ta yaufiyero mermén
\q2 a wékarotat yénd ménamén yéngwanetan mer.
\q1 \v 21 Yau fémo kwéfrango, o Yuré.
\q2 Yau némakai nayuye, tane Ngánján.
\q1 \v 22 Néném wékeye ménát ta wáutárghét,
\q2 O Yuré tane wanjarégh ár.
\c 39
\s
\q1 \v 1 Yénd tanjoyo norayayén, "Yéndo so yéfandan némé so yéndo yafrotan
\q2 a yau so yaufi yafrotan némé yénd sái norayan.
\q1 Yéndo so yeretan tane kanké
\q2 njam ngánján ghérsafnar ár em tafafmé.
\q1 \v 2 Wénde njam yénd nokayoyén kété métare yam
\q2 ámb korayawén mer rokarmén
\q2 tane kénjún nanoi máméghérayé.
\q1 \v 3 Minde yénd skemnawén yénémamén,
\q2 waftayam waindam eindayén fésafé si.
\q1 \v 4 Yuré, mwighat wangota nderé ténjfi tane efogh mband maratan so yém.
\q2 Mwighat wangota ndené tane efogh sem waféghkaf
\q2 nderé wékeye awángéghmén tane ghérsé yém.
\q1 \v 5 Fémo té yafrotam tane ghérsé yau ndené kor tane ngángane marat.
\q2 Tane méinyotio ghérsamén ámnjogh yém mé tekofnar fefaf;
\q2 mérkéráye, yénd méinyotio siyéném wénde mé ambonero.
\q1 \v 6 Yénd mé imángégh mbanmbanro yéném
\q2 a méinyotio téfene wékeye ndarndare yam yauyau ngáyárongi.
\q1 Yéndfem yumendam mani,
\q2 yau mat yéném emo so yéngtérne rokaramé.
\q1 \v 7 A féyo, Yuré, ánde yéndo yékmetan tane kamnang?
\q2 Tane kamnang siyém mé fefafétro.
\q1 \v 8 Kwanjar yénd tane áyáréghofnar yamta.
\q2 Yau eumyota wasnengégh ár máméghéraye kembne yau so wambnat yénd.
\q1 \v 9 Yénd métar wém fene réré yénd yau so si néngorayan,
\q2 ménamén tane tékrat yam siyéném fe tambén.
\q1 \v 10 Ghérghérsisé kékmbo yau kwafngongi ndenayu!
\q2 Yénd imye té wiyáto fene wamnjogh árké yéném fene ngángata.
\q1 \v 11 Njam fémo téfél yénmarameta téfe téfene yaufiyammén,
\q2 fémo tawifo ndenanit uwakwauwakwa némé yém merfifi téfeyot.
\q2 Wénde yénd méinyotio siyéném ambonero.
\q1 \v 12 Náyáreta tane orayégh, O Yuré!
\q2 Náyáreta tane ye wáutárghét!
\q2 Yau ekarota tane yéngém.
\q1 Ménamén yénd wém fene ásáfogh ár
\q2 áligh téfnár néngawainde yénamé,
\q2 ndené tane ákif yénau ta frondeyo tamorwén.
\q1 \v 13 Kwéfrango yéndro ménát yénd so kurtangén wéikor
\q2 soramé yénd kawaindangén a yau so naketan wéikor.
\c 40
\s
\q1 \v 1 Yénd kwawanjetan métare Yurafaf ménát so kwáutánau yénd,
\q2 a fá nénawengoi tafaf a náyárai tane ye.
\q1 \v 2 Yémo wénguyoi kétamé wasnengégh
\q2 yékwta kétamé ngéndta a ngwérngwérta.
\q1 Yémo tane kafkaf ekmai táikér mbandan
\q2 a mbénmbénat wafrotai yénd táf nuwanoyén yénamé.
\q1 \v 3 Yémo té waramé totér wagh raméghét,
\q2 a ses áuwégh wagh yáyot téfene Ngánjáne.
\q1 Tárfáram so yéfandat némé yémo té yafrotam a so em sélngwél.
\q2 Yémofem so yéfandat Yuré mwighafé.
\q1 \v 4 O áuwégh yéfene emofem mwighafé yéfandat Yuré,
\q2 endene kor yau yém taikrataye áuwégh yéfeyot efe nawarmbotat
\q2 yéfefaf emofem ewáwefnotat mewangat.
\q1 \v 5 O Yuré tane Ngánján, fémo té tawafrote tárfár mer yam téfe.
\q2 Fene mwighé farorégh téfeyot sem minde tárfár kayoghét.
\q2 Fémafé yau némayafé nátemndat.
\q1 Njam yéndo yéta emndetan méinyotio fene yam merkéráye,
\q2 yénd yau so kétán wéngém ánde so eyáto yéné.
\q1 \v 6 Fémo yau yérse ménde ménayan ghéngén raméghan.
\q2 Sénonjo fémo té yénd wiyáto náyáran, yénd ambino mat namndan
\q2 fém yau eumyote warogh ghéngén ramégh o yaufiyam ghéngén ramégh.
\q1 \v 7 Féyo yénd norayayén, "Kértangé, yénd té kwéném.
\q2 Ndené fété yékai tanemén Buk sian:
\q1 \v 8 Yéndo yérsan áuwégh ménayan ewafrotan fene ménde, tane Ngánján,
\q2 ménamén fene wawanjagh si sem ekai tane tikfan."
\q1 \v 9 Yéndo té tawaufrotan méinyotio fene árét ménamén fene kwénjtafnar yammén.
\q2 Yénd yau kwém férfér afroghét,
\q2 ndené fété fém, O Yuré, mer mat ném.
\q1 \v 10 Yéndo yau tamndan mer si fene ámb rérero yammén etno tane tikéf kénjún;
\q2 yénd té korayan ménamén fene ndimbal mwighamén a wanjarégh waftamén.
\q1 Yéndo té tawaufrotan tárfár árét ndimbal áumengégh kénjún
\q2 ménamén fene kwénjtafnar uwéghmén a ndimbal mwighé túmén warawena yénd.
\q1 \v 11 Yuré, yau yangota fene ramégh kér ro uwégh kétamé ta tambén.
\q2 Tumyo fene kwénjtafnar uwégh a ndimbal mwighé túmén warawena yénd.
\q1 \v 12 Ménamén kérté yamam warendat yénd
\q2 tárfár em waféghét!
\q1 Tane yaufiyam faru nafayotat tukét
\q2 yéndo yau yéfandan tane end etorghét.
\q1 Fá em minde tárfár yau ndené séf tane sénkoyan.
\q2 Yénd té nolindangén méinyotio awamanroghta.
\q1 \v 13 Ghérghérsisé, Yuré, kwanjar yénd!
\q2 Kénaf wékeye, Yuré, a kwáutána ta.
\q1 \v 14 So fá emofem yéta wirorghét wérametat yénd
\q2 so takém yuwot a wáiwáiot.
\q1 So fá emofem klisa tanangi tane kérté kénjún
\q2 so kénawengongi áuwéghofnar.
\q1 \v 15 Taumyo fá so ndimbal férféram tawifongé yéfene wáiwáimén
\q2 ménamén fá norayat, "Aa! Yéndfem té yérangém sénonjo!"
\q1 \v 16 Wénde méinyotio fá emofem sái néronjat fém
\q2 so tawafongé áuwégham a klisaiyam fene kénjún.
\q1 So fá efe náuwétat fene wanjaréghmén
\q2 féréghe nutnat, "Yuré siyém ndimbal!"
\q1 \v 17 Wénde tayot, ndené mé kés wém yauyau a áronjagh ár,
\q2 so Yuram wmande yénd yáne mwighé kénjúmé.
\q1 Fém ném tane wáutárégh ár a tane wanjarégh ár.
\q2 O tane Ngánján, yau kamwaneta.
\c 41
\s
\q1 \v 1 O, yéfene áuwéghmén efe em raméghro yéfe yauyau árét!
\q2 Yuram ewanjane fá njam em kérté kénjún.
\q1 \v 2 Yuram ewarawene fá
\q2 a ghérsé ewakete.
\q1 Yémo tawaramangé remngogh mbandan
\q2 a ewarawene kétamé yéfene sénanégh téfnárafeta.
\q1 \v 3 Yuram ewarawene fá njam em enjne
\q2 a tanyatongé mer.
\q1 \v 4 Yénd Ngánjánafé norayan, "O Yuré, ghérghérsisé aném tafaf,
\q2 mer kwiyáto, ménamén yénd té yaufiyam kufrotan tafaf."
\q1 \v 5 Wénde tane sénángégh téfnár némé ámb yau norayat wénde yaufiro tanemén.
\q2 Ndernáye tekofnar so kér yém a mwighafnar tayangém" Fá kamotangi.
\q1 \v 6 Fá engém ndenanit tafaf kar em tane fútar,
\q2 wénde tekofnar fá naumendat ta si wafroghét,
\q2 a njam fá kuwanongi yémofem taranégh si téngwafnongi marataye.
\q1 \v 7 Méinyotio emofem yénd méndméndat wéfandat néngawanjat tanemén,
\q2 mwighé engérknat minde mámáfiyam.
\q1 \v 8 Fá norayat, "Yafaf yémámb yaufi enjne,
\q2 fá yau so mer káyátongé yéné yaufita!"
\q1 \v 9 Ndemamén em tane mer fútarfifi, fá yéndon efe mwighafafifi efandan méinyotio,
\q2 fá efe néngawaftat tane njamke, té nénawengongi ta sénanéghét.
\q1 \v 10 Yuré, aném ghérghérsisé tafaf.
\q2 Kwiyáto mer wéikor, ménát yéndo so fai wangogh tawafngon fá.
\q1 \v 11 Yénd mat wém fém náuwete tafaf,
\q2 ménamén fémo yau eumyo tane sénanégh téfnár sai kwésénawét yénd.
\q1 \v 12 Fémo té tane ghérsé tanjane ménamén yénd téfnofnar wém;
\q2 fémo té yénd wénmanai fefafétio tuot.
\q1 \v 13 Yuyotam Ngánján, Israil árfene Ngánján,
\q2 efe ghérsé nakete tuot.
\q1 Efalo a efalo!
\c 42
\s
\q1 \v 1 Ndené rusa yénau naronje wérér nuot,
\q2 yénémamén yénd naronjan feyot, O Ngánján.
\q1 \v 2 Yénd nu ménde yame ménde wém Ngánjánefaf, efe yém ghérsé Ngánján.
\q2 Njam so yénd wéngém a kokayon yánerére?
\q1 \v 3 Efogh a sémbár tane em yengamro njamket,
\q2 táf njam tane sénanégh árém túmén so wawafrotat, néngorayat,
\q2 "Ánde yém yéné fene Ngánján?"
\q1 \v 4 Tane tikéf siyém nafarone,
\q2 njam nawafarotan ndernaye táf témorwén:
\q1 Yénd kwiyotau wáwefnogh árfene néndkfan télimndawém ndimbal yam kétán Ngánjánene méngot,
\q2 áuwégh wagh taufanawém a tarametawém kánjo ndimbal wagh ramégh usénanégh kénjún!
\q1 \v 5 Némamén yénd áuwéghofnar wém?
\q2 Némamén tane tikéf yém wáiwáififi?
\q1 Yéndo so tékman tane kamnang Ngánjánene kénjún!
\q2 Yéndo so fá yarsan wéikor
\q2 tane ghérsé urtogh ár \v 6 tane Ngánján!
\q1 Sénonjo yénd té minde kénjkame yuwan wiyátongi áuwéghofnar,
\q2 wénde yéndo so némafarotan fém
\q1 nayu mband tunakéfta Ermon, Jodenene téfén
\q2 kétamé mband tunakéfta Mijar.
\q1 \v 7 Yénd náyáretan wasnengégh nékwafé arakaf
\q2 kés em ndené fété fene sof a mbarkándaye muyé kér ro ráf kéféram wésambune yénd.
\q1 \v 8 Wénde túmén efogh Yuram yasune yánjo kwénjtafnar uwégh tafaf,
\q2 a tumén sémbáramé yéndo yéngufanan yáne wagh,
\q2 norayan Ngánjánefaf emo waramete ghérsé.
\q1 \v 9 Yénd néngendan, "O Ngánján tane wém
\q2 Némamén fémo mwighafnar kwite yénd?
\q1 Némamén so yénd náyáretan nawarendan kérté kénjún,
\q2 wéngsénat tane sénanégh téfnaram?"
\q1 \v 10 Yémofem eráfnat tane sot njam kwénmanetangi.
\q2 Yémofem so máméghéraye enwitat, "Ánde yém yéné Ngánján fene?"
\q1 \v 11 Némamén yénd wékmangi áuwéggofnarot?
\q2 Némamén tane tikéfan yém wáiwái?
\q1 Yéndo so tékman tane kamnang Ngánjánene kénjún!
\q2 Yéndo so yarsan fá wéikor
\q2 tane wanjarégh ár a tane Ngánján
\c 43
\s
\q1 \v 1 Kwiyáto yénd téfnofnar, O Ngánján!
\q2 Kwamarota yénd kétamé yéné ngájánofnar árfeta.
\q2 Kwanjar yénd kétamé yéné mbarkándofnar unyégh árfeta.
\q1 \v 2 Ménamén fém ném Ngánján, tane mé fémro wanjarégh sifayé.
\q2 Némamén fémo yénd
\q1 Némamén so yénd náyáretan nawarendan kérta kénjún
\q2 wékarotat tane sénanégh téfnáram?
\q1 \v 3 Téngwatemb fenjo kwayaghé a fene efalo;
\q2 tanéghmiyo so wambetat yénd.
\q1 Taumyo so wélimndat yénd kétán fene njunnjunofnar mband tunakéffaf,
\q2 kétán yéné sifayat ánde fém némor.
\q1 \v 4 Kété yénd so wéngém Ngánjánene ghéngén ramégh kitarafaf,
\q2 yáfaf Ngánjánefaf efe yém tane áuwéghoene kémbun.
\q1 Yéndo so némuyotan tane gitaye,
\q2 O Ngánján, tane Ngánján!
\q1 \v 5 Némamén yénd áuwéghofnar wém?
\q2 Némamén tane tikéf yém minde wáiwáian?
\q1 Yéndo so tékman kamnang Ngánjánene kénjún!
\q2 Yéndo so yarsan fá wéikor
\q2 tane ghérsé urtogh ár a tane Ngánján!
\c 44
\s
\q1 \v 1 O Ngánján, yéndfemyo té káyáretam ménaye téfenjo téngane
\q2 téfene ákiam té ténmaufortawét téfe
\q1 méinyotio ménamén fémo némé tawafrotau yéfene efghon
\q2 tándái eghon:
\q1 \v 2 Fémo tangtarnau ndimbal yu dabi ngánján téfnár ménaye fenjo waftaye
\q2 a tawarametau méinyotio mband yéfe téfene ákiafet.
\q1 Fémo tawironau yéfene sénanégh téfnár
\q2 a esa ke kutnangayénd.
\q1 \v 3 Yémofem yau mband yanayénd ménaye yéfene witmafé sénté naifé stamorwén
\q2 yau yéfenjo táikér muyaro ngángayam ewaramai ménat sai kwaindangayénd ásméghan.
\q1 Yéné yémormén fene tambén ngángé a muyaro ndangwés
\q2 a ghékéf waurogh kwayaghé kétamé fene sáfta árkéménayam ewáutánam fá,
\q2 ménamén fémo euwetam fá.
\q1 \v 4 Fém ném tane warsagh ár a tane Ngánján.
\q2 Fémo Israil ewafarete mékan sái nawindat.
\q1 \v 5 Mé fene waftayero so kwémbkwémb engwimndam téfene mék téfnár;
\q2 mé fene yétkwénero so yéndfem engsénam téfene mék téfnár.
\q1 \v 6 Yéndo yau mwighafé yéfandan tane námb;
\q2 yéndo yau ewaftan tane witmafé sénté naifé ménát so kwanjarngi.
\q1 \v 7 Fém yéné féném emo ténmaram téfe waingégh muyé yéfeyot téfene mék téfnarat;
\q2 fémo áuwéghofnar eyátote fá emofem méndméndat yéfandat yénd.
\q1 \v 8 O Ngánján, yéndfem minde kwayaghé némarametam fe méinyotio efogh tombé
\q2 a túmén yarsam fene yétkwén.
\q1 \v 9 Wénde sénonjo fémo té yénd yénmitam téndota utmanéghofnar.
\q2 Fémo yau elimnde téfene fiyaré kétán mékot.
\q1 \v 10 Fémo mé yénd yénmangote kétamé téfene mék téfnárafeta
\q2 a eumyote fá emofem tékrate yénrametat ménát sái téfene mbandot ménjtaye kéndaywangi a ároe ersat rokar.
\q1 \v 11 Fémo té yénd ténénfete ndenanit sif
\q2 a ténmafarne yénamé ndimbal yuwomé.
\q1 \v 12 Fémo maniot tatérne fene tikéfafé ár ménát némbnar maniotro,
\q2 ámb yau némé yafrote térarégh kénjún.
\q1 \v 13 Fémo eumyote téfene kaka fútar kembnekembne yéngmambnat yénd.
\q2 Yénd yéné fifi yéném máméghéraye kenaghmén a kembne siya yéngmamnbat yéfefaf ár efe em téfefafmé.
\q1 \v 14 Fémo té yénd yényátoi sékufé téfénnit yéfe si wafroghét;
\q2 yémofem sénko esambnetat téfefaf máméghéraye akenaghafé.
\q1 \v 15 Yénd yau so kengongém ándan túmén orsoghta,
\q2 wáiwái siyém faroghkaf yém téfene sáfamé.
\q1 \v 16 Méinyotio yéndfem eyáretam fifi alimanéghan téfene si wafrogh ár.
\q2 Méinyotio yéndfem séfandam em téfene fai wangogh mék téfnár.
\q1 \v 17 Méinyotio yéné té kénufrotat wénde yéndfem yau fém mwighafnar kénmitam.
\q2 Yéndfem yau mámáfi tafrotam fene árnégh yam.
\q1 \v 18 Téfene tikéfam yau fém kénéfrangote.
\q2 Yénd yau fene endta nayu namndayém.
\q1 \v 19 Wénde fémo té yénd ténmironau minjan ághafene fanfne yuwon.
\q2 Fémo té yénd ténmafnan ménaye kwéfitaye a kér.
\q1 \v 20 Njam yéndfem té mwighafnar titam téfene Ngánjánene yétkwén
\q2 o tásáfotam téfene ngángé oraighan nayu yumén ngánjánafefaf.
\q1 \v 21 Ngánjánam so táf mat káyátongai,
\q2 ménamén fá mat yém kwankwane yam méinyotio tikfamé.
\q1 \v 22 Wénde fene téfnan yénd yénésmetat kérotio méinyotio efghon;
\q2 yénd ndenanit máméghéraye yénéfetat sif.
\q1 \v 23 Kano, O Yuré! Némamén fém kémégh nékém?
\q2 Kokai! Yau yénkena yénd tuot.
\q1 \v 24 Némamén fém nérete ámb ende?
\q2 Némamén yékene téfene tékrat yam a mwighé kérté?
\q1 \v 25 Yénd mbandan ténmalindangé
\q2 yénmalinjo sáf yuwan njúnnjúnafé.
\q1 \v 26 Kano! Ténmáutána yénd!
\q2 Ténman yénd yaufiyam téfnár ménamén fne kwénjtafnar uwégh.
\c 45
\s
\q1 \v 1 Sariafé siam tane tikéf yéwende.
\q2 Yéndo so siye emndetan mbarkánd yam merkéráye áuwéghafé yandaghafé mwighé siye yánemén warsagh ár,
\q2 ménamén tane kanké siyém ndenanit fen matyam yandángégh faroghmén.
\q1 \v 2 Fém yénéf ném méinyotio árta séfakwro ambum.
\q2 Ngárámafé si wérér nénérse kétamé fene mbírmbírta.
\q2 Ngánjánam yémonyo té fém néfrendai tuot.
\q1 \v 3 Téfai fenjo witmafé sénté náifé, I ndimbal mék téfnár!
\q2 Fém ném ndimbal kwayaghafé minde ndimbal waftafé!
\q1 \v 4 Fene ndimbal utmanégham yéngérse kétán sái kawaindangém,
\q2 yamarote efalo, néndkéf ghérsé, a mbarkánd ámnjogh.
\q2 Néngém fronde ménát so tafuna matot méndefé yam wafrogh!
\q1 \v 5 Fene fimb sem sénté, ekindat fene mék téfnárafene tikéf.
\q2 Ndimbal yu nénuitat fene kafkaf mbanmbanot.
\q1 \v 6 Fene limánégh ámnjogh sifayé, O Ngánján, nakete tuot mbanjat.
\q2 Fémo yélimnde mbarkánd wétue.
\q1 \v 7 Fémo méndefé yéfande mbarkánd ámnjogh a méndméndat yéfande mámáfi.
\q2 Yénémaménnde Ngánján, fene Ngánjánam té néfagharyéng fém,
\q2 tasunau áuwégh oil fefaf mindefifi yau kor ámb ároefaf.
\q1 \v 8 Miré, aloe, a kasia wimafé wékwérafé yém fene tombé sáláme.
\q2 Kété aifori wékwérmén warsagh ároene sifayan wagh kémbnemén ángégham némumyote fém.
\q1 \v 9 Warsagh ároene mérés sem yéfene kénjún em minde tuk sifayé amafafefaf.
\q2 Yénamé fene tambén ngángata yakai warsagh amaf,
\q2 yawo jewel wímmén mer safot gol ménamén yém Ofirmén!
\q1 \v 10 Náyáreta tafaf, O tukén sifayamén mérés; tané tikfe némé yénd norayan.
\q2 Mwighafnar tawai fene ár a fene mérén nayu táyáto.
\q1 \v 11 Ménamén fene tukén sifayamén fenjar em yayamnete fene sari;
\q2 yutémnda fá ménamén fá siyém fene yuré.
\q1 \v 12 Tukén sariafé Tairemén mérsom so yuyafote rokar raméghe.
\q2 Mani ngonjélam so yamnende fene ménde.
\q1 \v 13 Tukén sariafé, aweréghét mérés nérete minde kwayaghafé
\q2 yáne golmén gaun sálámefé.
\q1 \v 14 Yánjo saiafé tombé sálámefé fá yélimayénd kétán warsagh ároefef
\q2 néngafghayénd ámb awerégh mérés fútarafé.
\q1 \v 15 Nderé áuwéghafé a minde méndefé yam yém
\q2 njam fá kényawetawét warsagh ároene limánégh ámnjogh sifayé!
\q1 \v 16 Féfene ghakér ambum so nénamndetat warsagh ár ndené arfé kés témorwén.
\q2 Fémofem so eyátotati fá limánégh téfnár tárfár mbandamé.
\q1 \v 17 Yéndo so yénérsan utmanégh yéném fene yétkwénfaf méinyotio ár saté kénjúmén.
\q2 Yénémamén, ndimbal yu tárfáram so némarsat fém tuot a nbanjat.
\c 46
\s
\q1 \v 1 Ngánján siyém téfene átnogh sifayé a muyé,
\q2 túmén afrengéghkaf yém wáutárghét kérté yam kénjún.
\q1 \v 2 Yénémamén yénd yau so férfér yéném njam sokrere yéném
\q2 a mband tunakéf nafunat arakafot.
\q1 \v 3 Yumyota arakaf so sof manumanu naramete mbéror kamafé.
\q2 Eumyota mband tunakéf so násámbnetat ndené yame nuone sof yénau nufrotat.
\q1 \v 4 Nuam yénérse áuwégh kétán téfene Ngánjánene ndimbal tesenot,
\q2 fénataye Minde Tukénoene méngotu.
\q1 \v 5 Ngánján kété násáfote ndimbal tesenan, yéné yau so kirorngé.
\q2 Kétamé rényégh efogh ánde naryaryéng, Ngánjánam so yarawene yéné.
\q1 \v 6 Ndimbal yu sem mere yau em,
\q2 a uwérsoghan em a yéfene limánégh nénironat!
\q1 Ngánjánene si kém toyé naramete,
\q2 a mband marat nérnde!
\q1 \v 7 Njafar fiyarafene Yuré siyém yéna yém téfefaf;
\q2 Israilafene Ngánján siyém téfene wambégh méngo.
\q1 \v 8 Taném téfandangi Yurane minde kwayaghé ásáfogh:
\q2 Téfandangi ndernaye yémo yénérse kérté yam mband maratan.
\q1 \v 9 Yémo yéngfune mék ménát so néngefotat yénamé mband maratan.
\q2 Yémo yéngráfne námb a sénté rokare so engétyane fimb;
\q2 yémo engwarote fimb awangogh mbakw.
\q1 \v 10 Wéndé mé aném, a mat aném ndené yénd wém Ngánján!
\q2 Yénd so utémndat méinyotio ndimbal yuam.
\q2 Yénd so utémndat yénamé mband maratan.
\q1 \v 11 Njafar fiyarafene Yuré siyém yéna yém téfefafén;
\q2 Israilafene Ngánján siyém téfene wambégh méngo.
\c 47
\s
\q1 \v 1 Kénaflangi méinyotio ár! Esmetati fene ngángé!
\q2 Nutnati Ngánjánefaf yarsati áuwéghafé!
\q1 \v 2 Ménamén minde tukén Yuré siyém férférafé.
\q2 Fá siyém ndimbal warsagh ár méinyotio mbandan.
\q1 \v 3 Yémo ewanjetae ndimbal yu téfe rére,
\q2 engékmete téfene mék téfnár téfene kafkaf mbanmbanot.
\q1 \v 4 Yémo yaferyéng wawéngsoghmén mband sai yém téfeyot.
\q2 awarmboghafé ásáfogh sifayé Jeikofene ákiambumafenemén efe yémo euwete.
\q1 \v 5 Ngánján té narmboi ménayafé ndimbal muyé kefé.
\q2 Yuré té narmboi ménayafé sufér ke kénamndau.
\q1 \v 6 Eufanat warsagh wagh yáyot Ngánjáne,
\q2 eufanati warsagh wagh!
\q1 \v 7 Ménamén Ngánján siyém warsagh ár yénamé méinyotio mbandan;
\q2 Yuyotati fá ménaye fénatayero waghe.
\q1 \v 8 Ngánjánene limánégham ewafne ndimbal yu,
\q2 yémorang yánjo njúnjúnofnar limánégh ámnjogh sifayan.
\q1 \v 9 Mband marat limánégh téfnár té káumendat
\q2 mérne Abraamene Ngánjánene árfé.
\q1 Ménamén méinyotio warsagh ár yéné mband maratmén em Ngánjánene.
\q2 Fá siyém minde tukén utémndat méinyotio sifayamé.
\c 48
\s
\q1 \v 1 Nderé ndimbal yém Yuré,
\q2 nderé wafrogh yamafé yém yuyotan,
\q1 téfene Ngánjánene ndimbal tesen kénjún,
\q2 árké yémor yánjo njúnnjúnofnar mband tunakfan.
\q1 \v 2 Yéné siyém tukén a sotafé;
\q2 méinyotio mband marat náuwetat ménát sái yéfandat yéné!
\q1 Jaion mband marat tunakéf,
\q2 siyém ndimbal warsagh ároene ndimbal tesen!
\q1 \v 3 Ngánján fáyo yém Jerusalem tawa kénjún
\q2 nauyafote fáyo yéné wamarogh ár.
\q1 \v 4 Mbandmén warsagh árém efghayénd mék téfnár
\q2 a frondeyo ndimbal tesen sénanéghét.
\q1 \v 5 Wénde njam yémofem yinjoyénd, fá sénko nawarendayénd;
\q2 sélngwél emormén a náwatembayénd.
\q1 \v 6 Fá ewerai ndimbal férféram
\q2 a ewanjmetai tékratam ndenanit amaf yénau yém araféghan.
\q1 \v 7 Fémo tawironau fá ndenanit ndimbal bout Tasismén
\q2 wafté kér ro wér mbormboram.
\q1 \v 8 Yénd té káyáretawén ménamén ndimbal tesenoene minde kwayaghamén,
\q2 wénde sénonjo yéndfem té yinjongém yéndfemyo
\q2 njararmén fiyarafene Yurane ndimbal tesen.
\q1 Yéné siyém téfene Ngánjánene ndimbal tesen,
\q2 yémo so yafrote yéné wasérmboghofnar tuot.
\q1 \v 9 O Ngánján, yéndfem mwighaye yéknam fene kwénjfnar uwégh
\q2 njam yéndfem némáwefnotam fene wáwefnogh méngon.
\q1 \v 10 Fene yétkwén wafrogh yamafé yém, O Yuré,
\q2 fém so némuyotam yénamé mband marat árkamé yiyáto.
\q2 Fene tambén ngángé sem awaingégh muyayam té nafo.
\q1 \v 11 Taumyo ár kété mband tunakéf Jaionén náuwetat.
\q2 Taumyo méinyotio Judamén tesen so em klisafé
\q2 ménamén fene mbarkánd yammén.
\q1 \v 12 Tangém, yényamndat Jerusalemén ndimbal tesen.
\q2 Eyota yarendati a ewaftati tafar tawa.
\q1 \v 13 Kor tawinjongi mbakw arake
\q2 a tawifongi méinyotio táikér átnogh sifayé,
\q1 ménát fémofem so engwaufrotati yénémamén yéfeyot
\q2 soramé ambumat.
\q1 \v 14 Ménamén ndené yéné Ngánján fiyém.
\q2 Fá siyém téfene Ngánján tuot a mbanjat,
\q2 a yémo so yénd yénmarawene kétánotio yénd kér yéném.
\c 49
\s
\q1 \v 1 Náyáretati yéné, fém méinyotio ár!
\q2 Áyárégh ár aem, méinyotio ár mband maratan!
\q1 \v 2 Tukén ár a yuwén ár,
\q2 wemar ár a yauyau ár-náyáretati!
\q1 \v 3 Ménamén tane si sem káfeté,
\q2 a tane mwighé sem afoghkaf em kénjkam emaréghe.
\q1 \v 4 Yénd merkéráye náyáretan tárfár káfetá si
\q2 a efenan ámogh si ménaye gita kembne klisafé.
\q1 \v 5 Némamén yénd so férfér wém njam kérté yam yéném,
\q2 njam mék téfnáram kwarendangi?
\q1 \v 6 Yémofem mwighafé efandat yéfene mani ngonjél
\q2 a nawarsat ndimbal wemarmén.
\q1 \v 7 Wénde yau so kafrngi fáyo kétamé kér tambén
\q2 ménaye wafatoghmén fai sái yangotat kétán Ngánjáne.
\q1 \v 8 Aferégh ár yau yéném mé afráte,
\q2 ménamén árké ár yau so fai nufrote féyotaroan
\q1 \v 9 ménát so emor tuot
\q2 a yau so tinjongi mbéwé.
\q1 \v 10 Fá efe em káfeté so ambino kér em,
\q2 ndené fété mwighémwighafnar ár a awasnengégh ár,
\q2 engéfrangotat méinyotio yéfenjo mani ngonjél sémta.
\q1 \v 11 Mbéwé siyém yéfene tuot mengotu,
\q2 ánde fá so emor tuot,
\q1 Téu yémofem yétkwéne emndetat yéfenjo wafroghmén yam yéfene soramayo.
\q1 \v 12 Wénde yéfene marataye yam yau so nakete.
\q2 Fá so kér em, ndenanit wérár kés em.
\q1 \v 13 Yéné fiyém awasnengégh árfene kér,
\q2 ndemamén téu ewafaretat ndené fá káfeté tamorwén.
\q1 \v 14 Ndenanit sif, fá elimndat kétán mbéwéfaf,
\q2 ánde kér so yém yéfene wanjengégh ár.
\q1 Akwna ngánján ghérsafé árém so limánégh yafrotat yéfene tukén.
\q2 Yéfene fifi norndat mbéwéyan,
\q2 nayu kétamé yéfene ndimbal wafroghmén némé tamorwén.
\q1 \v 15 Wénde tayot, Ngánjánam so tane ghérsé tanjarngé.
\q2 Yémo so ngwétnongé yénd kétamé mbéwane waftata.
\q1 \v 16 Féyo yau mwighayan nuita njam yaufiyam awasnengégh ár náyátotat wemar
\q2 a yéfene méngo nénayátoat minde kwayagharo.
\q1 \v 17 Ménamén njam fá kér em, yémofem ámb yau némé fangwanongi.
\q2 Yéfene mani ngonjélam yau so tawaitongi mbéwé kénjút.
\q1 \v 18 Yéné sénonjo ghérsayan fá fáyo nafandat féyotaro
\q2 a em náuwetat yéfene remngoghmén.
\q1 \v 19 Wénde fá so kér em ndené yéfene fronde ámb méinyotio kés emormén
\q2 a yau wéikor so yéfandat efghoene kwayaghé.
\q1 \v 20 Ár efe nawarsat yéfenjo mani ngonjélmén yau mat em;
\q2 fá so kér em, ndené fété wérár kés em.
\c 50
\s
\q1 \v 1 Yuré, Muyé Kér ro, siyém Ngánján,
\q2 a fá té norayai;
\q1 yémo té wafaretai méinyotio ár
\q2 kétamé árkamé efogh nénareinde kétán ánde nuite.
\q1 \v 2 Kétamé mband tunakéf Jaion, féwénféwénofnar saifafé,
\q2 Ngánján natremngote minde kwayaghayam nálále.
\q1 \v 3 Téfene Ngánjánam yénmanete,
\q2 a fá yau yém métar.
\q1 Fésam yákérne méinyotio rokar yáne endmé,
\q2 a ndimbal nékwafé kiwalam yarende fá.
\q1 \v 4 Fá kutnangé njafar tukét a yuwot mbandot
\q2 ménát sái ghékéf ewafayotat yáne árfene mogh efghon.
\q1 \v 5 Tanwasrongi tane ndimbal mwighé kér ro ár yénan tafaf-
\q2 fá emofé nareindamém yéndfé ménaye ghéngén raméghe."
\q1 \v 6 Féyo taumyo njafar so nafrotat yáne mbarkánd yammén
\q2 ménamén Ngánján fáyo so yém mogh téfnár.
\q1 \v 7 "O tane ár, náyáretati sái yénd norayan.
\q2 Yéna em tane téféf féfeyot, O Israil:
\q2 Yénd wém Ngánján, féfene Ngánján!
\q1 \v 8 Tane yau yém áwátaranégh ménamén féfene ghéngénmén
\q2 o warogh ghéngén raméghmén fémofem árkéméné túmén erametati.
\q1 \v 9 Wénde yéndo yau méndefé efandan kau féfene sifayata
\q2 a gout féfene arake kénjúta.
\q1 \v 10 Ménamén méinyotio wérár wénaromén em tane
\q2 a tane em kau kés em tauwen mband tunakfan.
\q1 \v 11 Yénd mat wém méinyotio mer mband tunakfan,
\q2 a mbandmén méinyotio wérár sem tane.
\q1 \v 12 Njam yénd kwémorwén siogh, yéndo yau so tawaufrongayén,
\q2 ménamén méinyotio mband marat siyém tane a méinyotio rokar yéné kénjún.
\q1 \v 13 Té yéndo enetan kauafene fenjén?
\q2 Té yéndo enetan gout férék?
\q1 \v 14 Ewafrotati kánjo raméghmén féfene ghéngén yáyot Ngánjáne,
\q2 a ewarawenati féfenjo ufoghmén si fémofem árké ewafrotaménd kétán Minde Tukénoefaf.
\q1 \v 15 Féyo kutna tafaf njam fém ném kértayan,
\q2 a yéndo so kémanjare,
\q2 a fémo so waramete minde kwayaghé.
\q1 \v 16 Wénde Ngánján noraye kétán yaufi árfefaf:
\q1 "Némamén néwérsotati efértati tane nák
\q2 a anégh yafrotati ménát sái náyáretati tane arnéghfaf?
\q1 \v 17 Ménamén fémofem yékenati tane téfél
\q2 a tane ndenanit eyátotati njénnjén.
\q1 \v 18 Njam fémofem tawinjongi oro téfnár, fémofem efalo táyátongi,
\q2 a fémofem féfenjo efogh yiyátotati yémafé amafanyo awanégh téfnárafé.
\q1 \v 19 Féfene sénféne siyém té nafongi yaufiyam,
\q2 a féfene kanké sem afoghare em unyéghan.
\q1 \v 20 Fém kwawarendangi ámnjoghan a si wafrogh tawafngongi féfenjo fútar-
\q2 féfenjoyo amane ambumoe.
\q1 \v 21 Njamandio fémofem yéné yafrotati, yénd wémor métar,
\q2 a fém kemnati yéndo yau kar ewambetan.
\q1 Wénde sénonjo yéndo so eusérmbotan fém,
\q2 fefayan ekayotan féfene téfénmén fai.
\q1 \v 22 Kawengongi méinyotio fém emofem mwighafnar witat yénd,
\q2 o yéndo wé karéf ewafrotat fétraréghan,
\q2 a árké árom yau so ewáutáne fém.
\q1 \v 23 Wénde kánjo ramégh siyém ghéngénghéngén yém árkéményan utémndati yénd.
\q2 Njam fém em tane endén,
\q2 yéndo so sáfét yufanan féfefaf Ngánjánene wajarégh."
\c 51
\s
\q1 \v 1 Aném ghérghérsisé tafaf, o Ngánján,
\q2 ménamén fene kwénjtafnar uwégh.
\q1 Ménamén féfene ndimbal ghérghérsisamén,
\q2 tangwaufeta tane yaufiyam.
\q1 \v 2 Wumbna yénd tane yaufiyamta.
\q2 Njúnnjúnofnar kwiyáto kétamé tane yaufiyamta.
\q1 \v 3 Ménamén yénd mat namndan tane áyáréghofnar yam;
\q2 tane yaufiyam siyém túmén tane frondeta.
\q1 \v 4 Mé fefaftro, a mé fémro, té yéndo yaufiyam tafrotan.
\q2 Yéndo té tawafrotan némé tam mámáfi fene sáfan.
\q1 Fém so efalo kényátongén yénayan fifi némé njam fém koraya,
\q2 a fene mogh tayot siya yém mbarkánd.
\q1 \v 5 Ménamén yénd náráftamén yaufiyam téfná-
\q2 néméwét, yéné efoghta tane amam ánde wéráftam yénd.
\q1 \v 6 Wénde fene ménde témorwén unyégh yau so témorwén kafkalan,
\q2 kwatametau yénd káfeté mwighé táf kété.
\q1 \v 7 Njúnnjúnofnar kwiyáto kétamé tane yaufiyamta, a yénd so kamndan merro;
\q2 wumbna yénd a tane kwayagham so yáinde kafe ngarot kwayaghé.
\q1 \v 8 O, kwaram kwawango tandio tane áuwégh wéikor;
\q2 fémo té kwirone yénd,
\q2 sénonjo yénd kwumyo so náuwetan.
\q1 \v 9 Yau ndenayu wafanda tane yaufiyam.
\q2 Eumbna tane méinyotio yaufiyam árké yéndo tawafrotan.
\q1 \v 10 Téfuna tane kénjún mer tikéf, o Ngánján.
\q2 Wéikor témina áyárégh kér ro mbérmbér tane kénjún.
\q1 \v 11 Yau táf wifna yénd fene sáfta,
\q2 a yau téngwan fene Ngánján Mbérmbér ta tambén.
\q1 \v 12 Wéikor téfuna tafaf wanjarégh áuwégh,
\q2 a kwiyáto yénd ménde sái wém fe waitoghét.
\q1 \v 13 Féyo yéndo so ewatametan fene end yéfe áyáréghofnar árét,
\q2 a fá so néngangotat fefaf.
\q1 \v 14 Kémawalindangé tane yaufi ménamén férék eréghmén, o Ngánján emo wanjane,
\q2 féyo yéndo so áuwéghafaro wagh eufanan ménamén tane yaufi wawalingéghmén.
\q1 \v 15 Tésawér tane mbírmbír, o Yuré,
\q2 ménát tane sénféneyam so fém némarse.
\q1 \v 16 Fémo yau méndefé yéfande ghéngén, o yéndo ámbiro ghéngén sái téraman.
\q2 Fém méndefnar ném waroghmén ghéngén.
\q1 \v 17 Fémo árké ghéngén méndefé yéfande siyém wiroréghkaf mbérmbér.
\q2 Fémo yau so ekene wiroréghkaf a yaufiyamta awengogh tikéf, o Ngánján.
\q1 \v 18 Méndefé yéfanda Jaion a yáutána fá,
\q2 wéikor erametati Jerusalemene mbakw áráke.
\q1 \v 19 Féyo fém so táf nauwete ménáyan ghéngén sái erametati mbarkánd mbérmbéran,
\q2 ménaye waroghmén ghéngén a méinyotio warogh ghéngén.
\q2 Féyo kau wéikor táf so ghéngén ewafrotati féfenjo ghéngén kitarayan.
\c 52
\s
\q1 \v 1 Némamén fém nawarmbote ménamén fene ár ngimén, dnimbal mék téfnár?
\q2 Yau fémo yáyamngo Ngánjáne mbarkánd siyém mé so yéngém tuot?
\q1 \v 2 Méinyotio efogh tombé fémofem kwankwane mwighé yéfaronati kértat.
\q2 Féfene kankayam yéngénfete ndenanit sénté résa;
\q2 fém yéné fété em séno ménayan unyéghan.
\q1 \v 3 Fémo méndefé yéfande yaufi mindefifi yau kor mer
\q2 a néngunde mindefifi yau kor efaloyan.
\q1 \v 4 Fémofem méndefé yéfandati sái engwironati ámb ár ménaye féfene siye,
\q2 féfene unyégh!
\q1 \v 5 Wénde Ngánjánam so kéntarmangé fém yuwot ambinotmaro a ambino.
\q2 Yémo so nénlimnde fém fenjo méngota
\q2 a kénrufangé fém kétamé ghérsé ámnjogh mbandta.
\q1 \v 6 Mbarkánd ghérsafé árém so yéfandat yéné a so em sélngwél.
\q2 Fá so nurtat a norayat,
\q1 \v 7 "Kéretangi némé natyanat ndimbal mék téfnárafefaf
\q2 emofem yau efalo yiyátotat Ngánján.
\q1 Yémofem efalo eyátotat yéfene mani
\q2 a nanotat mindefifi marataye yéfenjo yaufiyam kénjún."
\q1 \v 8 Wénde tayot yénd ndenanit wém loif wén Ngánjánene méngo kénjún.
\q2 Yéndo mwighé yéfandan Ngánjánene kwénjtafnar uwégh tuot a mbanjat.
\q1 \v 9 Yéndon so némuyotan fém tuot, O Ngánján,
\q2 ménamén némé fémo té tafrote.
\q1 Yéndo so mwighafé yéfandan fene mer yétkwén
\q2 fene ndimbal mwighafé árfene sáfan.
\c 53
\s
\q1 \v 1 Awasnengégh árro néngorayat yéfenjo tikéf kénjún,
\q2 "Yéna yau yém Ngánján."
\q1 Fá sem awasnengégh téfnár, a yéfene yam wafrogh sem mámáfit;
\q2 yau emo ámb yafrote mer!
\q1 \v 2 Ngánján nénrete yuwot kétamé njafarta
\q2 yéfefaf méinyotio fénaté ár sáffat;
\q1 fá nénrete ménát so tinjongé efe kor efalo káfeté mwighafé yém,
\q2 njam té ámb árom yéronja Ngánján.
\q1 \v 3 Wénde yau, méinyotio té sem kawengotat;
\q2 méinyotio té nénamndangi awasérmbogharé.
\q1 Emo ámb yau yafrote mer,
\q2 yau ámb ámbiroyam!
\q1 \v 4 So fá emofem ewafrotat mámáfiyam so mat náyátotat?
\q2 Yémofem enetat tane ár ndenanit féskaf flawé
\q2 a yau nemnat ménát sái numbértotat Ngánjánefaf.
\q1 \v 5 Férféram so tawerangé fá,
\q2 yéné férfér ánde yau yémormén frondeyan.
\q1 Ngánjánam so ewafarne féfene mék téfnárafene sot.
\q2 Fémofem so tákmangi wáiwáiot, ménamén Ngánjánam té ekena fá.
\q1 \v 6 Efe so yéném kétamé Jaion mband tunakéfta ménát tawanjarngé kértata Israil?
\q2 Njam Ngánjánam wéikor tafnangé yánjo ár,
\q2 Jeikof so nutne áuwéghafé, a Israil so náuwete.
\c 54
\s
\q1 \v 1 Kénaf ndimbal waftafé, O Ngánján, a kwanjar kértafé yénd!
\q2 Kwamarota yénd fene muyaye.
\q1 \v 2 Náyáreta tane ghékéf umbértogh, O Ngánján.
\q2 Kamyo tane sifaf.
\q1 \v 3 Ménamén fénaté árém yénd wafngongi;
\q2 kérté wafrogh téfnáram wafngongi yénd kérotio ngiot.
\q2 Ngánján yau yémofem fronde yékmetat.
\q1 \v 4 Wénde Ngánján siyém tane wáutárégh ár!
\q2 Yuram mé tane ghérsé yérete!
\q1 \v 5 So tane mék téfnarafene yaufi mwighé faroréghmén nawengotat yéfefafétio.
\q2 Yafrota yéné némat fém té unyéghofnar si norayai a tékmang yéfe ánde so eyato.
\q1 \v 6 Yéndon so yafrotan ghéngén tanjoménro ghéngén ramégh yénan feyot;
\q2 yéndo so yarsan fene yétkwén, O Yuré,
\q2 ménamén yéné siyém mer.
\q1 \v 7 Ménamén fémo té yénd wanjaryéng tane kérté yamta
\q2 a wáutánam ta ménát so nufrote tane mék téfnarafefaf.
\c 55
\s
\q1 \v 1 Náyáreta tane ghékéf umbértogh, O Ngánán.
\q2 Yau tane ye yékena wáutárghét!
\q1 \v 2 Ghérghérsisé káyára a kwawango ta,
\q2 ménamén yénd ndimbal kéráye wérse tane kérté yamam.
\q1 \v 3 Tane mék téfnár nénutnat tafaf,
\q2 ndeimbal keye máméghéraye usémboghafé.
\q1 Yémofem yénérsat kérté tafaf
\q2 a nékwafé eném tafaf.
\q1 \v 4 Tane tikéf náutáne wéfan.
\q2 Ker férféram kwafngongé ngi yénd.
\q1 \v 5 Férfér a ngerngeram ndimbal kéráye wérse,
\q2 a yénd yau kékmbon ásámbnengégh.
\q1 \v 6 Yénd norayayén, "O, tane fiya tam njamb ndené mamuoene kés em!
\q2 Yénd so kanefangayén nayu a kwémorwén enaghan!
\q1 \v 7 Yénd so kanefangayén nayu
\q2 kétán métar fanfne yuwot.
\q1 \v 8 Nderé wékeye so yénd ofé ngaraman-
\q2 nayu kétamé nékwafé méndménd kiwalta.
\q1 \v 9 Tawanjmeta mwighayan, Yuré, a muyafnar tayáto yéfene mwighé wafrogh,
\q2 ménamén yéndo yéfandan kértanyam a ásnanégh ndimbal tesen kénjún.
\q1 \v 10 Yáne arake mbakw yiyamndat efogh a sémbár yéfeta efe wirorégh téfnár
\q2 wénde mbarkánde férfér siyém áyáréghofnar ghérsé ndimbal tesenan.
\q1 \v 11 Méinyotio yam sem nénguitat fénatayero;
\q2 yéru náuwégh a waghnyégh sem máméghéraye marat náyátote endmé.
\q1 \v 12 Yéné yau yém mék téfnár emo áuwéghofnarot so wémeinde
\q2 yéndo sái yáyáretan yéné.
\q1 Yéné yau yém tane sénamégh ár efe fáyo namndete minde mer kar yém tane si méndeyan-
\q2 yénd fai katnongayén yéfeta.
\q1 \v 13 Wénde, fém yénéf ném-tafaf nátémnde,
\q2 yéndfé yénre a ném kaka fútar.
\q1 \v 14 Némé mer awarnégh táf té yéndfem tayamnetawém
\q2 njam yénd mérne tényotau kétán Ngánjánene méngot.
\q1 \v 15 So kéram ewaitote tane mék téfnar;
\q2 so mbéwé méngoyam taulongé fá ghérséghérsé,
\q2 ménamén yaufiyamam méngo yéramete yéfene kénjún.
\q1 \v 16 Wénde yénd so kutnangén Ngánjánefaf,
\q2 a Yuram so kwanjarngé yénd.
\q1 \v 17 Akw, efoghméfan, a sémbáran
\q2 yénd yefé néngutnan tane kérté yam njam wétumnda,
\q2 a Yuram káyárangé tane kém.
\q1 \v 18 Yémo wétnote yénd a wambete merkéráye
\q2 kétamé mékta kés nénufngo tafaf,
\q2 mé tárfáram wékarotat yénd.
\q1 \v 19 Ngánján, efe mé limánéghan yéném tuot,
\q2 so kwiyárangé yénd a métar táyátongé fá.
\q1 Ménamén tane mék téfnár nakenat ménát yau so tawengongi yéfenjo yam;
\q2 yémofem yau férférafé yéfandat Ngánján.
\q1 \v 20 Wénde awarnégh téfnárom, yémo sén erametam yánjo fútar;
\q2 yémo eráfnam yánjo si.
\q1 \v 21 Yáne si sem ndené njennjenat bata kés yém,
\q2 wénde yáne tikéf kénjún siyém mék.
\q1 Yáne si stamorwén minde afrátyo yau ndené oil,
\q2 wénde yéné tamorwén olitoghét fimb!
\q1 \v 22 Erameta fene kérté kétán Yurafaf,
\q2 a yémo so némáutáne fém.
\q2 Yémo yau so eumyote mbarkánd ár sái esambnetat.
\q1 \v 23 Wénde fém, O Ngánján, so enérse fá
\q2 ewewona kétán tékrat yékwét.
\q1 Ár ngi téfnár a unyégh téfnár so kér em totér ambumanyo,
\q2 wénde yéndo mwighafé néfandan fém ménát so wanjane yénd.
\c 56
\s
\q1 \v 1 O Ngánján, aném ghérghérsisé tafaf,
\q2 ménamén árém yénd túmén waghnat tane mék.
\q2 Téfnáram kwafngongi méinyotio efogh tombé.
\q1 \v 2 Yénd túmén waghénan yémofem emofem si wawafrotat ta,
\q2 a tárfáram marataye kwafngongi yénd.
\q1 \v 3 Wénde njam yénd férfér wém,
\q2 yéndo táf mwighafé kéminjon fém.
\q1 \v 4 Yéndo yarsan Ngánján ménamén yémo té unyéghofnar si norayai.
\q2 Yéndo mwighafé yéfandan Ngánján, féyo némamén so yénd férféram wéramete?
\q2 Némé so mé ornégh árém yafrotat yénan tafaf?
\q1 \v 5 Yémofem túmén ewengotat tane si némé njam norayan;
\q2 yémofem ewifotat yéfenjo efogh kwankwane mwighé wafroghan ménát sái tékrat kwaramangi.
\q1 \v 6 Fá eném mérne ménát siya ghékéf wafayotat ta-
\q2 yéfandat tane méinyotio áligh, ménde em sái kérotio kwésmangi.
\q1 \v 7 Yau eumyota fá nayu káyátongi ménayafé yéfenjo yaufiyafé;
\q2 fene nékwe, O Ngánján, enemnja fá yénan.
\q1 \v 8 Fémon mbarkándro end yafrota ménamén yemén.
\q2 Fémo té takafete tane yengam fene wésot.
\q2 Fémo té matot takayote fénatayero fene bukan.
\q1 \v 9 Tane mék téfnaram so kwafngongi máméghérayero njam yénd kutanangén fefaf ménát wáutárghét.
\q2 Yéné yénd mat wém, Ngánján siyém ta tambén!
\q1 \v 10 Yéndo Ngánján yarsan ménamén ndernaye fá unyéghofnar si norayai;
\q2 néméwét, yéndo yarsan Yuré ménamén ndernaye fá unyéghofnar so norayai.
\q1 \v 11 Yéndo mwighafé yéfandan Ngánján, féyo némamén so yénd férféram wérametae?
\q2 Némé so mé orngégh árém yafrotat tafaf?
\q1 \v 12 Yéndo so tanjo si eyátotan fefaf, O Ngánján,
\q2 a so kánjo ramégh ghéngén némarametan fene wáutáréghmén.
\q1 \v 13 Ménamén fémo té ghérsé urtoi yénd kétamé kérta;
\q2 fémo té tawarawene tane kafkaf kétamé eunoghta.
\q1 Féyo sénonjo yénd so wiyota fene sáfan, O Ngánján,
\q2 fene ghérsé ramégh kwayaghayan.
\c 57
\s
\q1 \v 1 Aném ghérghérsisé tafaf, O Ngánján, aném ghérghérsisé!
\q2 Yénd néngretan fefaf wambghét.
\q1 Yénd so katnon fene njamb njar mbanmbanan
\q2 kétánotio férférafé yam kawaindangé.
\q1 \v 2 Yénd so yefé kutnangén kétán Ngánjánefaf Minde Tukén,
\q2 Ngánjánefaf emo so yafrote yánjo ménde tayot.
\q1 \v 3 Yémo so yénmafarete wáutárégh yam kétamé njafarta ménát sái kwanjarngé,
\q2 yuwot so tákmangé fá emofem yénd túmén waghnat.
\q1 Tane Ngánjánam so yénmafarete yánjo kwénjtafnar uwégh a ndimbal mwighé.
\q1 \v 4 Tane ghérsé siyém ndimbal munjan fusafene kénjún,
\q2 yénd so walinjo yéfefaf
\q1 emofem amboneye yénmitat fés árfene ambumam, endefene sén em tot a besi fimbnit.
\q2 A yéfene kanké ndenanit witmafé sénté naifé.
\q1 \v 5 So némuyotat njafar tukmé, O Ngánján!
\q2 So fene minde kwayaghé natremngote méinyotio mband marat tukén.
\q1 \v 6 Tane mék téfnáram té tafrendat urér tayot.
\q2 Yénd té omyégh wiyátonmwighé kérté yam.
\q1 Yémofem té tétanat kénjkam yékw tane endén,
\q2 wénde fá fáyo té nuyayénd yéné kénjút.
\q1 \v 7 Tane tikéf siyém féyotaro yém fene kénjún, O Ngánján;
\q2 tane tikéf siyém féyotaro yém.
\q2 Taikrataye yéndo so warsagh wagh fene némaufanan!
\q1 \v 8 Tano, tane tikéf!
\q2 Kano, o laire a arf!
\q2 Yéndo so akw yanotan tane waghe.
\q1 \v 9 Yéndo so kánjo némarametan fe, Yuré, méinyotio ár kénjún.
\q2 Yéndo so eufanan fene warsagh wagh méinyotio ndimbal yuwomé.
\q1 \v 10 Ménamén fene kwénjtafnar uwégh siyém ndené tuk fété yém njafar kés em.
\q2 Fene ndimbal mwighayam eyanje nu kwéf.
\q1 \v 11 So némuyotat, O Ngánján, yéné tukmé minde tuk njafaramé.
\q2 So fene minde kwayaghé natremngote méinyotio mbandamé.
\c 58
\s
\q1 \v 1 Mbarkánd yam-té yén é sioene fifi mat em fém limánégh téfnár?
\q2 Té fémofem ekmetati ár moghan ámbrérero?
\q1 \v 2 Yau! Fémofem ménjuta mwighé kwankwane tikfan ewafrotati.
\q2 Fémofem yafarnat kérté yam mbandan.
\q1 \v 3 Yéné áyáréghofnar ár náráftat yaufiyam téfnár;
\q2 kétamayo táf njam náráftaménd fá té unyéghro tanmorwéna tayotau yéfenjo ende.
\q1 \v 4 Yémofem mbérém ewitat ghaftamén ndenanit em kérwén kamban;
\q2 fá ndenanit em korban kamban yénau nakenat áyárghét.
\q1 \v 5 Ekenat kambanafene méndefé kém,
\q2 ndemamén nderé mat yáme fá téu nambnat.
\q1 \v 6 Engrafna yéfene tuk sén, O Ngánján!
\q2 Etyana yéné ndimbal munjan fusafene fétkam, O Yuré!
\q1 \v 7 So fá néngolindat ndenanit nu yénau yém ghérnat mbandan.
\q2 Ewafrota yéfene mék rokar fifiofnar yéfene ngángayan.
\q1 \v 8 So fá em ndenanit tot yénau kolindagné naméghan,
\q2 ndenanit mé arafoghofnar ambum yénai yém emo yau so yéfande efogh.
\q1 \v 9 Ngánjánam so tangsamburngé nayu, totér ár a bulu,
\q2 mé tekofnar yau ndené wafté sinan yénau waftafé táyátongé wakraréghkaf wítwít.
\q1 \v 10 Ngánján ghérsafé ár so náuwetat njam yémofem tinjongi mbarkánd yammén fai sái yangotat.
\q2 Yémofem so eumbénat yéfene kafkaf yaufiyam árfene férkan.
\q1 \v 11 Féyo kerkeran méinyotio ár so norayat,
\q2 "Kété efalo yém fai yéfeyot efe tamor Ngánjáneyot;
\q2 fété yéna yém Ngánján emo mbarkánd yammén mogh yafrote yéna mbandan.
\c 59
\s
\q1 \v 1 Kwanjar yénd kétamé tane mék téfnarafeta, O Ngánján.
\q2 Wmabeta yénd kétamé yéfeta efe té taném ta wiroréghét.
\q1 \v 2 Kwanjar yénd kétamé yéné oro téfnárafeta;
\q2 wambeta yénd kétamé yéné ár ngi téfnárafeta.
\q1 \v 3 Yémofem té téfrendat werghét átnogh sifayé tayot.
\q2 Mámé nékw kér ro mék téfnár kété em nawanjetat, Yuré,
\q2 yéndo yau yaufi tafrotan o kérté tafrotan yéfeyot.
\q1 \v 4 Yéndo yau tafrotan ámb mámáfi,
\q2 wénde fá nafrendat ménát sái kwafnongi.
\q2 Kano! Téfanda némé natyane a kwáutána ta.
\q1 \v 5 O njafar fiyarafene Yuré Ngánján, Israil árfene Ngánján,
\q2 kano a tékratan ekmeta yéné fene méndefnar ndimbal yu.
\q2 Yau yuyafota ghérghérsisé yéfefaf yaufiyam tiyáreghafé árét.
\q1 \v 6 Fá kéntorngi sémbáran
\q2 ndenanit wánangogh tékrat ághé
\q2 métare narota endmé.
\q1 \v 7 Náyáretati kétán mámáfi árké yéném kétamé yéfene sénféneta;
\q2 yéfene siam yéngénfete ndenanit witmafé sénté naifé.
\q2 Yémofem sáf ngiye kwésmangi, "Yéné soramé méinyotio, emo so yényárete yénd?"
\q1 \v 8 Wénde Yuré, fémo fén ewérte fá.
\q2 Fémo si ewawafrote méinyotio yéfe yéné méndefnar ndimbal yu kés em.
\q1 \v 9 Fém ném tane muyé; yénd nawanjetan feyot ménát sái yénd kwanjar,
\q2 ménamén fém, O Ngánján, ném tane wmabégh méngo.
\q1 \v 10 Fene kwénjtafnar uwégh kénjún, tane Ngánján so kokayongé tafaf.
\q2 Yémo so kumyongé yéndo sái efandan ndimbal kéráye ewafrotan yam remngoghafé yéfefaf mé méinyotio tane mék téfnár.
\q1 \v 11 Yau esmeta kérotio, ménamén tane árém so wékeyero mwighafnar tayangi yéné mat yam;
\q2 fene waftayan so nawakayotat fá, enémnja fá kétán yéfenjo budém eyéghfaf,
\q2 O Yuré téfene awamogh mbakw.
\q1 \v 12 Ménamén yaufiyamafé si fá norayat,
\q2 ménamén yaufi árké yém yéfene mbírmbíran
\q1 taumyo so tawerangé fá yéfenjo tuktukam,
\q2 yéfene mbawar, a yéfene unyégh.
\q1 \v 13 Tawiror fá fene nékwe
\q2 taséna ambino!
\q1 Féyo méinyotio mband marat so mat yém
\q2 ndené Ngánjánam yélimnde Israil.
\q1 \v 14 Tane mék téfnár eném sémbáran,
\q2 ndenanit wánangogh tékrat ághé
\q2 narotat endmé.
\q1 \v 15 Fá naronjat njamket
\q2 wénde kémégh kakmangi remngoghofnar.
\q1 \v 16 Wénde tayot, yénd so néngorayan fene waftamén.
\q2 Tándái akwan yéndo so yérametan áuwégh wagh ménamén fene kwénjtafnar uwéghmén.
\q1 Ménamén fém témorwén tane átnogh sifayé,
\q2 Wambégh sifayé táf yénd njam wém mwighé tékratan
\q1 \v 17 O tane muyé, kétán fefaf, yéndo warsagh wagh eufanan,
\q2 feyot, O Ngánján, ném tane átnogh sifayé,
\q2 yéné Ngánján emo wauyafote ta kwénjtafnar uwégh.
\c 60
\s
\q1 \v 1 Fémo té yénd yénkena, O Ngánján, a yiror téfene awamarogh.
\q2 Fém té nékwafé kéném téfefaf; sénonjo ténmango fene méndefaf.
\q1 \v 2 Fémo té tésambnete téfene yu a yéfaror násáfo
\q2 mer eyáto karéfkaréf, ménamén yu násambnete.
\q1 \v 3 Fém té kéném minde tikéf táikér téfefaf,
\q2 yinyáto tanetam wain yénmafaretam téfe awakayogh.
\q1 \v 4 Wénde fémo té yéramai sáláme faroghkaf yéfe emofem férférafé néfandat fém,
\q2 ndené so yéné yuyafotat ménamén efalo téfnan.
\q1 \v 5 Sénonjo ghérsé tawerto fenjo áuwéghafé ár.
\q2 Kénwango a ténmanjar ménaye fene waftaye.
\q1 \v 6 Ngánjánam té unyéghofnar norayai yénémamén ménaye yáne njúnnjúnofnare:
\q1 "Yéndo so téfalon Sekem
\q2 a tufon Sukot mband eworéghfaf.
\q1 \v 7 Giliad siyém tane,
\q2 a Manase, wéi.
\q1 Efraim, tane walaf, so efune tane ndimbal mék téfnár,
\q2 a Juda, tane wétu, so efune warsagh ár.
\q1 \v 8 Wénde Moab, tane umbaréghmén beisin, so kénamndangé tane ásáfogh ár,
\q2 a yéndon so tane kafkaf ewányányotan yáfaf Edim
\q2 a nutnan ndimbal kéráye yam wafroghét yéfeyot Filistain.
\q1 \v 9 Emo so kwénmanangé yénd kétán taikrataye ndimbal tesen kénjún.
\q2 Emo so yénérse ta sái taindangén Edom?
\q1 \v 10 Té fémo yénkenayénd, O Ngánján?
\q2 So fém yau kor folene eyota yémafé téfene fiyárafé?
\q1 \v 11 O, ghérghérsisé yénmáutána téfe yéfeta téfene mék téfnárafetat,
\q2 ménamén árfifi wáutárégh siyém fifiofnar.
\q1 \v 12 Ménaye Ngánjánene wáutárghan yéndfem so ewafrotam ndimbal yam,
\q2 ménamén yémo so etarne téfene mék téfnár.
\c 61
\s
\q1 \v 1 O Ngánján, náyáreta tane ye!
\q2 Náyáreta tane Ngánjánafé orayégh!
\q1 \v 2 Yénamé mband marat árkamé yiyáto,
\q2 yénd ye nendan fefaf ménát wáutárghét
\q2 njam tane tikéf kérté yam tétumndangé.
\q1 Wélimnda yénd kétán wambégh tawa wímfaf,
\q2 \v 3 ménamén fém ném tane wambégh átnogh sifayé,
\q2 wambégh méngo ánde tane mék téfnáram yau so kwéyanjangi.
\q1 \v 4 Kumyo yénd so wémor tuot fene wáwefnogh méngon,
\q2 merro fene njamb méngoméngo mbanmbanan!
\q1 \v 5 Ménamén fémo té náyára tane unyéghofnar si, O Ngánján.
\q2 Fémo té waram ta rokar yéfeyot árké em emofem férférafé yéfandat fene yétkwén.
\q1 \v 6 Tafai tárfáryo yúnjéf warsagh ároene ghérsat!
\q2 So yáne yúnjéf fénefénean em ár saté!
\q1 \v 7 So yáne limánégh yém Ngánjánene wambégh mbanmbanan tuot.
\q2 So fene kwénjtafnar uwégham a ndimbal mwighayam yéfandat fá.
\q1 \v 8 Féyo yéndo so warsagh wagh eufanan fene yétkwénan tuot
\q2 yéndo sái efalo eyátotan tane unyéghofnar so efogh fénefénero.
\c 62
\s
\q1 \v 1 Yénd nawanjetan wékeye Ngánjánene rére,
\q2 ménamén yá tambén yéné fiyéném yénd sái wém wainghéghan.
\q1 \v 2 Fáro fété yém tane wím a tane wanjarégh,
\q2 tane wambégh méngo ánde yénd yau so wésambnetat.
\q1 \v 3 Féyo tárfár mék téfnár yá ámbino ároe
\q2 méinyotioyam yéta ngiot wérametat yénd kérotio.
\q1 Yéfeyot yénd mé wirorégh mbakw wém
\q2 o fétrarégh arake.
\q1 \v 4 Yémofem mwighé yéfaronat ménát wémeindat sái téfrangon tane tuk sifayé.
\q2 Yémofem ndimbal méndefé yéfandat ménayan néngafrotat unyéghe tanemén.
\q1 Yémofem warsat sáfan
\q2 wénde wafalngotat yéfene tikéf kénjún.
\q1 \v 5 Tane ghérsé, nawanjete métar kénjún yáyot Ngánjáneyot,
\q2 ménamén tane kamnang siyém yá tambén.
\q1 \v 6 Fá fáyo siyém tane wím a tane wanjarégh,
\q2 Fá siyém tane átnogh, yénd yau so tasambnan.
\q1 \v 7 Tane waingégh a utmanégh siya yéném kétamé mé Ngánjáneta.
\q2 Fá siyém tane átnogh sifayé, a wím ánde yau mék téfnáram so kwéyanjangé.
\q1 \v 8 O tane ár, mwighafé yéfandati fá méinyotio efogh.
\q2 Yasuna fene tikéf yáfaf,
\q2 ménamén Ngánján siyém téfene átnogh sifayé.
\q1 \v 9 Yuwan ár sem ndenanit fifiofnar kar em
\q2 waftafé ár sem unyégh téfnár.
\q1 Njam etémndat fá nármbotat, fá em méinyotio fés tiarégh ár
\q2 wénde mindeyo yém ambone.
\q1 \v 10 Yau yéné ghérsé ámnjoghe némor sái wáfareghan rokar ersa
\q2 o kamnang ném orot.
\q1 A njam fene mani narmbota,
\q2 yau yiyátota namndeta néndkéf sifayé fene ghérsayan.
\q1 \v 11 Ngánján té norayai safénro,
\q2 a yénd té náyárayén tárfár mbinotmé:
\q1 Wafté, O Ngánján, yém fene.
\q2 \v 12 kwénjtafnar uwégh, o Yuré, siyém fene.
\q1 Fémo fai tawaram méinyotio árét
\q2 yénanyan némé ásáfogh yémofem ewafrotat.
\c 63
\s
\q1 \v 1 O Ngánján, fém tane Ngánján;
\q2 yéndo mindefifi néronjan fém.
\q1 Tane mbérmbére ghérsé nu sioghnit yém feyot;
\q2 tane méinyotio fifi naronje feyot
\q1 yéné ghérnát a yongnai mbandan
\q2 ánde yau yém nu.
\q1 \v 2 Yéndo té néminjoyén fém fene wáwefnogh méngo sifayan
\q2 a ghékéf ernayén fene waftafaf a minde kwayaghafaf.
\q1 \v 3 Fene kwénjtafnar uwégh siyém merfifi yém kétamé ghérsata;
\q2 ndernaye yéndon némarsan fém!
\q1 \v 4 Yéndo némarsan fém yéné teke yénd ghérsé swém,
\q2 euyotan tane ngángé Ngánjánafé oraighan.
\q1 \v 5 Fémo yénd wéremngote mindefifi yau kor wemar árfene téméndam.
\q2 Yéndo so némarsan fém áuwégh waghe.
\q1 \v 6 Yénd mé néretan kéméghan nemnan fenemén,
\q2 mwighaye néknan fém sémbáran.
\q1 \v 7 Ménamén fém ném tane wáutárégh ár,
\q2 a fene njamb njar mbanmbanan yéndo áuwéghét wagh yérametan.
\q1 \v 8 Tane mbérmbére ghérsé nawerete fefaf;
\q2 fene tambén ngángayam wamarote yénd.
\q1 \v 9 Wénde fá emofem kwankwane mwighé yéfaronat ménát sái wironat so eyota awasérmboghfaf.
\q2 Fá so néwonat mbandoene kénjkam kénjút.
\q1 \v 10 Fá so kér em witmafé sénté naifamén
\q2 a kénamndango njamke yéfene ághafene.
\q1 \v 11 Wénde warsagh ár so náuwete Ngánjánene kénjún.
\q2 Méinyotio emofem mwigháfé yéfandat so yarsat fá,
\q2 táf so unyégh téfnár em métar.
\c 64
\s
\q1 \v 1 O Ngánján, náyáreta kétán tane wátaranégh sifaf.
\q2 Yambeta tane ghérsé kétamé tane mék téfnárafene féghta.
\q1 \v 2 Kwétno yénd kétamé yéné mámáfi ár mérnafene kwankwane mwighé faroréghta,
\q2 kétamé yéné mor wafroghofnar mérénta.
\q1 \v 3 Yémofem esénat yéfene kanké ndenanit witmafé sénté naifé
\q2 a tawafarengi yéfene ghafté si ndenanit fimb.
\q1 \v 4 Yémofem enwafyatotat kétamé átnoghta mé téfnofnar ár.
\q2 Tawafngongi sunsune a férférafaro.
\q1 \v 5 Fá nawawéngsotat yéfenjo kénjún ménát yaufi wafroghét
\q2 a mwighé yáfaronat ndenáye so yéfene urér ekeindat kwankwane.
\q2 Fá so korayangi, "Efe so ámb mat yém?"
\q1 \v 6 Njam yémofem kwankwane mwighé yéfaronat yéfene kérté tiyárghét, fá korayangi,
\q2 "Yéndfem té tafrotam féwénféwénofnar mwighé farorégh!"
\q2 Néméwét, árfene tikéf a mwighé sem awarengéghafé em.
\q1 \v 7 Wénde Ngánjánam yémonro so ewafyatote yénjo fimb,
\q2 sélngwéle etarmeta.
\q1 \v 8 Yéfenjo kankayam so ewasérmbote
\q2 a méinyotio árém emofem efandat fá so esambnetat yéfenjo sénko si wafroghafé.
\q1 \v 9
\q2
\q2
\q1 \v 10 Ngánján ghersafé so yáuwetat Yurane kénjún
\q2 a tinjongi átnogh sifayé yáne kénjún.
\q1 A fá emofem ewafrotat némé em mbarkánd
\q2 so yarsat fá.
\c 65
\s
\q1 \v 1 Némé ndimbal warsagh yém, O Ngánján,
\q2 fene yém Jaion kénjún.
\q1 Yéndfem so téfenjo ufogh so efalo eyátotam,
\q2 \v 2 ménamén fémo téfene Ngánjánafé orayégh náyárete.
\q2 Méinyotio yénd so yéném fefaf.
\q1 \v 3 Ndemamén yénd téfene yaufiyamam yénmasérmbote,
\q2 fémo méinyotio engwawite.
\q1 \v 4 Nderé frengéghkaf yém fá efe fémo tékaf a enérsa kaka fefaf,
\q2 fá efe emor njúnnjúnofnar limánégh sifayan.
\q1 Némé téménd nawanjete téfe
\q2 fene njúnnjúnofnar wáwefnogh méngo kénjún.
\q1 \v 5 Fémo ndimbal mwighafé téfene Ngánjánafé orayégh náyárete mámé tikéf ménayafé,
\q2 O Ngánján téfene wanjarégh ár.
\q1 Fém ném méinytio árfene kamnang mband maratan
\q2 yémafayo efe nárayat nayu arakafamé.
\q1 \v 6 Fémo taminau mband tunakéf ménaye fene waftaye
\q2 a mék sáf yérse ménaye ndimbal muyaye.
\q1 \v 7 Fémo ekmbote nékwafé arakafamé
\q2 sof ménayafé yéfene ásméghafé
\q2 a métar engyátote ndimbal yu árfene ke.
\q1 \v 8 Fá efe emor yénamé mband marat kerkeramé
\q2 kokayongi fene sarimén tikéf ménayafé.
\q1 Kétamé árkamé efogh nénareinde kétán árkamé nirone,
\q2 fémo merkéráye yéfune áuwégh ke.
\q1 \v 9 Fémo ewarawene mband marat a nu,
\q2 eyátote yéné wemar a mulmulafé.
\q1 Ngánjánene wanje siyém tárfár nuafé;
\q2 yéné yam ewaramete tárfár nu yéné yam ewaramete tárfár waghuyu mbwe rokarat,
\q2 ménamén fémo ndenáye té ekmai.
\q1 \v 10 Fémo fuslat yiyátote tarégh wengogh mband ndimbale
\q2
\q1 Fémo tambamé mband sémkéf engéfrende,
\q2 fémo efrende yéfene anogh.
\q1 \v 11 Fémo tárfár waghu yue yamametam yúnjéf
\q2 ndemamén em táikér end féne nafune séfe.
\q1 \v 12 Yus sifayé fanfne yuwon kénamndangi fuslafé manjarégh wérárafene nénet
\q2 a mband tunakéf tambén ndrum nárametat áuwéghafé.
\q1 \v 13 Mbumbu ndau sifayé em wamanéghkaf tárfár sifafé,
\q2 a mband eworégh sem mbwe fiyangoghkaf.
\q2 Fá méinyotio kutnawét a áuwéghét wagh taufanawét!
\c 66
\s
\q1 \v 1 Nutnati áuwéghafé kétán Ngánjánefaf, méinyotio mband marat!
\q2 \v 2 Wagh yufanati ménamén ndimbal yétkwén kwayaghamén!
\q2 Néngafarotati mband maratan nderé minde kwayaghafé yém fá.
\q1 \v 3 Korayangi Ngánjánefaf, nderé tikéf anegghafé em fene wafroghyam!
\q2 Fene mék téfnár neye kakayongi fene ndimbal waftafaf.
\q1 \v 4 Méinyotio rokaram mbandan so némáwefnotat fé
\q2 yémofem so fene warsagh wagh eufanat
\q2 nutnat fene yétkwénan minde kwayaghé wagh raméghamé.
\q1 \v 5 Kénaflangi a téfandangi némé téfene Ngánjánam té tafrote,
\q2 némé tikefanefghafé ufrogh yamm yémo yafrote yéfe árét!
\q1 \v 6 Yémo yafrotam ghérnát endféne yénamé Férkat arakafan,
\q2 a yáne ár néférmayénd álighe witmé karfot.
\q2 Kété yénd káuwetawém yáne kénjún.
\q1 \v 7 Ménaye yáne ndimbal waftaye yémo yélimnde tuot.
\q2 Yémo efande méinyotio itérmboghyam ndimbal yauafené
\q2 Yau so táikér yam téfnár nawarmbotat fáyo.
\q1 \v 8 So méinyotio mband maratam yéfrendat téfene Ngánján
\q2 a marat kéme yáne warsagh wagh yufanat.
\q1 \v 9 Téfene ghérsé sem yáne ngángayan,
\q2 a yémo ewarawene téfene kafkaf kétamé unyéghta.
\q1 \v 10 Fémo té yénmufetam yénd, O Ngánján;
\q2 fémo té yénd kor ténmafenan ndenanit silfé.
\q1 \v 11 Fémo ténmeretau yénd ndenanit net
\q2 a yékmai kérté faiofnar ásáfoghyam téfene sémsotan.
\q1 \v 12 Féyo fémo yékmai téfene limánégh téfnár.
\q2 Yénd yényotam yénamé fés a nu kéfér,
\q2 wénde fémo yénd yénérsam yéné ngonjél sifayat.
\q1 \v 13 Sénonjo yénd wéném yénan fene wáwefnogh méngot ménayafé warogh ghéngénafé
\q2 ménát sai efalo táyáton tane unyéghofnar si yéndon árkéméné eyátoyén fefaf-
\q1 \v 14 néméwét, utmanéghafé unyéghofnar si yéné yéndo árkéméné yafrotamén
\q2 njam yénd kwémorwén kénjkam tékrat yaman.
\q1 \v 15 Yéné téfnan yéndo yérametan warogh ghéngén fefaf-
\q2 tane minde merfifi ghakér sif ndené fété mer wimafé wékwér,
\q2 a ghakér kauafene ghéngén a ghakér goutafene.
\q1 \v 16 Kénaflangi a káyárangi, méinyotio fém emofem férférafé yéfandati Ngánján,
\q2 a yéndo so tawaufron féfe némé yémo yafrotam tayot.
\q1 \v 17 Yénémamén yénd yefé nutnayén yáfaf ménát wáutárghét.
\q2 Tarwawén fá njamandio yénd korayawén.
\q1 \v 18 Njam yénd kawafenawén tane tikfan yaufiyammén,
\q2 Yuré yau so káyáretau.
\q1 \v 19 Wénde Ngánján té náyárai;
\q2 fá mé namyoi kétán tane Ngánjánafé orayéghfaf.
\q1 \v 20 So yuyotam Ngánján, emo yau yékena tane Ngánjánafé orayégh
\q2 o yango yánjo kwénjtafnar uwégh ta tambén.
\c 67
\s
\q1 \v 1 So Ngánján yém ghérghérsiafé a yénéfrenda yénd.
\q2 So yáne sáf nurte téfene méndefé.
\q1 \v 2 So fene end mat náyátotat yénamé mband maratamé,
\q2 fene wanjarégh wafté árfefafmé méinyotio sifayamé.
\q1 \v 3 So ndimbal yu árém néngmarsat fém, O Ngánján.
\q2 Néméwét so méinyotio ndimbal yu árém néngmarsat fém.
\q1 \v 4 Tumyo méinyotio mband marat so áuwéghét yufanat wagh,
\q2 ménamén fémo ewanjete ndimbal yu mbarkánde
\q2 a ewambete méinyotio mband maratamé ár.
\q1 \v 5 So ndimbal yuwam némarsat fém, O Ngánján.
\q2 Néméwét, so méinyotio ndimbal yuwam némarsat fém.
\q1 \v 6 Féyo mband maratam so yéfune yánjo waghu yu,
\q2 a Ngánján, téfene Ngánjánam so remngoghe yénefrende yénd.
\q1 \v 7 Néméwét, Ngánjánam so yénéfrende yénd,
\q2 a ár yénamé méinyotio yuwomé so férferafé yéfandat fá.
\c 68
\s
\q1 \v 1 Kokai, O Ngánján a tawiror fene mék téfnár.
\q2 Taunoyo fá emofem méndméndat yéfandat Ngánján kengongi yéfenjo ghérsat.
\q1 \v 2 Negwaufeta ndenanit kwam.
\q2 Ernda ndenanit njemar yénau yém fésén.
\q2 Taumyo yaufiyam téfnár so kér em Ngánjánene sáfrére.
\q1 \v 3 Wénde taumyo Ngánjánene ár so náuwetat.
\q2 Taumyo fá kliasafé so em Ngánjánene sáfan.
\q2 Taumyo fá so tawafongé fá áuwégham.
\q1 \v 4 Warsagh wagh yérametat Ngánjáne a yáne yétkwénot!
\q2 Warsagh wagh minde erametati yáyot emo ewawerete njafar kwamkwam.
\q1 Yáne yétkwén siyém Yuré-
\q2 náuwetati yáne sáfan!
\q1 \v 5 Afé yéfene afafnar, kwirafene wamarogh ár-
\q2 yéné féyém Ngánján, endene amnjogh yém njúnnjúnofnar.
\q1 \v 6 Yéndo téramangé yumén sái nufrotat mérén.
\q2 yémo tautorngé nák méngota kérté ár a tawaramangé áuwégh.
\q1 Wénde yémo ewafrote táikér ghérsafé ár sái emor efogh fálágh yuwon.
\q1 \v 7 O Ngánján, njam fémo elimai fene lar eytoryéng kétamé Ijif,
\q2 njam fém folene tayotau yénamé ménd yuwomé.
\q1 \v 8 Mband kásambnetau, a njafaram yénmasuryéng nu
\q2 fene sáfan, Sainaimén Ngánján,
\q2 Ngánjánene sáfrére, Israilafene Ngánján.
\q1 \v 9 Fémo enwafarete ndimbalero nu, O Ngánján,
\q2 ménát mer klisa sái tawaramangé térmbat mbandat.
\q1 \v 10 Kété fene ár ambino namnjoyénd,
\q2 a ménayafé tárfár wagh yu, O Ngánján,
\q2 fémo ewaramete fene árét yéfe efe ménde em.
\q1 \v 11 Yuram tawaramangé si
\q2 a ndimbal fiyaram yénérse mer si.
\q1 \v 12 Mék téfnár warsagh ár a yéfene fiyaré néngarnoyénd,
\q2 táf Israilmén amafam oroe kawaftawét yéné yumén rokar.
\q1 \v 13 Yémafayo efe tákmangérwén sif wanjengégh sifayamé tawinjotawét yéfene wafroghmén rokar
\q2 mamu silfamén njambafé
\q2 a síf golmén.
\q1 \v 14 Minde muyé kér ro árom euférmoi mék téfnár warsagh ár
\q2 ndenanit waufégh es kwam kété Jalmon mband tunakfan.
\q1 \v 15 Mband tunakéf Basanmén sem sariafé,
\q2 ménayafé tárfár tukta mind engém ndené njafarot.
\q1 \v 16 Némamén fém néretati ndené fém wéi ndenáyo em, O mbétérmbétérafé mband tunakéf,
\q2 kété mband tunakéf Jaion, ánde Ngánjánam té yaferyéng ménát ámnjoghét,
\q2 ánde Yuré fáyo so yémor tuot?
\q1 \v 17 Yarendat ménayam waftafnar tausen kariotam,
\q2 Yuré yénmormén kétamé mband tunakéf Jaionta kénjút kétán yánjo utmanégh sifayafaf.
\q1 \v 18 Njam fém nuyoi kétán tukét,
\q2 fémo elimai ár mérén efe tamorwén kwélalan.
\q1 Fémo ewinjoi ramégh árfeta,
\q2 yéfeta wéi emofem sém kémawengotawét fe.
\q2 Sénonjo Yuré Ngánján so yémor téfefaf kété.
\q1 \v 19 Yuyotam Yuré; yuyotam Ngánján téfene wanjarégh ár!
\q2 Ménamén efogh fénatayero yémo yénérse yénd yáne ngángaye.
\q1 \v 20 Téfene Ngánján siyém yéné Ngánján yém emo yénmanjane.
\q2 Warsagh ár Yuram téfene ghérsé yénmawarawene kétamé kérté.
\q1 \v 21 Wénde Ngánjánam so sénko efamngote yáne mék téfnárafene,
\q2 etyana sénko sot yéfene emofem euwetat yéfene kértafé yam.
\q1 \v 22 Yuré noraye, "Yéndo so tanwasron yéndfé mék téfnár kétamé Basan;
\q2 Yéndo so tanwasron kétamé arakaf kénjúta.
\q1 \v 23 Fém, tane árém so eumbénati féfene kafkaf yéfene férkan,
\q2 a so féfene ághayam tawanangi ámb yéfendio!
\q1 \v 24 Fene ásáfogh wimángégh té téném wayamngoghfaf, O Ngánján-
\q2 ásáfogh wayamngogh tane Ngánjánene a warsagh ár siya fá kuwanongé limánégh ámnjogh sifayé kénjút.
\q1 \v 25 Wagh ufarégh téfnár sem fronde sifayan, gita kembne ár sémta;
\q2 yéfene néndkfan aem totér amaf néngambnat tambarine.
\q1 \v 26 Yuyotati Ngánján, méinyotio fém Israilmén ár;
\q2 yuyotati Yuré, Israil árfene ghérsé téfén.
\q1 \v 27 Kéretangi, némbnar mérnam Benjaminene yélimndat end.
\q2 Féyo eném ndimbal ár mérén limánégh téfnár kétámamén Juda
\q2 a méinyotio limánégh téfnár Jebulunene a Naftali.
\q1 \v 28 Féfene Ngánjánam té ewafareta féfene muyé.
\q2 Kauyafo fémyo muyafé, O Ngánján, efe té kásáfote téfe téfnan.
\q1 \v 29 Ménamén fene wáwefnogh méngo
\q2 kété Jerusalemén warsagh árém so enérsat ramégh fefaf.
\q1 \v 30 Eusérmbotat yéné téfe mék téfnár ndimbal yu-
\q2 yéné kéghat wérár natnotat ndanan,
\q2 yéné síf ghakér kauafene kénjún em totér kau.
\q1 Eméindati fá so enérsat silfamén karéf métare féghét.
\q2 Yéngwafarna ndimbal yu emofem yayamnetat mék.
\q1 \v 31 Tumyo Ijif so eném mer frengégh ramégh tot téfénmén;
\q2 taumyo Etiofiamén budéme naramnjotat yáyot Ngánjáne.
\q1 \v 32 Wagh eufanati Ngánjáne, fém yéné mband maratmén limánégh téfnár.
\q2 Wagh erametati kétán Yurai.
\q1 \v 33 Wagh erametati kétán ámbiro ároe emo ewawerete fronde ufroghmén njafar,
\q2 yáne muyé kér ro kém toyanit násmetat kétamé njafarta.
\q1 \v 34 Ewaufrotati méinyotio árét ménamén Ngánjánene waftamén.
\q2 Yáne sariafé kwayaghé nálále kétán yéfefaf Israil;
\q2 yáne muyé siyém minde muyafé njafaran.
\q1 \v 35 Ngánján so férféafé yéfandam yáne utmanégh méngo sifayan.
\q2 Israil árfene Ngánjánam ewarametae wafté a muyé yáne árét.
\q1 Ngánján so yarsam!
\c 69
\s
\q1 \v 1 Kwanjar yénd, O Ngánján,
\q2 ménamén nu kéfér té náyátongi tane kémfaf.
\q1 \v 2 Kénjút a kénjtio yénd néngnyawetan ngwarngawaran;
\q2 yéndo yau tinjon kafkaf awerghét.
\q1 Yénd wém kénjkam nuan,
\q2 a nu kéféroene nuyé mindefifi yém tafaf.
\q1 \v 3 Yénd té wesyo yeyan wáutárghét yéta skemnan;
\q2 tane kém té yékai.
\q1 Tane ghékéf mbwe téfe ewarene yemén,
\q2 nawanjetau tane Ngánjánefaf ménát yénd sái wáutána.
\q1 \v 4 Fá emofem yénd tékrat wérametat téfnofnar
\q2 watofnar eyátota síf tane sénkoyan.
\q1 Tárfár tane sénanégh téfnáram yéta wiroréghét wérametat ménaye unyéghe,
\q2 nomnendat yénat yéndon sái tawaraman yéné yéndon árkéméné yau oroe enmanayén.
\q1 \v 5 O Ngánján, fém mat ném nderé mwighémwighafnar yénd wém;
\q2 tane yaufiyam yau so etno fe tambén.
\q1 \v 6 Yau eumyota fá emofem mwighafé néfandat sái em wáiwái tane téfnan,
\q2 O wafté kér ro njafar fiyarafene Yuré.
\q1 Yau wumyota yéndo sái ekmetan fá wáiwáiot,
\q2 O Israil árfene Ngánján.
\q1 \v 7 Ménamén yéndo ewamarotan sotafé si fene téfnan;
\q2 wáiwái siyém farokaf yém méinyotio tane sáfan.
\q1 \v 8 Ndenayo tane fútar aninjo nénuindat fá kar mat yau em tanemén;
\q2 yémofem yénd ndenanit wafrotat naimén kar wém.
\q1 \v 9 Minde ndimbal wáyárégham té wéfngo ménamén fene méngoyam té yénd wifo
\q2 a sotafé si yéfeta emofem sotafé si némndetat té náfayongi tafaf.
\q1 \v 10 Njam yénd ye kwawarametan a kawafarmetau njamkefnar,
\q2 fá kenagh si korayawét tafaf.
\q1 \v 11 Njam yénd nawotan sagh ménát sái yuyafotan ghérghérsisé,
\q2 yémofem fén wurtat.
\q1 \v 12 Yénd yéné féwén méndefé si sénko tesenan ende yawafrotat,
\q2 a méinyotio weri nu nénet téfnáram wagh warametat ta.
\q1 \v 13 Wénde yénd mé Ngánjánafé orayégh norayn fefaf, Yuré,
\q2 kamnang wém yéné efogh fémo so kwauyafo ta ménde.
\q1 Fene kwénjtafnar uwégh kénjún, O Ngánján,
\q2 kwawango tane Ngánjánafé orayéghmén ménaye fene féyotaro wanjaréghe.
\q1 \v 14 Kwurto kétamé ngwarngwarta;
\q2 yau wumyota sái néngnyawetan minde kénjút!
\q1 Kwanjar yéfeta emofem tékrate wéngrametat,
\q2 a kwénlimangi yénata kénjkam nu kés em.
\q1 \v 15 Yau eumyota nu kéfér minde muyafé yém tayot,
\q2 o kénjkam nu kés em kwelongi yénd,
\q2 o kér yékwam kwalindangé.
\q1 \v 16 Wawangota tane Ngánjánafé orayéghmén, O Yuré,
\q2 ménamén fene kwénjtafnar uwégh siyém merro.
\q1 Kora warawena yénd,
\q2 ménamén fene ghérghérsisé siyém tárfár.
\q1 \v 17 Yau natnota fene ásáfogh árfeta;
\q2 kwawango ta wékeye, ménamén yénd wém kénjkam tékrat yaman!
\q1 \v 18 Kénaf a ghérsé kwanjar;
\q2 yuwek kwiyato tane sénanégh árta.
\q1 \v 19 Fém mat ném tane wáiwái, féghmén, a mwighafnar wéfandat.
\q2 Fémo efande méinyotio ndené tane sénanégh árém kés ewafrotat.
\q1 \v 20 Yéfene téfnam té tane tikéf térafne,
\q2 a yénd wém awasnengéghan.
\q1 Táf njam ámbiro árom té tuyafongé ámb ghérghérsisé;
\q2 táf ámbiro ár njam té kénawengongé ta wamaroghét.
\q1 \v 21 Wénde ndené, yémofem waramangi ghafté rokar njamket;
\q2 yémofem waramangi njérmat wain tane kém ufoghét.
\q1 \v 22 Taumyo rokar tárfárafé seko efrenda yéferére kénamndangi ndéndén
\q2 a yéfene awaingégh yam kénamndangi urér.
\q1 \v 23 Taumyo yéfene ghékéf so ngamndagni kwéfkwéf ménát yau so néretat,
\q2 a ewafrota yéfene fifi so mé néngasambnetat.
\q1 \v 24 Tasur fene kwérnár kétán yéfefaf
\q2 tawifo fá fene wakrarégh nékwe.
\q1 \v 25 Taumyo yéfene méngotu so kénamndangi sotro
\q2 a yéfene farai méngo em wáutáréghofnar.
\q1 \v 26 Yáfaf fémo efe tékratan yékmai, yémofem farun téfayongi si wánangogh ménát tékrat raméghét;
\q2 yémofem farun téfayongi yéfene tékratfaf efe fémo té tékratan ekmai.
\q1 \v 27 Ewawarmbota yéfene yaufiyam tukét.
\q2 a yau eumyota engém yuweke.
\q1 \v 28 Tawawalinda yéfene yétkwén kétamé ghérsé bukta;
\q2 yau eumyota siya ewafta mbarkánd árfene kénjún.
\q1 \v 29 Yénd nawambetan tékratan.
\q2 Ghérsé kwanjar, O Ngánján, ménaye fene wanjarégh waftaye.
\q1 \v 30 Féyo yéndo so yuyotan Ngánjánene yétkwén ménaye wagh raméghe,
\q2 a yéndo so utémndan fá ménaye kánjo raméghe.
\q1 \v 31 Ménamén yénayan so yém Yuré minde klisafé yau kau ghéngén
\q2 yau ndimbal kau sái téramangi tártárafé a ngángé sotafé.
\q1 \v 32 Yuwan árém so yéfandat yéfene Ngánján ásáfoghan a náuwetat.
\q2 Eumyota méinyotio fá emofem yéronjat Ngánjánene wáutárégh so ewawéngsotat.
\q1 \v 33 Ménamén Yuram náyárete ye áronjagh árfené
\q2 yémo yau tékrate eramete yáne ár nák méngo kénjún.
\q1 \v 34 Yarsati fá, O njafar a mband,
\q2 arakaf a méinyotio némé nimndat yéné kénjúmé.
\q1 \v 35 Ménamén Ngánjánam so tanjarngé Jerusalem
\q2 a kor wéi engrameta tesen Judan.
\q1 Yáne ár so emor kété
\q2 a so mer kéráye kamnjongi yéfenjo mbandan.
\q1 \v 36 Yéfene yéfeki ambum emofem yiyáretat fá so tanangi mband,
\q2 a fá emofem yuwetat fá so emor kété merro.
\c 70
\s
\q1 \v 1 Ghérghérsisé Ngánján, kwanjar yénd!
\q2 Kénaf wékeye, Yuré, a wáutána ta.
\q1 \v 2 Wáiwáiot fá so ekmete
\q2 yuwot emofem yéta kér ngiot wérametat
\q1 So fá em emofem yérsat klisa tane tékrat yam kénjún
\q2 so soramé kawinjongi áuwéghofnar.
\q1 \v 3 Taumyo fá so mámáfi ewafrote yéfene wáiwáiam,
\q2 ménamén fá norayayénd, "Aa! Yéndfem té yérangém sénonjo!"
\q1 \v 4 Wénde tárfár árém emofem néronjat fém
\q2 so ewafote áuwégham a klisayam fene kénjún.
\q1 So fá emofem yuwetat fene wanjarégh
\q2 féréghe nutnat, "Ngánján siyém ndimbal!"
\q1 \v 5 Wénde tayot, yénd wém yau yam a áronjagh ár;
\q2 ghérghérsisé wékeye kufrota ta wáutárghét, O Ngánján.
\q1 Fém ném tane wáutárégh ár a tane wanjarégh ár;
\q2 O Yuré, yau nawaneta.
\c 71
\s
\q1 \v 1 O Yuré, yénd té nénaflan fefaf ménát waraweréghét;
\q2 yau wumyota sái wém áuwéghofnar.
\q1 \v 2 Kwanjar a kwamba,
\q2 ménamén fémo ewafrote némé yém mbarkánd.
\q1 Tanwengo fene téngan ménát sái náyáreta yénan tafaf,
\q2 a kwiyáto yénd yuwek.
\q1 \v 3 So ném tane wambégh wém
\q2 ánde yénd túmén so nátnotan.
\q1 Tawaram wafarégh si ménát so yénd kwanjarngi,
\q2 ménamén fém ném tane wém a tane wambégh méngo.
\q1 \v 4 Tane Ngánján, kwanjar kétamé yaufi árfene waftata,
\q2 kétamé máméghéraye fegh árfene taikrataye weréghta.
\q1 \v 5 O Yuré, fémro ném tane kamnang.
\q2 Yéndo mwighafé néfandan fém, O Yuré, kétamé ambum tosé.
\q1 \v 6 Néméwét, fémafé yénd té ténérwén kétámayo náraftamén;
\q2 tane amane fút kénjúta fémo té kwarawenau yénd.
\q2 Yénémamén yéndo túmén némarsan fém!
\q1 \v 7 Tane ghérsé siyém tárfár árét yém ufénmanéghét,
\q2 ménaném fém té kénmorwén tane muyé a wambégh ár.
\q1 \v 8 Yéné téfnan yénd yau so kékmbon fe warsaghan;
\q2 Yéndo efalo yiyátotan fene minde kwayaghé méinyotio efogh tombé.
\q1 \v 9 A sénonjo, tane buluan, yau téndot kwékém.
\q2 Yau kwéfrango njam tane muyé uyégh kufngongé.
\q1 \v 10 Ménamén tane sénanégh téfnár nawawanjat tanemén.
\q2 Fá mérne kwankwane mwighé wafroghan em ménát sái wésmetat yénd kérotio.
\q1 \v 11 Fá norayat, "Ngánjánam té yéfrangoi fá.
\q2 So kuwanongém a ténmerangém fá,
\q2 ménamén árké árom yau so yáutáne fé sénonjo."
\q1 \v 12 O Ngánján, yau nayu ném.
\q2 Tane Ngánján, O mbané, wékeye kufrota ta wáutárghét.
\q1 \v 13 Yénérsa áuwéghofnar yam a kérté yam yéfefaf ta mérorégh téfnárafefaf.
\q2 Yuwot ekmeta a wáiwáiot fá efe ménde em ta wághanéghét.
\q1 \v 14 Wénde yénd mé so kamnang wém fene wáutárghét;
\q2 yéndo fém so némarsan minde a mindefifi.
\q1 \v 15 Yéndo so engwaufrotan méinyotio árét ménamén fene mbarkánd yammén.
\q2 Méinyotio efogh tombé yéndo so néngafrotan fene wanjarégh waftamén,
\q2 ndemamén yénd yau kor sian wém mer.
\q1 \v 16 Yéndo so ewarsan fene ndimbal muyamén wafroghmén, O Wafté kér ro Yuré.
\q2 Yéndo so méinyotio árét engwaufrotan ndené mé fémo ném mbarkánd.
\q1 \v 17 O Ngánján, fémo té watametam yénd kété tane totér ambum tosayan,
\q2 a yéndo túmén ewaufrotan ámb árét ménamén sariafé yam fémo sewafrote.
\q1 \v 18 Sénonjo ndené yénd wém bulu a kérufafé,
\q2 yau táf kwéfrango yénd, O Ngánján.
\q1 Kwumyo yénd so néngafrotan fene waftamén yéné ár satafaf sem,
\q2 fene ndimbal ufrogh yammén yéfeyot méinyotio efe so eném ta soramé.
\q1 \v 19 Fene mbarkánd yamam, O Ngánján, eyanje njafar tuk.
\q2 Fémo té tawafrote ndené mer sariafé yam.
\q2 Emafé so etémwam fémafé, O Ngánján?
\q1 \v 20 Fémo té wumyote yénd ménát táikér yam kénjún sái nawambetan,
\q2 wénde fémo so wéi kwénmango ghérsat wéikor
\q2 a kwénmuyo tukét kétamé mband kénjúta.
\q1 \v 21 Fémo so yénd kwénmango ghérsat kétán ndimbal utmanégh yamfaf
\q2 a kwamarota ámbinotmaro wéikor.
\q1 \v 22 Féyo yéndo so némuyotan fém ménaye af kembneye,
\q2 ménamén fém ndimbal mwighafé ném kétán fene unyéghofnar sifaf, O tane Ngánján.
\q1 Yéndo so warsagh wagh yérametan fefaf ménaye laire,
\q2 O Njúnnjúnofnar Israilmén.
\q1 \v 23 Yénd so nutnan áuwéghét a eufanan fene warsagh wagh,
\q2 ménamén fémo té fai wafrotam yénd.
\q1 \v 24 Yénd so néngafrotan ménamén fene mbarkánd yammén
\q2 méinyotio efogh,
\q1 ménamén méinyotio árém emofem yáta wasérmboghét wérametat
\q2 em yuwan a wáiwái
\c 72
\s
\q1 \v 1 Taram fene uwéghafé mbarkánd yam yá warsagh ároe, O Ngánján,
\q2 a mbarkánd yá warsagh ároene ambumoe.
\q1 \v 2 Yáutána fá moghan ekmeta fene ár mbarkánd endmé;
\q2 éumyota yauyau ár túmén táf ámbrérero ewásáfotat.
\q1 \v 3 Taumyo so mband tunakfam yénérsat krufrat yam kétán árét,
\q2 a mband sémkéf eworégham mbarkánd yam.
\q1 \v 4 Yáutána yá ménát so ewamarote yauyau ár,
\q2 ménát so ghérsé ewanjane áronjagh ambumtértér,
\q2 a so engwasérmbote yéfe wasérmbogh téfnár.
\q1 \v 5 So fá férfér em fefaf yéné teke efogh kés nánete,
\q2 yéné teke ghérare mé kés yém njafaran.
\q2 Néméwét, tuot!
\q1 \v 6 So warsagh árfene limánégh yém sariafé ndenanit afamégh nu yénau yém kété totér yus néféghfaf,
\q2 ndenanit nu saiam yénau nue yéfamnde mband marat.
\q1 \v 7 So méinyotio ngánján ghérsafé ár marat náyárotat yáne limánégh kénjún.
\q2 So kété yém ndimbale nawaindat kétánotio ghérare yau so yém.
\q1 \v 8 Yáne limánégh so yém kétamé arakafta kétán ámb arakaf,
\q2 a kétamé Eufrat wanjeta kétán mband kerkerfaf.
\q1 \v 9 Tawafarna ofnengégh árém so wáwefnogh yafrotat yáneréré
\q2 yáne mék téfnár so nuitat yáne sáfan ngwérméngan.
\q1 \v 10 Mbormborta Tarsismén warsagh árém a ámb nayu yumén kés em
\q2 so yénmarsat yá féghét.
\q1 Wér ta Shebamén warsagh árém a Sebam
\q2 so yénmarsat ramégh.
\q1 \v 11 Méinyotio warsagh árém so yáwefnotat yá,
\q2 a méinyotio ndimbal yu so néngásáfotat yáyot.
\q1 \v 12 Yémo so tawanjarngé yauyau ár njam fá yefé nutnat yáfaf;
\q2 yémo so ewáutáne fá efe mwighayan etumndat, endefene yau yém yéfé wamarogh ár.
\q1 \v 13 Fá táf ghérghérsisé yém yéfefaf efe em mwighayan ongén a omnengégh ár,
\q2 a yémo so tawanjarngé fá.
\q1 \v 14 Yémo so ghérsé tawértongé fá kétamé mwighayam kés etumnde a kérté yam,
\q2 ménamén yéfene ghérsé sem minde mer yáfaf.
\q1 \v 15 Tombé ghérsé ámnjogh warsagh ár!
\q2 So Shebamén gol taraman yáyot
\q1 So túmén ár Ngánjánafé orayégh norayat yáyot
\q2 a yéfrendat méinyotio efogh tombé.
\q1 \v 16 So kété em tárfár mbwe rokar yénamé mbandamé,
\q2 marat néngayatotat wéi yénamé eworégh mband tunakfamé.
\q1 So wén mbwe marat néngayatotat ndenanit Levanonmén wén kés em,
\q2 a so árém yéngwayamnetat ndenanit yus kés em ndau sifayan.
\q1 \v 17 So warsagh ároene yétkwén nakete tuot;
\q2 so mé yéngém ndené teke efogh ndernaye nanete.
\q1 So méinyotio ndimbal yu em frengéghan yáne kénjún
\q2 a yénmarsat warsagh yáyot.
\q1 \v 18 Yarsam Yuré Ngánján, Israilmén Ngánján,
\q2 emonro ewafrote yéné sariafé yam.
\q1 \v 19 Yarsati yáne ndimbal kwayaghé yétkwén tuot!
\q2 So méinyotio mband kafongé ménayam yáne minde kwayaghayan.
\q1 Efalo a efalo!
\q1 \v 20 Yénayam yénérse yáne Ngánjánafé orayégh wifoghfaf Jesene ambum Deifid.
\c 73
\s
\q1 \v 1 Efalofifi Ngánján siyém mer yéfefaf Israil,
\q2 kétán yéfefaf endefene tikéf em njúnnjúnofnar.
\q1 \v 2 Wénde tayot yéndo téfe yétarnamén tane kafkaf áligh.
\q2 Tane kafkaf keunotawét, a yénd mé fétfétanro álighét kwérmorwén.
\q1 \v 3 Ménamén yénd wéi ndenáyo mwighafé kwém yéfenemén emofem ámb ár efandat ndené fá kár merfifi em yéfeta
\q2 njam yéndo yinjoyén yaufiyam árfene awaingégh yam.
\q1 \v 4 Fá ndenanit em tékratofnar ghérsé kár emor;
\q2 yéfene fifi sem mulmulafé a muyaro.
\q1 \v 5 Yéfefaf yau em kérté ndené ámb árfefaf kés em;
\q2 fá yau kérté yamam erse ndené méinyotio ár kés em.
\q1 \v 6 Fá ewawo tuktuk ghérsé yam ndenanit Jewelmén kém waméghmén ndindi
\q2 a numanetat ménaye njérmat ghérsaye.
\q1 \v 7 Yéné ndurémndurémafé fusafene ewam méienyotio rokar
\q2 yéfene tikéf kétán nareinde!
\q1 \v 8 Yémofem si ngiye esmetat a norayat yaufi kéráyero;
\q2 yéfene awarmbogh ghérsé kénjún fá ménde em ménát sái ewaghnat ámb ár.
\q1 \v 9 Fá nawarsat nasmetat yémafé njafar kés em,
\q2 a yéfene si tuktuk yém yénamé méinyotio mband marat.
\q1 \v 10 A ár sem wáiwái a mwighé éuwérsoghan,
\q2 nunit enetat yéfenjo si.
\q1 \v 11 Fá kamotangi, "Ngánján némé mat yém?
\q2 Némé minde tukén ár té mat yém némé natyane?"
\q1 \v 12 Tafanda yéné yaufi ghérsafé ár-
\q2 yayamnetat afráte ghérsé njamandio yéfene rokare awayogh narmbote.
\q1 \v 13 Té yéndo tiyátotan féwénféwénofnar a fifiofnar tane tikéf?
\q2
\q1 \v 14 Yéndo némé yau tinjotan wénde mé tékrat yamro méinyotio efogh;
\q2 ákw tárfáram enérsat ta tékratro.
\q1 \v 15 Njam yénd té efaloe korayan yéné ende kétán ámb árfefaf,
\q2 yénd so táf kawarendawén fene árfe sénot.
\q1 \v 16 Féyo yéndo yéta mwighé taronjawén némémén yaufiyam ár narmbotat.
\q2 Wénde némé taikrafé yam yéné yém.
\q1 \v 17 Féyo wéngmormén kénjút fene wáwefnogh utmanégh sifayat, O Ngánján,
\q2 a yéndo ambino mat náyátoyénd yaufiyam árfene end.
\q1 \v 18 Efalofifi, fémo ekmete fá kété wénwat sifayan
\q2 a engwatembete néngeunotat yékwamé kétán tékratfaf.
\q1 \v 19 Mé tekofnar fá ewasérmbote,
\q2 ambino tasamburngé férféram.
\q1 \v 20 Njam fém kokai, O Yuré,
\q2 fémo so ewawérte yéfene awasnéngégh mwighé
\q2 ndené ár yénau nurte akwan onjomén.
\q1 \v 21 Féyo yénd mat namndayén ndené tane tikéf stémorwén ghafta,
\q2 a yénd méinyotio wironam kénjún.
\q1 \v 22 Yénd wémormén mwighan ongén a áyáréghofnar-
\q2 yénd mété táf kwemorwén ndenanit mwighémwighafnar wérár fefaf.
\q1 \v 23 Wénde yénd mé fene wém;
\q2 fémo yérete tane tambén ngángé.
\q1 \v 24 Fémo wambete yénd fene awafenagh yame
\q2 wélimnde yénd kétán minde kwayaghé álighfaf.
\q1 \v 25 Efe ámb yém tane kété njafaran wénde fém?
\q2 Yéndo minde tikéfafé néfandan fém yau kor mbandmén rokar.
\q1 \v 26 Tane mer afrengéghmén ámnjogh téu kuyangé, a tane mbérmbér káyátongé muyafnar,
\q2 wénde Ngánján mé kété yém tane tikéfoene muyé;
\q2 fá siyém tane tuot.
\q1 \v 27 Yéné ár emofem yéfrangotat fá so kér em,
\q2 ménamén fémo tawalinde fá emofem kénéfrangongi fém.
\q1 \v 28 Wénde tayot, nderé mer yém sái wém kaka Ngánjánefaf!
\q2 Yéndo té yiyáton wafté kér ro Yuré tane enagh kitaré,
\q2 a yéndo so engwaufrotan méinyotio árét ménamén sariafé yam fémo árké ewafrote.
\c 74
\s
\q1 \v 1 O Ngánján, némamén fémo yénd yénkena ndenayu?
\q2 Némamén fene nékw minde ndimbal yém yéfeta fenjo sifafene yus néne sifayata?
\q1 \v 2 Nawafarota ndené yénd yéné ár fiyéném fémo efe ewaferyéng tándái,
\q2 yéné ár téfén fémo endefet ewaramai mer mwighé ndené fété fene fénaté ásáfogh sifayé!
\q2 A yafarota Jerusalem, fene méngotu yéna mbandan.
\q1 \v 3 Álighe niyotat yénamé ndimbal tesenan máméghéraye wasérmbogh sifayamé;
\q2 téfanda ndernaye mék téfnáram té téngwasérmbotat fene utmanégh wáwefnogh sifayé.
\q1 \v 4 Kété fene mék téfnár mékan awaingéghmén kutnawét;
\q2 kété yémofem yéfrendaménd yéfene ásméghét yam.
\q1 \v 5 Yémofem kafnendawét mbilé
\q2 ndenanit fés ténj néféghmén yénau em wénaron.
\q1 \v 6 Ménaye mbié a fik
\q2 yémofem táfamnotawét fénaté sáfot wafroghmén rokar kés tamorwén.
\q1 \v 7 Yémofem yuwaroyénd fene utmanégh wáwefnogh méngo sifayé kétánotio mband.
\q2 Yémofem taghnaghét yéné sifayé ánde yétkwén témndetawét.
\q1 \v 8 Féyo fá némnayénd, "So yironam méinyotio rokar!"
\q2 Féyo yémofem yuwarotaménd méinyotio sifayé ánde Ngánjáne táwefnotawét.
\q1 \v 9 Yéndfem sénonjo yau efandam fene sélngwéle ufarogh yam.
\q2 Méinyotio Ngánjánene mat yátogh ár té nefongi,
\q2 a árké árom so ténmaufrongé ánde yéné so yiyato.
\q1 \v 10 Nderé teke, O Ngánján, so fémo eumyote fene mék téfnár ménát sái sotafé si yénémndetat yénd?
\q2 So fémo eumyote fá fene yétkwén yau siya utémndat tuot?
\q1 \v 11 Némamén fémo ewango fene muyé kér ro tambén ngángé?
\q2 Sunsun tawaram fene wafté kér ro faise a tawiror fá.
\q1 \v 12 Fém, O Ngánján, ném tane warsagh ár kétámayo yúnjéf kés nénawaindat,
\q2 yénérse wanjarégh yénau mbandot.
\q1 \v 13 Fémo tafaror arakaf ménaye fene muyaye
\q2 a etyane arakaf ngánjánngánjánafene sénko.
\q1 \v 14 Fémo yáne sénko yétyane ndimbal rokaroene
\q2 a téimiyo ghérnát fanfne yu wéráram yénetat fá.
\q1 \v 15 Fémo yénfune nu a wérér nu sái nénefnota,
\q2 a fémo ghérnát eyátote wanje árkéméné yau ghérnatam ewafrote.
\q1 \v 16 Yéné sómbio efogh a sémbár ere fené
\q2 fémo ewafrotam kénd kwayaghé a efogh.
\q1 \v 17 Fémo ekmetam mbandamé fu
\q2 a fémo ewafroméng efoghyu a yúnjéf.
\q1 \v 18 Tafanda ndernaye yéné mék téfnáram némasalotat fém, Yuré.
\q2 Awasnengégh ndimbal yu kés em yau yutémndat fene yétkwén.
\q1 \v 19 Yau eumyota yéné kéghat ngasia ewironat fene fisor mamu.
\q2 Yau mwighafnar tawai fene ár efe nawambetat tuot.
\q1 \v 20 Ewafarota fene unyéghofnar árnéghmén si,
\q2 ménamén yu siyém kwéfntayam té nofai a kértafé yamam!
\q1 \v 21 Yau eumyota fá efe máméghéraye ekarotat wéi nénangotat utmanéghofnar.
\q2 Taumoyo fá efe kérté yam etumnde a áronjagh ár em so yarsat fene yétkwén.
\q1 \v 22 Kokai, O Ngánján, a tamarota fene end.
\q2 Nawafarota ndernaye yéné awasnengégh árém némasalitat túmén efogh tombé.
\q1 \v 23 Yau kétán néreta némé fene mék téfnár té norayat
\q2 o yéfene tukén kém narmbote.
\c 75
\s
\q1 \v 1 Yéndfem kánjo némarametam fe, O Ngánján!
\q2 Yéndfem kánjo némarametam fe ménamén fém ném kaka.
\q2 Ár méinyotio yuwomé néngafrotat ménamén fene saiafé yammén.
\q1 \v 2 Ngánján noraye, "Kété yéné efghon yéndo té mwighé yáfaronamén,
\q2 yéndo so yénérsan mbarkánd yam yéfe yaufiyam árfet.
\q1 \v 3 Njam sokrere a yénayoene ár emor mwighé éwérsoghan,
\q2 yénd yéné fwém emo yerete yénayoene téfén taikrataye.
\q1 \v 4 Yéndo ewawengotan tuktuk ár, 'Tékmbongi féfene awarmbogh yam!'
\q2 Yéndo emndayén yaufiyam téfnár, 'Yau euyotati féfene fais!'
\q1 \v 5 Yau euyotati féfene áyáréghofnar fais kétán njafar kés em
\q2 o norayati awarmbogh si!
\q1 \v 6 Efe ámb yau mbandan- kétamé wérta o mbormborta,
\q2 o téu kétamé fanfne yuta-
\q2 euyotat marataye awarmbogh fais.
\q1 \v 7 Ngánjánro yém emo moghan ekmeté
\q2 yémo mwighé yéfarone efe so kokayongi a efe so kuyangi.
\q1 \v 8 Ménamén Yuram yerete kafusi yánjo ngángaye
\q2 árké yém mbérorkamafé wain mer wimafé wékwér wanjmeghkaf.
\q1 Yémo yasune wain moghan
\q2 a méinyotio yaufiyam téfnáram so yénetat,
\q2 kor sotro yiyátotat kétán njérfaf.
\q1 \v 9 Wénde tayot, yénd so túmén néngafrotan némé Ngánjánam té tafroté
\q2 yénd so warsagh wagh yérametan kétán Jeikofene Ngánjánefaf.
\q1 \v 10 Ménamén Ngánján noraye, "Yéndo so yéngrafnan yaufiyam árfene muyé,
\q2 wénde yéndo so yarmbotat ngánján ghérsafé árfene wafté."
\c 76
\s
\q1 \v 1 Ngánján siyém yutémndat kété Juda;
\q2 yáne yétkwén siyém ndimbal kété Israil.
\q1 \v 2 Jerusalem siyém ánde fá yémor;
\q2 Mband tunakéf Jaion siyém yáne méngotu.
\q1 \v 3 Kété yémo té térafnau fésafé fimb mék téfnárafene,
\q2 fimb awamogh mbakw a witmafé sénté naifé a mék rokar.
\q1 \v 4 Fém ném minde kwayagharo a minde saiafé
\q2 yau akegh mband tunakéf.
\q1 \v 5 marataye mék téfnáram té kwérnáre rokar tarsat
\q2 Yémofem téfe ténmawindat kémégh kéran.
\q2 Yau ámb mék téfnáram yuyo ngángé téfefaf.
\q1 \v 6 Kétamé fene ambone kés yéngwaufete, O Jeikofene Ngánján,
\q2 yéfene kariot a os mé ekém.
\q1 \v 7 Éwérsoghofnar fém sném ndimbal kéráye férférafé néfandat!
\q2 Efe so kokayongé ferére njam fene nékw kéfnongé?
\q1 \v 8 Kétamé njafarta fémo ambino engwatembete fene mék téfnár;
\q2 mband násambnetam a nokayoi métar fenerére.
\q1 \v 9 Fém kokai ménát moghan sái takém fá emofem ewafrotat yaufi, O Ngánján,
\q2 a sái tawanjar fá efe ekarotat mbandan.
\q1 \v 10 Ároene sáfén áyáréghofnar ghérsayan yénérse fene minde kwayaghé,
\q2 ménamén fémo yéné so yerete ndenanit ásmégh rokar.
\q1 \v 11 Efalo si ewafrotati Yurafefaf féfene Ngánjánefaf, a ewarawenati.
\q2 So eumyota méinyotio ár so enérsat féghet kétán férférafé ámbiro ároefaf.
\q1 \v 12 Ménamén yémo erafne tuk árfene tuktuk yam,
\q2 a mbandmén warsagh árém férférafé yéfandat fá.
\c 77
\s
\q1 \v 1 Yénd yefé kutnawén kétán Ngánjánefaf; néméwét, yénd nutnayén.
\q2 O yéné Ngánjánam so kwiyarangé yénd.
\q1 \v 2 Njam yénd kwémorwén kénjkam kértayan,
\q2 yéndo ronjargh yáfngoyén Yuré.
\q1 Méinyotio sémbár tombé yénd Ngánjánefaf korayawén, ménayafé ngángé uyoghafé ndené njafarot,
\q2 wénde tane mbérmbér yau wamaroghan témorwén.
\q1 \v 3 Yéndo tafarotawén Ngánján, a yénd ye mikeghéro kendawén
\q2 minde muyafé yéta ménde kwémorwén yémo ta fiya kwáutárnangé.
\q1 \v 4 Yau fémo wumyota kémégh sái kakman.
\q2 Yénd wétumnde mwighayam ménát sái Ngánjánafé norayan.
\q1 \v 5 Yénd nemnan tándáwár mer efogh táwár,
\q2 tombéyu kétánotio ánde so kefongá.
\q1 \v 6 Njam tane sémbár tawafotau áuwégh wagham.
\q2 Yéndo téronjawén tane mbérmbér a mwighayan yéknangén fénataye sénjonjon.
\q1 \v 7 Njam Yuram kwékenangi yénd tuot?
\q2 Wét so fá wéikor warsagh ár yém tayot?
\q1 \v 8 Té yáne kwénjtafnar uwégh nitér tuot?
\q2 Té yáne unyéghofnar si ambino nuya?
\q1 \v 9 Té Ngánján yawalinda sái yém ngárámafé?
\q2 Té yémo yémna fasa yáne ghérghérsisé?
\q1 \v 10 A yénd norayayén, "Yéné siyém tane mámáfi;
\q2 minde tukén árom té engwitremb yánjo ngángé tatambén.
\q1 \v 11 Wénde yéndo wéi mwighaye tawafarotan méinyotio fémo némé tanwafrotau, O Yuré;
\q2 yéndo ewafarotan fene sariafé yam wafrogh tándái stanwafrotau.
\q1 \v 12 Yéna em túmén tane mwighayan.
\q2 Yénd yau so kwalindangé sái nawafarotan fene wafta kér ro ásáfoghmén.
\q1 \v 13 O Ngánján, fene end sem njúnnjúnofnar.
\q2 Té yém ámb Ngánján ndené waftafé fém séném?
\q1 \v 14 Fém yéné Ngánján fném ndimbal sélngwél yamafé!
\q2 Fémo yuyafote fene férférafé wafté yénamé ndimbal yu sifayamé.
\q1 \v 15 Fene muyé kér ro ténde, fémo ghérsé ewanjaryéng fene ár,
\q2 Jeikofene ákiambum a Josefene.
\q1 \v 16 Njam férkat arakafam némnjoi fém, O Ngánján,
\q2 yáne ámb nu stamorwén ngerngerafé kéretawét!
\q2 Arakaf sokreream tésambetau kétánotio yénayoene kénjú.
\q1 \v 17 Nu kwéfta nu kénafamndau;
\q2 arurke kásmetawét njafaran.
\q2 Fene fimb toyé karemngongayénd.
\q1 \v 18 Fene toya nénnaroghat kétamé mbormbor téfitéfiafé;
\q2 toyayam tértremngongai mband marat!
\q2 Mband ngerngeram térametau a kasambnetau.
\q1 \v 19 Fene endam elimai arakaf kénjúmé,
\q2 fene end féne yénamé ndimbal muyafé nuamé-
\q2 end féne efe ámb yau mat témorwén yéné kété témorwén!
\q1 \v 20 Fémo elimai fene ár yéné endmé ndenanit sif mérén,
\q2 yémafé Moses a Aron tarwén yéfene limánégh ár.
\c 78
\s
\q1 \v 1 O tane ár, náyáretati tane si.
\q2 Tasawérngi féfenjo téngan yénan némé yénd norayan,
\q1 \v 2 ménamén yéndo so fém emndetau rengerengeye.
\q2 Yéndo so ewatametan fém ténoghmén natyam kétamé téfene fronde tándáwár.
\q1 \v 3 Si yénd té káyáretam a mat náyátongém,
\q2 si téfene ákifam árkéméné yénmafamayénd yénan téfefaf.
\q1 \v 4 Yéndfem yau so etnotam yéné efalomén kétamé téfene ambumta;
\q2 yéndfem so ewafrota yénamayo ár satat
\q1 ménamé Yurane minde kwayaghé kér ro yam wafroghmén
\q2 ménamén yáne wafté kér ro sélngwélafé yam.
\q1 \v 5 Ménamén yémo yaramai yánjo nák Jeikofé
\q2 yémo ewaramai yánjo si matot yéfe Israil árét.
\q1 Yémo ewafaretai téfene ákif
\q2 ménát so ewatametat yéné yéfene ambumat.
\q1 \v 6 Ménát yénamayo ár saté so mat em-
\q2 yénémamén yémafayo efe ambum mé em araféghofnar-
\q2 a fá so kokayongi so ewatametat yéfenjo ambum.
\q1 \v 7 Féyo fénaté ár satayam fiya tákmangi yéfenjo kamnang káyátongi totér Ngánjáneyot,
\q2 yau mwighafnar ewitat yáne minde kwayaghé kér ro sélngwélafé yam
\q2 a ewaitotat yáne wafarégh si;
\q1 \v 8 Féyo fá yau so ndené em yéfene ákif-
\q2 tikéf táikér, áyáréghofnar a ndimbal mwighafnar,
\q2 nakenat ménát siya taramangi yéfene tikéf kétán Ngánjáne.
\q1 \v 9 Efraimene mék téfnár, ndemamén tamorwén nambafé mékot,
\q2 fá nawengoyénd sémta a nawatembayénd ásmégh efghon.
\q1 \v 10 Yémofem yau tarawenawét Ngánjánene rényégh yam
\q2 a kakenawét ménát sái tamorangérwén yáne mat sian.
\q1 \v 11 Fá ewawalindai némé yémo tawafrotau-
\q2 ndimbal sélngwélafé yam yémo té tawuyafotau yéfe.
\q1 \v 12 Sélngwélafé yam yémo árké tawafrotau yéfe yéfene ákifet
\q2 Joanén fanfne sifayan Ijif mbandan.
\q1 \v 13 Ménamén yémo yéfaroryéng arakaf a elimai yénamé,
\q2 yiyátoi nu nokayoyénd ndenanit mbakwe nawégh!
\q1 \v 14 Efghon yémo talimndau ménaye nu kwéfe,
\q2 a méinyotio sémbáran sotafé fése.
\q1 \v 15 Yémo karéf ewafrote wém ghérnát fanfne yuwon
\q2 tawarametau nu kétamé téfnogh nuta.
\q1 \v 16 Yémo ewafrotam nu wérér nénusunat wímta,
\q2 eyátote nu yénferone ndenanit wanje!
\q1 \v 17 Wénde fá ménjta tamorwén yaufiyaman yáfaf,
\q2 áyáréghofnar tamorwén yáfaf efe yém monde tukén ghérnát fanfne yuwon.
\q1 \v 18 Yémofem táikér tikfe tufotawét Ngánján yéfene tikéf kénjún,
\q2 komnendawét njamket yémofem árké méndefé tafandawét.
\q1 \v 19 Fá wéi korayawét Ngánjáneta, korayawét,
\q2 "Ngánjánam yau so ténmaramangé téfe njamke ghérnát fanfne yuwon.
\q1 \v 20 Néméwét, yémo féyotaro so tétyarngé wém a nu so kénéfnongé,
\q2 wénde yémo yau so tawaramangé yánjo árét féskaf flawé a faso.
\q1 \v 21 Njam Yuram eyárai fá, fá nékwam yáindai.
\q2 Yáne fés nékw kakérnau yá tambén Jeikof.
\q2 Néméwét, yáne nékw nokayoi kétán Israilét,
\q1 \v 22 ménamén yémofem yau efalo tiyárotawét Ngánján
\q2 o mwighafé téfandawét ménát sái tawarawenau fá.
\q1 \v 23 Wénde yémo ewafaretai njafr ménát so kasawérngi;
\q2 yémo esawéryéng fasa njafaroene.
\q1 \v 24 Yémo yénmasuryéng yuwot Mana flawa yéfeyot német;
\q2 yémo tawarametan flawa njafarta.
\q1 \v 25 Yémofem enetaménd njafar si résagh árfene njamke.
\q2 Ngánjánam tawarametau yéfe méinyotio taweretawét féyo taroyan.
\q1 \v 26 Yémo yéngwatembai wér mbormbor njafaran
\q2 a tambetan mbormbor kiwal ménaye yáne ndimbal muyé kér ro waftaye.
\q1 \v 27 Yémo nunit ténmasunau faso tawarametau sénjté ndené tamorwén mband-
\q2 ton minde tárfáre ndené miri mband maso téndomé!
\q1 \v 28 Yémo taméindau men kuitawét yéfene méngo aramégh sifayamé
\q2 a méinyotio yánamé tawawarendau yéfene farai méngo.
\q1 \v 29 Árém tané tawat kétánotio kor taremngotau.
\q2 Yémo tawarametau némat ménde tamorwén, táf wérár fifi mé njam tawafarongérwén mbérmbéran.
\q1 \v 30 Yéné soramé njam yémofem yéfenjo ménde kor ewifoyénd
\q2 táf yéfene njamke njma té tawafayongérwén yéfene mbérmbéran.
\q1 \v 31 Ngánjánene nékw nokayoi yéfefaf,
\q2 a yémo kérotio ngi ewafngoi a yémo yéfene muyé kér ro ár ngi engwafngoi.
\q2 Yémo mér tanfetau mbandan mer totér ambum Israilmén.
\q1 \v 32 Wénde yéné yam kénjún, árém mé yaufi ténwafrotawét.
\q2 Yau efalo táyátotawét yáne ndimbal sélngwékafé yam.
\q1 \v 33 Féyo yémo yéfene ghérsé ekmai yauyauan,
\q2 yéfene yúnjéf ersam férféram.
\q1 \v 34 Njam Ngánjánam ngi ewafngoi kérotio,
\q2 yémofem ambino ronjagh yafngoyénd fá,
\q2 fá yaufiyamta áwengogh nufngoyénd a yénayénd Ngánján minde méghméghafé.
\q1 \v 35 Féyo fá nawafarotayénd ndené Ngánján témorwén yéfene wím,
\q2 ndené Ngánján minde tukén témorwén yéfene mwighé frengégh ár.
\q1 \v 36 Wénde fá mbérmbérero kawánangotawét;
\q2 fá kundawét yáfaf yéfene kankayero.
\q1 \v 37 Yéfene tikéf yau yáfaf tamorwén.
\q2 Yémofem yau tarawenawét yáne árnégh yam.
\q1 \v 38 Wénde fá mé témorwén ghérghérsisé kér ro a tangwawitau yéfene yaufiyam
\q2 a yau méinyotio fá tawalindangai.
\q1 Tárfár mbinotmé yémo mé térangai yánjo mékw
\q2 a yau téngéumyongai yáne muyé kér ro nékw.
\q1 \v 39 Ménamén fá nawafarotai ndené fá stamorwén mé orngégh téfnár,
\q2 ngawaindangi ndenanit mbormborene ambone árkéméné yau so kénangongé.
\q1 \v 40 O, túmén yau yémofem yiyátetat féfene yuwon
\q2 a tikéf uwérsoghan yékmetat yéné ghérnát fifiofnar mband.
\q1 \v 41 Féréghférégh tufotawét Ngánjáne métar yam
\q2 a méndménd tawafrotawét Israilmén njúnnjúnofnar ároe.
\q1 \v 42 Yémofem yau tafarotawét yáne wafté
\q2 a ndenáye yémo ewanjaryéng kétamé yéfene mék téfnárafeta.
\q1 \v 43 Yémofem yau tafarotawét yáne sélngwélafé ufarogh yam Ijif kénjún
\q2 yáne ndimbal sélngwélafé yamanan kété Joan saf yuwon.
\q1 \v 44 Yémo tawengongai yéfene wanje férkot,
\q2 árké árom yau so ténetau yéné nu.
\q1 \v 45 Yéndo tawafaretau ndimbal séfero mberang ménát sái tawifongayénd fá
\q2 a férférafé ndokre ménát sái tawasérmbotawét.
\q1 \v 46 Yémo yéfene wén mbwe njamke bugérbugérat eramai;
\q2 yéfene wagh yu yifoyénd ngumbainyam.
\q1 \v 47 Yémo tawasérmbotau yéfene géreif mbwe ménj
\q2 a muyafnar táyátotan yéfene mbénge mbwe ménaye kértaye nafamdam krufrafé.
\q1 \v 48 Yémo efrangoi yéfene kau kétán kértaye nu afaméghfaf,
\q2 yéfene manjarégh fáso rokar kétán toyane bolt kés tamorwén.
\q1 \v 49 Yémo ténmumyongé yéfefaf yáne férférafé nékw-
\q2 méinyotio yáne kwérnár, utnaméghofnar nékw, a ásméghét yémafé.
\q1 Yémo engwatembai yéfe
\q2 sénanéghét njafar si résagh ár wiroréghét mérén.
\q1 \v 50 Yémo yéngwengoi yánjo nékw yéfefaf;
\q2 yémo yau eutémai Ijif árfene ghérsé
\q2 wénde ewasérmbotam fai tawifongai kérté yame.
\q1 \v 51 Yémo kérotio tasmetau fronde sénko ambum Ijif árafé sénko mérén kénjún,
\q2 totér ambumafene sari yénamé méinyotio Ijif mbandamé.
\q1 \v 52 Wénde yémo elimai yánjo ndenanit sif mérén,
\q2 tawambetau fá tawarawenau yénamé fanfne yuwomé.
\q1 \v 53 Yémo tawarawenau fá ménát yau so férfér tamorwén,
\q2 wénde arakafam ewafaryéng yéfene sénanégh téfnár.
\q1 \v 54 Yémo enérsam kétán njúnnjúnofnar mband fu ánde témorwén,
\q2 kétán yéné mband tunakéfafé yémon ándan yéfe ewaufoi.
\q1 \v 55 Yémo ndimbal yu tangwayangai sémta yéfe réré
\q2 yémo tawaramangai yéfene rokar séfe.
\q2 Yémo merkéráye tafrendangai fénaté ár sénkoyero Israil ár mérén yéfene méngotuamé.
\q1 \v 56 Wénde yémofem ménjtaye mé tufotawét a áyáréghofnar káyátotawét Minde Tukén Ngánjánefaf.
\q2 Yémofem yau tawatotawét yáne mák.
\q1 \v 57 Yémofem sém tawengongayénd a kamndangayénd némbne mwighaye ndené yéferafaf a yéfetmaf kés tamorwén.
\q2 Fá wamaroghofnar kufotawét aknyégháre nambnit.
\q1 \v 58 Yémofem Ngánján nékwafé téfghangayénd ménaye yéfene tukén yu kés tamorwén;
\q2 tawafngongai waramnjagh ménamén yéfene ámb wafroghmén sáf mbanmban.
\q1 \v 59 Njam Ngánjánam eyárai, fá namndai minde nékwafé,
\q2 a yémo féyotio ekenai Israil ár.
\q1 \v 60 Féyo fá nitérmboi yánjo ásáfogh sifayata kétamé Silo,
\q2 yánjo wáwefnogh méngota ánde fá témor árfene kénjún.
\q1 \v 61 Yémo yumyoi yánjo wafrogh muyé ménát so tawerangayénd;
\q2 fá nawarendam yánjo minde kwayaghaye yéfene mék téfnárafeta yéfene ngángayan sái tamorwén.
\q1 \v 62 Yémo eramai yánjo ár ménát so tanfetawét,
\q2 ménamén fá nékwafé témorwén yánjo árfefaf yáne fénataye ásáfogh sifayé yéta ánde témorwén.
\q1 \v 63 Yéfene totér ambum tangésmetawét fésé
\q2 yéfene tot amaf kér tamorwén yéfene awerégh wagh soramé.
\q1 \v 64 Yéfene ghéngén warogh ár yaufi kéráye tásmetawét,
\q2 a yéfene séfarék amaf yau ye kendawét yéfene kéran.
\q1 \v 65 Féyo Yuré nanoi ndenanit kémégh ngaféngafé kar tiyotau
\q2 ndenanit mék téfnár yénau kawaindangé wain wéri nue.
\q1 \v 66 Yémo minde muyaye eknai yáne mék téfnár
\q2 a engwatembai tuot wáiwáiafé.
\q1 \v 67 Wénde yémo takenau Josefene ákiambum;
\q2 yémo yau yaferyéng Efraimene ár sénko mérén.
\q1 \v 68 Wénde yémo yaferyéng yáne ár sénko mérén Judane,
\q2 a Jaion mband tunakéf, árké yémo tuwetau.
\q1 \v 69 Kété yémo yérametam wambégh sifayé méngo
\q2 ndené tukét njafar kés em taikre a nakete ndené fété mband siyém.
\q1 \v 70 Yémo yékafai yáne ásáfogh téfnár Deifid,
\q2 témotau kétán sif arake kénjút.
\q1 \v 71 Yémo yanai Deifid kétamé túmén sif tértér tawanjetau
\q2 a yiyátoi fá Jeikofene ákiambumafene limánégh ár-
\q2 Ngánjánene yánjo ár Israilmén.
\q1 \v 72 Yémo efalo tikfe tawarawenau
\q2 a elimai ménaye yáne mat yam kér ro ngángaye.
\c 79
\s
\q1 \v 1 O Ngánján, dabi ndimbal yuwomé kés em té yamongi fene mband,
\q2 fene fénataye ásáfogh sifayé.
\q1 Yémofem té taghnat fene njúnnjúnofnar wáwefnogh méngo
\q2 a yiyátoi Jerusalem wasérmbogh mérmérnit.
\q1 \v 2 Yémofem té efrangongi fene ásáfogh téfnárafene fifi
\q2 njamkenit njafar tuk menafet
\q1 ngánján ghérsafé efe tamorwén yéfene fifi
\q2 té némandangi njake kéghat wérárat.
\q1 \v 3 Férék nuwan taukangérwén Jerusalemén;
\q2 efe yau nafrangoi mband raméghét.
\q1 \v 4 Yénd méndméndat yénfandat téfene fútárém,
\q2 a yéném karogh ár fifiofnar yéfefaf efe em téfefafmé.
\q1 \v 5 O Yuré, nderé tek so nékw ném téfefaf? Tuot?
\q2 Nderé tek so fene waramnjagh nakérne fésnit?
\q1 \v 6 Tasur fene nékw yéné ndimbal yuwomé efe nakenat ménát mat sái káyátongi fenemén-
\q2 yéné warsagh árfene limánégh emofem yau yémndetat fene yétkwén.
\q1 \v 7 Ménamén yémofem té kwérnáre ewifongi fene ár Israil,
\q2 yiyátongi mband sotro fanfne yu.
\q1 \v 8 Yau téfene ákiafene yaufiyam téfnan yénd yénmereta kértaye!
\q2 Tumyo fene ghérghérsisayam so wékeye tafangongé ménát ménde yéném,
\q2 ménamén yénd mé fétfétan yéném awasnengéghétro.
\q1 \v 9 Yénmáutána yénd, O Ngánján téfene wanjarégh ár!
\q2 Yénmáutáne yénd fene minde kwayaghé yétkwénot.
\q1 Ténmanjar yénd a ténmawai téfene yaufi
\q2 ménát fene yétkwén utmanéghét.
\q1 \v 10 Némamén so dabi ndimbal yu kés em eumyotat ménát ménde ewawafrotat,
\q2 namnotat, "Ánde yém yéfene Ngánján?"
\q1 Tuyafo téfe fene fai wangogh yéfeyot ndimbal yu kés engém,
\q2 ménamén yémofem té férék téngwasunawét fene ásáfogh ténárafene.
\q1 \v 11 Náyáreta mike yéfene kérté wafrogh ár kwéfkwéf méngon efe kutnawét.
\q2 Yuyafota fene ndimbal wafté ménaye sái tawanjar fa efe ekmayénd kérot.
\q1 \v 12 O Yuré, tawawango fai téfene fútarét 7 mbinotmé
\q2 ménamén té kénkarotat yémofem té kémanangotawét fém.
\q1 \v 13 Féyo yénd fene ár, sif fene arake kénjúmén,
\q2 so kánjo némarametam fe tuot a mbanjat,
\q2 némarsam fém nderé ndimbal ném kétémé ámb ár saté kétán ámb saté.
\c 80
\s
\q1 \v 1 O mbané káyár, Israil sif wanjegnégh ár,
\q2 fémo emo elimai Josefene ákiambum ndenanit sif mérén.
\q1 O Ngánján tuk limánégh ámnjogh sifayan némor njafar si résagh árfene tukta,
\q2 yuyafote feen álálégh minde kwayaghé
\q2 \v 2 yáyot Efraim, Benjamin, a Manase.
\q1 Ténmauyafo fene minde wafté.
\q2 Kénaf ménát ténmanjar yénd!
\q1 \v 3 Ténmengo yénd wéikor fefafétro, O Ngánján.
\q2 Tiyáto fene sáf so nénálálé yénan yuwot téfefaf.
\q2 Yénayanro yénd so ténmanjar.
\q1 \v 4 O Yuré Njafarmén Fiyarafene Ngánján,
\q2 ndenayu so fém ném nékw téfene Ngánjánafé orayéghfaf?
\q1 \v 5 Fémo té yénd ténmanjne ghérghérsisaye kéran
\q2 a tiyátote yénd tane tam yengam baket afoghare.
\q1 \v 6 Fémo té yénd yinyátoi tárfár ndimbal yumén ár fútaram sái yénkarotat yénd.
\q2 Téfene mék téfnáram yéngmambnat kembekembenit.
\q1 \v 7 Ténmengo yénd wéikor fefafétro, O Njafarmén Fiyarafene Ngánján.
\q2 Tiyáto fene sáf so nálále yénan yuwot téfefaf.
\q2 Yénayanro yénd so ténmanjar.
\q1 \v 8 Fémo yénémnjam yénd kétamé Ijif ndenanit géreif mbwe ménj ;
\q2 fémo engtarne ámb ndimbal yu dabi wafarogh téfnár a wéikor yénete yénd fne mbandan.
\q1 \v 9 Fémo yéfrendam mband téfeyot
\q2 a yéndfem ewanayém sérémb a yafoyém mband.
\q1 \v 10 Téfene njaram ewafaryéng mband tunakéf;
\q2 Téfene kafekafeyam ewafaryéng ndimbal seda wén.
\q1 \v 11 Yéndfem tawafarnawén téfene kafekafe mbormborta kétán Meditaria árfene arakafot;
\q2 téfene sérémb nofarnayénd wérta kétán Eufrates wanjet.
\q1 \v 12 Wénde sénonjo, némamén fémofem tawironati téfene naweghmén
\q2 ménamén efe méinyotio njam nawaindat mété oroe engérsat téfene mbwe?
\q1 \v 13 Kéghat kimb wénaromén yéné yam tawifongi wékeyero
\q2 a kéghat wéráram tanetawét yéné.
\q1 \v 14 Kénango, yéndfem némamnendam, O Njafarmén Fiyarafene Ngánján.
\q2 Nénreta kétamé njafarta a téfanda téfene kérté ndernaye yém.
\q1 Yarawena yéné graf wén ménj
\q2 \v 15 árkéméné fémonyo té yéngyai,
\q2 yéné ambum fémo árké kérté yéngwanoi fendio.
\q1 \v 16 Ménamén yénd yéndaronat a ténwarongi téfene mék téfnáram.
\q2 Fá so kér em fene sáf atambaréghan.
\q1 \v 17 Muyé taram yéné ároe fémo efe yuwete,
\q2 ambum fene kaféghmén.
\q1 \v 18 Féyo yéndfem yau so kénéfrangongém wéikor.
\q2 Kor wéi muyé yéngmarameta téfe ménát yénd so néngutnam fene yétkwénan ambinotmaro.
\q1 \v 19 Ténmengo yénd wéikor fefafétro, O Yuré Njafarmén Fiyarafene Ngánján.
\q2 Tiyáto fne sáf so nénálále yuwot téfefaf.
\q2 Mé yénayanro yénd so kunjarngém.
\c 81
\s
\q1 \v 1 Yufanati warsagh wagh Ngánjáne, téfene muyé.
\q2 Wagh yufanati yá Jeikofene Ngánjáne.
\q1 \v 2 Wagh taufarngi! Tambarine ngi tawafngongi.
\q2 Nambunati méndefé lairaye a afe.
\q1 \v 3 Yaufetati sif tartarmén sufér totér ghérareyan,
\q2 a wéikor ménayan néndkéf ghérareyan sái tanmongi téménd!
\q1 \v 4 Ménamén yéné siyém so fété yém Israilafene wáfareghan;
\q2 yéné siyém Jeikofene Ngánjánene náknák.
\q1 \v 5 Yémo yiyátoi nák yéfe Israil árét
\q2 njam yémo yafngoi Ijif ménát yénd sái tinyátongai yuwek.
\q1 Yénd náyárayén wayamngoghofnar kém kénorayau.
\q1 \v 6 "Sénonjo yéndo so tawengwanan kérté féfene faderta;
\q2 yéndo so tafitrarén féfene ngángé kétamé yéfene kértafé yamta.
\q1 \v 7 Fém yefé kutnati tafaf tékrat kénjún, a yéndo tawanjarngayén;
\q2 yénd kénwangongayén nu kwéf ararketa
\q2 a kémaufotawén fene ndimbal mwighé njam yau nu témorwén kété Meriba.
\q1 \v 8 Náyáretati tafaf, O tane ár, njamandio yéndo ewarametan férférafé mat yam.
\q2 O Israil, njam fém té náyárete tafaf!
\q1 \v 9 Féfefaf yau táf em ámb yu árfene ngánjánngánján;
\q2 fémofem yau táf ewáwefnotati yéfe unyégh ngánjánngánjánafet.
\q1 \v 10 Ménamén yénd yénéf kwémorwén, Yuré fene Ngánján,
\q2 emo ewanjaryéng kétamé Ijif mbandta.
\q2 Ewasawéryén féfene sénféne marat, a yéndo so ewafotan mer rokare.
\q1 \v 11 "Wénde yau, tane ár so náyáretat.
\q2 Israil árém yénamé yau méndefé wéfandat.
\q1 \v 12 Féyo yéndo eumyo so ewaitotat yéfenjoyo áyáréghofnar ménde,
\q2 emor ndenáye yéfene mwighé emarégh yém.
\q1 \v 13 O, ndené tane árém fiya kwéyáretangi!
\q2 O, ndené Israil árém so wénmaitotat, eyota tane endmé!
\q1 \v 14 Nderé wékeye so yéndo tawaindangén yéfene mék téfnár!
\q2 Nderé wékeyero so em tane ngángé yéfefaf yéfene mék téfnárafaf.
\q1 \v 15 Fá emofem méndméndat yéfandat Yuré so wáiwáiafé em yáfaf.
\q2 Fá so tákmangé tékratan ambino.
\q1 \v 16 Wénde yéndo so tamanjnawén fém totér flawafé.
\q2 Yéndo so taremngotawén fém kéghát famégháre wímta tautonawét."
\c 82
\s
\q1 \v 1 Ngánjánam kété ámnjogh yérse njafar méngotu sifayan;
\q2 yémo so moghan tákmangé njafar ár:
\q1 \v 2 "Nderé teke ewerete mbarkándofnar mwighé
\q2 ménayan wéi méndefé sefande yaufiyam ár?
\q1 \v 3 Tawaram mbarkánd yéfe yauyau árét a séfarékw ambumat;
\q2 tukén ewereta yéfene mbarkánd efe ekarotat a efe etonat.
\q1 \v 4 Éwanjana yauyau ár a wáutáréghofnar;
\q2 tawanjar fá kétamé yaufi árfene weréghta.
\q1 \v 5 Wénde yéné sénanégh téfnár némé ámb yau mat em;
\q2 fá em minde áyáréghofnar!
\q1 Fá néwersotat kwéfkwéfan,
\q2 táf mband maratoene néndkéf násambnete.
\q1 \v 6 Yénd norayan, 'Fém em némbnar ngánján;
\q2 fém em Minde Tukénoene ambumtértér.
\q1 \v 7 Wénde fém so kér em ndené árfifi
\q2 a nuitati ndené méinyotio ámb limánégh téfnár kés em."
\q1 \v 8 Kano, O Ngánján, a moghan tékém mband,
\q2 ménamén méinyotio ndimbal yu fene em.
\c 83
\s
\q1 \v 1 O Ngánján, yau métar ném!
\q2 Yau aném méngu.
\q2 Yau aném métar, O Ngánján.
\q1 \v 2 Yau fém náyárete fene mék téfnárafene tukén kéme nutnat?
\q2 Yau fémo efande fene tuktuk kér ro mék téfnar nénokayotat?
\q1 \v 3 Yémofem mer unyégh kembne kwankwane yéngwafrotat fene ár sénángéghét;
\q2 yémofem kwankwane mwighé yafrotat fene mer ár sénanéghét.
\q1 \v 4 Fá korayangi, "Taném, so yéndfem talimangém Israil ndimbal yu.
\q2 Yéndfem so ewironam yáne awafarogh sifayafifi ménát yau so naketat."
\q1 \v 5 A néméwét, yéné féyémormén yéfene ámbiro mwighayan mwighé wafrogh.
\q2 Yémofem té férénan efalo yiyátoyénd méinyotio ndimbal yu daféghetat fe ásméghét.
\q1 \v 6 Yéné sem Edom ár a Ismail ár;
\q2 Moab ár a Agri ár;
\q1 \v 7 Gebal ár, Amon ár, a Amalek ár;
\q2 a ámb ár kétámamén Filistain a Taire.
\q1 \v 8 Asiria té wéi néngufnyai yéfefaf,
\q2 a naféghetaménd yémafé Lotene ákiambumafé.
\q1 \v 9 Ewafrotati yéné yam yéfefaf némé yam tawafrotati Midian ár
\q2 a wéi kés tawafrotati Sisera ár a Jabin ár kété Kison wanjen.
\q1 \v 10 Fá kété ewalindayén Ednorén,
\q2 a yéfene ngwaurosam dégwérafé yiyátoi mband.
\q1 \v 11 So yéfene minde mwighafé ár kér em ndené Oreb kés yémormén a Jif.
\q2 So méinyotio yéfene minde tukén utmanégh ár kés em ndené yame Jeba a Jalmuna kés ermén,
\q1 \v 12 ménamén fá korayawét, "So yéndfem kwérnáre tanangém téfenjoyo ásáfoghét
\q2 yéné Ngánjánene dégwér yusafé mband kés em!"
\q1 \v 13 O tane Ngánján, etarna ndenanit farumén sérémb,
\q2 a ndenanit mbormboram yénau njénnjén yasane.
\q1 \v 14 Ndené yame fésam yénai yakérne wénaro
\q2 a fés arenjam yénau yamnjote mband tunakéf nakérna.
\q1 \v 15 Ewifna fá fene férférafé kwiwale
\q2 férférot ewawinda fene kekofnar nékwe.
\q1 \v 16 Féyotio so em áuwéghofnar
\q2 kétanotio kor kamyongi fene yétkwénfaf o Yuré.
\q1 \v 17 So em wáiwái a férférafé tuot.
\q2 So kér em ngárámofnar.
\q1 \v 18 Féyo fá so mat namndetat ndené fémro fété némndetat Yuré,
\q2 ndené fémro fété ném Minde Tukén,
\q2 wafté kér ro méinyotio mbandan.
\c 84
\s
\q1 \v 1 Nderé áuwéghafé yém fene ámnjogh sifayé,
\q2 O Njafarmén Fiyarafene Yuré.
\q1 \v 2 Yénd naronjan, néméwét, yénd tikfan nénguitan
\q2 ménamén naronjan ménát sái kényawan Yurane utmanégh sifayat.
\q1 Ménaye tane méinyotio ghérsaye fifie a mbérmbére,
\q2 yénd so nutnan áuwéghafé ghérsé Ngánjánefaf.
\q1 \v 3 Ndené némbne menam yénau tinjongé méngota,
\q2 a bikutram yérameta njén a ndimbal eyátota tosétosé
\q1 kété ghéngén kitaré sifayan,
\q2 O Njafarmén Fiyarafene Yuré, tane warsagh ár a tane Ngánján!
\q1 \v 4 Nderé áuwégh yém yéfeyot efe so emor fene méngon,
\q2 túmén sái erametat fene warsagh wagh.
\q1 \v 5 Nderé áuwégh yéfeyot endefet yéném muyé kétamé Yurata,
\q2 emo té ewakmai yéfe mwighat tombé yu álighét kétán Jerusalemét.
\q1 \v 6 Njam fá eyota yénamé Ye Eworégh Yékw kénjúmé,
\q2 yéné sifayé so kénamndangé nuam sái yéfésta.
\q2 Yunjéf néndkéf nu kés nafamndat so ewamanete ménaye frengéghe.
\q1 \v 7 Fá so mé nénganotat muyafé,
\q2 a yéné méinyotio so kufarngi Ngánjáne rére Jerusalem kénjún.
\q1 \v 8 O Yuré njafarmén fiyarafene Ngánján, náyáreta tane Ngánjánafé orayégh.
\q2 Náyáreta, O Jeikofene Ngánján.
\q1 \v 9 O Ngánján, yéfanda méndefé warsagh ár, téfene áwamogh mbakw!
\q2 Tuyafo ménde yáfaf fémo efe yétetatai.
\q1 \v 10 Ámbiro efogh fene méngo sifayan
\q2 yém merfifi yau kor tausen ánde yau so yém!
\q1 Yénd so wém sésafne wanjengégh ár tane Ngánjánene méngo kénjún
\q2 féyo ténéfrangon mer ghérsé yaufiyam árfene méngotuan.
\q1 \v 11 Ménamén Yuré Ngánján siyém téfene efogh a téfene áwamogh mbakw.
\q2 Yémo yénmaramete ngárám a minde kwayaghé.
\q1 Yuram yau yénayafé so terangé yaufi rokarafé
\q2 yéfeta emofem ewafrotat mer mbarkánd yam.
\q1 \v 12 O Njafármén fiyarafene Yuré,
\q2 némé áuwégh yém yéfeyot emofem mwighafé néfandat fém.
\c 85
\s
\q1 \v 1 Yuré, fémo tasur fenjoyo frengégh fenjo mbandan!
\q2 Fémo kor tane Israiloene mani ngonjél.
\q1 \v 2 Fémo mwighafnar ewawitam fene árfene yaufiyam kérté-
\q2 néméwét, fémo ewafaryéng méinyotio yéfene yaufiyam.
\q1 \v 3 Fémo mé yerai fene nékw.
\q2 Fémo mé yangoi fene fésafé nékw.
\q1 \v 4 Sénonjo wéikor ténmano, O Ngánján téfene wanjarégh ár.
\q2 Tékém téndon fene nékw ambinotaro téfeta.
\q1 \v 5 So fém ném nékwafé téfefaf tumén?
\q2 So fémo tombaya tiyáto fene nékw yéfefaf méinyotio ár sáté kés yém?
\q1 \v 6 Yau wét fémo so mwighat yénmangote wéikor,
\q2 ménát fene ár so náuwetat fene kénjún?
\q1 \v 7 Ténmauyafo téfe fene kénjtafnar uwégh, O Yuré,
\q2 a ténmaram téfe fne wanjarégh.
\q1 \v 8 Yénd náyáretan kor merkéráye kétán némé Ngánján Yuré noraye,
\q2 ménamén fá noraye krufrate yéfefaf yáne ndimbal mwighafé árfefaf.
\q2 Wénde yau taumiyo fá sái nangotat kétán yéfene awasnengégh yamfaf.
\q1 \v 9 Yáne wanjarégh siyém kaka yéfefaf emofem férférafé yéfandat fá,
\q2 féyo téfene mband so tawafongé yáne minde kwayaghaye.
\q1 \v 10 Kwénjtafnar uwégh a efalo té nafangénd mérne.
\q2 Mbarkándyam a krufratyam té násnetangend!
\q1 \v 11 Efalo nanote tukét kétamé mband maratta,
\q2 a mbarkándyam nénurte yénan njafarta.
\q1 \v 12 A néméwét, Yuram enwasune yuwot yáne frengégh.
\q2 Téfene mbandam so yéfene tárfár wau yu.
\q1 \v 13 Mbarkándyam yéngém ndenanit si résagh téfnároe soramé,
\q2 yéngéfrende end yáne kafkaf enaghét.
\c 86
\s
\q1 \v 1 Káwefno, O Yuré, a káyár tane Ngánjánafé;
\q2 ta kwawango, ménamén yénd ménde wém fémon wáutána.
\q1 \v 2 Warawene yénd, ménamén yénd tikéf wém fefaf.
\q2 Kwanjar yénd, ménamén yénd násáfotan feyot a mwighafé néfandan fém.
\q2 Fém ném tane Ngánján.
\q1 \v 3 Aném ghérghérsisé tafaf, O Yuré,
\q2 ménamén yénd néngutnan fefaf túmén.
\q1 \v 4 Kwaram tá áuwégh, O Yuré,
\q2 ménamén yénd narametat fefaf.
\q1 \v 5 O Yuré, féml ném merfifi, afrengéghkaf ménát yaufiyam wighét,
\q2 minde kwénjtafnar uwégh afoghare yéfeyot méinyotio efe nomnendat fefaf wáutárghét.
\q1 \v 6 Náyáreta kor kaka yénan tane Ngánjánafé orayéghfaf, O Yuré;
\q2 náyáreta tane wékeye ye.
\q1 \v 7 Yénd so kutnangén fefaf yénd ánde njam wém kértayan,
\q2 a fémo kawangé ta.
\q1 \v 8 Yau dabi ngánján yém ndené fém kés ném, O Yuré.
\q2 Yau emo so ewafrote yéné fémo némé ewafrote.
\q1 \v 9 Méinyotio ndimbal yu fémo kés ewafrotam
\q2 so eném a budéme nénetat yáfaf, Yuré;
\q2 yémofem so yuyotat fene njúnnjúnofnar yétkwén.
\q1 \v 10 Ménamén fém ném ndimbal a ewafrote mer sariafé yam.
\q2 Fémo fété ném Ngánján.
\q1 \v 11 Watameta fene yam, O Yuré,
\q2 ndené yénd sof wémor fene efaloyan!
\q1 Kwaram ta féméghféméghofnar tikéf,
\q2 ménát yéndo so némutémndan fém.
\q1 \v 12 Méinyotio tane tikfe yéndon so némuyotan fém, O Yuré tane Ngánján.
\q2 Yéndon so ndimbal kwayaghé némarametan fene yétkwénot tuot.
\q1 \v 13 Ménamén fene uwégh tayot siyém ndimbalfifi.
\q2 Fémo té wanjaryéng kétamé kér yékwta.
\q1 \v 14 O Ngánján, ménjté ár kokayongi ta sénanéghét;
\q2 a wasérmbogh árém yéta kér ngiot wérametat.
\q2 Fém fifiofnar ném yéfefaf.
\q1 \v 15 Wénde fém, O Yuré,
\q2 ném ngárám a ghérghérsisé Ngánján,
\q1 afraye ném nékwan
\q2 a wafoghkaf ném kwénjtafnar uwégh a ndimbal mwighayan.
\q1 \v 16 Nénreta yuwét aném ghérghérsisé tafaf.
\q2 Kwaram fene muyé fene ásáfogh téfnároené
\q2 kwanjar, fene ásáfogh ároene ambum.
\q1 \v 17 Ténmafarete ta fene méndefé ufarogh yam.
\q2 Féyo fá emofem tékrat wéfandat yénd so wáiwáiafé em,
\q2 fémo, O Yuré, wáutána a wamarota yénd.
\c 87
\s
\q1 \v 1 Kété njúnnjúnofnar mband tunakfan
\q2 yakai ndimbal tesen yeita Yuram.
\q1 \v 2 Yémo yuwete Jerusalem ndimbal tesen minde kéráye
\q2 yau kor ámb ndimbal tesen kés em Israil kénjún.
\q1 \v 3 O Ngánjánene ndimbal tesen,
\q2 némé minde kwayaghafé si korayat fenemén!
\q1 \v 4 Yéndo so yaftan Ijif a Babilon
\q2 yéfene kénjún efe mat em tanemén
\q1 Filistain a Taire, a wéikés yém nayu Etiofia.
\q2 Fá té méinyotio nénamndangi Jerusalem ár!
\q1 \v 5 Yéfeyot Jerusalem ndené si yém,
\q2 "Méinyotio árém yanyamnetat yéné mbarkánd kétán ár kés ngáyátongi."
\q2 A minde tukén árom so yémonyo yambia frengéghan tékmangén yéné ndimbal tesen.
\q1 \v 6 Njam Yuram mbarkánd ewarameta fefayan, fá so noraye,
\q2 "Fá té méinyotio náyátongi Jerusalemmén ár."
\q1 \v 7 Árém so ewaufetat sifrafér a wagh erametat,
\q2 "Tane kémbun ghérsamén nu nénérse kétamé Jerusalem!"
\c 88
\s
\q1 \v 1 O Yuré, Ngánján tane wanjarégh ár,
\q2 yénd ye néngendan fefaf efghon.
\q2 Yénd wéném fefaf sémbáran.
\q1 \v 2 Sénonjo káyár tane Ngánjánafé orayégh;
\q2 náyáreta ta ye.
\q1 \v 3 Ménamén tane ghérsé siyém kérté afoghare yém,
\q2 a kér kwénmitremb kaka.
\q1 \v 4 Yénd kar merro wém kétán kérfaf,
\q2 ndenanit muyé kér ro ár yénai káyátongé muyafnar.
\q1 \v 5 Yémofem té wéfrangongi ár kér néndkfamé,
\q2 a yénd walinjo ndenanit kér téfnár mbéwayan.
\q1 Yénd té mwighafnar kwitat,
\q2 wénfangi kétamé fene waraweréghta.
\q1 \v 6 Fémo té witam yénd kétán yékw kwémbfaf
\q2 kwéfité yékw kénjút.
\q1 \v 7 Fene nékwam wewone yénd yuwot;
\q2 ménaye sof mé nénafayota farufaru fémo té yénd warendai méinyotio.
\q1 \v 8 Fémo té engérsam tane fútar nayu
\q2 ménayan yénd nakenayén yéfeta.
\q1 Yénd uréran wém end yau yém wérset.
\q2 \v 9 Tane ghékéf té kwéfkwéf táyátote tane yengamam.
\q1 Ámbiro efghe yénd táf nomnendan fefaf ta wáutárghét, O Yuré;
\q2 yéndo tauyon tane ngángé fefaf ghérghérsisat.
\q1 \v 10 Té sariafé fene wafrogh yam ámb násáfote kér ároefaf?
\q2 Té kér ár kanongi a némarsat fém?
\q1 \v 11 So fá efe em tokéfan marat yiyátotat fene kwénjtafnar uwégh?
\q2 So yémofem néngafrotat fene ndimbal mwighamén kérté résagh sifayé kénjúta?
\q1 \v 12 So kwéfita noraye fene mer sariafé yam wafroghmén?
\q2 So ámb ár mwighafnar wigh mbandta nénoraye ménamén fene mbarkánd yammén?
\q1 \v 13 O Yuré, yénd nendan fefaf.
\q2 Yénd ménjté so wéngém túmén efogh némamnendan.
\q1 \v 14 O Yuré, némamén fémo wékeye?
\q2 Némamén fémo fene sáf téngwengo ta tambén.
\q1 \v 15 Yénd té kwémorwén enjne a kaka kwémorwén kérot tane tot ambuman.
\q2 Yénd wakai wáutáréghofnar a kamnang yau fene minde férférafé rére.
\q1 \v 16 Fene férférafé nékwan té wafar yénd.
\q2 Fene minde férféram té kwékeinde yénd.
\q1 \v 17 Yémofem kwarendawét yénd ndenanit nu suke
\q2 yénau yém nu kéféran efogh tombé.
\q1 \v 18 Fémo té engwan nayu tane wáutárégh ár a tikéfmén ár.
\q2 Kwéfita siyém tane kaka fútar.
\c 89
\s
\q1 \v 1 Yéndo so kwénjtafnar uwéghmén wagh eufanan tuot!
\q2 Totér ambum a bulu so náráretat fene ndimbal mwighamén.
\q1 \v 2 Fene kwénjtafnar uwégh so nakete tuot.
\q2 Fene ndimbal mwighé siyém so nawmarote ndené njafar kés em.
\q1 \v 3 Yuré norayan, "Yénd té nárnyeyayém Deifidfé, tane kaféghmén ásáfogh téfnár.
\q2 Yéndo té sote norayayén yéné kwérnár si norayai yáfaf.
\q1 \v 4 Yéndo so marat táyáton féfene ákiambum sái em warsagh ár tuot;
\q2 fá so em fene limánégh ámnjogh sifayan yénamé sénonjo kétánotio tuot.
\q1 \v 5 Méinyotio njafaram so yarse fene ndimbal sélngwélafé yam, Yuré;
\q2 minde tárfár njafar si résagh ár em so némarsat fém fene ndimbal mwighamén.
\q1 \v 6 Emafé kété méinyotio njafar kénjún so etérmndam Yurafé?
\q2 Árké wafté kér ro njafar si résagh ár ndené yém Yuré kés?
\q1 \v 7 Tukén njafar si résagh árfene wafté yakai taftau Yurafaf.
\q2 Fá siyém mindefifi taftau yau kor méinyotio fá emofem yarendat yáne limánégh ámnjogh sifayé.
\q1 \v 8 O Yuré Njafarmén Fiyarafene Ngánján!
\q2 Ánde ámb ár yém kété ndené waftafé fém sném, O Yuré?
\q2 Fém ném méinyotio ndimbal mwighé kér ro.
\q1 \v 9 Fémo elimnde arakaf.
\q2 Fémo té muyaye ewainda yéfene mbormbor méméghéra wigh sof.
\q1 \v 10 Fémo engfanende ndimbal arakaf ártonam.
\q2 Fémo engwirone fémafé mék téfnár ménaye fene wafté ngángaye.
\q1 \v 11 Njafar sem fene, a mband siyém fené
\q2 méinyotio rokar mband maratan sem fene-fémo méinyotio yafrotam.
\q1 \v 12 Fémo yafrotam yambérmé a naikai.
\q2 Tabor mband tunakéf a Ermon mband tunakéf yarsat fene yétkwén.
\q1 \v 13 Wafté kér ro em fene sérakw!
\q2 Muyaro em fene ngángé!
\q2 Fene tambén ngángé tukén euyo minde kwayaghé muyayan.
\q1 \v 14 Mbarkándyam a ámbrérero yam em téfén sifayé fene limánégh ámnjogh sifayayan.
\q2 Kénjtafnar uwégh a efalo eyowé fe fronde kétán engre.
\q1 \v 15 Áuwéghafé fá em efe náyáretat áuwéghafé ke kétán wáwefnoghét,
\q2 fá so eyota kwayaghayan fene sáfan, Yuré,
\q1 \v 16 Fá náuwetat efogh tombé fene sariafé yaman.
\q2 Fá nawarmbotat fene mbarkánd yaman.
\q1 \v 17 Fém ném yéfene minde kwayaghane muyé.
\q2 Yénayam klisafé niyátote ménát so tanyato muyafé.
\q1 \v 18 Néméwét, téfene warawerégh yéném kétamé Yurata,
\q2 a fá, Israilmén njúnjúnofnar, té yénmaramai téfe téfene warsagh ár.
\q1 \v 19 Tándái yuwon fém kénorayau ghékéf waingéghe fene ndibal mwighé kér ro árfefaf.
\q1 Fém korayau, "Yéndo té yunjan mék téfnár.
\q2 Yéndo té yékafayén matkaf árfeta siya yém warsagh ár.
\q1 \v 20 Yéndo té yinjoyén tane ásáfogh téfnár Deifid.
\q2 Yéndo té yéfagharyén tane njúnnjúnofnar séfake.
\q1 \v 21 Tane ngángayam so yém imángéghofnar;
\q2 tane wafté kér ro sérakwe yéndo tiyáton muyaro.
\q1 \v 22 Yáne mék téfnáram yau so taindangi,
\q2 yaufi wafroghyam téfnár so em yáne wafté mbanmbanan.
\q1 \v 23 Yéndo so ertetan yáne mék téfnár yáne sáfan
\q2 a engwironan fá emofem méndméndat yéfandat.
\q1 \v 24 Tane ndimbal mwighé a kwénjtafnar uwégh yáfaf so yém
\q2 a tane limánégh muyayan fá so nanote waftayan.
\q1 \v 25 Yéndo so yasamngotan yáne limánégh arakafamé,
\q2 yáne wafrogh muyé wanjeyamé.
\q1 \v 26 A fá so kutnangé tafaf, 'Fém ném tane afé,
\q2 tane fronde sénko ambum minde wafté kér ro warsagh ár mbandan.'
\q1 \v 27 Yéndo so tiyáron fá tane fronde sénko ambum,
\q2 minde wafté kér ro warsagh ár mband.
\q1 \v 28 Yéndo so yuwetan a kwénjtafnar so wém yáfaf tuot;
\q2 tane árnégh yémafé yau so yiyáto.
\q1 \v 29 Yéndo so yamndan ár yáyot;
\q2 yáne limánégh ámnjogh sifayé yau so yiyáto ndené so yém efogh kés em njafaran.
\q1 \v 30 Wénde njam yáne ákiambumam táfrangongi tane watamegh si
\q2 a kuyangi yau sái náyáretat tane náknákfaf.
\q1 \v 31 Njam yémofem yau náyáretat tane wimángégh si
\q2 a kuyangi yau sái eyátotat tane wafarégh si.
\q1 \v 32 Féyo yéndo so yéfene yaufiyam tékratan tákman ménaye tot téfén yakaye
\q2 a yéfene áyáréghofnar tikéf anambéghan.
\q1 \v 33 Wénde yéndo mé so yuwetan fá
\q2 tane si yam so kolangi yáfaf.
\q1 \v 34 Yau, yéndo yau so térafarén tane rényégh yam;
\q2 yéndo ámb némé si yau so tangon árké norayayén.
\q1 \v 35 Yénd té soté néyayayén kwérnáre si Deifidefaf,
\q2 a njúnnjúnofnar kénjún yénd yau so nuindan:
\q1 \v 36 Yane yuré sifayé so yéngém tuot;
\q2 yáne limánégh ámnjogh sifayé so nawerete ndené efogh.
\q1 \v 37 Yéné so yém tuot ndené ghérare kés,
\q2 tane ndimbal mwighafé ghékéf fayogh ár njfar nekérnekéran.
\q1 \v 38 Wénde sénonjo fémofem té yékenangi a yéngutorngi.
\q2 Fém nékw em féfene teghkaf warsagh ároefaf.
\q1 \v 39 Fémofem té téndot yékmangi féfene rényégh yámafé;
\q2 fémofem té titati yáne akiki ngwérmengot.
\q1 \v 40 Fémofem té anawégh mbakw tawironati árkéménayam ténawete
\q2 a tawasérmbote méinyotio yéné árkéménayam tamarotat fá.
\q1 \v 41 Méinyotio a efe taném té oro tafrotat,
\q2 a fá té nénamnda kembnekemnet yáne kaka fútarfefaf.
\q1 \v 42 Fémo té muyé tawaramete yáne mék téfnarat
\q2 a eyáto fá méinyotio náuwetat.
\q1 \v 43 Fémofem té yiyátongi yáne witmafé sénté naifé fifiofnar
\q2 a nakenangi yá wáutáréghét mékan.
\q1 \v 44 Fémofem té yékmbongi yáne kwayaghé
\q2 a yéngongi yáne limánégh ámnjogh sifayé.
\q1 \v 45 Fémofem té yiyátongi bulu kétamé yáne efogh kés tanmorwén
\q2 a maratau wáiwáiot yékmangi.
\q1 \v 46 O Yuré, nderé tek yéné so yéngém?
\q2 So fémyo katno tuot?
\q2 Nderé teke so fene nékw nakérne fésnit?
\q1 \v 47 Nawafarota nderé ténjfi yém tane ghérsé,
\q2 nderé sotro a féyotarofnar yém yéné árfene akegh.
\q1 \v 48 Árké ár yau so yémor tuot; méinyotio so kér em.
\q2 Efe yau so kawatemba kér tokéf waftata.
\q1 \v 49 Yuré, ánde yém fene kwénjtafnar uwégh?
\q2 Fém árké unyéghofnar si norayai Deifidefaf ndimbal mwighaye olaghofnar si.
\q1 \v 50 Mwighaye téfandé, Yuré, ndernaye fene ásáfogh téfnár wáiwáiot ekmetat!
\q2 Yéndo ersan tane tikéf kénjún ufrogh yamménfifi tárfár árfene.
\q1 \v 51 Fene mék téfnáram fén ngwawafrotat, O Yuré;
\q2 yémofem fén tawafrotat fene tegh warsagh ároe árkamé fá tiyota.
\q1 \v 52 Yuyotam Yuré tuot!
\q2 Efaloe a efaloe!
\c 90
\s
\q1 \v 1 Yuré, méinyotio ár saté kénjún
\q2 fém té kéném téfene méngotu!
\q1 \v 2 Soramé mband tunakéf karaftawét,
\q2 soramé fémo yéfunai mband a mband marat,
\q2 kétamé rényégh kétán yátoghfaf, fém ném Ngánján.
\q1 \v 3 Fémo ár tawengogh ngwérméngot, korayang,
\q2 "Kangongai kétán ngwérméngfaf fém orngégh ár!"
\q1 \v 4 Féfeyot tausen yúnjéf em ndenanit ámbiro efogh yéném kawaindangé,
\q2 ndené yame ámb sémbár yénau ngwawaindangi.
\q1 \v 5 Fémo tasambur ár nayu ndenanit onjo yénau kolindangé.
\q2 Fá em ndenanit yus yénau nanotat akwan.
\q1 \v 6 Akwan yéné ndram narametat a merro nanotat,
\q2 wénde séiteyan sérét kamndangi a wau káyátongi.
\q1 \v 7 Yénd sérét káyátongém fene nékw mbanmbanan;
\q2 yénd méinyotio ténmanangé fene minde muyé kér ro nékwam.
\q1 \v 8 Fémo efaloe téfene yaufiyam fene sáfan-
\q2 téfene átnoghe yaufiyam- a fémo efande méinyotio.
\q1 \v 9 Yéndfem efrangotam téfene ghérsé fene nékw mbanmbanot,
\q2 ewifotam téfene yúnjéf mikefé.
\q1 \v 10 70 yúnjéf té yénmaramai téfe!
\q2 Ámb so engmor kétán 80.
\q1 \v 11 Efe so mat káyátongé fene nékoene wafté?
\q2 Fene nékw siyém túmén férférafé fene méndeyan.
\q1 \v 12 Yénmatamete kétán mat so kamndangém mwighé sénté ghérsamén,
\q2 ménát yénd mato so nanotam káfeté mwighayan.
\q1 \v 13 O Yuré kénango téfefaf!
\q2 Nderé tek fém so nawanete?
\q2 Ghérghérsisé aném fene ásáfogh árfenemén!
\q1 \v 14 Yénremngota yénd túmén awkan fene kwénjtafnar uwéghe,
\q2 a yéndfem so eufanam wagh áuwéghét kétán ánde so eyáto téfene ghérsé.
\q1 \v 15 Ténmaram téfe áuwégh wéikor kétamé ndernaye tándái awasérmbogh ténmorwén!
\q2 Mer yúnjéf tanwaso yaufi yúnjéfta.
\q1 \v 16 Ténmumamyo yénd, fene ásáfogh téfnár so yéfandam fene ásáfogh wéikor;
\q2 taumyo téfene ambumtértér so yéfandat fene minde kwayaghé.
\q1 \v 17 A so Yuram téfene Ngánjánam yuyafote téfe yánjo yátogn si
\q2 a tayátongé téfene yam wafrogh fifiafé.
\q2 Néméwét, tawafrota téfene yam wafrogh fifiafé.
\c 91
\s
\q1 \v 1 Fá efe emor Minde Tukénoene sékian
\q2 so tawinjongi enagh méinyotio wafté kér roene njaran.
\q1 \v 2 Yénd mat wém Yuranemén:
\q1 Mé fáro tane átnogh sifayé, tane wanjarégh sifayé;
\q2 fá yém tane Ngánján, a yéndo mwighafé yéfandan.
\q1 \v 3 Ménát yémo si néngmanjane méinyotio urér árnéghta
\q2 a némambeta kétamé kér enjneta.
\q1 \v 4 Yémo so komafarngé yánjo men sífe.
\q2 Yémo so séki némaramete yánjo njambe.
\q2 Yáne unyéghofnar ndimbal mwighé sem fene mék ásméghét a awambghét.
\q1 \v 5 Yau táf férfér ném ngerngerafé sémbáran
\q2 yau ménamén fimb kés nénanefetat efghon.
\q1 \v 6 Yau táf yéné áuwéghofnar enjne árké enyau kwéfitayan,
\q2 yau táf kaukau árkémé so kufarngé efogh néndkéf.
\q1 \v 7 Ndemamén téu tausen nénguitat fene téndota,
\q2 ndemamén téu uyo tausen kér yéngramngota fefafmé,
\q2 némarenda yéné yaufiyam téfnár tékratan ekmete.
\q1 \v 8 Mé táf taswér fenjo ghékéf,
\q2 a efanda yéné yaufiyam téfnár tékratan ekmete.
\q1 \v 9 Njam fémo yiyátota Yuré fene átnogh sifayé,
\q2 njam fémo yiyátota efe yém Minde Tukén fendio ámnjogh séki.
\q1 \v 10 Yau yaufiyam so kémafarngé;
\q2 yau tékratafé yam so eném kaka fene méngot.
\q1 \v 11 Ménamén yémo so tawafaretangé yánjo njafar si résagh ár
\q2 ménát so némarawenat árkémé fém niyota.
\q1 \v 12 Yémofem so némaretat yéfenjo ngángaye
\q2 ménát yau so fene kafkaf tasém wíman.
\q1 \v 13 Fémo so kérotio engtumnde ndimbal munjan fus a kombran.
\q2 fémo so efarne férférafé sáfot ndimbal munjan fus a kamban fene kafkafe.
\q1 \v 14 Yuré noraye, "Yéndo so ewanjanan fá emofem yénd uwetat.
\q2 Yéndo so ewarawenan fá emofem mwighafé yéfandat tane yétkwén.
\q1 \v 15 Njam fá kutnangi tafaf, yéndo so tawawangon,
\q2 yénd so wém yéfefaf kérté kénjún.
\q2 Yéndo so tawanjarén fá a eutémndan.
\q1 \v 16 Yéndo so fai tawaraman ménaye tombé ámnjogh ghérsaye
\q2 a tawaraman tane wanjarégh.
\c 92
\s
\q1 \v 1 Merfifi yém sái yarametam kánjo Yuré,
\q2 ménát Minde Tukén sái yarsam waghe.
\q1 \v 2 Merfifi yém ménát sái néngafrotam fene kwénjtafnar uwéghmén akwan,
\q2 fene ndimbal mwighamén séiteyan.
\q1 \v 3 Yénayafé 10 ángéghafé gita af
\q2 a méndefé kembnemén laireye.
\q1 \v 4 Fémo klisa waramete, Yuré, ménaye méinyotio fémo némé tawafrote tayot.
\q2 Yénd wagh erametan áuwéghét ménamén fémo némé tafrote.
\q1 \v 5 O Yuré, némé ndimbal ásáfogh fémo ewafrote!
\q2 A ndené kénjkam yém fene mwighé.
\q1 \v 6 Mé fáro efe em kor mwighafnar yau so mat em,
\q2 a efe nengawawindat mat yau so em yéné.
\q1 \v 7 Ndemamén yaufi ár náfyanat ndenanit yus kéghat
\q2 a yaufiyam wafrogh téfnár em féyotaro rokaran narmbotat merro a mulmulafé
\q2 fá so némasérmbote tuot.
\q1 \v 8 Wénde fém, O Yuré, so némuyotat tuot.
\q1 \v 9 Fene mék téfnár, Yuré, so kér engém;
\q2 méinyotio yaufi wafrogh téfnár so nofarnat.
\q1 \v 10 Wénde fémofem té wiyátongi muyafé ndené kwérnar kau.
\q2 Fémofem té wétetayénd frengéghkaf oile.
\q1 \v 11 Tane ghékfam té téfande uyégh sifayé tane mék téfnárfené
\q2 tane ténganam té táyárete tane yaufiyam árfene sénanégh téfnárafene.
\q1 \v 12 Wénde ngánján ghérsafé ár so nanotat mer mulmulafé ndanit nginar
\q2 a nanotat muyé kér ro ndenanit sedas wén kés em Lebanonén.
\q1 \v 13 Ménát fá so kor eitat kété Yurane méngonyo.
\q2 Fá so nanotat mer mulmulafé téfene Ngánjánene sifayan.
\q1 \v 14 Buluan mé so yéngfunat mbwé
\q2 fá mé so em mulmulafé a wén árau ngarot.
\q1 \v 15 Yémofem so yuyafotat ndené, "Yuré siyém mbarkánd!
\q2 Fá siyém tane wím!
\q2 Kété ámb yaufi yau yém yáne kénjún.
\c 93
\s
\q1 \v 1 Yuré siyém warsagh ár! Fá siyém yamanetaménd warsagh ár sariafé sálámeye.
\q2 Wéi, Yuré yamanetaménd sariafé sálámeye a árméghét wéi muyaye.
\q1 Mband marat yakai taikrataye
\q2 a yau so tésambnetangi.
\q1 \v 2 Fene limánégh ámnjogh sifayé, o Yuré, té nokai kétamé yéné efogh awafaroghta néném.
\q2 Fém fémyo néném kétamé tándái efogh kés nénawaindat.
\q1 \v 3 Kéfér té nénarmbongi tukét, O Yuré.
\q2 Kéfér té wérse nufngo ndenanit árurké
\q2 kéféram té ewarmbo yéfene tikéf áneféghafé sof.
\q1 \v 4 Wénde kor yau muyafé em wasnengégh nékw arakaf,
\q2 yau kor muyafé em arakaf sóf snasmetat maso téndot-
\q2 Yuré mindefifi yém muyayan yau kor yéném!
\q1 \v 5 Fene tikéfmén nák yau so tawengongi.
\q2 Fene limánégh, O Yuré, siyém njúnnjúnofnar tuot a mbanjat.
\c 94
\s
\q1 \v 1 O Yuré, fai wangogh ár Ngánján,
\q2 O Ngánján fai wangogh ár, tumyo fenjo ndimbal kwayaghane mbarkánd yam nátremngota kétán.
\q1 \v 2 Kokai, O mband maratoene mogh téfnár.
\q2 Tawaram tuktuk árét némat ménde tam.
\q1 \v 3 Nderé teke, O Yuré?
\q2 Nderé teke so yaufi ár eumyote ménát ménde yáyáreta?
\q1 \v 4 Nderé tek fá so norayat ndené kar merfifi em ámb árfeta?
\q2 Nderé tek so yéné mámáfi ár nawarsat?
\q1 \v 5 Yémofem esénat fene ár, Yuré,
\q2 áuwéghofnarot emeindat fá efe norayat ndené fene em.
\q1 \v 6 Yémofem kérotio esmetat séfarékw amaf a dabi ár
\q2 a séfarékw ambum.
\q1 \v 7 Fá norayat, "Yuré yau nérete,
\q2 a yéné téndon, Israilafene Ngánján yau nautémnde."
\q1 \v 8 Kemnangi kor, fém ongén téfnár!
\q2 Njam so fémofem ambino terangi?
\q1 \v 9 Fá yém méngu-yéné ár emo ewawafrotam féfene téngan?
\q2 Fá yém ghékéf kwéfkwéf-yéné ár emo ewafrotam féfene ghékéf?
\q1 \v 10 Yémo tékratau tákmangé ndimbal yu-wét yémo yau so tékratan tákmangé fém?
\q2 Fá mat yém méinyotio rokar-yau wét mat yém fémofem némé ewafrotati?
\q1 \v 11 Yuré mat yém árfene mwighé;
\q2 fá mat yém fá sem afrengéghofnar.
\q1 \v 12 Áuwéghafé fá em fémo efe ewatamete téfle, Yuré,
\q2 yéné ár fémo efe ewatamete fene yam wafroghmén si.
\q1 \v 13 Fémo mer tawaram yéfe kérté efghon,
\q2 kétánotio yékw kor sái yétanat ménát sái yaufi ár.
\q1 \v 14 Yuram yau so takenangi yánjo ár;
\q2 yémo so kénorongé yánjo minde utmanéghafé ásáfogh sifayé.
\q1 \v 15 Mogh yam wéikor so tinjongi mbarkándan,
\q2 a fá efe tikfefifi em so yaitotat yéné.
\q1 \v 16 Emo so kwanjarngé kétamé yaufi árta?
\q2 Efe so kokayongé yémafé ásnanéghét yaufiyam téfnárafé.
\q1 \v 17 Táfandro Yuram njam wáutáne,
\q2 yénd so táf tekofnar kafrendangén kér mbéwé métar sifayata.
\q1 \v 18 Yénd néngutnayén, "Yénd néngéghnotan!"
\q2 wénde fene kwénjtafnar uwégham, O Yuré, wamarotai yénd.
\q1 \v 19 Njam mwighé uwérsogham yafoi tane mwighé,
\q2 fene wamarogham waramai kor yéminai kamnang a áuwégh.
\q1 \v 20 So féyotaro mbarkándofnar limánégh téfnár nawarsat ndené Ngánján siyém yéfe tambén.
\q2 Yéné limánégh téfnár endefene wafarégh nákan yau yém mbarkánd?
\q1 \v 21 Fá nafghetat yéfeyot mbarkánd ár sénanéghét
\q2 a ambino tákmangi téfnofnar ár kérot.
\q1 \v 22 Wénde Yuré siyém tane wambégh méngo;
\q2 tane Ngánján siyém minde wafté kér ro wím ánde yénd nátnotan.
\q1 \v 23 Ngánjánam so euwengote yaufi árfene yaufiyam yéfefaftio.
\q2 Yémo so tawirorngé fá yéfene yaufiya téfnan.
\q2 Yuré téfene Ngánjánam so tawirorngé fá.
\c 95
\s
\q1 \v 1 Taném, so yéndfem wagh yérametam Yurafaf!
\q2 So yénd nutnam áuwéghafé yáfaf téfene wanjarégh wím efe yém.
\q1 \v 2 Yénd so yéném yáfaf kánjo wangogh siafé.
\q2 so yéndfem yérametam wafyagh warsagh wagh yáfaf.
\q1 \v 3 Ménamén Yuré siyém ndimbal Ngánján,
\q2 ndimbal warsagh ár méinyotio ngánján em yáne yuwon.
\q1 \v 4 Yémo yerete yánjo ngángaye mband maratoene kénjú
\q2 a muyé kér ro mband tunakéffaf.
\q1 \v 5 Arakaf yáne yém, ménamén yémo yafrotam.
\q2 Yáne ngángayam efunai ghérnat mband, wéi.
\q1 \v 6 Taném so yéndfem yáwefnotam a naramnjotam.
\q2 Yénd so budme néghtam Yuré rére téfene wafrogh ár,
\q2 \v 7 ménamén fá siyém téfene Ngánján.
\q1 Yénd yéné ár fiyéném yémo yénfande,
\q2 yéné mérén yáne wambégh mbanmbanan.
\q1 Tafro fém njam náyáretati yáne kém sénonjo!
\q1 \v 8 Yuré noraye, "Yau tikéf táikér eyátotati ndené Israil ár kés kufrotawét kété Meriba,
\q2 a wéi Masan fanfne yuwon.
\q1 \v 9 Ménamén kété féfene ákifem kwufotawét a yéta tufotawét tane métar yam,
\q2 táf yéta tafandawét méinyotio yam némé tawafrotawét.
\q1 \v 10 Kétán 40 yúnjéf yénd kwémorwén nékw yéfefaf, a norayayén,
\q1 'Fá yéné árfem endefene tikéf yau em tafaf.
\q2 Fá nakenat yéné wafroghét némé yéndo yéta emndetan.'
\q1 \v 11 Féyo tane nékwe yénd kwérnárafé korayangayén:
\q2 'Fá yau so kényawangi tane enagh sifayat.'
\c 96
\s
\q1 \v 1 Yérametati totér wagh kétán Yurai!
\q2 Taumyo méinyotio mband yérametat wagh kétán Yurai!
\q1 \v 2 Yérametati wagh kétán Yurai yarsat yáne yétkwén.
\q2 Efogh fénataye néngafrotati mer si ndené yémo yénmanjane.
\q1 \v 3 Marataye yékmetati yáne ndimbal kwayaghayam yénamé ndimbal yu kés engém.
\q2 Engwaufrotati ménamén sélngwélafé yémo sewafrote.
\q1 \v 4 Ndimbal yém Yuré! Fá siyém minde utmanéghafé warsaghét!
\q2 Fá so férférafé yéfandam ewafne méinyotio ngánjánngánján.
\q1 \v 5 Ngánjánngánján ámb ndimbal yumén sem ghérsafnar,
\q2 wénde Yuram ewafrotam njafar!
\q1 \v 6 Utmanégh a sariyam warende yénd;
\q2 muyé a méndefé kwayaghayam yafne yáne limánégh ámnjogh sifayé.
\q1 \v 7 O ndimbal yu mband maratan, mat tiyátongi Yuré;
\q2 mat tiyátongi ndené Yuré siyém ndimbal kwayaghé a muyé.
\q1 \v 8 Taramangi Yurai ndimbal kwayaghé yáne ménde némat yém!
\q2 Enérsati féfene ghéngén a eném yáne sifayat.
\q1 \v 9 Yáwefnotati Yurai yáne njúnnjúnofnar kwayaghayan.
\q2 So méinyotio mband marat nasambnetat yáne rére.
\q1 \v 10 Tawaufrongi méinyotio ndimbal yuafé, "Yuam elimnde!"
\q2 Mband marat yakai taikrataye a yau so tésambnetangi.
\q2 Yémo moghan so tákmangé ár ámb rérero.
\q1 \v 11 Njafar so klisafé, a mband marat so náuwete!
\q2 So arakaf a méinyotio rokar yéné kénjún nutnat yáne warsaghan!
\q1 \v 12 So ndau a nénemén njamke téfén néngafotat áuwéghafé!
\q2 So wénaro rérke yakai warsaghan.
\q1 \v 13 Yuré rére, ménamén fá yéném!
\q2 Fá yéném ménát mband marat sái moghan tékmangé.
\q1 Yémo so mbarkánde yémote mband marat,
\q2 a ndimbal yu kés em ménaye yáne efaloe.
\c 97
\s
\q1 \v 1 Yuré siyém warsagh ár!
\q2 So náuwete mband marat!
\q2 So nayu maso yu em kliasayan.
\q1 \v 2 Kwéfité kwéfam yarende fá.
\q2 Mbarkand yam a ámbrérero yam ere yáne utmanégh ámnjogh sifayan téfén sifayé.
\q1 \v 3 Fés natarne yáne frondeta
\q2 a ewakérne méinyotio yáne ásmégh téfnár.
\q1 \v 4 Yáne toyé karamangi kofatarngi mband maratamé.
\q2 Mbandam yéfande a férféram yéramete.
\q1 \v 5 Mband tunakéf nérndat ndenanit kwas yénau yém fésan Yurane rére,
\q2 méinyotio mbandoene Yurane rére.
\q1 \v 6 Njafaram nafrote yáne mbarkánd yammén;
\q2 méinyotio tárfár ndimbal yuam yéfandat yáne ndimbal kwayaghé.
\q1 \v 7 Fá emofem ewáwefnotat mewangat wáiwái so ersat-
\q2 méinyotio efe nawarsat yéfene fifiofnar ngánjánngánjánmén-
\q2 ménamén méinyotio ngánjánngánjánam so táwefnongi yá.
\q1 \v 8 Jerusalem té náyárai a káuwetau,
\q2 a méinyotio tesen Juda kénjún tamorwén klisayan
\q2 ménamén fene ámbrérero yammén, O Yuré.
\q1 \v 9 Ménamén fém, O Yuré, ném minde tukén yénamé méinyotio yuwomé,
\q2 fém némuyotat minde tukényo méinyotio ngánjánngánjánafeta.
\q1 \v 10 Fémofem emofem yuwetati Yuré, méndefnar efandati yáfaf.
\q2 Yémo ewambete yéfene ghérsé yáne ngánján ghérsafé árfene
\q2 a ewanjane yaufi ároene waftata.
\q1 \v 11 Kwayaghé nanete ngánján ghérsafé árfefaf,
\q2 a áuwégh yéfefaf endefene tikéf em mbarkánd.
\q1 \v 12 So méinyotio efe em ngánján ghérsafé náuwetat Yurane kénjún
\q2 a yarsat yáne njúnnjúnofnar yétkwén!
\c 98
\s
\q1 \v 1 Eufanat totér wagh Yurafaf,
\q2 ménamén yémo té tanwafrote meryam.
\q1 Yáne tambén ngángaye té nawainda waftafé;
\q2 yáne njúnnjúnofnar sérakwam té tuyafote yáne wanjarégh wafté!
\q1 \v 2 Yuram té mat táyátote yáne awaingéghmén
\q2 a té safét tékmetau yáne mbarkánd yam yéfefaf méinyotio ndimbal yuafefaf!
\q1 \v 3 Yémo té yafrotai yánjo unyéghofnar si ménát sái táuwetau a ndimbal mwighé sái témorwén Israilét.
\q2 Mband maratoene fétfét árém té téfandat téfene Ngánjánene wanjarégh.
\q1 \v 4 Nutnati Yurafaf, méinyotio mband;
\q2 kafrangongi ndené mé áuwégh a warsagh wagh ufarghan!
\q1 \v 5 Féfene wagh eufananit ménaye afe,
\q2 ménaye afe siya yém méndefé wagh kémafé,
\q1 \v 6 ménayafé sufér keyafé a sif tartatmén sufér kés.
\q2 Yafrotati áuwéghafé tárfár kembne rokare sái nambnati Yurane rére, efe yém Warsagh ár!
\q1 \v 7 So arakaf a méinyotio rokar yéné kénjún nutnat sái yarsat fá!
\q2 So méinyotio ghérsafé rokar yéné kénjút kényufnyangi.
\q1 \v 8 So wanjeyam esmetat yéfene ngángé klisafé.
\q2 So mband tunakéf yéfene áuwégh wagh yéngrametat
\q1 \v 9 Yurane rére.
\q2 Yuré nénangote ménát mband marat sái moghan tékmangé.
\q1 Yémo so moghan tékmangé mband marat mbarkándaye,
\q2 a ndimbal yu ámbrérero.
\c 99
\s
\q1 \v 1 Yuré siyém warsagh ár!
\q2 So ndimbal yu férféram eramete!
\q1 Fá yémor yánjo limánégh ámnjogh sifayayan njafar so résagh árfene néndkfan.
\q2 So méinyotio mband sokrereyam yérse!
\q1 \v 2 Yuré yémor sariafé Jerusalemén,
\q2 méinyotio tukét ndimbal yuwomé.
\q1 \v 3 So yémofem yarsat fene ndimbal a férférafé yétkwén.
\q2 Fene yétkwén siyém njúnnjúnofnar!
\q1 \v 4 Wafté kér ro warsagh ár, emo yuwete mbarkánd yam,
\q2 fémo té yeitam ámbrérero yam
\q1 a fém té kimndau náke
\q2 a mbarkándaye méinyotio Israilén.
\q1 \v 5 Yuyotam Yuré téfene Ngánján!
\q2 Náwefnotam yuwot yáne kafkaffaf, ménamén fá yém njúnnjúnofnar!
\q1 \v 6 Moses a Aron tarwén yéfenjo ghéngén warogh árfene kénjún;
\q2 Samuelém wéi táf tanmongai yáne yétkwén.
\q1 Fá kutnangayénd kétán Yurafaf wáutárghét,
\q2 a yémo tawawangongai.
\q1 \v 7 Fá kénorayau Israil árfefaf kétamé sénjté nu kwéfta,
\q2 a yémofem tawaitotawét nák a wafarégh yémo ewaramai.
\q1 \v 8 Yuré téfene Ngánján, fémo táf tanwawangongai.
\q2 Fém ném yaufiyam wigh téfnár Ngánján yéfeyot,
\q2 wénde fémo tékratan tákmangai njam mámáfi tafrotawét.
\q1 \v 9 Yuyotam Yuré téfene Ngánján,
\q2 a yáwefnotam kété yáne njúnnjúnofnar mband tunakfan Jerusalem kénjún,
\q2 ménamén Yuré téfene Ngánján siyém njúnnjúnofnar.
\c 100
\s
\q1 \v 1 Nutnati áuwéghafé Yurafaf, méinyotio mband marat!
\q2 \v 2 Yáwefnotati Yurai mer tikéf áuwéghafé.
\q2 Eném yáne rére enaufanati wagh áuwéghafé.
\q1 \v 3 Mat aem ndené Yuré siyém Ngánján!
\q2 Yémo yénd yénmafrotam, a yénd yéném yáne.
\q2 Yénd yéném yáne ár, yénd yéném yáne sif mérén.
\q1 \v 4 Kényawangi yáne sésafnemé kánjo wangoghafé;
\q2 engém kényawangi yáne sifayat warsagh waghafé.
\q2 Yarametati kánjo a yarsati yáne yétkwén.
\q1 \v 5 Ménamén Yuré siyém mer.
\q2 Yáne kwénjtafnar uwégh mé so yéngém tuot,
\q2 a yáne ndimbal mwighé mé so yéngém kétán fénatayero ár satafaf.
\c 101
\s
\q1 \v 1 Yéndo so wagh erametan fene uwéghmén a mbarkánd yammén, Yuré.
\q2 Yéndo so némarsan fém waghe.
\q1 \v 2 Yénd so kor nawarawenan ménát sái wémor téfnofnar ghérsé-
\q2 njam so fém néném ta wáutárghét?
\q1 Yéndo so yélimndan ghérsé efaloe tanjo méngon.
\q1 \v 3 Yénd so nakenan sái efandan
\q2 némé yaufi em a méndefnar.
\q1 Yéndo méndefnar efandan efe néngawareindat end wasnengéghan;
\q2 Yéndo yau némé so yafrotan yéfefaf.
\q1 \v 4 Yéndo so engkenan wengogh mwighé
\q2 a nayu so wém kétamé méinyotio yaufita.
\q1 \v 5 Yénd yau so néngafghetan yéné árfefaf emofem si erafnat yéfe fútaréf.
\q2 Tafaf yau so yém awarambogh mwighé a tuktuk.
\q1 \v 6 Yénd so naronjan ndimbal mwighé kér ro árfefaf
\q2 sái em yéndfé awarnyégh ár.
\q1 Mé fáro endefefaf tawinjon kérté si tanemén
\q2 so eumyotan tafaf so násáfotat.
\q1 \v 7 Yéndo yau so eumyotan unyégh téfnár sái násáfotat tane méngon,
\q2 a unyégh téfnár yau so emor tane sáfrére.
\q1 \v 8 Tane efoghmén ásáfoghan so enérse kwayaghat yaufiyam ár
\q2 a yuwek tiyáton Yurane ndimbal tesen kétamé yéfene matétta.
\c 102
\s
\q1 \v 1 Yuré náyáreta tane Ngánjánafé orayégh!
\q2 Náyáreta tane ménde némat yém.
\q1 \v 2 Yau sém kwawengo
\q2 tane mwighé kérté efghon.
\q1 Kénáwefno wékeye,
\q2 a kwawango ta njam yéndo kénmotangén.
\q1 \v 3 Ménamén tane efogh nawaindat ndenanit kwam,
\q2 a tane sot nakérnat ndenanit férkat wafté karéf mbwenit.
\q1 \v 4 Tane tikéf siyém enjnefé yém, ghérnat namndete ndenanit yus,
\q2 a yénd té tétarnan tane njamke néne.
\q1 \v 5 Ménamén tane mike,
\q2 yénd té namndan ménát sot ewatonan.
\q1 \v 6 Yénd ndenanit wém men fanfne yuwon,
\q2 ndenanit rawa árké yémo nayuyo fanfne yuta.
\q1 \v 7 Yénd walinjogh mé néretan,
\q2 yumén nufrotan ndenanit féfét men méngo sémsot tukén.
\q1 \v 8 Tane mék téfnáram tékrat wéfandat túmén efogh.
\q2 Yémofem si wafrotat a wafalngotat.
\q1 \v 9 Yéndo enetan sénko njamkenit.
\q2 Tanjo yengam enetan nunit.
\q1 \v 10 Ménamén fene nékw a kwérnar.
\q2 Ménamén fémo té werai wakayoi a witam téndot.
\q1 \v 11 Tane ghérsé nawainde nimnde wékeyero ndené séitemén njar yénau yém.
\q2 Yénd ghérnat namndetat ndenanit yus.
\q1 \v 12 Wénde fém, O Yuré, so némor fene limánégh ámnjogh sifayayan tuot.
\q2 Fene marataye yammén so yiyota kétán méinyotio fénatayero ár saté.
\q1 \v 13 Fém so kokai a ghérghérsisamén Jerusalemét,
\q2 a sénonjo yéné efogh yém sái ghérghérsisé ném yáfaf,
\q2 sénonjo yéné efogh fémo árké olaghofnar si norayai ménát wáutárghét.
\q1 \v 14 Ménamén fene árém euwetat méinyotio wím yáne anawégh mbakwan
\q2 a mer kéráye ewarawenat ngwérméng yáne endmé.
\q1 \v 15 Féyo méinyotio ndimbal yu so ngerngeram eramete Yurane sáfrére.
\q2 Mband maratmén warsagh ár so ngernger em yáne ndimbal kwayaghayan.
\q1 \v 16 Ménamén Yuram so kor yéramete Jerusalem.
\q2 Fá so kété mé kufarngé yánjo ndimbal kwayaghafé.
\q1 \v 17 Fá so náyárete yéfene Ngánjánafé orayégh efe em yauyau.
\q2 Yémo yau so ekene yéfene ménde némat em.
\q1 \v 18 So yéné nafarotat yéfe soramé ár saté kés eném,
\q2 ménát ár efe yau náráftat so yémofem yéngwarsat Yuré.
\q1 \v 19 Tawaufro Yuré nénrete yuwot
\q2 kétamé njafar méngotu utmanégh sifayata.
\q1 Fá nénretai yuwot mband maratot kétamé njafarta
\q2 \v 20 ménát so náyárete yéfene mike kwéfkwéf méngot efe enyawetaménd,
\q2 ménát so taferngé fá efe ewatembayénd kérot.
\q1 \v 21 A féyo Yurane marataye yammén so néusénat kété Jaionén,
\q2 wéi kété so yarsat Jerusalemmén,
\q1 \v 22 njam tárfár ár méinyotio náumendat
\q2 a warsagh árfene limánégh yu eném ménát sái yáwefnotat Yurai.
\q1 \v 23 Yémo yérafnam tane muyé totér árányo,
\q2 enfetam tane kwéf ténjfi.
\q1 \v 24 Wénde yénd yefé nutnayén yáfaf, "O tane Ngánján, efe nakete tuot,
\q2 yau tango tane ghérsé táf totér ambum mé swém!
\q1 \v 25 Tándái yuwon fémo té yéfnyangoi mband maratoene téfén
\q2 a ewafrotam njafar fene ngángaye.
\q1 \v 26 Yéné so kawaindangi, wénde fém mé so ném tuot;
\q2 fá ndenanit so naftérnat tándáwár sáláme.
\q1 Fémo so ewengote ndenanit soda
\q2 a mwighafnar engwita.
\q1 \v 27 Wénde fém ndenaro mé fété ném;
\q2 fém so némor tuot.
\q1 \v 28 Fene árfene ambumtértér
\q2 so emor wambégh kénjún.
\q1 Yéfene ambumtértérafene ambumtértér
\q2 so nanotat muyafé fene sáfan.
\c 103
\s
\q1 \v 1 Mat táyáto ár méinyotio yéndo yarasan Yuré;
\q2 méinyotio tane tikfe, yéndon so yarsan yáne njúnnjúnofnar yétkwén.
\q1 \v 2 Mat táyáto ár méinyotio ndené yéndo yarsan Yuré;
\q2 yau so yénd kwawalindangé yáne mer yam yémo némé ewafrote tayot.
\q1 \v 3 Yémo wawite méinyotio tane yaufiyam
\q2 a mer wéngyátote tane enjneta.
\q1 \v 4 Yémo wanjane kérta
\q2 a wamanete uwéghe a ghérghérsisé tikfe.
\q1 \v 5 Yémo yafote tane tikéf mer rokare.
\q2 Tane bérkararta kor wanote ndenanit ndikaka!
\q1 \v 6 Yuram ténramangé mbarkánd yam
\q2 a ámbrérero yam yéfe méinyotio efe ewawérsotat a yau kor em ámbrérero.
\q1 \v 7 Yémo yufayéng safét yáne yam Mosesefaf
\q2 a yáne wafrogh yam yéfe Israil árét.
\q1 \v 8 Yuré siyém ngárám a ghérghérsisé téfnár,
\q2 afraye yém nékwot a kwénjtafnar uwégh kér ro yém.
\q1 \v 9 Yémo yau so túmén yénémrone
\q2 yau so yém nékw túmén.
\q1 \v 10 Yémo yau tékratan yénékmete téfene méinyotio yaufi yammén;
\q2 fá yau máméghéraye nafghete téfefaf, némat yénd ménde yéném.
\q1 \v 11 Ménamén yáne kwénjtafnar uwégh yéfeyot emofem férférafé yéfandat
\q2 yém ndimbal ndené tuk njafar kés em yéughanyo mband yém.
\q1 \v 12 Yémo té ewitrémb téfene yaufiyam nayu téfeta
\q2 ndené wér kétán naikai.
\q1 \v 13 Yuré siyém ndenanit afé yánjo ambumtértérat,
\q2 a ngárám yéfeyot emofem férférafé yéfandat fá.
\q1 \v 14 Ménamén fá mat yém nderé muyafnar yénd yéném;
\q2 fá kawafarotangé ndené yénd mé ngwérméng yéném.
\q1 \v 15 Téfene kwéf mbandan sem ndenanit em yus;
\q2 ndenanit kéghat mbumbu, yénd ndram narametam a kér yéném.
\q1 \v 16 Mbormbor yénmaufete, a yénd nguwanongém-
\q2 ndenanit yénd yéna yau kar ténmorwén
\q1 \v 17 Wénde Yurane uwégh mé yakai tuot
\q2 yémafé emofem férférafé yéfandat fá.
\q1 Yáne wanjarégh nusamngote kétán ambumafene ambumfaf.
\q1 \v 18 Yéfeta efe em ndimbal mwighafé yáne arnégh yamfaf,
\q2 yéfeta emofem ewaitota yáne nák!
\q1 \v 19 Yuram té ewafrotam njafar yáne limánégh ámnjogh sifayé;
\q2 kétamé yémo yélimnde méinyotio rokar.
\q1 \v 20 Yarsam Yuré, fém njafar si résagh ár,
\q2 fém wafté kér ro emofem yaitotat yáne mwighé faroréghmén,
\q2 náyáretat yáne fénatayero yáne wafrogh sifaf.
\q1 \v 21 Néméwét, yarsam Yuré, fene njafar si résagh árfene fiyaré
\q2 emofem yafrotat yáne ásáfogh a yáne ménde.
\q1 \v 22 Yarsam Yuré, méinyotio rokar yémo yafrotam,
\q2 méinyotio rokar kété yáne limánégh kénjún.
\q1 Mat táyáto méinyotio ndené yéndon yarsan Yuré.
\c 104
\s
\q1 \v 1 Mat táyáto méinyotio ndené yéndon yarsan Yuré.
\q1 O Yuré tane Ngánján, nderé ndimbal fém ném!
\q2 Fém tombé sálámeye némamanetaménd utmanéghafé a sariafé.
\q2 \v 2 Fém némawotaménd kwayaghé tombé sálámeye.
\q1 Fémo té tafyangotau kéndafé marat sáláme njafaramé;
\q2 \v 3 fémo yafrotam tékutéku fene méngomén kété nu kwéfan.
\q1 Fémo eyátote nu kwéf fene os wérsamén rokar;
\q2 fémo ewawerete mbormborafene njamb.
\q1 \v 4 Njam sem fene si waitoghmén;
\q2 fés kanké em fene ásáfogh téfnár.
\q1 \v 5 Fémo yéfayoi mband marat yánjo téfén sifayan
\q2 ménát yau so kitérmbongé.
\q1 \v 6 Fémo yémanetam mband ménaye nu kéfére,
\q2 nu yéné árkéménayam tawafarngé mband tunakéf.
\q1 \v 7 Fene wafarégh sian nu táf ngefongé;
\q2 fene árurke njam kutnangé, wékeye táf yém ngefongé.
\q1 \v 8 Mband tunakéf nanotat a sémkéf newonat
\q2 yéné sifayat fémo ándan ewafaretai.
\q1 \v 9 Féyo fémo taikrataye ekemetam arakafafene fú,
\q2 ménát yau so wéikor tafarngé mband marat.
\q1 \v 10 Fémo ewafrote nu enefrone térkafe yékwamé tararesfaf,
\q2 féyo nu wérér nénefnotat kétamé mband tunakéfta.
\q1 \v 11 Yénayam yénrametat nu yéfeyot méinyotio wérárot,
\q2 a kéghat ndonkiyam nu ménde ewifotat.
\q1 \v 12 Men njén narametat nu wérér téndomé
\q2 a wagh yéngrametat wén kafeyamé.
\q1 \v 13 Fémo enwafarete nu yénamé mband tunakéfafmé kétamé njafar méngota,
\q2 a fémo so yafote mband marat mbwe funagh ásáfoghe.
\q1 \v 14 Fém eméinde yus anoghét ménát manjarégh wérárat
\q2 a wén rokar kés yéngém ménát sái néngásáfotat yéné yamé.
\q1 Fémo eumyote yéné ménát so efunat njamke kétamé mbandta-
\q2 \v 15 wain ménát so eyátote klisafé,
\q1 olif séfak ménát yéfene ngar merot,
\q2 a féskaf flawé ménát so ewaramete muyé.
\q1 \v 16 Yurane wén sem merkéráye wambghét,
\q2 yéné sedas wén Lebanonmén árké yémo eitam.
\q1 \v 17 Kété menam ewafrotat njén,
\q2 a watkuam méngo ewafrotat yéné wén yétkwénan sifres.
\q1 \v 18 Tukén mband tunakéf kénjún emor kété kéghat gout,
\q2 a wíman nufrotat átnogh sifayé yéfeyot.
\q1 \v 19 Fémo ewafrotam ghérare ménát wérwér fénataye so em,
\q2 a efogh mat yém njam so nénguite.
\q1 \v 20 Yémo yéngwafarete kwéfité, a kénamndangé sémbár,
\q2 táf méinyotio wérár nokambotat métare.
\q1 \v 21 Féyo tot munjan ndimbal fus táf kwérnare kutnangi yéfenjo nénet,
\q2 tukénro njamket árkéméné Ngánjánam tawaramangé.
\q1 \v 22 Kété akwan fá métare aninjogh ngangongi
\q2 yéfenjo yékwét enaghét.
\q1 \v 23 Féyo ár néngwanoyénd yéfenjo ásáfoghét,
\q2 kété násáfotaménd kétánotio séite.
\q1 \v 24 O Yuré, némé fénatayero rokar fémo téngwafrotau!
\q2 Káfetaye fémo tangwafrotau méinyotio.
\q2 Mband marat siyém fene wafroghmén rokar afoghare.
\q1 \v 25 Yéné yém arakaf, ndimbal a marat,
\q2 yérafte fénatayero rokar,
\q2 ndimbal a némbnar.
\q1 \v 26 Yéfandati bout kés yiyota
\q2 dugon árkéméné fémo ewafrotam kembne néngambnat arakafan.
\q1 \v 27 Fá méinyotio namyotat fefaf
\q2 ménát sái ewarameta njamke fá ménde kés em.
\q1 \v 28 Njam fémo tawaram, yémofem eumendat.
\q2 Fémo tásáfogh fenjo ngángé ménát sái ewanjnafé,
\q2 a fá mindefifi eremngote.
\q1 \v 29 Wénde njam fémo sém tawengo yéfe, yéfene tikéf natnat.
\q2 Njam fémo tanwango yéfene ambone,
\q2 fá kér em a kwawengongi wéikor ngwérméngot.
\q1 \v 30 Njam fémo tawaram fene ambone, ghérsé kufrotangé,
\q2 a fémo wéikor totér tényáto mbandoene sáf.
\q1 \v 31 So Yurane ndimbal kwayaghé nusamngote tuot!
\q2 Yuram klisa yérse yéné yam némé yémo ewafrotam.
\q1 \v 32 Mband ngernger yém yáne kwayaghamén,
\q2 a mband tunakéf kwam yáne yanjaghan.
\q1 \v 33 Yéndo so wagh erametan Yurai yéné teke ghérsé swém.
\q2 Yéndo yarsan tane Ngánján kétán tane ambone ánde so yiyáto!
\q1 \v 34 So tane méinyotio mwighé em méndefé yáfaf,
\q2 ménamén yénd náuwetan Yurane kénjún.
\q1 \v 35 So méinyotio yaufiyam téfnár nérndat kétamé mband maratta;
\q2 so yaufiyam tiyárégh ár kolindangé ambino.
\q1 Mat yiyáto méinyotio ndené yéndo yarsan Yuré.
\q1 Yarsan Yuré!
\c 105
\s
\q1 \v 1 Yarametati kánjo Yurai a néngafrotati yáne ndimbalmén.
\q2 So méinyotio mband marat mat yém némé yémo tafrote.
\q1 \v 2 Wagh erametati yáyot, néméwét, eufanati yáne warsagh wagh.
\q2 Ewaufrotati méinyotio árét ménamén yáne mer wafroghmén.
\q1 \v 3 Yuyotati yáne njúnnjúnofnar yétkwén,
\q2 náuwetati, fém emofem yáwefnotati Yurai.
\q1 \v 4 Yéronja Yuré a yáne muyé;
\q2 ménjtaye yéronja fá.
\q1 \v 5 Ewafarotati sariafé yam yémo kés tawafrote,
\q2 yáne sélngwélafé yam, a limánégh yémo té ewaramai.
\q1 \v 6 Fém Ebraamene ásáfogh ároene ambumtértér,
\q2 fém Jeikofene Aki ambumtértér yáne kaféghménfifi.
\q1 \v 7 Fá yém Yuré téfene Ngánján.
\q2 Yáne mbarkánd yam yéfandat yénamé mbandan.
\q1 \v 8 Fá túmén yakai yánjo rényégh sian
\q2 té si yufoi kétán tausen ár saté kénjút.
\q1 \v 9 Yéné fiyém rényégh yémo yafrotam yémafé Ebraam
\q2 a kwérnare si sot norayai yáfaf Aisek.
\q1 \v 10 Yémo efalo yiyátoi Jeikofefaf ménamén fété wafarégh yémormén,
\q2 a kétán Israil árfefaf ambino rényégh efoghofnar.
\q1 \v 11 "Yéndo so tawaraman féfe Kanan mband
\q2 ndené fété féfene fénaté ásáfogh sifayé."
\q1 \v 12 Fá norayai yéné táf njam tárfárofnar tamorwén,
\q2 mé fénaté mérén wan téfnár Kananén.
\q1 \v 13 Fá yénamé kwéwérsotawét ámb ndimbal yu kétán ámb ndimbal yu,
\q2 kétamé ámb warsagh árfene ndimbal yu kétán ámb warsagh árfene ndimbal yu.
\q1 \v 14 Wénde yémo yau efe yumyoi sái mwighé kértayan tákmangai fá.
\q2 Yémo tawawéngsotau warsagh ár yéfene téfnan.
\q1 \v 15 "Yau táf eyanjati tane kaféghmén ár,
\q2 a yau táf ewasérmbotati tane mat yátogh ár."
\q1 \v 16 Yémo yamnendai káukáu Kanan mbandan,
\q2 tangénfetau yéné sifayé njamke árkémé tanmorwén.
\q1 \v 17 Féyo yémo yéngwafaretam ámb ár kétán Ijifét fronde Josef yéfeta-
\q2 efe yéngtérnayénd néngamndai faiofnar ásáfogh ár.
\q1 \v 18 Yémofem yáne kafkaf tasénawét ménaye seine yaumbayénd
\q2 a kémamé yarendayénd tot téfne.
\q1 \v 19 Kétánotio efogh yénmormén ánde yáne onjo efalo náyátoi,
\q2 Yuram tufotau Josefene yam.
\q1 \v 20 Féyo Farawam enwafaretam yáyot a yéferyéng
\q2 ndimbal yu limánégh téfnáram yésawéryéng yáne kwéfkwéf méngo fasa.
\q1 \v 21 Josef yékmayénd méinyotio warsagh árfene méngo wanjengéghét;
\q2 fá nénamndai méinyotio warsagh árfene limánégh ásáfogh sifayé résagh ár.
\q1 \v 22 Yémo so watamegh si tawarametau warsagh árfene sénko árét yéfene ménde tawawafrotau
\q2 a tawatametau warsagh árfene wawanjagh téfnár.
\q1 \v 23 Féyo Israil nufaryéng Ijifét;
\q2 Jeikof témorangérwén dabi ár Amene mband.
\q1 \v 24 Féyo Yuram yéfunai Israil ár
\q2 kétánotio kor nénamndayénd minde muyafé yéfene mék téfnárafé ásméghét.
\q1 \v 25 Féyo yémo ewengoi Ijif ár sém enwawengoyénd Israil árét,
\q2 kwankwane mwighé téfaronawét Yurane ásáfogh ár sénanéghét.
\q1 \v 26 Wénde Yuram yéngwafaretam Moses yánjo ásáfogh ár,
\q2 yémafé Aaron, efe yémo ekafeyai.
\q1 \v 27 Yémofem tawafrowét sélngwélafé ufarogh yam Ijif árfefafmé,
\q2 a sunsunafé Amene mbandan.
\q1 \v 28 Yuram yérautoi Ijif kwéfitaye,
\q2 ménamén yémofem té yutmayénd yáne wafarégh si ménát sái taumyongayénd yáne ár nguwanongayénd.
\q1 \v 29 Yémo tawengongai yéfene nu férkat,
\q2 a tarnau méinyotio yéfene wagif.
\q1 \v 30 Féyo ndokreyam nofayoi mband
\q2 a tasnendawét warsagh árfene kémégh sifayé.
\q1 \v 31 Njam Yuré korayangai, mberang kénewérngayénd Ijif árfefaf,
\q2 a wakéwakwo séfam nofayoi Ijif.
\q1 \v 32 Yémo tawanfaretau yéfeyot kérufrat nu saisai yau nufifi,
\q2 a toyé kálálangayénd mbandan.
\q1 \v 33 Yémo tawawérmbotau yéfene graf wén ménj a fig wén
\q2 a téngrafnau méinyotio wén.
\q1 \v 34 Fá korayau, a séfafé ngumbainy tanmorwén-
\q2 tosé ngumbainy wafoghofnar.
\q1 \v 35 Yémofem néneyan tifotawét méinyotio mer árauafé wén yéné yuwon,
\q2 téngwasérmbotawét méinyotio yéfene ndau rokar.
\q1 \v 36 Féyo tasmetau fronde sénko ambum Ijif árfene méngomé,
\q2 tuktuk árfefaf a áuwégh mérnafefaf.
\q1 \v 37 Yuram enéutoryéng yánjo ár kétamé Ijifta, silfé awasoghkaf a gol;
\q2 a yau ámb ár sénkota Israilmén nuyai.
\q1 \v 38 Ijif ár áuwéghan tamorwén njam néngwanoyénd,
\q2 ménamén yémofem férférafé tafandawét ndimbalkéráye.
\q1 \v 39 Yuram ewafarnai njafar kwamkwam yéfene tukén,
\q2 a ewafaryéng a ewaramai yéfe ndimbal fés tuwarotau kwéfita.
\q1 \v 40 Fá komnendangayénd fasoyot, a yémo tanwafaretau men yétkwén suweki;
\q2 yémo suafé táyátongai mana flawaye njafarmén.
\q1 \v 41 Yémo téfarorngai tésawérngai wím, a nu kénasurngai
\q2 tafrotangai wanje yénamé ghérnat ménd mbandamé.
\q1 \v 42 Ménamén fá nawafarotai yáne ámb fénaté unyéghofnar si
\q2 kétán yáne ásáfogh téfnaroefaf Ebraam.
\q1 \v 43 Féyo yémo enéutoryéng yánjo ár Ijifta áuwéghafé,
\q2 yáne kaféghmén ár kénauwetawét.
\q1 \v 44 Yémo tawarametau mband yánjo árét yéfenemén ámb ngánján wáwefnogh yu kés tamorwén,
\q2 a yémofem wagh yuwon tantanawét njamke téfén yéné ámb árém árké tangeitawét.
\q1 \v 45 Méinyotio yéné kufrotawét ménát yémofem so tawaitotawét yáne wafatarégh si
\q2 a káyáretawét yáne sifaf.
\q1 Yarsam Yuré!
\c 106
\s
\q1 \v 1 Yarsam Yuré!
\q1 Yarametati kánjo Yurai, ménamén fá siyém mer!
\q2 Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 2 Emo so ekayote ndimbal kwayaghé sélngwélafé yam Yurane?
\q2 Emo so féyotaroe yarse?
\q1 \v 3 Kété yém áuwégh yéfeyot emafé néngawarmanetat mbarkándro ámb árfé
\q2 a túmén ewafrotat némé em mbarkánd.
\q1 \v 4 Wafarota yénd, Yuré, njam fémo yuyafota ménde fene árét;
\q2 kénaf kaka a kwanjar yénd.
\q1 \v 5 Kwumyo so yénd wafnyangé fene kaféghmén árfene mani ngonjélan.
\q2 So yénd náuwetan fene árfene áuwégh kénjún;
\q2 so yéndo némuetan yémafé efe em fene.
\q1 \v 6 Téfene ákife yame yénd té yaufiyam kufrotam.
\q2 Yéndfem té tafrotam mámáfi! Yénd té kimndam mámáfie!
\q1 \v 7 Téfene ákif Ijifén
\q2 yau tikéftikéf tamorwén Yurane sélngwélafé yaman.
\q1 Fá tekofnar tawawalindangai yáne tárfár kwénjtafnar yam wafrogh yéfefaf,
\q2 wénde yémofem sém yawengoyénd kété férkat arakafan.
\q1 \v 8 Féyo yémo ewanjaryéng fá
\q2 ménát yánjo yétkwén
\q2 so tamarotau yánjo muyé kér ro wafté.
\q1 \v 9 Yémo yafaretai Férkat arakaf ghérnat nufrotam.
\q2 Yémo elimai Israil ár kéférmetawét arakaf ndenanit fanfne yu kar témorwén.
\q1 \v 10 Féyo yémo ewambai fá yéfene mék téfnarafeta
\q2 a ewanjayéng yéfene mék téfnárafeta.
\q1 \v 11 Féyo nu nawengoi a ewafaryéng yéfene mék téfnár;
\q2 yau ámb efe nunjaryéng.
\q1 \v 12 Féyo yáne árém efalo yiyátoyénd yáne unyéghofnar si.
\q2 Féyo yémofem wagh tufanawét yáyot.
\q1 \v 13 Wénde tekofnar fá tawawalindangai némé yémo tawafarotau!
\q2 Fá yau kwénjetawét yáne fénaghét.
\q1 \v 14 Fanfne yuwon onon namndayénd yéfene ménde yaman,
\q2 tufotawét Ngánjánene métar yéné ghérnat ménd yuwon.
\q1 \v 15 Féyo yémo tawaramangai némat tamnendangayénd,
\q2 wénde yémo yénayafé tanwafaretau kérté yamafé.
\q1 \v 16 Ár kété méngo aramégh sifayan tamorwén taramnjawét Moses
\q2 a méndménd tamorwén wéi Aronefaf, Yurane njúnnjúnofnar ghéngén warogh ár.
\q1 17w\~
Yéné téfénmén, mband násáfoi;
\q2 néloi fá Datan
\q2 a yiyátotam fá Abiram a ámb áyáréghofnar ár kés em.
\q1 \v 18 Fés nuyai yéfene waitogh árfefaf;
\q2 a yaufiyam wafrogh ár kankékankéam ewifoi.
\q1 \v 19 Árém yafrotaménd kau tosé kété Sainai mband tunakéfan;
\q2 yémofem táwefnotawét yéné golmén wafroghmén kau sáf mbanmbanoe.
\q1 \v 20 Yémofem maniot yétérnayénd yéfenjo ndimbal kwayaghé Ngánján
\q2 yéné kau sáf mbanmbanot kar yus ténetau.
\q1 \v 21 Fá ewawalindai Ngánján, yéfene wanjarégh ár,
\q2 emo té tawafrotau ámb ndimbal yam Ijifén.
\q1 \v 22 Ámb mer yam Amene mbandan,
\q2 ámb férférafé yam wafrogh kété Férék arakafan.
\q1 \v 23 Féyo fá ambone norayai yémo so tawalindangé.
\q2 Wénde Moses, yáne kaféghmén ár, nokayoi Yuré a árfene néndkéfan.
\q2 Yémo yamnendai ménát yau so nékw témorwén a yau so tawalindangai.
\q1 \v 24 Ár nakenayénd yau nényawayénd méndefé mbandfaf,
\q2 ménamén yémofem yau yiyátoyénd yáne unyéghofnar si fá siya tawarawenau.
\q1 \v 25 Wénde, fá mikemikefé kafghetawét yéfenjo farai méngomé
\q2 a kakenawét ménát yau so tiyáretawét Yuré.
\q1 \v 26 Yénémamén, fá fénofnar sotafé si norayai
\q2 ndené yémo so kérotio tasmetau fanfne yuwon,
\q1 \v 27 ndené yémo so tawafarnau yéfene ákiambum yénamé ndimbal yu,
\q2 kés tamorwén sémta tawayangai nayu mbandamé.
\q1 \v 28 Féyo téfene ákif nufnyayénd Baal wáwefnoghfaf kété Feor;
\q2 yémofem wéi enetaménd kér árfene ghéngén ramégh njamke!
\q1 \v 29 Yémofem nékwafé téfghétawét Yuré yéné méinyotio yame,
\q2 féyo kértafé yam natyaryéng yéfefaf.
\q1 \v 30 Wénde Fineas féyotaro yémormén
\q2 a mé nényawai táf kértafé yam nefoi.
\q1 \v 31 Féyo fá yinjoyénd ndené mbarkánd ár
\q2 témorwén yéné efghon táf.
\q1 \v 32 Kété Meriban, wéi, yémofem nékwafé téfghétawét Yuré,
\q2 tawafrotawét Mosese mindefifi kérté.
\q1 \v 33 Yémofem téméndawét Moses nékwafé,
\q2 a fá si nufngoi máméghéraye.
\q1 \v 34 Israil ár mwighayan nuyayénd ménát sái tawironawét ndimbal yu mbandan,
\q2 ndernaye Yuram yéta ewafaretai.
\q1 \v 35 Wénde fá kafghétawét téndo árfefaf
\q2 a térsawét yéfene yaufi wafrogh yam.
\q1 \v 36 Yémofem tawáwefnotawét yéfenjo mewangat,
\q2 árkéménayam talimndau uyéghfaf.
\q1 \v 37 Yémofem wéi ghéngén tawafrotawét yéfenjo ghakér ambum
\q2 a mérés kétán yaufi mbérmbérafefaf.
\q1 \v 38 Fá mend ár férék kértawét,
\q2 yéfene férék ghakér ambumafene a mérés.
\q1 Ménaye tawafrotawét ghéngén Kanan mewangofaf,
\q2 yémofem yéraryénd mband ményan ár ngian.
\q1 \v 39 Fá mámáfi kawafrotawét farofaro ménaye yéfenjo yaufi wafrogh yame,
\q2 a yéfene uwégh sáf mbanmban namndai áwéréghanyo awanégh Yurane sáfan.
\q1 \v 40 Yéné téfnan Yurane nékw kakérnau yánjo árfefaf,
\q2 a yémo tétnotau yánjoyo ásáfogh sifayé.
\q1 \v 41 Yémo eramai kétán téndo ndimbal yu kés tamorwén,
\q2 a fá yémofem talimndawét emofem tékrat tafandawét.
\q1 \v 42 Yéfene mék téfnáram tarnotawét
\q2 a tanérsawét yéfene wasérmbogh wafté mbanmbanot.
\q1 \v 43 Túmén férghe yémo tawanjanau,
\q2 wénde fá ménde tamorwén yau sái tiyáretawét fá,
\q2 a fá féyotio tawalindangai yéfene yaufiyamam.
\q1 \v 44 Féyo, fá ghérghérsisayam terangai yéfefaf yéfene uwérsoghan
\q2 a táyárangai yéfene ye.
\q1 \v 45 Fá kawafarotangai yáne rényéghyam yémafé
\q2 a afrát kamndangayéng ménamén yáne kwénjtafnar uwégh.
\q1 \v 46 Yémo wéi taméindangai yéfene werégh téfnár
\q2 ménát so tawanjetawét kwénjtafnar.
\q1 \v 47 Ténmanjar yénd, O Yuré téfene Ngánján!
\q2 Ténmumenda wéikor yénamé ndimbal yu sem,
\q1 ménát yéndfem so kánjo yarametam fene njúnnjúnofnar yétkwénoe
\q2 a náuwetam a némarsam fém.
\q1 \v 48 Némarsam Yuré, Israil árfene Ngánján,
\q2 efe mé nénakete kétándmayo tuot!
\q1 So méinyotio ár norayat, "Efalo!"
\q1 Yarsam Yuré.
\c 107
\s
\q1 \v 1 Yarametati kánjo Yurai, ménamén fá yém mer!
\q2 Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 2 Té Yuram ewanjaryéng fém? Féyo néngafrotati!
\q2 Ewaufrotati ámb yémo té ewanjaryéng fém kétamé féfene mék téfnárafeta.
\q1 \v 3 Ménamén yémo té eumendai orsogh ár kétamé tárfár mbandta,
\q2 kétamé wérta a mbormborta,
\q2 kétamé yambérmata a naikaita.
\q1 \v 4 Ámb mé koyáretawét fanfne yuwon,
\q2 nolindayénd a méngofnar tamorwén.
\q1 \v 5 Njamke siogh a nuot wéi siogh ndenáyo,
\q2 kaka kérotro tamorwén.
\q1 \v 6 "Yuré, ténmáutána!" fá kutnawét yéfene kértayan,
\q2 a yémo tawanjarngai yéfene tékratta.
\q1 \v 7 Yémo talimangai mbarkándaye kétán wambéghfaf,
\q2 yéné ndimbal tesenfaf ánde so tamorangérwén.
\q1 \v 8 Taumyo so yarsat Yuré yáne ndimbal uwéghmén
\q2 a ménamén mer yammén yémo stawafrotau yéfeyot.
\q1 \v 9 Ménamén yémo taremngongé fá efe nuam eramete
\q2 a ewafote siogh ár mer rokare.
\q1 \v 10 Ámb kamnjongayénd kwéfitayan a kénjkam kwéfkwéfan,
\q2 nák méngot tanyawangayénd áuwéghofnar tot téfén seinafé.
\q1 \v 11 Fá yau káyáretawét Ngánjánene si,
\q2 tékenawét Minde Tukoene wawanjagh.
\q1 \v 12 Yéné téfnan yémo tákmangai táikér ásáfoghan;
\q2 fá kuyangayénd, a efe ámb yau kété témorwén yéfe wáutárghét.
\q1 \v 13 "Yuré, ténmáutána!" fá kutnawét yéfene kérté yaman,
\q2 a yémo tawanjarngai kétamé yéfene uwérsaoghta.
\q1 \v 14 Yémo talimangai kétamé kwéfitata a kénjkam kwéfkwéfta,
\q2 yémo tawafngongai tiyárégh sein.
\q1 \v 15 Taumyo so yarsat Yuré ménamén yáne ndimbal uwéghmén
\q2 a ménamén mer yam yémo kés tawafrotau yéfe.
\q1 \v 16 Ménamén yémo tarafnau yéfene ár nyawéghmén nák méngo fasa yuwot bronj tot téfénmén;
\q2 yémo tanfangai karéf tawafrotangai yéfene tot téfén fu.
\q1 \v 17 Ámb tamorwén onon; fá yau káyáretawét
\q2 a tékratan tamorwén yéfenjo yaufiyammén.
\q1 \v 18 Fá njamke mwighafnar kokayongayénd
\q2 a fá tamorwén kér fasayan kwáutánawét.
\q1 \v 19 "Yuré, ténmáutána!" fá kutnangayénd yéfene kérta yaman,
\q2 a yémo tawanjarngai yéfene uwérsoghan.
\q1 \v 20 Yémo téngwafaretangi yánjo si
\q2 a mer táyátongai tangétnongai kétamé kér sésafneta.
\q1 \v 21 Taumyo so yarsat Yuré ndimbal uwéghmén
\q2 a ménamén mer yam yémo kés tawafrotau yéfeyot.
\q1 \v 22 Taumyo so erametat kánjo ramégh ghéngén
\q2 a wagh áuwéghafaro so erametat ménamén yáne ndimbal kwayaghafé wafrogh yam.
\q1 \v 23 Ámb engmormén arakafot ménát boutamé sái tafandawét
\q2 túmén téngrametawét maniot rokar witérmbogh end mband maratoene.
\q1 \v 24 Yémofem, wéi kor téfandawét Yurane wafté wafrogh yaman,
\q2 yáne minde kérmbanéghafé ásáfogh kénjkam arakafan.
\q1 \v 25 Fá korayangai a mbormbor kokayongai
\q2 tangwanjmetau sof.
\q1 \v 26 Yéfene bout tangwitau ndenae njafar kés em
\q2 a nguyangai wéikor yékwét;
\q2 wawerégh téfnár férférmén kaknyangayénd.
\q1 \v 27 Fá sénko wériot tawawindau a kawakayotawét wérinit
\q2 a yéta fá témorwén mwighé yéta tawafrotawét kerkeran.
\q1 \v 28 "Yuré, ténmáutána!" fá kutnangayénd yéfene kérté kénjún,
\q2 a yémo tawanjarngai kétamé yéfene uwérsoghta.
\q1 \v 29 Yémo métar tiyátongai mbormbor yénan kéme
\q2 a imanéghofnar táyátongai sof.
\q1 \v 30 Némé frengégh témorwén imanéghofnar stayátongai
\q2 a tanemnjau tanwarawenau yénanotio surfaf.
\q1 \v 31 Taumyo so yarsat Yuré ménamén yáne ndimbal uwéghmén
\q2 a ménamén mer yam yémo kés tanwawafritan yéfe.
\q1 \v 32 Taumyo fá so yuyotat marataye ár sáfan
\q2 a ndimbal yu limánégh árfene sáfan.
\q1 \v 33 Yémo ewengote wanje fanfneyot,
\q2 a wérár nu ghérnat nu siogh mbandot.
\q1 \v 34 Yémo ewengote mbwe funagh mband kétán solnit fifiofnar mband kamndangi
\q2 ménamén yéné árfene yaufi yammén efe kété ekém.
\q1 \v 35 Wénde yémo wéi fanfne yu ewengote nu
\q2 ndémnguot ghérnat mband ménát wérér nuot.
\q1 \v 36 Yémo enérse siogh ár ménát méngo so narametat kété
\q2 a engrametat yéfenjo ndimbal tesen.
\q1 \v 37 Yémofem yéngéitat yéfenjo ndawan, engéitat géreif mbwe ménj fuamé,
\q2 engnetat térkérro njamke yéfenjoyo.
\q1 \v 38 Ndenaye yémo efrende fá!
\q2 Fá ndimbal mérén té namndangi kété,
\q2 a yéfene séf manjarégh kau marat káyátotawét.
\q1 \v 39 Njam yéné neworyénd yuwot waféghan a nénamndayénd
\q2 yauyau yéné kénjúmé mwighé tékrat, kérté yam, a ye,
\q1 \v 40 Yuram yasuryéng utmanéghofnar yam kétán yéfene séfakro árfefaf
\q2 tameindau namnam ténamndawét endofnar mé yuwomé.
\q1 \v 41 Wénde yémo ewanjane yauyau ár kérté yam kénjún
\q2 a yéfene mérén eyátote tárfár ndenanit sif mérén.
\q1 \v 42 Ngánján ghérsafé árém so efandat yéné yam
\q2 a náuwetat, táf yaufi ár métar tawafrotangé.
\q1 \v 43 Fá efe em kafeta mwighafé so yéné méinyotio tanangi tikfé
\q2 yémofem so yéngfandat téfene ufrogh yammén Yurane ndimbal mwighafé uwégh.
\c 108
\s
\q1 \v 1 Tane tikéf siyém táikér mwighafé yém fefaf, O Ngánján;
\q2 némamén wét yéndon so fene warsagh wagh yérametan ménaye méinyotio tane tikfe!
\q1 \v 2 Kanend, laire a arf!
\q2 Yénd so akwan kanon tane waghafé.
\q1 \v 3 Yéndo so kánjo némarametan fe, Yuré, méinyotio ár kénjún.
\q2 Yéndo so fene warsagh wagh yéngrametan yénamé ndimbal yuwomé.
\q1 \v 4 Ménamén fene kwénjtafnar uwégh siyém minde tukén ewainde njafar.
\q2 Fene ndimbal mwighayam eyanje nu kwéf.
\q1 \v 5 So némnyotat, O Ngánján, minde tuk njafar tukmé.
\q2 So fene ndimbal kwayaghé nálálégh yéma méinyotio mbandamé.
\q1 \v 6 Sénonjo ghérsé tawérte fene áuwéghafé ár.
\q2 Kénwango a ténmanjar yénd ménaye fene waftaye.
\q1 \v 7 Ngánján té unyéghofnar si norayai yéné yánjo njúnnjúnofnare:
\q1 Yéndo so téfalon sekem áuwéghafé.
\q2 Yéndo so mato etémndan Sukotén mband eworégh.
\q1 \v 8 Giliad siyém tane,
\q2 a Menase, wéi.
\q1 Efraim, tane walaf, yémo so efune tane mék téfnár,
\q2 a Juda, tane wétu, so efune tane warsagh ár.
\q1 \v 9 Wénde Moab, tane umbarégh merekin, so kénamndangé tane ásáfogh téfnár,
\q2 a yéndon so tawányányon tane kafkaf yáfaf Edom
\q2 a nutnan minde remngoghafé Filistainfaf.
\q1 \v 10 Emo so wénérse yénd kétán wimanéghofnar ndimbal tesenot?
\q2 Emo yénérse tayot waingégh ménát sái taindangén Edom?
\q1 \v 11 Té fémo yénkena yénd, O Ngánján?
\q2 Yau so wét fém folen nufrotati yémafé téfene fiyarafé?
\q1 \v 12 O, yénmáutána téfene sénanégh mék téfnárafet,
\q2 ménamén méinyotio árfifi wáutárégh siyém fifiofnar.
\q1 \v 13 Ngánjánene wáutárghan yéndfem so ewafrotam ndimbal yam,
\q2 ménamén yémo so engtarmete téfene mék téfnár.
\c 109
\s
\q1 \v 1 O Ngánján, efe yéndo yarsan,
\q2 yau némakai métar a nayu
\q1 \v 2 táf yaufi árém njangén wérsat
\q2 a néngafrotat unyégh si tanemén.
\q1 \v 3 Yémofem kwarendangi yénd tékrat siafé
\q2 a ngi kwafngongi fifiofnar.
\q1 \v 4 Yéndo euwetan fá, wénde yémofem yéta wasérmboghét wérametat
\q2 ménaye mérorégh táf yéndo mé Ngánjánafé norayan yéfenemén.
\q1 \v 5 Yémofem fai wanwangotat yaufiero mer téfnan,
\q2 a méndménd em tane uwéghmén.
\q1 \v 6 Fá norayat, "Ténmanangi yaufi ár yá sénanéghét.
\q2 Ténmatemb amrorégh ménát sái tafngongé fá.
\q1 \v 7 Njam yáne kérté yéngém kétán moghfaf,
\q2 tumyong so témndangi kértayafé yém.
\q2 Ewaftati yáne yaufiyamafé Ngánjánafé orayégh.
\q1 \v 8 Taumyo yáne yúnjéf so em tárfárofnar;
\q2 tumyo ámb árom so tanangé yáne ásáfogh sifayé.
\q1 \v 9 So yáne ambum kénamndangi afafnar,
\q2 a yáne amaf séfarékw.
\q1 \v 10 So yáne ambum néngawarendat aem omnengégh téfnár
\q2 a so engwéutonat yéfene afrengéghofnar méngota.
\q1 \v 11 So téréf wangoghofnar árém yéronjat yáne marat sifayé,
\q2 a ámb nayu árém táf tawanangi méinyotio yémo té téfune.
\q1 \v 12 Efe ár yau tumyo ramégh kér ro sari yém yáfaf;
\q2 yau tumyo ámb ár sái ghérghérsisé yém yáne afafnar ambumtértérafefaf.
\q1 \v 13 So méinyotio yáne ambum kér em.
\q2 So yáne mérnafene yétkwén kolindangé yéné ámbiro ároene satayan.
\q1 \v 14 Yuram yau so mwighafnar tawayangé yáne yárefafene yaufiyam;
\q2 yáne yátmafene yaufiyam yau so kawalindangi wafaroghofnar.
\q1 \v 15 So Yuram túmén ewafarote yéné yaufiyam
\q2 a so yáne yétkwén kolindangé árfene mwighata.
\q1 \v 16 Ménamén yémo ekene méinyotio ramégh ghérsé kétán ámb árfefaf;
\q2 yémo máméghéraye tangérnotau yauyau ár a áronjagh ár,
\q2 a fá yéfe áligh karotau tikfan efe kafrendawét a tákmangai kérot.
\q1 \v 17 Yáne méndefé fandagh sái tawafalngotau ámb ár
\q2 sénonjo fémo fá tafalngo.
\q1 Yémo yau efrende ámb ár;
\q2 sénonjo yau yéfenda.
\q1 \v 18 Wafalngogh yáyot siyém ndenanit mer ghérsé kar yém yawo sálámenit,
\q2 o ndenanit nu njam yéneta,
\q2 o ndenanit mer njamke njam eneta.
\q1 \v 19 Sénonjo so yáne mbawar kénangongé a kawamangé yáfaf ndenanit sálámé
\q2 so yéné eumbang yáfafmé ndenanit beles.
\q1 \v 20 So yéné mbawar kénamndangi tékratan sái tákmangé
\q2 tane mérorégh téfnár efe korayat yaufi si tafaf.
\q1 \v 21 Wénde merkéráye tafngo yam tafaf, O Warsagh ár Yuré,
\q2 ménamén fenjoyo yammén!
\q1 Ghérsé kwurto yénd
\q2 ménamén fém ném ndimbal mwighé kér ro a mer.
\q1 \v 22 Ménamén yénd wém yauyau a aronjagh ár,
\q2 a tane tikéf siyém ndémke afoghare yém.
\q1 \v 23 Yénd nawaindan ndenanit kwéfité mbanmban;
\q2 yénd kwésenangi ndenanit ngumbany.
\q1 \v 24 Tane budém sem muyafnar ménat awafarmanéghét,
\q2 a yénd wém sotkéf a sotro.
\q1 \v 25 Yénd wém kembne wénwambnat árém méinyotio sifayamé;
\q2 njam yémofem kwinjongi, yémofem sénko tasamnetangi utmanéghofnar.
\q1 \v 26 Kwáutána ta, O Yuré tane Ngánján!
\q2 Kwanjar ménamén fene kwénjtafnar uwéghmén.
\q1 \v 27 Taumyo fá ménát so yéfandat ndené yéné siyém fene wafrogh yam,
\q2 ndené fémo fémonyo té tafrote, Yuré.
\q1 \v 28 Féyo taumyo fá so mbawaran kwékmangi njam fá em ménde,
\q2 wénde fémo so wéfrende yénd!
\q1
\q2
\q1 \v 29 So tane mérorégh téfnár ewawo sáláme áuwéghofnar,
\q2 so yéfene yuwan áyátogh ghérsayam ewafne ndenanit sodé.
\q1 \v 30 Wénde yéndo so yarametan féréghe kánjo si Yurai,
\q2 yéngwarsan méinyotio árfefaf.
\q1 \v 31 Ménamén fá kokayongé aronjagh árfene téndota,
\q2 kafrendangé ménát so tawanjarngé fá yéfeta emofem méndefnar efandat.
\c 110
\s
\q1 \v 1 Yuré norayai kétán tane Yurafaf,
\q2 "Kámnjo yéna tane utmanégh sifayan tane tambén ngangata
\q1 kétánotio yéndo yuwan tákman fene mék téfnár,
\q2 táyáton fene kafkaf mbanmbanan ánde fene kafkaf so efai."
\q1 \v 2 Yuram so marat yéngyátote fene wafté kér ro limánégh ámnjogh sifayéan kétamé Jerusalem;
\q2 fémo so elimnde fene mék téfnár.
\q1 \v 3 Njam fém kuwano mékot,
\q2 fene árém so némausáfotat fe tikfe.
\q1 Fém so némamanetat njúnnjúnofnar sodae,
\q2 a fémo muyé so yérse túmén efogh ndenanit akwan es yénau em.
\q1 \v 4 Yuram té kwérnar si noraye a yau so térafarngé yánjo si:
\q2 "Fém ném ghéngén warogh ár tuot ámb rérero Melkisedekfé."
\q1 \v 5 Yuré yakai fene tambén ngangata fe wambéghét.
\q2 Yémo mér engtarmete tárfár warsagh ár njam yáne nékw kokayongé.
\q1 \v 6 Yémo so tékratan tákmangé ndimbal yu
\q2 a yéfene mband kér wén árém so kofayongé;
\q2 yémo so etyane sénko méinyotio mbandan.
\q1 \v 7 Wénde fá so eske néngutne wérér nuamé alighan endmé.
\q2 Fá so yém waingégh téfnár.
\c 111
\s
\q1 \v 1 Yarsam Yuré!
\q1 Yéndo so yarametan kánjo Yurai méinyotio tane tikfe
\q2 njam yénd nafangotam yáne ngánján ghérsafé árfé.
\q1 \v 2 Nderé sélngwélafé Yurane wafrogh yam em!
\q2 Méinyotio efe ndimbal ménde em yáfaf so mwighé mé nemne yéfenemén.
\q1 \v 3 Méinyotio yáne yam wafrogham yuyafote yáne ndimbal kwayaghé a wafté.
\q2 Yáne mbarkánd yam yau kuyangé.
\q1 \v 4 Yémo yénméinde yénd ménát sái yafarotam yáne mer ásáfogh.
\q2 Nderé ngárám a ghérghérsisafé yém téfene Yuré!
\q1 \v 5 Yémo ewaramete njamke yéfe emofem férférafé yéfandat fá;
\q2 yémo túmén yéfarote yáne rényégh yam.
\q1 \v 6 Yémo té yuyafoi yánjo ndimbal wafté kétán yánjo árfefaf
\q2 ménaye ewaramai ámb ndimbal yuafene mband.
\q1 \v 7 Méinyotio yémo ewafrote mbarkánd a mer,
\q2 a méinyotio yáne nák em mwighafé.
\q1 \v 8 Yéné em efalo tuot,
\q2 ménát sái ewaitotam ndimbal mwighaye a efalo ghérsaye.
\q1 \v 9 Fá té fai nufrotam méinyoye yaufiyammén yánjo árét.
\q2 Yémo té yumyoi yánjo rényégh yam yémafé tuot.
\q2 Némé njúnnjúnofnar, férfér tikéf anambéghafé yétkwén yém yáne.
\q1 \v 10 Yurafaf férfér siyém efalo káfeté mwighé téfén.
\q2 Méinyotio árém emofem ewaitotat yáne nák so nanotat káfeté mwighayan.
\q1 Yarsam fá tuot!
\c 112
\s
\q1 \v 1 Yarsam Yuré!
\q1 Nderé áuwéghafé em fá emofem férférafé yéfandat Yuré
\q2 a ndimbal ménde em ménayan ewaitotat yáne wafarégh si.
\q1 \v 2 Yéfene ambum sái em fifiafé méinyotio yuwomé;
\q2 méinyotio ár saté ngánján ghérsafé so em frengéghan.
\q1 \v 3 Fá fáyo so em mani kér ro,
\q2 a yéfene mer ásáfogh so naketat tuot.
\q1 \v 4 Kwayaghé nanete kwéfitayan yéfeyot ngánján ghérsafé árét.
\q2 Fá em marataye ramégh kénjún, ghérghérsisé kér ro, a mbarkándro.
\q1 \v 5 Mer yéném yéfefaf emofem ewarametan mani marataye
\q2 a yéfene ásáfogh ewafrotat ámb rérero.
\q1 \v 6 Ndené ár yau so taindangé yaufiyam.
\q2 Fá efe em mbarkánd ár so ewafarotat tek.
\q1 \v 7 Yémofem yau férférafé yéfandat yaufimén ghany;
\q2 yémofem mwighé taikre mwighafé yéfandat Yuré ménát so ewarawene fá.
\q1 \v 8 Fá em mwighé táikér o férférofnar
\q2 a so sáfe nafandat yéfene mék téfnárafé áuwéghafé waingéghmén.
\q1 \v 9 Yémofem ewaftat yuweke a ewarametat nitafnar yéfeyot efe em áronjaghan.
\q2 Yéfene mer wafroghyam so ewafarotat tuot.
\q2 Yémofem so mwighat emeindat a eutémndat.
\q1 \v 10 Yaufi árém so yéfandat yéné a nékw em.
\q2 Yémofem so yéfenjo sén ekérnat nékwan;
\q2 fá so métare nénimndat yéfene kamnang yau kété so yém.
\c 113
\s
\q1 \v 1 Yuyotam Yuré!
\q1 Néméwét, yuyotam, O Yurane ásáfogh téfnár.
\q2 Yuyotam Yurane yétkwén!
\q1 \v 2 Frengégh yém Yurane yétkwén
\q2 sénonjo a tuot.
\q1 \v 3 Méinyotio sifayamé kétamé wérta
\q2 kétán naikaita yuyotam Yurane yétkwén.
\q1 \v 4 Ménamén Yuré siyém tukén yém ndimbal yu yuwanyo em;
\q2 yáne ndimbal kwayaghé siyém minde tukén ewainde njafar.
\q1 \v 5 Emafé so etémndam Yuré téfene Ngánjánafé,
\q2 efe wamanéghkaf yémor tukén?
\q1 \v 6 Fá kénawenangé yuwot yénfande
\q2 njafar a mbandan.
\q1 \v 7 Yémo tanauyongé yauyau ár kétamé ngwérméngta
\q2 a áronjagh ár kétamé njénnjén yékwta.
\q1 \v 8 Yémo ekmete yénamé minde tukén ár
\q2 árkamé em yéfenjo efe em minde tukén.
\q1 \v 9 Yémo taramangé ambumofnar amafoe ambum
\q2 sái em tiyátongé áuwéghro amé.
\q1 Yuyotam Yuré.
\c 114
\s
\q1 \v 1 Njam Israil ár nétoryénd kétamé Ijif
\q2 táf njam Jeikofene mérnam yéfrangoyénd yéné dabi yu.
\q1 \v 2 Judane mband nénamndai Ngánjánene utmanégh méngo sifayé,
\q2 a Israil nénamndai yáne limánégh yu.
\q1 \v 3 Férkat arakaf ewinjoi fá tanmorwén a wékeye nitérmboi fá endta!
\q2 Joden wanjemén nu nénangoi.
\q1 \v 4 Mband tunakéf kénalawét ndenanit ghakér sif kés em,
\q2 a mband tunakéf ndenanit tosé sif kés em!
\q1 \v 5 Némé yém mámáfi, Férkat arakaf, árkéménayam kéméinde fém ndarndarot yéfene endta?
\q2 Némé kufrote, Joden wanje, ndené fém wéi nénango?
\q1 \v 6 Némamén, mband tunakéf, fém kénalati ndenanit ghakér sifnit?
\q2 Némamén, mband tunakéf, ndenanit tosé sifnit?
\q1 \v 7 Férférmén so násámbnete, O mband marat, Yurane sáfan,
\q2 Jeikofene Ngánjánene sáf rére.
\q1 \v 8 Yémo yéngoi wím nu yékwot;
\q2 néméwét, nu wérér nénérse kétamé táikér wimta.
\c 115
\s
\q1 \v 1 Yénd yau, O Yuré, yénd yau,
\q2 wénde fene yétkwénan yéngém ndimbal kwayaghé
\q2 ménamén fene kwénjtafnar uwéghmén a ndimbal mwgighé.
\q1 \v 2 Némamén eumyote ndimbal yu néngorayat,
\q2 ánde yém yéfene Ngánján?
\q1 \v 3 Téfene Ngánján siyém njafaran,
\q2 a yémo ewafrote yéné fá némat ménde yém.
\q1 \v 4 Yéfene ngánjánngánján em ménd rokar silfé a gol,
\q2 ár ngángé wafroghmén.
\q1 \v 5 Yéfene em mbérmbér wénde yau so norayat,
\q2 a ghékéf wénde yau so néretat.
\q1 \v 6 Yéfene em téngan wénde yau so náyáretat,
\q2 a min wénde yau so ewamndat.
\q1 \v 7 Yéfene em ngángé wénde yau so eyanjat,
\q2 a kafkaf wénde yau so eyota,
\q2 a kémngaféne ewam wénde yau so ke yafrotat.
\q1 \v 8 A fá emofem ewafrotat ngánjánngánján em ndenanityo yénayo kés em,
\q2 a em méinyotio kété emofem mwighafé efandat.
\q1 \v 9 O Israil, mwighafé yéfandati Yuré!
\q2 Fá yém féfene wáutárégh ár a féfene wambégh mbakw.
\q1 \v 10 O ghéngén warogh ár, Aronene áki ambum, mwighafé yéfandati Yuré!
\q2 Fá yém féfene wáutárégh ár a féfene wambégh mbakw.
\q1 \v 11 Méinyotio fém emofem férférafé yéfandati Yuré, mwighafé yéfandati Yuré!
\q2 Fá yém féfene wáutárégh ár a féfene wambégh mbakw.
\q1 \v 12 Yuram yénmafarote yénd a so yénéfrende.
\q2 Yémo so tafrendangé Israil ár
\q2 a tafrendangé ghéngén warogh ár, Aronene áki ambum.
\q1 \v 13 Yémo so efrende fá emofem férférafé yéfandat Yuré
\q2 ndimbal árém a yuwan árém.
\q1 \v 14 So Yuram ewayote frengéghe
\q2 fém féfenjo ambumafayo.
\q1 \v 15 So fém efrende Yuram,
\q2 emo yafrotam njafar a mband.
\q1 \v 16 Njafar em Yurane,
\q2 wénde yémo té yéramai mband méinyotio árét.
\q1 \v 17 Kér árém yau so erametat warsagh wagh Yurai,
\q2 ménamén té tangém métar sifayafaf tokéffaf.
\q1 \v 18 Wénde yéndfem so yarsam Yuré
\q2 sénonjo a tuot!
\q1 Yarsam Yuré!
\c 116
\s
\q1 \v 1 Yéndo yuwetan Yuré ménamén yémo náyárete tane kém
\q2 a tane Ngánjánafé orayégh ghérghérsisat.
\q1 \v 2 Ménamén fá káwefnongé ménát áyárghét,
\q2 yénd so Ngánjánafé norayan njamandio yém tafaf ambone!
\q1 \v 3 Kéram eumbete yánjo ángégh tafafmé;
\q2 mbéwé férféram wane yénd.
\q2 Yéndo yinjon kértaro a yéro!
\q1 \v 4 Féyo yénd nutnayénd Yurane yétkwéne.
\q2 O mbana Yuré, kwanjar yénd!
\q1 \v 5 Nderé raméghro yém Yuré! Nderé mer yém fá!
\q2 Ghérghérsisaro yéné téfene Ngánján
\q1 \v 6 Yuram ewarawene efe em ambum tosanit ndimbal mwighayan;
\q2 yéndo téfandawén kér a yémo wanjaryéng.
\q1 \v 7 Tumyo tane ghérsé so yém enaghan wéikor,
\q2 ménamén Yuré té tém mer tafaf.
\q1 \v 8 Yémo té wanjar kétamé kérta,
\q2 tane ghékéf kétamé yeta,
\q2 tane kafkaf kétamé eunoghta.
\q1 \v 9 A yénd wiyota Yurane ghékéfanro
\q2 njamandio yénd ghérsé wém yéna mband!
\q1 \v 10 Yénd awafarogh ár wém fene kénjún, yénémamén yénd norayangén,
\q2 "Yénd kénjúe kérté yamé wém, Yuré."
\q1 \v 11 Tane mwighé wawérsoghan yénd ke nutnayén fefaf,
\q2 "Yéné ár méinyotio em unyégh ár!"
\q1 \v 12 Némé so Yurai taraman
\q2 ménamén méinyotio yémo némé tafrote tayot?
\q1 \v 13 Yéndo so tuyon wanjarégh kafusi
\q2 a yarsan Yurane yétkwén ménamén té wanjaryéng.
\q1 \v 14 Yéndo so yarawenan tane unyéghofnar si kétán Yurafaf
\q2 yáne méinyotio árfene ghékéf kénjún.
\q1 \v 15 Yuram kénjkame ewarawene
\q2 njam yáne áuwéghafé ár kér em.
\q1 \v 16 O Yuré, yénd wém fene ásáfogh téfnár;
\q2 néméwét, yénd wém fene ásáfogh téfnár, náráftamén fene méngot;
\q2 fémo té wéfitrar yénd tane tot ángéghta.
\q1 \v 17 Yéndo so kémaraman kánjo ramégh ghéngén
\q2 a kutnangén Yurane yétkwénan.
\q1 \v 18 Yéndo so efalo eyátotan tane olaghofnar si kétán Yurafaf
\q2 yáne méinyotio árfene ghékéf kénjún.
\q1 \v 19 Kété Yurane méngo kénjún
\q2 Jerusalem tikéf kénjún.
\q1 Yarsam Yuré!
\c 117
\s
\q1 \v 1 Yarsati Yuré, fém méinyotio ndimbal yu.
\q2 Yarsati fá, méinyotio fém mband maratmén ár.
\q1 \v 2 Ménamén yémo yénd yénmuete kwénjtafnar uwéghé
\q2 Yurane ndimbal mwighé nakete tuot;
\q1 Yarsam Yuré!
\c 118
\s
\q1 \v 1 Yarametati kánjo Yurai, ménamén fá siyém mer!
\q2 Yane ndimbal mwighafé uwégh nakete tuot.
\q1 \v 2 Taumyo méinyotio Israil ár wéi so nafértat:
\q2 "Yáne ndimbal mwighafé uwégh nakete tuot."
\q1 \v 3 Taumyo Aronene ákiambum, ghéngén warogh ár, wéi so nafértat:
\q2 "Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 4 Taumyo méinyotio emofem férférafé yéfandat Yuré wéi so nafértat:
\q2 "Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 5 Tane mwighé uyégh kénjún yénd Ngánjánafé korayawén,
\q2 a Yuram wawangoi a yénd yuwek so árfifiam wiyátoi.
\q1 \v 6 Yuré siyém tane, yénémamén yénd yau so wém férfér.
\q2 Némé so árfifiam yafrotat tafaf?
\q1 \v 7 Néméwét, Yuré siyém tané yémo so wáutáne ta.
\q2 Yénd so néretan minde remngoghafé yéfefaf emofem méndméndat wéfandat yénd.
\q1 \v 8 Merfifi yém siya ersam átnogh sifayé Yurane kénjún
\q2 yau táf mwighé yéngém árfefaf.
\q1 \v 9 Merfifi yém siya ersam átnogh sifayé Yurane kénjún
\q2 yau táf mwighafé efandam minde tukén ár.
\q1 \v 10 Ndemamén karogh ndimbal yuwam warendat yénd,
\q2 yéndo ewironan fá méinyotio ménaye Yurane waftaye.
\q1 \v 11 Néméwét, yémofem warendayénd a wafngoyénd
\q2 wénde yéndo ewiroryén fá méinyotio Yurane waftaye.
\q1 \v 12 Yémofem séfe warendat ndenanit kunj;
\q2 yémofem wamnjotat ndenanit fés yénau nakérne.
\q2 Wénde yéndo tawironawén ménaye Yurane waftaye.
\q1 \v 13 Tane mék téfnáram tafrotat mer ta kér ngiot,
\q2 wénde Yuram wanjaryéng yénd.
\q1 \v 14 Yuré siyém tane muyé a tane wagh;
\q2 yémo té waramai waingégh.
\q1 \v 15 Áuwégh wagh a waingéghmén wagh eufanat ngánján árfene méngo aramégh sifayan.
\q2 Yurane muyafé tambén sérakwam té tawafrote ndimbal kwayaghayam!
\q1 \v 16 Yurane muyafé tambén sérakw té nokai minde remngoghafé.
\q2 Yurane muyafé tambén sérakwam té tawafrote ndimbal kwayaghafé yam.
\q1 \v 17 Yénd yau so kér wém, wénde, yénd so ghérsé wém
\q2 ménát so néngafrotan némé Yuram té tafrote.
\q1 \v 18 Yuram té kértayan kwénékmete ámb efogh kés taném.
\q2 wénde yémo yau yénd wumyo kérot.
\q1 \v 19 Tésawér sésafne tayot ándan mbarkand ár so nényawetat,
\q2 a yénd so ngényawan a kánjo yarametan Yurai.
\q1 \v 20 Yéné sésafne yékém kétán Yurane ghékéf fandaghfaf,
\q2 a ngánján ghérsafé so nényawetat kétán.
\q1 \v 21 Yéndo kánjo némarametan fe ménamén tane Ngánjánafé orayégh wawangoghmén
\q2 a waramete waingégh!
\q1 \v 22 Wím yéné méngo ramégh téfnáram árkéméné yékenayénd
\q2 té sénonjo nénamndé kwéndkwénd wím.
\q1 \v 23 Yéné siyém Yurane yam wafrogh,
\q2 a yéné yém mer fandaghét.
\q1 \v 24 Yéné efogh siyém Yuram árké yafrotam.
\q2 Yénd so náuwetam a so yéném áuwéghafé kété.
\q1 \v 25 O mbana, Yuré, ghérghérsisé ténmanjar yénd.
\q2 O mbana, Yuré, ghérghérsisé ténmaram téfe remngogh.
\q1 \v 26 Téfenda yéné ár efe yéném Yurane yétkwénan.
\q2 Yéndfem néfrendam fém kétamé Yurane méngota.
\q1 \v 27 Yuré yém Ngánján, nálále téfefaf.
\q2 Téngwan ghéngén a eumbeta ángéghe ghéngén kitarayan.
\q1 \v 28 Fém ném tane Ngánján, a yéndon so némarsan fém!
\q2 Fém ném tane Ngánján, a yéndon so némuyotan fém!
\q1 \v 29 Yarametati kánjo Yurai, ménamén fá siyém mer!
\q2 Yáne ndimbal mwighafé uwégh nakete tuot.
\c 119
\qa Alef
\q1 \v 1 Áuwégh kér ro yéné ár em efe em unyéghofnar,
\q2 emofem ewaitotat Yurane si.
\q1 \v 2 Áuwégh kér ro fá em emofem ewaitotat yáne nák
\q2 a yéronjat fá méinyotio yéfene tikfe.
\q1 \v 3 Fá yau náféghetat yaufiafé,
\q2 a fá eyota mé yáne endmé.
\q1 \v 4
\q2
\q1 \v 5 O, ndené tane wafrogh yamam so túmén
\q2 eufarote fene wafarégh.
\q1 \v 6 Féyo yénd yau so wém wáiwái
\q2 njam yéndo etémndan fene wafarégh si tane ghérsafé.
\q1 \v 7 Njam yénd notametan fene mbarkánd náknák,
\q2 yéndo so kánjo némarametan fe ndernaye té wémor!
\q1 \v 8 Yéndo so ewaitotan fene wafarégh.
\q2 Ghérghérsisé yau kékmbogh tambén!
\qa Bet
\q1 \v 9 Ndenaye so totér ambum yémor fénjfénjofnar?
\q2 Ménayan sái ewaitota fene si.
\q1 \v 10 Yénd té yéta taikre kufotan ménát sái kéminjon fém;
\q2 yau wémyota sái náyáretan fene wafarégh sian.
\q1 \v 11 Yéndon té yétnon fene si tane tikéf kénjún,
\q2 ménát yéndo yau so yaufiyam yafrotan fefaf.
\q1 \v 12 Yéndo némarsan fém, O Yuré;
\q2 watameta fene wafarégh.
\q1 \v 13 Yéndo té férghe tafértan ndimbal kéme
\q2 méinyotio náknák fémon árké yénmaramai téfe.
\q1 \v 14 Yénd té káuwetan fene nák kénjún
\q2 mindefifi ndené wemaran yénau em.
\q1 \v 15 Yéndo so ewafénmetan fene nák
\q2 a nálálan fene yamamé.
\q1 \v 16 Yéndo so minde méndefé efandan fene wafarégh
\q2 a yau so kwawalindangé fene si.
\qa Gimel
\q1 \v 17 Aném mer fene ásáfogh téfnárfaf,
\q2 ndené yénd so wémor a ewaitotan fene si.
\q1 \v 18 Tasawér tane ghékéf ménát so efandan
\q2 mer sariafé efalo si fene waufarogh si kénjún.
\q1 \v 19 Yénd mé dabi wém mbandan.
\q2 Yau etnota fene waferégh si ta tambén!
\q1 \v 20 Yénd túmén kwafarngé
\q2 fene náknák méndeyam
\q1 \v 21 Fémo eusérmbote tuktuk ár;
\q2 fá efe náyáretat fene wafarégh sian em mbawaran.
\q1 \v 22 Yau eumyota tékratro nawangotat a wánangotat yénd,
\q2 ménamén yéndo té tawaitotan fene nák.
\q1 \v 23 Ndemamén minde tuk ár kamnjongi a norayat ta tambén,
\q2 wénde yéndo so mé mwighaye eknan fene wafarégh.
\q1 \v 24 Fene nákam klisa waramete ta;
\q2 yémofem warametat káfeté wawanjagh si.
\qa Dalet
\q1 \v 25 Yénd walinjo ngwérméngan;
\q2 kor wéi muyé kwaram fene siye.
\q1 \v 26 Yéndon kémaufrotan tane mwighé wafrogh a fémo kwawangote.
\q2 Sénonjo kwatameta fene wafarégh.
\q1 \v 27 Kwáutána ta mat so káyáton fene nákoene fifi,
\q2 a yéndo so mwighé eknan fene mer sari yam.
\q1 \v 28 Yénd ye nawarametan ghérghérsisafé;
\q2 wawéngsota yénd fene siye.
\q1 \v 29 Warawena yénd kétamé yéndo kés nawawindan;
\q2 kwaram yéné klisa ánde mat so kamndan fene waufarogh si.
\q1 \v 30 Yéndo té yaférén sái wém ndimbal mwighé kér ro;
\q2 yéndo té mwighé tafrotan ménát wémor fene náknákan.
\q1 \v 31 Yénd néngatémndan kétán fene nákfaf.
\q2 Yuré yau wumyota yénd kwékém wáiwáiot!
\q1 \v 32 Yéndo so ewaitotan fene wafarégh si,
\q2 ménamén fémo marat wáyátote tane matyam.
\qa E
\q1 \v 33 Kwatameta fene wafarégh si, O Yuré;
\q2 yéndo so ewaretan kétánotio yatoghfaf.
\q1 \v 34 Kwaram ta mat a yéndo so ewaitotan fene si;
\q2 yéndo so tákman yam wafroghét méinyotio tane tikfe.
\q1 \v 35 Kwiyáto so wiyota fene wafarégh si endmé
\q2 ménamén yéné féyém ánde tane áuwégh tinjon.
\q1 \v 36 Kwaram ta yéné tikéf fene nákfaf
\q2 manioene uwégh yuwanyo yém!
\q1 \v 37 Tane ghékfam yau so efande fifiofnar rokar,
\q2 a kwaram ghérsé fene si kénjúmé.
\q1 \v 38 Tano tafaf fene unyéghofnar si
\q2 yafrotam yéfeyot emofem férférafé néfandat fém.
\q1 \v 39 Kwáutána so efrangotan tane wáiwáiafé yam;
\q2 ménamén fene náknák sem mer.
\q1 \v 40 Yénd náronjan ménát sái ewaitotan fene nák!
\q2 Kor totér tiyáto tane ghérsé fene meryame.
\qa Faf
\q1 \v 41 Yuré, kwaram fene kwénjtafnar uwéghta
\q2 wanjarégh yéné fémo árké té unyéghofnar si wémndai.
\q1 \v 42 Féyo yéndo so ewawangotan yéfe emofem tékrat wéfandat,
\q2 ménamén yéndo mwighafé efandan fene si.
\q1 \v 43 Yau fémo tangwan fene efalo si ta tambén,
\q2 ménamén fene náknák sem tane yénaro kamnang.
\q1 \v 44 Yéndo mé so ewaitotan fene si
\q2 tuot a mbanjat.
\q1 \v 45 Yénd so wiyota yuwekan,
\q2 ménamén yénd té naramayén fene nákfaf.
\q1 \v 46 Yénd so néngorayan kétán warsagh árfefaf fene nákmén,
\q2 a yénd yau so wáiwái wém.
\q1 \v 47 Ndernáye yéndo minde méndefé efandan fene nák!
\q2 Ndernáye yéndo euwetan.
\q1 \v 48 Yéndo eutémndan a euwetan fene wafarégh si.
\q2 Yéndo so mwighaye eknan fene wafarégh.
\qa Jain
\q1 \v 49 Ewafarota fenjo unyéghofnar si tafaf;
\q2 yéné siyém tayot yénaro kamnang.
\q1 \v 50 Fene unyéghofnar siam wanote ghérsayan;
\q2 yéné yam wamarote méinyotio tane kértayan.
\q1 \v 51 Tuktuk árém kwérangi yénd téfnot,
\q2 wénde yéndo yau sem tengotan fene wawanjagh sifaf.
\q1 \v 52 Yéndo so mwighé erametan fronde tawar náknák;
\q2 O Yuré, yéné yam yénd wamarotat.
\q1 \v 53 Yénd kénamndan nékwafé yaufiyam téfnárafefaf,
\q2 ménamén yémofem ekenat fene wawéngsogh si.
\q1 \v 54 Fene wafarégh tamorwén tane waghoene sénko si
\q2 ánde njam yénd kwémorangérwén.
\q1 \v 55 Yéndo kémufarotawén fém sémbáran, O Yuré;
\q2 yénémaménnde, yéndo ewaitotan fene wawéngsogh si.
\q1 \v 56 Yéné fiyém ndernaye yéndo tane ghérsé
\q2 yérametau ewaitotan fene wafarégh si.
\qa Et
\q1 \v 57 Yuré, fém sném tane!
\q2 Yénd unyéghofnar si norayan ménát sái ewaitotan fene si!
\q1 \v 58 Méinyotio tane tikfe yénd ménde wém fene frengégh.
\q2 Aném ghérghérsisafé ndené fété ndernaye fémo unyéghofnar si té wémndai.
\q1 \v 59 Yénd té mwighayam kwawérsotau tane ghérsé álighmén,
\q2 a yénd nawengoyén ménát sái ewaitotan fene nák.
\q1 \v 60 Yénd so wékeye nufrotan awanéghofnar,
\q2 ménát sái ewaitotan fene wafarégh si.
\q1 \v 61 Yaufi árém yéta kétán wéroghat yaufiyamot,
\q2 wénde yénd taikrataye náweretan kétán fene wawéngsogh sifaf.
\q1 \v 62 Yénd kanon sémbár néndkéf ménát fe kánjo raméghét
\q2 fene mbarkánd náknákmén.
\q1 \v 63 Yénd wém fútarot árké ároefaf téu emo férférafé néfanda fém,
\q2 árké ár téu emo ewaitota fene nák.
\q1 \v 64 O Yuré, fene kwénjtafnar uwégham yafote mband marat;
\q2 watameta fene wafarégh si.
\qa Tet
\q1 \v 65 Fémo té tawafrote tafar mer yam tayot, Yuré,
\q2 ndené fété fémo ndernaye unyéghofnar si néngorayai.
\q1 \v 66 Yéndo ewafarotan fene wafarégh si;
\q2 sénonjo kwatameta mer mogh a matyam.
\q1 \v 67 Yénd táf néwérsotan kétánotio fémo watameghan kwékém;
\q2 wénde sénonjo yéndo kakae ewaitotan fene si.
\q1 \v 68 Fém ném mer a ewafrote mé merro;
\q2 watameta fene wafarégh.
\q1 \v 69 Awarmbogh ár árém yénd wengwatarnat unyéghe,
\q2 wénde efaloe yéndo ewaitotan fene nák méinyotio tane tikfe.
\q1 \v 70 Wénde yéfene tikéf sem kwéfkwéf a yaufi,
\q2 wénde yéndo minde méndefé efandan fene watamegh si.
\q1 \v 71 Tane tékrat témorwén tane merot,
\q2 ménamén yéné yam watametam ménát áyárégh ár sái kamndan fene wafaréghfaf.
\q1 \v 72 Fene watamegh si sem minde tukén tayot yuwon em
\q2 milion milion gol a silfé.
\qa Yod
\q1 \v 73 Fémo wafrotam yénd; fémo wéfunai yénd.
\q2 Sénonjo kwaram ta yéné emarégh sái ewaitotan fene wafarégh si.
\q1 \v 74 So méinyotio fá emofem férférafé néfandat fém ewinjotat tane kénjún téfén áuwéghét,
\q2 ménamén yéndo tétane kamnang ekmayén fene si kénjún.
\q1 \v 75 Yénd mat wém, O Yuré, ndené fene náknák sem mé ndenaro em;
\q2 fémo wékmete watameghan ménamén fémo ménde yénat.
\q1 \v 76 Sénonjo tumyo fene kénjtafnar uwégham wamarota yénd,
\q2 ndené fété fémo té unyéghofnar si wémndai, fene ásáfogh téfnár.
\q1 \v 77 Warenda yénd fene ghérghérsisé tikfe ménát yénd so ghérsé mé wéngém,
\q2 ménamén fene watamegh si sem tane minde méndefé.
\q1 \v 78 Yénérsa áuwéghofnar yam yéfefaf awarmbogh árfefaf efe nénguindat tanemén;
\q2 wénde yénd so méghmégh wém fene nákfaf.
\q1 \v 79 Kumyo yénd so yéném ámbiro emofem férférafé néfandat fém,
\q2 yémafé efe mat em fene nák.
\q1 \v 80 So yénd wém téfnofnar yéné kénjún sái ewarawenan fene nák;
\q2 féyo yau so wém wáiwái.
\qa Kaf
\q1 \v 81 Yénd wésyo nawanjetan fene wanjarghét,
\q2 wénde yéndo té kamnang tane yékman fene sifaf.
\q1 \v 82 Tane ghékéf naftérnat ménát sái yéfandan fene unyéghofnar si sái efalo náyátotat.
\q2 Njam so fémo yénd kwamarota?
\q1 \v 83 Yénd kamndan ndenanit ghérnat wain wén ngar yénau kwaman yém,
\q2 wénde yénd wawalinda ménát mwighafnar sái ewitan fene wafarégh.
\q1 \v 84 Nderé teke so yénd nawanjetan?
\q2 Njam so fémo takém tékratan fá emofem wérnotat yénd?
\q1 \v 85 Yéné awarmbogh téfnár emofem méndméndat efandat fene watamegh si
\q2 té tétanat kénjkam yékw ta werghét.
\q1 \v 86 Méinyotio fene wafarégh si sem mwighafé.
\q2 Wáutána ta yéfeta efe alé narotat tayot téfnofnar.
\q1 \v 87 Yémofem téfe wifongi yénd,
\q2 wénde yénd yau nakenayén fene nák frengéghét.
\q1 \v 88 Fene kwénjtafnar uwégh kénjún, tanjar tane ghérsé;
\q2 féyo yéndo táf so ménjtaye ewaitotan fene nák.
\qa Lamed
\q1 \v 89 Fene akegh si, O Yuré,
\q2 ewakai taikrataye njafaran.
\q1 \v 90 Fene ndimbal mwighé nusamngote kétán méinyotio ár saté,
\q2 nakete ndené mband fémo kés yafrotan.
\q1 \v 91 Fene náknák mé em efalo yénan sénonjo efogh,
\q2 ménamén méinyotio rokaram ásáfogh yafrotat fene mwighayan.
\q1 \v 92 Njam fene watamegh siam yau kwáutánau áuwéghafé,
\q2 yénd so táf kér kwémorwén tane awanjmegh kénjún.
\q1 \v 93 Yéndo yau so mwighafnar tawayan fene nák,
\q2 ménamén yénaye kwaramangi ta ghérsé.
\q1 \v 94 Yénd fene wém; kwanjar!
\q2 Ménamén yénd té kénásáfotan taikrataye ménayan tanwaitotan fene nák.
\q1 \v 95 Ndemamén yaufi ár ngatnotawét tane endmé ménát ta kér ngiot,
\q2 yéndo so métare tawarawenawén tane mwighaye fene nák.
\q1 \v 96 Fénjfénjofnar ghérsé siyém fuafayo yém,
\q2 wénde fene wafarégh si sem fuofnar.
\qa Mem
\q1 \v 97 O, nderé minde euwetan fene watamegh si!
\q2 Yéndo táf ewafarotan efogh tombé.
\q1 \v 98 Fene wafarégh siam kwiyátongé minde káfeté mwighafé yuwanyo em tane mék téfnár,
\q2 ménamén yéné em tane túmén wambégh.
\q1 \v 99 Néméwét, tafaf yém minde kénjún matyam tane watamegh téfnár yuwanyo em,
\q2 ménamén yénd túmén nemnan fene nákmén.
\q1 \v 100 Yénd wém minde káfeté mwighafé ewaindan tane fronde ár,
\q2 ménamén yéndo tawanjetawén fene nák.
\q1 \v 101 Yénd té kakenawén siya kwiyátau ámb yaufi endmé,
\q2 ménát yénd mé so kwémorwén áyárégh téfnár fene sifaf.
\q1 \v 102 Yéndo yau séme engwitamén fene náknák,
\q2 ménamén fémo té watametam mere.
\q1 \v 103 Nderé méndero yém fene si tayot;
\q2 fá em méndero ewainde fáméghár.
\q1 \v 104 Fene nákam waramete ta matyam;
\q2 yénémamén yéndo méndméndat tangfandan méinyotio unyégh ghérsé end.
\q1 \v 105 Fene si siyém lambefé ménát so ewambete tane kafkaf
\q2 a kwayaghé em tane end álighét.
\q1 \v 106 Yénd té unyéghofnar si norayayén ambinotaro, a yénd so unyéghofnar si korayangén wéikor:
\q2 yéndo so ewaitotan fene mbarkánd náknák.
\q1 \v 107 Yénd té tékrat téfandan minde, O Yuré;
\q2 tano tane ghérsé wéikor fémo kés unyéghofnar si wémndai.
\q1 \v 108 Yuré, taumyo tane warsaghmén ramégh,
\q2 a watameta fene náknák.
\q1 \v 109 Tane ghérsé túmén yame mé féneféneyan,
\q2 wénde yénd yau so kékmbon fene watamegh sita.
\q1 \v 110 Yaufi árém té takeindat urér tayot,
\q2 wénde yéndo yau so séme engwitan fene nák.
\q1 \v 111 Fene nák sem tane ngonjél;
\q2 yéné em tane tikéfmén minde méndefé.
\q1 \v 112 Yéndo mwighé yafrotan siya yéngsotan fene wafarégh
\q2 kétánotio kerker.
\qa Samek
\q1 \v 113 Yéndo méndméndat efandan fá afalogh tikéf wafaréghafé,
\q2 wénde yéndo euwetan fene watamegh si.
\q1 \v 114 Fém ném tane átnogh sifayé a wambégh mbakw;
\q2 fene si siyém tane kamnangoene kémbun.
\q1 \v 115 Ngitérmbongi tane ghérsata, fém yaufi mwighafé ár,
\q2 yénd narametan ménát sái ewaitotan tane Ngánjánene wafarégh si.
\q1 \v 116 Yuré, kwáutána ta ndené fém kés unyéghofnar si norayai, ménát yénd ghérsé so wéngém!
\q2 Yau tane kamnang yumyota sái kirorngé.
\q1 \v 117 Kwáutána ta, a yénd so táf kunjarén;
\q2 féyo yéndo so ewafénmetan túmén fene wafarégh.
\q1 \v 118 Wénde fémo té takene méinyotio efe nayu tam kétamé fene nákta.
\q2 Fá fáro néngawawindat.
\q1 \v 119 Fémo ewitérmbote yaufi ár mbandan ndenanit mangérmangér uwérsoghofnar;
\q2 yénd euwetan fene nák sái ewaitotan.
\q1 \v 120 Yénd fene férférmén ngerngeram wérameté
\q2 yénd kokayon táf téu férférafé fene náknákmén.
\qa Ayin
\q1 \v 121 Yau wéfrangota yénd kétán tane mék téfnárafene ghérghérsisafaf,
\q2 ménamén yéndo té tawafrotan némé em mé merro a mbarkánd.
\q1 \v 122 O mbana tumyo frengégh tayot.
\q2 Yau eumyota awarmbogh téfnáram ghafewétnat yénd.
\q1 \v 123 Tane ghékéf naftérnat ménát sái yéfandan fene wanjarégh,
\q2 ménát sái yéfandan fene efalo unyéghofnar simén sái nufrota.
\q1 \v 124 Yénd wém fene ásáfogh téfnár; nawarmanwam yéndfé fene kwénjtafnar uwégh kénjún,
\q2 a watameta fene nák.
\q1 \v 125 Kwaram wayamngogh mwighé ta, fene ásáfogh téfnár;
\q2 féyo yénd so mat wém fene nákmén.
\q1 \v 126 Yuré, yéné yém efogh feyot sái yaman tékém,
\q2 ménamén yéné yaufi árém té yaufi tawafrotat fene watamegh si.
\q1 \v 127 Efalofifi, yéndo euwetan fene wafarégh si
\q2 minde ewaindat gol, a wéi teghmén gol.
\q1 \v 128 Yéné nák fene kés em mbarkánd em.
\q2 Yéné téfnan yéndo méndméndat méinyotio unyéghe yam.
\qa Fe
\q1 \v 129 Fene nák sem sariafé.
\q2 Yénémamén yéndo ewaitotan!
\q1 \v 130 Fene watamegh sian yémaramete kwayaghé,
\q2 féyotaro nékamb ár mat so káyátongé.
\q1 \v 131 Yénd wafyángégh yátoghkaf wém,
\q2 náronjan fene wafarégh siot.
\q1 \v 132 Kénaf a kwáyáfo fene ghérghérsisé,
\q2 ndené fété fémo kés tangwafrotan yéfeyot méinyotio emofem fene yétkwén tuwetawét.
\q1 \v 133 Ewarawena tane kafkaf enagh fene siye,
\q2 ménát yénd yau so wainde yaufiyamam.
\q1 \v 134 Ngwétno kétamé yaufi árfene sénanéghta;
\q2 ménát yéndo so ewaitotan fene nák.
\q1 \v 135 Uwéghafaro wéfanda;
\q2 watameta fene nák.
\q1 \v 136 Wanje nu yengam nénasunat kétamé tane ghékéfta
\q2 ménamén árém yau ewaitotat fene watamegh si.
\qa Tsade
\q1 \v 137 O Yuré, fém ném mbarkánd,
\q2 a fene náknák sem ámbrérero.
\q1 \v 138 Fene nák sem fénjfénjofnar
\q2 a mwighafé efandam.
\q1 \v 139 Yénd té wérauto tikéf áneghfégham,
\q2 ménamén tane mék téfnáram té tawitat fene si.
\q1 \v 140 Fene unyéghofnar si té máméghéraye tufotat;
\q2 yéné téfnan yéndo euwetan mindefifi.
\q1 \v 141 Yénd kor yau mer wéfandat a wémronat,
\q2 wénde yéndo yau fene nák mwighafnar tawayan.
\q1 \v 142 Fene nákan mbarkándyam siyém tuot,
\q2 a fene watamegh si sem fénjfénjofnar efalo.
\q1 \v 143 Kénarmbongé a mwighayan kuyan,
\q2 yéndo tinjon áuwégh fene wafarégh si kénjún.
\q1 \v 144 Fene nák sem túmén mbarkánd;
\q2 wáutárna ta ménát mat so táyáton yéné ménát yénd so ghérsé wém.
\q1 \v 145 Yénd Ngánjánafé norayan méinyotio tane tikfe, Yuré!
\q2 Yéndo so ewaitotan fene nák.
\q1 \v 146 Yénd néngutnan fefaf; kwanjar,
\q2 ménát yéndo so ewaitotan fene nák.
\q1 \v 147 Yénd kanon frondeyo, soramé efogh kénáyátongé tukén;
\q2 yénd kutnangén ménát wáutárghét a tékman tane kamnang fene siamé.
\q1 \v 148 Yénd mé néretan sémbáran,
\q2 nemnan ménamén fene unyéghofnar simén.
\q1 \v 149 Fene ndimbal mwighé uwégh kénjún, O Yuré, náyáreta tane yé
\q2 kwumyo yénd wéikor muyé kwaram ménaye sái ewaitotan fene náknák.
\q1 \v 150 Nákofnar ár eném ta ngiot;
\q2 fá emor nayu kétamé fene watamegh sita.
\q1 \v 151 Wénde fém ném kaka, O Yuré,
\q2 a méinyotio fene wafarégh si sem efalo.
\q1 \v 152 Yénd té mat nénáyátoyén totér ndené fene nák so naketat tuot.
\qa Res
\q1 \v 153 Néreta kétán tane tékratfaf a kwanjar,
\q2 ménamén yénd yau wawalinda fene watamegh si.
\q1 \v 154 Néwit ta téfnár; ta tambén aném!
\q2 Yambeta tane ghérsé ménamén unyéghofnar si norayai.
\q1 \v 155 Yaufi ár sem nayu em wanjaréghta,
\q2 fá yau kor nemnat fene nákmén.
\q1 \v 156 Yuré, nderé ndimbal yém fene ghérghérsisé;
\q2 kwumyo yénd wéikor muyé kwaram ménaye sái ewaitotan fene náknák.
\q1 \v 157 Tárfáram wérnotat a kértat wékmetat,
\q2 wénde yénd yau notenayén fene nákta.
\q1 \v 158 Efandan yéné yam téfnár wiyátotat enjnefé tikfan,
\q2 ménamén yémofem yau yutémndat fene si.
\q1 \v 159 Téfanda ndernaye yéndo euwetan fene nák, Yuré.
\q2 Kwawango tane ghérsé ménamén fene kwénjtafnar uwégh yém.
\q1 \v 160 Fene sioene kémbunfifi siyém efalofifi;
\q2 méinyotio mbarkándro náknák so kokayongi tuot.
\qa Shin
\q1 \v 161 Wafté kér ro árém túmén kérta kwékmangi téfnofnar,
\q2 wénde tane tikéf ngerngeran wém mé fene siménro.
\q1 \v 162 Yénd náuwetan fene si kénjún
\q2 ndenanit árom yénau tinjongé ndimbal mani.
\q1 \v 163 Yéndo méndméndat efandan a etnotan méinyotio unyégh yam,
\q2 wénde yéndo euwetan fene watamegh si.
\q1 \v 164 Yéndo so némarsan fém 7 mbinotmé ámbiro efghon
\q2 ménamén méinyotio fene náknák sem mbarkánd.
\q1 \v 165 Fá emofem euwetat fene watamegh si yéfene yém ndimbal krufrat ámnjogh
\q2 a yau so nuitat.
\q1 \v 166 Yénd náronjan fene wanjarghét, Yuré,
\q2 féyo yéndo té tanwaitotan fene wafarégh si.
\q1 \v 167 Yéndo té tawaitotan fene nák,
\q2 ménamén yéndo táuwetan mindefifi.
\q1 \v 168 Néméwét, yéndo té tawaitotan fene náknák a nák
\q2 ménamén fém mat ném méinyotio yém yéndo sewafrotan.
\qa Tau
\q1 \v 169 O Yuré, náyáreta tane yé
\q2 kwaram ta wayamngogh mwighé fémo árké unyéghofnar si wémndai.
\q1 \v 170 Náyáreta tane Ngánjánafé orayégh;
\q2 kwanjar yénd ndené fém kés unyéghofnar si néngorayai.
\q1 \v 171 Tumyo warsagh nasuna tane mbírmbírta,
\q2 yénat fémo té watametam yénd fene wafaréghfaf.
\q1 \v 172 Tumyo tane kanké wagh so eramete fene simén,
\q2 ménamén méinyotio fene wafarégh si sem mbarkánd.
\q1 \v 173 Kwaram wáutárégh ngángé,
\q2 ménamén yéndo té yaférén sái ewaitotan fene nák.
\q1 \v 174 O Yuré, yénd té káronjan fene wanjarghét,
\q2 a fene watamegh si sem tane minde méndefé.
\q1 \v 175 Kwuyo yénd ghérsé mé so wéngém ménát yéndo so némarsan,
\q2 a so fene náknákam wáutánat.
\q1 \v 176 Yénd té koyáretan nayu ndenanit olingégh sif;
\q2 kéném a kwinjo,
\q2 ménamén yéndo yau mwighafnar tawitan fene wafarégh si.
\c 120
\s
\q1 \v 1 Yénd tangérsan tane kérté Yurafaf;
\q2 yénd ye kendan yáfaf, a yémo kwawangote ta Ngánjánafé orayégh.
\q1 \v 2 Kwanjar yénd, O Yuré, kétamé unyéghta
\q2 a kétamé méinyotio wanégh téfnárafeta.
\q1 \v 3 O unyégh kanké, némé so Ngánjánam yafrote fefaf?
\q2 Ndernáyefifi so tarmbongé fene tékrat?
\q1 \v 4 Fém so nékuindat sénté fimbe
\q2 a némakérnat ménaye kwayaghé ngunde.
\q1 \v 5 Ndernáye yénd tékratan wém nayu kétamé Mesek.
\q2 Yénayam tékrat waramete ménát sái wémor nayuta Kedar.
\q1 \v 6 Yénd sakram wéramete
\q2 yéné árfe sénmor emofem méndméndat yéfandat krufrat ámnjogh.
\q1 \v 7 Yéndo yéronjan krufrat ámnjogh;
\q2 wénde njam yénd norayan krufrat ámnjoghmén, fá ménde em mékot!
\c 121
\s
\q1 \v 1 Yénd néngretayén kétán tukét mband tunakéfamé,
\q2 té tane wáutárégh yéném kétamé?
\q1 \v 2 Tane wáutárégh yéném kétamé Yurata,
\q2 emo ewafrotam njafar a mband marat.
\q1 \v 3 Yémo yau so kumumyongé sái nuita;
\q2 emo néfande fém yau so kémégh yékém.
\q1 \v 4 Fété, fá emo yéfande Israil
\q2 yau kéméghan yém a yékém.
\q1 \v 5 Yuram yémonro efande fém!
\q2 Yuré yakai féfe kaka féfene wambégh njar.
\q1 \v 6 Efgham yau so ewasérmbote efghon,
\q2 yau ghéraream sémbáran.
\q1 \v 7 Yuram ewarawene fém méinyotio wasérmboghta
\q2 a efande féfene ghérsé.
\q1 \v 8 Yuram mé efande fém ndené kés eném a engém,
\q2 sénonjo a tuot.
\c 122
\s
\q1 \v 1 Yénd áuwéghan kwémorwén njam norayayénd tafaf,
\q2 "So yénd yéngém kétán Yurane méngot."
\q1 \v 2 A sénonjo yéna yénd yéném,
\q2 yénmakai kénjún fene sésafnefaf, O Jerusalem.
\q1 \v 3 Jerusalem siyém mer kéráye raméghmén ndimbal tesen yém;
\q2 yáne tombane náuwéghmén mbakw yau so ewironat.
\q1 \v 4 Méinyotio Israilmén ár téfén Yurane árém
\q2 so yafrotat yéfene áligh yénan.
\q1 Fá eném ménát kánjo so yarametat Yurane yétkwénoe,
\q2 ndené fété nák yém Israil árét.
\q1 \v 5 Yéna ewakai limánégh ámnjogh sifayé ánde migh ewarametat,
\q2 Deifidene mérnafene limánégh ámnjogh sifayé.
\q1 \v 6 Ngánjánafé orayégh norayati krufrat ghérsat Jerusalemét.
\q2 So méinyotio fá emofem yuwetat yéné ndimbal tesen so manian féyotaro em.
\q1 \v 7 O Jerusalem so kété yém krufrat ghérsé fene anawégh mbakwamé
\q2 a mani armbogh sifayé fene utmanégh sifayamé.
\q1 \v 8 Yéfene téfnan tane mérén a fútar, yénd so korayangén,
\q2 "So fefaf yém krufrat ghérsé."
\q1 \v 9 Téfene Yuré Ngánjánene méngo téfnan,
\q2 yéndo so yéronjan némé yém merfifi féfeyot, O Jerusalem.
\c 123
\s
\q1 \v 1 Yéndo ghékéf euyoyén fefaf,
\q2 O Ngánján néfai limánégh ámnjogh sifayan njafaran.
\q1 \v 2 Yénd mé néngretam kétán Yurafaf téfene Ngánján ménát ghérghérsisat,
\q2 ndené yame ásáfogh téfnár yénau néretat yéfene ndimbaloefaf,
\q2 ndené yame faiofnar mérsom yénau yéfande amaf téfnár emo túmén yanete ménát so taunangé afráte.
\q1 \v 3 Aném ghérghérsisé téfefaf, Yuré, aném ghérghérsisé,
\q2 ménamén téfefaf yau tém utmanégh.
\q1 \v 4 Téfene té tém mindefifi tawainde téfene tárfár si wafrogh tuktukmén
\q2 a utmanéghofnar awarmbogh téfnár téném.
\c 124
\s
\q1 \v 1 Ndernáye táf so yém Yuré yau njam yém téfe tambén?
\q2 So méinyotio Israil árém yéfértat.
\q1 \v 2 Ndernáye táf so yém Yuré yau njam yém téfe tambén
\q2 njam árém ténmafngongi yénd?
\q1 \v 3 Yémofem so yénd yénlotat ghérséghérsé
\q2 yéfene fés nékwe.
\q1 \v 4 Nu so kafarnangé téfefaf;
\q2 a mámé ghéraye kéféram so ténmafarngé yénd.
\q1 \v 5 Néméwét, kwérnar nu yéfenjo muyafayo
\q2 so táf tawafarngé téfene ghérsé.
\q1 \v 6 Yarsam Yuré,
\q2 emo yau eumyoi yéfene sén ténéftérnawét mámé ghéraye!
\q1 \v 7 Yénd nafrendayém ndenanit men kétamé álegh téfnárane urérta.
\q2 Urér siyém anféghare yém, a yénd séném yuwek!
\q1 \v 8 Téfene wáutárégh siyém kétamé Yurata,
\q2 emo ewafroméng njafar a mband marat.
\c 125
\s
\q1 \v 1 Yéné ár emofem mwighafé yéfandat Yuré wambéghan em ndené yame mband tunakéf Jaion kés yém;
\q2 fá yau so tawaindangi wénde so naketat tuot.
\q1 \v 2 Ndené yame mband tunakfam siyarendat Jerusalem,
\q2 yénémamén Yuram ewarend yánjo ár sénonjo a tuot.
\q1 \v 3 Yaufiyam árém yau so yélimndat ngánján ghérsafé árfene mband,
\q2 ménamén ngánján ghérsafé ár mété táf eufotat mámáfi wafroghét.
\q1 \v 4 O Yuré, ewafrota mer yéfeyot emofem ewafrotat mer,
\q2 endefene tikéf yém mwighé fefaf.
\q1 \v 5 Wénde nayu tanguwatemb fá efe nénawengotat awaknégh end waitoghét, O Yuré.
\q2 Engérsa nayu yémafayo emofem ewafrotat yaufi.
\q1 So Israil ár em krufrat ghérsayan.
\c 126
\s
\q1 \v 1 Njam Yuram ewangotam yánjo ár ámb árfene yuta kétán Jerusalem,
\q2 ndenanit yémormén onjo!
\q1 \v 2 Yénd áuwégh féghnan ténmorwén,
\q2 a yéndfem wagh taufanawén áuwéghét.
\q1 A ámb ndimbal yu norayayénd,
\q2 "Némé sélngwélafé yam Yuram tafrote yéfeyot."
\q1 \v 3 Néméwét, Yuram té tafrote sélngwélafé yam téfeyot!
\q2 Némé áuwégh yém!
\q1 \v 4 Tawano téfene fifiofnar yam, Yuré,
\q2 ndené yame nu wéréram yénau totér tiyátongé ghérnat fanfne yu.
\q1 \v 5 Yéné ár emofem eitat yefé
\q2 so wau yuwon etanat áuwégh keafé.
\q1 \v 6 Fá ye néngendat táf njam engém njamke téfén yéghét,
\q2 wénde fá táf waghafé nangotat njam yémofem wau yuwon entanat.
\c 127
\s
\q1 \v 1 Tafandro Yuram yérameta méngo,
\q2 méngo ramégh árfene ásáfogh fifiofnar yém.
\q1 Tafandro Yuram njam yarawena ndimbal tesen,
\q2 yambete fiyáraye so ewafrote mámáfi.
\q1 \v 2 Yéné fifiofnar feyot yém sái minde násáfota
\q2 kétamé tándái akwan kétánotio férégh,
\q1 méghméghafé ásáfogh ménát njamke nénet;
\q2 ménamén Ngánjánam ámb ewaramete yéfe yánjo uwéghafé árét.
\q1 \v 3 Ambumtértér sem ramégh em kétamé Yurata;
\q2 fá em fai yá tambén.
\q1 \v 4 Ambumtértér seunjete totér ambumom
\q2 em ndenanit fimb yénau em mék téfnároene ngángayan.
\q1 \v 5 Nderé áuwéghafé yém yéné ár endene mbanmban nofai yéfefaf!
\q2 Fá yau so wáiwáiot yékmetat njam yémo sáfe ewaneta yáne sénanégh téfnár ndimbal tesen sésafnefaf.
\c 128
\s
\q1 \v 1 Nderé áuwéghafé fá em emofem férférafé yéfandat Yuré,
\q2 emofem méinyotio ewaitotat yáne end!
\q1 \v 2 Fémo so ewayamnete njamke téfén ásáfoghmén.
\q2 Nderé mani kér ro fém so ném!
\q1 \v 3 Fene amaf so yém mbwe kér ro graf wén ménjnit,
\q2 náfota fene méngon.
\q1 Fene ambumtértér so em ndenanit minde muyafé totér olif wén,
\q2 njam fá nénamnjotat tarendangi néne séki.
\q1 \v 4 Yéné fiyém Yurane frengégh
\q2 yéfeyot emofem férférafé yéfandat.
\q1 \v 5 So Yuram ménjtaye efrende fém Jaionmén.
\q2 So fémofem yéfandati Jerusalem nawainda manian yéné tekan njamandio fém ghérsé em.
\q1 \v 6 So fém emor náuwetat féfene áki ambumafé,
\q2 So Israil ár em krufrat ghérsayan!
\c 129
\s
\q1 \v 1 Kétamé tane bérkararta tane mék téfnáram té kwérnotawét yénd.
\q2 So méinyotio Israil árém yéfertat yéné:
\q1 \v 2 Kétamé tane bérkararta tane mék téfnáram té kwérnotawét yénd,
\q2 wénde yémofem yau yénd waindayénd.
\q1 \v 3 Tane sémsot siyém mbor ofáyoghare yém,
\q2 ndené yame ndau téfnáram yénau tawafrote tombé ton.
\q1 \v 4 Wénde Yuré siyém mer;
\q2 yémo té wénéf yuweke kétamé ngánján ghérsafnar árfene ángéghta.
\q1 \v 5 So méinyotio fá emofem méndméndat yéfandat Jerusalem
\q2 so nénangotat wáiwáita waingéghmén.
\q1 \v 6 So fá em ndenanit fifiofnar yus yénau em méngo sémsot tukén,
\q2 kawengongi téndal ngarot ndené yame kor yau yénau eyang mbandan.
\q1 \v 7 Ekene wau yu téfnáram,
\q2 méndméndat efande umbégh téfnáram.
\q1 \v 8 A so fá efe álighan néngawaindat
\q2 nakenat ménát sái tawaramangé yéné frengégh:
\q1 "Yuram néfrende fém;
\q2 yéndfem néfrendam fém Yurane yétkwénan."
\c 130
\s
\q1 \v 1 Méinyotio mámáfi kénjkaman, O Yuré,
\q2 yénd nutnam fene wáutárghét.
\q1 \v 2 Náyáreta tane ye, O Yuré.
\q2 Métar kékmbogh tane Ngánjánafé orayégh.
\q1 \v 3 Yuré, njam fémo ewereta téfene yaufiyammén yam,
\q2 O Yuré, efe so kunjarngé?
\q1 \v 4 Wénde fémo yéramete yaufiyam wigh,
\q2 ndené yénd so notametam ménát férférafé so yéfandam fá.
\q1 \v 5 Yénd nawaftan fene kénjún Yuré;
\q2 néméwét, yénd nawaftan yáne kénjún.
\q2 Yéndo té yékman tane kamnang yáne sian.
\q1 \v 6 Yéndo yéronjan Yuré
\q2 mindefifi ewainde fiyaré efe náronjat akwot,
\q2 néméwét, mindefifi fiyaré náronjat akwot.
\q1 \v 7 O Israil ár, kamnang aem Yurafaf;
\q2 Yurafaf kété yém kwénjtafnar uwégh.
\q2 Yáne mwighé frengégh nasune.
\q1 \v 8 Yémo yémonyo so mwighayan tafrendangé Israil ár
\q2 kétamé tárfár saf yaufiyamta.
\c 131
\s
\q1 \v 1 Yuré, tane tikéf yau yém tuktukan;
\q2 tane ghékéf yau em mámáfi.
\q1 Yéndo yau minde ndimbal kéráye efrendan kérté
\q2 o minde kérté ménát yéndo sái taweran.
\q1 \v 2 Wénde, yénd so métar kufrotangén a kékmbon yéndyo,
\q2 ndenanit fasri ambum yénau nénefé kamndangé yau kor so ndené yátmane nonot.
\q2 Néméwét, ndenanit fasri ambum yénau nénefé kamndangé tane mbérmbér ndené fiyém tane kénjún.
\q1 \v 3 O Israil ár, tákmangi féfene kamnang Yurane kénjún
\q2 sénonjo a túmén.
\c 132
\s
\q1 \v 1 Yuré, yafarota Deifid
\q2 a méinyotio yéné tékrat yémo stérsau.
\q1 \v 2 Yémo sotafé unyéghofnar si norayai kétán Yurafaf.
\q2 Yémo unyéghofnar si norayai kétán Israilmén Minde Waftafé ároefaf,
\q1 \v 3 "Yénd yau so néngangotan méngot;
\q2 yénd yau so yéndyo naumyotan enaghét.
\q1 \v 4 Yéndo yau so tane ghékéf eumyotan kéméghét
\q2 yau ghékéf séf so tamnangén kéméghan.
\q1 \v 5 Kétánotio yéndo tinjon sifayé ánde so yérametan Yurane méngo,
\q2 ghéngén ramégh méngo sifayé yáyot Israilmén minde waftafé ároe.
\q1 \v 6 Yénd náyárayém ndené Ak témorwén kété Efrata;
\q2 wénde yéndfem yinjoyém Jarén nayuta kéghat sifayan.
\q1 \v 7 Ténmumyo yénd yéngém kétán Yurane ghéngén warogh méngo sifayat;
\q2 so yáwefnotam kété yáne kafkaf kés eyang kétamé limánégh ámnjogh sifayan kés yénmor.
\q1 \v 8 Kokai, O Yuré, a kénagh fenjo enagh sifayat,
\q2 ménayafé akwafé, yufarote fene wafté.
\q1 \v 9 So fene ghéngén warogh ár nawamanetat ngánján ghérsayé
\q2 so fene tikfe ásáfogh árém eufanat wagh áuwéghafé.
\q1 \v 10 Ménamén yáne téfnan fene ásáfogh ár Deifid,
\q2 yau yékenai warsagh árot fémo efe té yétetai.
\q1 \v 11 Yuram sotafé kwérnar si norayai Deifidefaf
\q2 yéné unyéghofnar siafé yémo árké yau so tangongé:
\q1 Yéndo so téfayon ámb fene áki ambuman
\q2 fene limánégh ámnjogh sifayayan.
\q1 \v 12 Njam fene áki ambumam ewaitotat yam rényéghmén
\q2 a nákmén yéné yéndo árké tawatametan,
\q1 féyo warsagh ár yétkwén mérnamé
\q2 so mé néfermete tuot a mbanjat."
\q1 \v 13 Ménamén Yuram té yékaf Jerusalem;
\q2 yémo té tikéfafé téfande yéné yáne méngotu sái yém.
\q1 \v 14 Fá norayai, "Yéné siyém tane enagh sifayé tuot,
\q2 yénd so wémor yéna, ménamén yéné féyém méngotu yéndo árké tikfafé téfandan.
\q1 \v 15 Yéndo so yéfrendan ndimbal tesen a tiyáton mani kér ro;
\q2 yéndo so eremngotan yauyau ár njamkeye.
\q1 \v 16 Yéndo so ewamanetan yáne ghéngén warogh ár ngánján ghérsaye
\q2 yáne ndimbal mwighafé árém so wagh eufanat áuwéghét.
\q1 \v 17 Yéna yéndo so yarmbotan Deifidene wafté;
\q2 tane teghkaf so yém kwayaghé tane árét.
\q1 \v 18 Yéndo so ewamanetan yáne mék téfnár wáiwáie,
\q2 wénde fá so yém ndimbal kwayaghafé warsagh ár."
\c 133
\s
\q1 \v 1 Nderé mer a méndefé yém
\q2 njam fútar ekém mérne krufrate!
\q1 \v 2 Ménamén krufrat ghérsé siyém minde merfifi ndenanit fágharéghmén séfak
\q2 árkéméné yasuryénd Aronene sénkoyan
\q2 yéné nénengoi yénamé yáne fétséfafmé
\q2 a kétán yáne tombé sáláme fétfétfaf.
\q1 \v 3 Krufrat siyém ndenanit esae ndenanit es kétamamén Ermon mband tunakéfmén
\q2 yéné árké nuitat Jaion mband tunakéffaf.
\q1 A kété Yuram té norayam ménamén yáne frengéghmén,
\q2 a tuot ghérsamén.
\c 134
\s
\q1 \v 1 O, yarsam Yuré, méinyotio fém Yurane ásáfogh téfnár,
\q2 fém násáfotati sémbáran Yurane méngo kénjún.
\q1 \v 2 Tauyongi njúnnjúnofnar ngángé Ngánjánafé oraighan,
\q2 a yarsati Yuré.
\q1 \v 3 So Yuram, emo ewafroméng njafar a mband marat
\q2 efrende fém kétándmé Jerusalemta.
\c 135
\s
\q1 \v 1 Yarsam Yuré!
\q1 Yarsam Yurane yétkwén!
\q2 Yarsam fá, fémofem efe násáfotati Yurai,
\q1 \v 2 fém efe násáfotati Yurane méngo kénjún,
\q2 limánégh ámnjogh sifayé kénjún, téfene Ngánjánene méngon.
\q1 \v 3 Yarsam Yuré, ménamén Yuré siyém mer;
\q2 néusénati yáne uwégh kér ro yétkwénan ménayafé gita kembnefé.
\q1 \v 4 Ménamén Yuram té yékafai Jeikof yandio,
\q2 Israil ménát yandio fénataye kétamé mani ngonjélot.
\q1 \v 5 Yénd mat wém Yurane ndimbal yammén,
\q2 ndené téfén Yuré siyém ndimbalfifi yém ewainde ámb ngánján.
\q1 \v 6 Yuram ewafrote árkéméné em yáne méndeyan
\q2 yénamé méinyotio njafaran a mband marat,
\q2 a arakafan a yéfene kénjún.
\q1 \v 7 Yémo efune nu kwéf ménát so nénarmbotat méinyotio mband maratan.
\q2 Yémo engwafarete toyé nuafé
\q2 a tangéumyongé mbor kétamé yáne wembégh méngo kés em.
\q1 \v 8 Yémo tangésmetau fronde sénko ambum ámbiroámbiro árfene méngomé,
\q2 árafayo a wérár.
\q1 \v 9 Yémo tawafrotau sunsunafé ufarogh yam a sélngwélafé yam Ijif kénjún
\q2 yáfaf Faraoefaf a yáne ár.
\q1 \v 10 Yémo tawironau mbandot ndimbal yu
\q2 a tangénfetau waftafé warsagh ár,
\q1 \v 11 Jaion warsagh ár Amor árfene,
\q2 Ok warsagh ár Basanmén,
\q2 a méinyotio warsagh ár Kananmén.
\q1 \v 12 Yémo ewaramai yéfene mband nénamndayénd
\q2 yéfene fénataye ásáfogh sifayat yánjo árét Israil.
\q1 \v 13 Fene yétkwén, O Yuré, nakete tuot;
\q2 fene marataye yammén, O Yuré, mat néngáyátotat méinyotio ár saté.
\q1 \v 14 Ménamén Yuram so tawaramangé mbarkánd nák yánjo árét
\q2 a so yém ghérghérsisafé yánjo ásáfogh árfefaf.
\q1 \v 15 Mewang ndimbal yuafene em ménd rokarmén ménamén silfé a gol,
\q2 ár ngángé faréghmén.
\q1 \v 16 Yéfene ewam sén fene wénde yau so norayat,
\q2 a em ghékfafé wénde yau so néretat.
\q1 \v 17 Yéfene ewam téngan wénde yau so norayat,
\q2 a ewam min wénde yau so ewamndat.
\q1 \v 18 A fá emofem ewafrotat ámb sáf mbanmban ndené sáfotio em,
\q2 yéné fém méinyotio emofem mwighafé efandat yéné.
\q1 \v 19 O Israil ár, yarsati Yuré!
\q2 O ghéngén warogh ár Aronene áki ambum yarsati Yuré!
\q1 \v 20 O Lefi ár, yarsati Yuré!
\q2 Méinyotio fém emofem férférafé yéfandati Yuré, yarsati Yuré!
\q1 \v 21 Yuré so yénmarsat kétamé Jaion,
\q2 ménamén fá yéna yémor Jerusalemén.
\q1 Yarsam Yuré.
\c 136
\s
\q1 \v 1 Yarametati kánjo Yurai, ménamén fá siyém mer!
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 2 Yarametati kánjo ngánjánngánjánafene Ngánjánoe.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 3 Yarametati kánjo yurafene Yurai.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 4 Yarametati kánjo yáyot emonro ewafrote waftafé sunsunafé yam.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 5 Yarametati kánjo yáyot emo tawafrotau njafar matyam tárfáre.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 6 Yarametati kánjo yáyot emo yéfayoi mband marat nufafmé.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 7 Yarametati kánjo yáyot emo ewafrotam njafaran kwayaghé.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 8 Efgham yélimnde efogh kwéf,
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 9 a ghérare a kéndam yélimndat sémbár.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 10 Yarametati kánjo yáyot emo kérotio tasmetau fronde sénko ambum Ijifmén.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 11 Yémo ténémnjau Israil yénmutoryéng kétamé Ijifta.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 12 Fá nufrote muyafé ngángae a waftafé sérakwe.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 13 Yarametati kánjo yáyot emo karéf ewafrotangeyai férkat arakaf.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 14 Yémo Israil ár talimndau tawanjanau yéné kénjúta.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 15 Wénde yémo wánangogh yafngoi Farao a yáne fiyaré férkat arakaf kénjút.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 16 Yarametati kánjo yáyot emo talimndau yánjo ár yénamé fanfne yuwomé.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 17 Yarametati kánjo yáyot emo tatarmangai waftafé warsagh ár.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 18 Yémo kérotio tangésmetau wafté kér ro warsagh ár.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 19 Jaionmén warsagh ár Amormén árfene,
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 20 a Okmén warsagh ár Basan árfene.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 21 Ngánjánam ewaramai mband yéné warsagh árfene nénamndayénd yéfene.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 22 fénataye ásáfogh sifayé yáne ásáfogh téfnárafet Israil árét.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 23 Yémo ténmafarotangai téfene njangénan.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 24 Yémo ténmanjarngai téfene mék téfnárafeta.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 25 Yémo ewaramete njamke méinyotio ghérsafé rokarafet.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\q1 \v 26 Yarametati kánjo yáyot njafarmén Ngánjáne.
\qr Yáne ndimbal mwighafé uwégh nakete tuot.
\c 137
\s
\q1 \v 1 Babilon wanje téndota, yénd namnjoyém a ye nufngoyém.
\q2 njam yéndo nemnam Jerusalem.
\q1 \v 2 Yéndfem engékmayém af,
\q2 engwayém wén kafeyamé.
\q1 \v 3 Ménamén téfene werégh téfnáram nénomnendayénd wagh raméghét téfefaf.
\q2 Téfene tékrat téfnár namyoyénd téfene warsagh waghan:
\q2 "Ténmaufanangi ámb yénémamén wagh Jerusalemmén!"
\q1 \v 4 Wénde ndernaye so Yurane wagh erametam
\q2 táf yéném yéna ámb ngánján wáwefnogh mbandan?
\q1 \v 5 Njam yéndo mwighafnar kémayan fém, O Jerusalem,
\q2 so tane tambén ngángé mwighafnar kamndangi ndernaye so nambnan af.
\q1 \v 6 So tane kanké so nofane tane sénfne tukén
\q2 njam yénd kwawalindangé fenemén,
\q2 njam yéndo yau tiyáton Jerusalem ndimbal áuwéghafé.
\q1 \v 7 O Yuré, nawafarota ndernaye Edommén ár kufrotawét
\q2 yéné kwéfon Babilon fiyaram njam yerayénd Jerusalem.
\q1 Fá nutnayénd, "Tiranangi yéné!
\q2 Fafat tiyátend mbandot!"
\q1 \v 8 O Babilon, fém so némironat.
\q2 Áuwéghafé fá so em emofem fai so némawangotat
\q2 ménamén fémo ndernaye témafrote yénd.
\q1 \v 9 Áuwéghafé fá em emofem engérsat fene fasri ambum
\q2 a etarmetat wíman.
\c 138
\s
\q1 \v 1 Yéndo némarametan kánjo, O Yuré, méinyotio tane tikfé
\q2 yéndo so fene warsagh wagh erametan ámb ngánjánafene sáfrére.
\q1 \v 2 Yéndo karamnjon fene njúnnjúnofnar wáwefnogh méngon njam némáwefnotan.
\q2 Yéndo yarsam fene yétkwén ménamén fene kwénjtafnar uwégh a ndimbal mwighamén;
\q1 ménamén fene unyéghofnar siam yénamayo yéngwaitote
\q2 ménayam méinyotio fene yétkwén utmanégham.
\q1 \v 3 Njam yénd Ngánjánafé norayan, fémo kwawango;
\q2 fémo wawéngsote a muyé waramete.
\q1 \v 4 Méinyotio warsagh ár méinyotio mband marat kénjún so kánjo némarametat, Yuré,
\q2 ménamén méinyotioyam so náyáretan fene si.
\q1 \v 5 Néméwét, yémofem so wagh engéufanat ménamén Yurane yammén
\q2 ménamén Yurane ndimbal kwayaghé siyém minde ndimbalfifi.
\q1 \v 6 Ndemamén Yuré yém ndimbal, yémo ewarawene métar ár,
\q2 wénde fá nayue yém yéfe tuktuk árfeta.
\q1 \v 7 Ndemamén yénd warende kérté yam,
\q2 fémo so warawene kétamé tane mék téfnárafene nékwta.
\q1 Fémo tanwatemb fene ngángé,
\q2 a fene tambén wafté ngángayam kwanjarngé.
\q1 \v 8 Yuram so yafrote mwighé tane ghérsamén
\q2 ménamén fene ndimbal mwighafé uwégh, O Yuré, nakete tuot.
\q2 Yau wéfrangota yénd, ménamén méinyotio tanemén.
\c 139
\s
\q1 \v 1 O Yuré, fémo té tafénmete tane tikéf
\q2 a mat ném méinyotio tanemén.
\q1 \v 2 Fém mat ném njam yénd kámnjon a kokayon.
\q2 Fém mat ném tane mwighé njam yénd wém nayu.
\q1 \v 3 Fémo yénd wéfande njam yénd wiyota
\q2 a njam yénd nenan méngon.
\q2 Fém mat ném méinyotio yénd némé ewafrotan.
\q1 \v 4 Fém mat ném némé yéndon so korayangén
\q2 soramé njam korayangén, Yuré.
\q1 \v 5 Fém néngém fronde a wéi wénmaitote.
\q2 Fémo tafai fene frengéghafé ngángé tane sénkoyan.
\q1 \v 6 Yéné matyam siyém minde merfifi tayot,
\q2 minde ndimbal yém tayot matot!
\q1 \v 7 Yénd yau so kawatemban kétamé fene Mbérmbéroeta!
\q2 Yénd yau so nayu náyátotan fene ghékéfta!
\q1 \v 8 Njam yénd karmbon njafarot, fém kété ném;
\q2 njam yénd kwewérngi mbéwé méngot, fém kété ném.
\q1 \v 9 Yéndo njam yérsan akwoene njamb,
\q2 njam yénd wémor nayufifi arakafamé.
\q1 \v 10 Kété mé fene ngángayam mé so wambete,
\q2 a fene muyayam so wamarote.
\q1 \v 11 Yéndo so témotangén kwéfité ménát so kwamongé
\q2 a kwayagham árké warende so kénamndangé kwéfité,
\q2 \v 12 wénde táf kwéfitayan yénd yau so katnon fe tambén.
\q1 Fefaf sémbár siyém kwayaghé yém ndené efghon.
\q2 Kwéfité a kwayaghé ámbrérero efe fefaf.
\q1 \v 13 Fémo yafrotam méinyotio tane fifi méndefé, tane fifi kénjún
\q2 a kwénamndau yénd ámbrérero tane amane fút kénjún.
\q1 \v 14 Kánjo fe ménamén wafrotam mer kéráye téféghetau!
\q2 Fene ár wafrogh ásáfogh siyém sélngwélafé- nderé mer yénd mat wém yénémamén.
\q1 \v 15 Fémo yénd kwéfandau njam yénd nufrotayén ndené kémafé métar sifayan,
\q2 njam yénd kwafrotau ámbrérero kwéfité fút kénjún.
\q1 \v 16 Yénd té winjoi frondeyo soramé náráftamén.
\q2 Méinyotio efogh tane ghérsamén kakayotawét fene bukan.
\q1 Méinyotio fénefénean yéné takmetawét
\q2 yau so ámbiro efogh kawaindangai.
\q1 \v 17 Nderé merfifi em fene mwighé tanemén, O Ngánján.
\q2 Yéné yau so nawaftat.
\q1 \v 18 Yéndo yaufifi so ewaftau;
\q2 yémofem té yéngwaindangi miri mbwembwe!
\q1 A yénd njam kanon,
\q2 fém mé ném tafaf!
\q1 \v 19 O Ngánján, njam fémonro té ewirone yaufi ár!
\q2 Kitérmbongi tane ghérsata, fém ár ngi téfnár!
\q1 \v 20 Yémofem fém némafalngotat;
\q2 fene mék téfnáram yaghta fene yétkwén.
\q1 \v 21 O Yuré, so yéndo tékrat efandan fá emofem tékrat néfandat fém?
\q2 So yéndo méndméndat efandan fá emofem néfetat fém?
\q1 \v 22 Néméwét, yéndo méndméndat efandan mindefifi,
\q2 ménamén fene mék téfnár sem tane mék téfnár.
\q1 \v 23 Wéronja yénd, O Ngánján, a yénd mat wém tane tikéf;
\q2 wufota yénd a mat káyáto tane minde méndefé mwighé.
\q1 \v 24 Tauyafo tafaf némé njam té mámáfi tafrotan fefaf,
\q2 a wélimnda yénamé tuot ghérsé endmé.
\c 140
\s
\q1 \v 1 O Yuré, kwanjar yénd kétamé yaufi árfeta,
\q2 wambete yénd kétamé efe em wasérmboghro.
\q1 \v 2 Fá emofem tikfan yaufi mwighé yéfaronat
\q2 a nawanjmetat kértafé méinyotio efogh tombé.
\q1 \v 3 Yéfene wéght kankayamé ewam ndenanit kamban;
\q2 ghafté raréghafé nérertat yéfene kankata.
\q1 \v 4 O Yuré, wéfnana yaufi árfene ngángata.
\q2 Wambeta yénd yéfeta efe em wasérmbogh ár,
\q2 ménamén yémofem kwankwane mwighé yéfaronat tayot.
\q1 \v 5 Awarmbogh árém té tékéindat urérta weréghét;
\q2 yémofem té tametat net;
\q2 yémofem té tengwametat urér endmé.
\q1 \v 6 Yénd norayayén Yurafaf, "Fém ném tane Ngánján!"
\q2 Náyáreta, O Yuré, tane ye ghérghérsisat!
\q1 \v 7 O minde waftafé Yuré, muyé kér ro emo wanjaryéng yénd,
\q2 fémo wanjaryéng yénd ásmégh efghon.
\q1 \v 8 Yuré, yau eumyota yaufi ár yéfene ende.
\q2 Yau eumyota yéfene yaufi farorégh mwighé siya néngufrotat,
\q2 o fá so kénamndangi awarmbogh kér ro.
\q1 \v 9 so tane mék téfnár ewirone
\q2 yéné mámáfimén yémofem némé mwighé yafrotaménd tayot.
\q1 \v 10 So fésafé akraréghkaf njér mband nénatarnat yéfene sénkoyan.
\q2 So fá ewite kétán fését
\q2 o nuafé yékwfaf ánde yau so kawanjarngi.
\q1 \v 11 Yau eumyota unyégh téfnár manian nawaindat sái em yéna téfene mbandan.
\q2 Tétyar ndimbal kaukau ménát so kuyangé wasérmbogh árfefaf.
\q1 \v 12 wénde yénd mat wém Yuram so ewáutáne fá efe ernotat;
\q2 yémo so tawaramangé mbarkánd nákan yéfe yauyau árét.
\q1 \v 13 Efalo mbarkánd árém siyém yarsat fene yétkwén;
\q2 ngánján ghérsafé sem so emor fene meranro.
\c 141
\s
\q1 \v 1 O Yuré, yénd nutnam fefaf. Ghérghérsisé wékeye kufrota!
\q2 Náyáreta njam yénd nendan fefaf wáutárghét!
\q1 \v 2 Taumyo tane Ngánjánafé orayégh ndené fété ghéngén ramégh feyot,
\q2 a tane uyogh ngángé ndené yame so em férghétro ghéngén.
\q1 \v 3 Wawarawena némé yénd korayangén, O Yuré,
\q2 a yambeta tane kanké.
\q1 \v 4 Yau yénd wumyota so wéngérse ndenáye yaufita
\q2 o yaufi wafrogh yaman sái sifayé yéngérsan.
\q1 Yau wamyota sái ámb sifayé yéngérsan
\q2 mámáfi árfene mer frengéghmén njamke néneyan.
\q1 \v 5 Taumyo ngánján ghérsafé árém so kwafngongi yénd!
\q2 Yéné so yém ngarame!
\q1 Njam yémofem wawéngsotat, yéné siyém nanfete ndenanit murémuranit.
\q2 Yau kwamyo sái tékenangén.
\q1 Wénde yénd Ngánjánafé norayan túmén
\q2 yéfeta yaufi ár a yéfene yam wafrogh.
\q1 \v 6 Njam yéfene limánégh téfnár enwitat kétán tararés yékwét,
\q2 yaufi ár so káyárangi tane sian a tawawinjon yéfe efalo.
\q1 \v 7 Ndenanit wím kar enwérfoyénd farut ménayan mband taréghan,
\q2 áyáréghofnar árfene sot so yéngmango yatoghofnar.
\q1 \v 8 Yénd néretan fefaf wáutárghét; o minde tukén Yuré.
\q2 Fém ném átnogh sifayé; yau eumyota fá sái kérotio wésmetat.
\q1 \v 9 Warawena kétamé urér yémofem kés tafrendat tayot,
\q2 kétamé yéfene ndéndénta emofem ewafrotat mámáfi.
\q1 \v 10 Taumyo áyáréghofnar ár so naflitat yéfenjo netan,
\q2 wénde kumyo yénd so kawatemban.
\c 142
\s
\q1 \v 1 Yénd kendawén Yurafaf;
\q2 yénd yéta kwatekwate kwémorwén Yurane ghérghérsisat.
\q1 \v 2 Yéndo tangékmangayén tanjo áwátaranégh yáne rére
\q2 a tauférotawén méinyotio tane kérté.
\q1 \v 3 Njam yénd kwafarngé,
\q2 fémro mat ném end yénd sái kawengon.
\q1 Ándan yénd wéngém,
\q2 tane mék téfnáram té urér takeindat tayot.
\q1 \v 4 Yénd néretan ámb árét ménát sái wáutárghét,
\q2 wénde árké árom yau kwaramangé waingégh mwighé!
\q1 Árké árom yau so wáutáné
\q2 efe yau mwighé yém némbnare némé natyane tafaf.
\q1 \v 5 Féyo yénd Ngánjánafé norayan fefaf, O Yuré.
\q2 Yénd norayan, "Fém ném tane átnogh sifayé.
\q2 Fém ném méinyotio yéndo méndefé néfandan ghérsé kénjún.
\q1 \v 6 Náyáreta tane ye,
\q2 ménamén yénd wém yuwanfifi.
\q1 Kwanjar yénd kétamé tane rénogh téfnárafeta,
\q2 ménamén fá em minde muyafé tayot.
\q1 \v 7 Kwénmutor yénd kétamé kwéfkwéf méngota
\q2 ménát yéndo so kánjo némarametan.
\q1 Ngánján ghérsafé árém so kwarendangi yénd,
\q2 ménamén fém ném mer tafaf."
\c 143
\s
\q1 \v 1 Náyáreta tane Ngánjánafé orayégh, O Yuré;
\q2 náyáreta kétán tane ménde kés yékmetan!
\q2 Kwawango ta ménamén fém ném ndimbal mwighé kér ro a mbarkánd.
\q1 \v 2 Yau yékmeta fene ásáfogh téfnár wufoghan,
\q2 ménamén efe ámb yau yém téfnofnar fene rére.
\q1 \v 3 Tane mék téfnáram té wénmifnam yénd.
\q2 Yémo té wétarmai mbandot
\q2 a kwafaretau sái kwémorangérwén kwéfitayan ndené kés em mbuwayan.
\q1 \v 4 Tane kamnang nefote méinyotio;
\q2 yénd férféram té kwékeinde.
\q1 \v 5 Yéndo tándáwármén efogh mwighaye esman.
\q2 Yénd kor so mer kéráye nemnan fene méinyotio ásáfoghmén
\q2 a mwighaye so nasmetan yénémamén némé fémo yafrotam.
\q1 \v 6 Yéndo tauyon tane ngángé Ngánjánafé oraighan.
\q2 Yénd fe sioghan wéramete ndené yame ghérnat mband yénau yém nu afaméghofnar.
\q1 \v 7 Kéném wékeye, Yuré, a kwawango
\q2 ménamén tane mwighé kérté yém.
\q1 Yau wéngwawengota sém tayot,
\q2 o mété kér wém.
\q1 \v 8 Kwumyo yénd so náyáretan fene kwénjta uwéghmén méinyotio akwan,
\q2 ménamén yéndo mwighafé néfandan fém.
\q1 Kwauyafo ta ándan so kaflan yénd,
\q2 ménamén yénd naraman yéndio fefaf.
\q1 \v 9 Kwanjar yénd tane mék téfnárfeta, Yuré;
\q2 yénd wérseye nénérsan fefaf ménát sái kwétno.
\q1 \v 10 Watameta ménát so yafrotan fene ménde,
\q2 ménamén fém ném Ngánján.
\q1 So fene ngaram Mbérmbéran wélimnde mé
\q2 táikér kafkaf enaghan.
\q1 \v 11 Ménát fene ndimbal kwayaghé yétkwénot, O Yuré, yanjana tane ghérsé.
\q2 Ménamén fene ndimbal mwighamén, kwénmutor yénd yéné mwighé kértata.
\q1 \v 12 Fene kwénjtafnar uwégh kénjún métar táyáto méinyotio tane mék téfnár
\q2 a tangwiror méinyotio tane sénanégh téfnár,
\q2 ménamén yénd wém fene ásáfogh téfnár.
\c 144
\s
\q1 \v 1 Yarsam Yuré, efe yém tane wím.
\q2 Yémo tane ngángé ewatamete ménát mékot
\q2 a ewaramete tane ngángéngángat matyam ménát ásméghét.
\q1 \v 2 Fá yém tane áuwéghafé wáutárégh ár a tane wambégh méngo,
\q2 tane ngumbar átnoghmén, tane wanjarégh téfnár.
\q1 \v 3 O Yuré, némé ménd ár em ndené fém sái mat náyárota yéfefaf,
\q2 mé orngégh fifi téfnár némat mwighaye so eramete fá?
\q1 \v 4 Ménamén fá em ndenanit ambone limánéghnit;
\q2 yéfene efogh em ndenanit awaingégh njar.
\q1 \v 5 Tasawér njafar, Yuré, a kénewor.
\q2 Tayanja mband tunakéf so yafrotat kwam.
\q1 \v 6 Etremngota toyégh a ewafarna
\q2 engwatembeta fene fimb a ewawérsota.
\q1 \v 7 Tanwatemb ngángé kétamé njafarta a kwanjar yénd;
\q2 kwanjar yénd kétamé nu kénjúta,
\q2 kétamé tane mék téfnárafene waftata.
\q1 \v 8 Yéfene sénfne sem unyégh afogharé
\q2 fá sosi norayat ménát so nafrotat efaloe.
\q1 \v 9 Yéndo so erametan totér wagh fefaf, O Ngánján!
\q2 Yéndo erametan fene warsaghmén wagh ménaye ángéghafé afe.
\q1 \v 10 Ménamén fémo ewaramete wanjarégh warsagh árét!
\q2 Fémo ghérsé yurtoi fene ásáfogh téfnár Deifid kétamé yaufi witmafé séntafé naifata.
\q1 \v 11 Kwanjar yénd!
\q2 Ghérsé kwurto kétamé tane mék téfnárafene waftata.
\q1 Yéfene mbérmbér sem unyégh afogharé
\q2 fá sosi norayat ménát so nafrotat efaloe, wénde fá nuindat.
\q1 \v 12 So fene ambum nanotat yéfene bérkaran
\q2 ndenanit mer kéráye anogh wén.
\q1 So téfene mérés em ndenanit áuwéghafé wamarogh sérasér yéfanaménd
\q2 ménát so sariafé nérete warsagh ároe sifayé.
\q1 \v 13 So téfene séfam nafote
\q2 ménayam mbwe wén rokaram fénaté safot.
\q1 So téfene manjarégh wérár téfene manjarégh sifayamé nafunat tausene
\q2 o ten tausene,
\q1 \v 14 a so téfene kau eremngote fifiam.
\q2 Yau so kété yém ke téfene áligh endmé.
\q1 \v 15 Néméwét, áuwéghafé fá so em efe emor ndenáye!
\q2 Áuwéghafé fá yéné fém endefene Ngánján yém Yuré.
\c 145
\s
\q1 \v 1 Yéndo so némuyotan fém, tane Ngánján warsagh ár,
\q2 a yarsan fene yétkwén tuot o mbanjat.
\q1 \v 2 Yéndo so némarsan fém méinyotio kwéfon;
\q2 néméwét, yéndon so némarsan tuot.
\q1 \v 3 Ndimbal yém Yuré a minde tukén sái yarsam!
\q2 Yane ndimbal yamafé yam so katmangém.
\q1 \v 4 Yéndo so yafénmetan fene sari, ndimbal kwayaghé méndefé
\q2 a fene mer ufrogh yam.
\q1 \v 5
\q2
\q1 \v 6 Fene férférafé ghékéf fayogh yam wafrogh so em méinyotio kankayan;
\q2 yéndo so yéngwaitotan fene ndimbalmén.
\q1 \v 7 Méinyotio árém so yéngwafarnat fene mer yammén si;
\q2 yémofem so wagh erametat áuwéghafé ménamén fene mbarkánd yammén.
\q1 \v 8 Yuré siyém ghérghérsisé kér ro a ngaramngaramafé,
\q2 yau so mé kwawerangé nékw a kwénjtafnar uwégh afoghare yém.
\q1 \v 9 Yuré siyém mer yém méinyotio árfefaf.
\q2 Yémo ngárámngárám eramete méinyotio yáne wafroghmén rokar.
\q1 \v 10 Méinyotio féfene ásáfogh so némarametat kánjo fe, Yuré,
\q2 a fene ndimbal mwighafé waitogh árém so némarsat fém.
\q1 \v 11 Fá so néngorayat ménamén fene ndimbal kwayaghé Ngánján limánéghmén;
\q2 a néngorayat fene waftamén.
\q1 \v 12 Fá so néngafrotat ménamén fene waftafé wafrogh yammén
\q2 a ménamén sari a ndimbal kwayaghé fene limánéghan.
\q1 \v 13 Ménamén fene Ngánján limánégh siyém tuot Ngánján limánégh.
\q2 Fene limánégh yénamé méinyotio ár satamé.
\q1 Yuram túmén ewarawene yánjo unyéghofnar si;
\q2 fá siyém ghérghérsisé kér ro yénayan méinyotio némé yémo ewafrote.
\q1 \v 14 Yuram ewáutáne fá efe kuyangi
\q2 a tanwanongé fá efe kérté yam ewefnote.
\q1 \v 15 Méinyotio árfene ghékéf néretat fefaftro kamnang kénjún;
\q2 fémo ewaramete yéfe njamke njam méndeyan em.
\q1 \v 16 Njam fémo ngángé tasafo,
\q2 fémo taremngo njamke sioghan a nu sioghan méinyotio ghérsafé rokar.
\q1 \v 17 Yuré siyém mbarkánd méinyotio yáne rokar wafrogh kénjún;
\q2 fá siyém ramégh kér ro afoghare.
\q1 \v 18 Yuré siyém kaka yéfefaf méinyotio efe nutnat yáfaf,
\q2 néméwét, yéfefaf méinyotio efe nutnat yáfaf efalo kénjún.
\q1 \v 19 Yémo so ewaramete yéfe emofem férférafé yéfandat fá;
\q2 yémo eyárete yéfene ye wáutárghét a ghérsé tawértongé.
\q1 \v 20 Yuram ewarawene fá méinyotio emofem yuwetat fá,
\q2 wénde ewirone áyáréghofnar.
\q1 \v 21 Yéndon so yarsan Yuré,
\q2 a so méinyotio árém mband maratan yéfrendat yáne njúnnjúnofnar yétkwén
\q2 tuot a mbanjat.
\c 146
\s
\q1 \v 1 Yarsam Yuré!
\q1 Taumyo méinyotio ndené yéndo yarsa Yuré.
\q2 \v 2 Yéndo so yarsan Yuré njamandio ghérsé wém.
\q2 Yéndo so yarsan waghe tane Ngánján ménaye tane kér amboneye.
\q1 \v 3 Yau ekmeta fene méghmégh waftafé árfefaf;
\q2 kété yau fene wáutárégh yém.
\q1 \v 4 Njam yémofem ambinomén ambone kokawangi, fá kangongi mbandot,
\q2 a méinyotio yéfene mwighé emaréghafayo kér em.
\q1 \v 5 Wénde áuwégh téfnár fá em endefefaf yém Israil árfene Ngánján yéfene wáutárégh ár,
\q2 endefene kamnang yém Yurafaf yéfene Ngánján.
\q1 \v 6 Yémo ewafrotam njafar a mband marat,
\q2 arakaf, a méinyotio rokar yéfene kénjún.
\q2 Yémo yánjo unyéghofnar si ewarawene.
\q1 \v 7 Yémo ewaramete mbarkánd yéfe efe ekarotat
\q2 a njamke yéfe efe siogh em.
\q1 Yuram taferngé kwéfkwéf méngon kérté téfnár.
\q2 \v 8 Yuram tasawérngé ghékéf kwéfkwéf árfene ghékéf.
\q1 Yuram tauyongé fá efe ewewonat.
\q2 Yuram euwete fá efe em ngánján ghérsafé.
\q1 \v 9 Yuram ewarawene dabi ár téfne kénjún.
\q2 Yémo ewarawene séfarékw ambum a séfarékw amaf,
\q2 wénde sakérafé yaufi árfene mwighé farorégh tayátongé.
\q1 \v 10 Yuram so yém limánéghan tuot.
\q2 Fá so yém féfene Ngánján, O Jerusalem, yénamé méinyotio ár satamé.
\q1 Yarsam Yuré.
\c 147
\s
\q1 \v 1 Yarsam Yuré!
\q1 Nderé mer yém sái warsagh wagh erametam téfne Ngánjáne!
\q2 Nderé minde méndefé a yémfeyotaro.
\q1 \v 2 Yuram wéikor so yéramete Jerusalem
\q2 a enwanongta dabi kétán Israil.
\q1 \v 3 Yémo mer eyátote tikéf afaroréghkaf
\q2 a ewaumbete yéfene bandaise.
\q1 \v 4 Yémo ewafte kénd
\q2 a emndete méinyotio yétkwéne.
\q1 \v 5 Nderé ndimbal yém téfene Yuré! Yane wafté siyém féyotaro!
\q2 Yáne mat siyém tukényo yém ámb matta.
\q1 \v 6 Yuram ewamarote yuwon ghérsafé,
\q2 wénde yémo enérse yaufiyam ár kétán ngwérméngfaf.
\q1 \v 7 Erametati kánjo wagh Yurafaf;
\q2 eufanat warsagh wagh kétán téfene Ngánjáne ménaye afe.
\q1 \v 8 Yémo ewafne njafar nu kwéfe,
\q2 yéramete nu mband maratoe,
\q2 a táyátongé yus anoghét mband tunakfan wérárafene kéfé sifayan.
\q1 \v 9 Yémo ewaramete njamke kéghat wérárat
\q2 a emanjne wimbu tosétosé njam fá nendat.
\q1 \v 10 Yémo yau klisa yérse osene muyayan
\q2 a árfene muyayan.
\q1 \v 11 Yau, Yurane minde ménde siyém yéfefaf emofem férférafé yéfandat,
\q2 fá emofem ekmetat yéfene kamnang yáne kwénjtafnar uwégh kénjún.
\q1 \v 12 Minde kwayaghé yarametati, O Jerusalem ár!
\q2 Yarsati féfene Ngánján, O Jaion!
\q1 \v 13 Ménamén yémo té muyé tawarametau féfene sésafne fuafet
\q2 a tafendau féfene ambumtértér féfene anawégh mbakwam.
\q1 \v 14 Yémo yéngwafarete krufrat ámnjogh ndimbal yuwot
\q2 a eremngote totér flawé mbweye sioghmén.
\q1 \v 15 Yémo engwafarete yáne wafarégh kétán mband maratot
\q2 nderé wékeye yáne si nanefete!
\q1 \v 16 Yémo ewafarete es ndenanit kwayaghé njéng;
\q2 yémo yéngratne es fétér mbandamé ndenanit fakfak.
\q1 \v 17 Yémo kwérnare yáutárne krufrat nu mbwe ndenanit wím.
\q2 Efe so kokayongé taikrataye táf yáne krufratam njam tasmangé?
\q1 \v 18 Féyo, yáne wafarégh sian, yéné méinyotio nérndat.
\q2 Yémo engwafarete yáne njamb, a ais kartangi.
\q1 \v 19 Yémo té yánjo si safét ekmai yáfaf Jeikof,
\q2 yáne wafarégh a náknák kétán Israilét.
\q1 \v 20 Yémo ámb yau ndené yafrotam ámb ndimbal yuwot;
\q2 fá mat yau em yáne náknák.
\q1 Yarsat Yuré.
\c 148
\s
\q1 \v 1 Yarsati Yuré!
\q1 Yarsati Yuré kétamé njafar kés em!
\q2 Yarsati fá kétamé njafarta!
\q1 \v 2 Yarsati fá, méinyotio njafar si résagh ár!
\q2 Yarsati fá, méinyotio mék téfnár njafarmén!
\q1 \v 3 Yarsati fá, efogh a ghérare!
\q2 Yarsati fá, méinyotio fém ánábégh kénd!
\q1 \v 4 Yarsati fá, njafar tukén!
\q2 Yarsati fá, nu es nu kwéf tukmé kés em!
\q1 \v 5 Taumyo méinyotio wafrogh rokaram sái yarsat Yuré,
\q2 ménamén yémo yéramai minde mwighé yáne wafarégh, a fá kénamndetawét fifiafé.
\q1 \v 6 Yémo ekmai sifayan tuot a mbanjat.
\q2 Yáne wafarégh yau so titérmbongi.
\q1 \v 7 Yarsam Yuré yénamé mband maratta,
\q2 fém wafrogh rokar arakaf kénjúmén,
\q1 \v 8 fés a krufér nu, es féter a nu kwéf,
\q2 mbormbor a wérwér árkéménayam yiyáretat fá.
\q1 \v 9 Mband tunakéf a méinyotio sémkéf
\q2 mbwe wén a méinyotio sedas wén.
\q1 \v 10 Kéghat wérár a méinyotio manjarégh wérár,
\q2 némbnar ndarndar wérár a men,
\q1 \v 11 mband maratmén warsagh ár a méinyotio ár,
\q2 limánégh téfnár a mogh téfnár mband maratmén,
\q1 \v 12 totér ár a totér ámaf,
\q2 bulu ár a ambumtértér.
\q1 \v 13 Taumyo fá méinyotio yarsat Yurane yétkwén.
\q2 Ménamén yáne yétkwén siyém minde ndimbalfifi;
\q2 yáne ndimbal kwayaghé ngumbar kés em mband maratan a njafaran!
\q1 \v 14 Yémo té ewafrotam yánjo ár muyaro,
\q2 eutémnde yáne ndimbal mwighafé
\q2 Israilmén ár efe em kaka yáfaf.
\q1 Yarsati Yuré.
\c 149
\s
\q1 \v 1 Yarsam Yuré!
\q1 Erametati totér wagh Yurai.
\q2 Yarsati yáne waghe ndimbal mwighé árfene áumengégh sifayé kénjún.
\q1 \v 2 O Israil ár, náuwetati féfene wafrogh ároefaf.
\q2 O Jerusalemmén ár, nawarsati féfene warsagh ároene kénjún.
\q1 \v 3 Yarsati yáne yétkwén wagh ermángéghafé fá,
\q2 yénayafé tambarin a afafé.
\q1 \v 4 Ménamén Yuram minde méndefé efande yánjo ár;
\q2 yémo ewamanete akikie métar ghérsafé ár wanjaréghafé.
\q1 \v 5 Taumyo ndimbal mwighé téfnár so náuwetat ménamén yémo eutémnde.
\q2 Taumyo fá wagh so erametat áuwéghét njam fá ewalinjo yéfene kémégh sifayamé.
\q1 \v 6 Taumyo warsagh wagh Ngánjánene so em yéfene mbírmbíramé
\q2 a witmafé sénté naifé yéfene so em ngángayamé.
\q1 \v 7 ménát so tawafngongi ndimbal yu wéndefai
\q2 a kérté yam so yém árfefafmé,
\q1 \v 8 ménát so eumbetat yéfene warsagh ár ndimbal mbwe tot téfén ángéghe
\q2 a yéfene limánégh téfnár tot téfene seine,
\q1 \v 9 ménát so tafngongi moghan yéfarotat férén yéfenemén.
\q2 Yéné siyém ndimbal kwayaghafé yam yáne ndimbal mwighafé árfene,
\q1 Yarsati Yuré!
\c 150
\s
\q1 \v 1 Yarsati Yuré!
\q1 Yarsati Ngánján yáne wáwefnogh sifayan;
\q2 yarsati fá yáne waftafé njafar kénjún!
\q1 \v 2 Yarsati fá ménamén yáne waftafé ásáfoghmén;
\q2 yarsati yáne ndimbal árké árfe yau so kátménd!
\q1 \v 3 Yarsati fá ménaye ghakér sifmén tartar sufér keyé
\q2 yarsati fá ménaye laire a afe!
\q1 \v 4 Yarsati ménaye tambarine eramángéghafé;
\q2 yarsati ménaye gita kembneye a sifrafére!
\q1 \v 5 Yarsati ménaye sin ngarngar weranégh,
\q2 yarsati fá ménaye minde kefé weranéghafé.
\q1 \v 6 Taumyo méinyotio rokar árkéménayam ambone yitat so yarsati waghe Yuré!
\q1 Yarsati Yuré!
