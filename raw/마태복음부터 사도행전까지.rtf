\par\pard\plain \s60\ql\fi180\lin0\rin0\sb0\sa0\b0\i0\ul0\scaps0\nosupersub\cf2\fs22 Soramam\u233?n s\u243?mbio \u225?r nokayeyay\u233?nd {\cs57\b0\i0\ul0\scaps0\super\cf2\fs22 61\~}
